Procedure AfficherDetailEcheancierPayement(TableauDetailEcheancierPayement:TStringGrid; NumEcheancier:integer; var MessagePenalite:string);
var OKEcheancierPayement:boolean;   Penalite,PenaliteJour,CapitalGlobal,CapitalTranche,Reste:real; i,R,Resultat,NbrJourDiffere:integer;  DateDebut,DateFin,DateTeste:string;
begin
     TableauDetailEcheancierPayement.ColCount:=9;
     TableauDetailEcheancierPayement.RowCount:=2;
     TableauDetailEcheancierPayement.Rows[1].Text:='';
     TableauDetailEcheancierPayement.Cols[0].Text:='Ordre';
     TableauDetailEcheancierPayement.Cols[1].Text:='Date Début';
     TableauDetailEcheancierPayement.Cols[2].Text:='Date Fin';
     TableauDetailEcheancierPayement.Cols[3].Text:='Capital';
     TableauDetailEcheancierPayement.Cols[4].Text:='Pénalité';
     TableauDetailEcheancierPayement.Cols[5].Text:='Montant Global';
     TableauDetailEcheancierPayement.Cols[6].Text:='Date Réglement';
     TableauDetailEcheancierPayement.Cols[7].Text:='Montant Régler';
     TableauDetailEcheancierPayement.Cols[8].Text:='Situation au: ';

     OpenFParc(RParc);
     ChParametreEcheancier:=RParc.Parcours+'\'+Exercice+'FParametreEcheancier';
     assignfile(FParametreEcheancier,ChParametreEcheancier);
     if FileExists(ChParametreEcheancier)then
     Reset(FParametreEcheancier)
     else Rewrite(FParametreEcheancier);
     Seek(FParametreEcheancier,0);
     OKEcheancierPayement:=false;
     while not eof(FParametreEcheancier)and(OKEcheancierPayement=false)do
     begin
          read(FParametreEcheancier,RParametreEcheancier);
          if(RParametreEcheancier.NumEcheancier=NumEcheancier)then
          begin
               OKEcheancierPayement:=true;
          end;
     end;
     CloseFile(FParametreEcheancier);

     if(OKEcheancierPayement=true)and(RParametreEcheancier.MontantGlobal>0)and(RParametreEcheancier.MontantTranche>0)then
     begin
          DateDebut:=RParametreEcheancier.DateEcheancier;
          PrevoirDateEcheancier(DateDebut,RParametreEcheancier.DureeTranche,RParametreEcheancier.NaturedureeTranche,DateFin);
          i:=0;
          DateTeste:=DateDebut;
          while(strtodate(DateTeste)<>strtodate(DateFin))do
          begin
               DateTeste:=datetostr(strtodate(DateTeste)+1);   Application.ProcessMessages;
               i:=i+1;
          end;

          if(i>0)then PenaliteJour:=strtofloat(Vergule(floattostr(RParametreEcheancier.MontantTranche*RParametreEcheancier.PourcentagePenalite/i),'2','C',''))
                 else PenaliteJour:=0;

          FSEcheancierPayement.EditPenaliteJour.Text:=floattostr(PenaliteJour);

          MessagePenalite:='Pas de pénalités !';
          if(PenaliteJour>0)then
          begin
               MessagePenalite:='Une Pénalité de: '+Vergule(floattostr(RParametreEcheancier.PourcentagePenalite),'2','C','%')+' soit: '+Vergule(floattostr(PenaliteJour),'2','C','')+' DA, sera appliquer chaque jour, aprés '+inttostr(RParametreEcheancier.DureeDiffereApplicationPenalite)+' '+RParametreEcheancier.NatureDureeDiffereApplicationPenalite+' de retard de la date de l''échéancier, sur le capital périodique';
               if(RParametreEcheancier.MontantMaxPenalite>0)
               then MessagePenalite:=MessagePenalite+', (Max: '+Vergule(floattostr(RParametreEcheancier.MontantMaxPenalite),'2','C','')+')'
               else MessagePenalite:=MessagePenalite+'.';
          end;

          CapitalGlobal:=RParametreEcheancier.MontantGlobal-RParametreEcheancier.ApportInitial-RParametreEcheancier.ApportBancaire;
          CapitalTranche:=RParametreEcheancier.MontantTranche;
          Resultat:=0;
          while(CapitalGlobal>=CapitalTranche)do
          begin
               CapitalGlobal:=CapitalGlobal-CapitalTranche;
               Resultat:=Resultat+1;
          end;
          Reste:=CapitalGlobal;

          if(Reste>0)then
          begin
               if(RParametreEcheancier.ApportInitial>0)
               then TableauDetailEcheancierPayement.RowCount:=Resultat+3
               else TableauDetailEcheancierPayement.RowCount:=Resultat+2;
          end
          else
          begin
               if(RParametreEcheancier.ApportInitial>0)
               then TableauDetailEcheancierPayement.RowCount:=Resultat+2
               else TableauDetailEcheancierPayement.RowCount:=Resultat+1;
          end;

          if(RParametreEcheancier.ApportInitial>0)then
          begin
               TableauDetailEcheancierPayement.Rows[1].Text:=inttostr(0);
               TableauDetailEcheancierPayement.Cells[1,1]:='Avant: '+RParametreEcheancier.DateEcheancier;
               TableauDetailEcheancierPayement.Cells[2,1]:=RParametreEcheancier.DateEcheancier;
               TableauDetailEcheancierPayement.Cells[3,1]:=Vergule(floattostr(RParametreEcheancier.ApportInitial+RParametreEcheancier.ApportBancaire),'2','C','');
               TableauDetailEcheancierPayement.Cells[4,1]:='';
               TableauDetailEcheancierPayement.Cells[5,1]:='';
               TableauDetailEcheancierPayement.Cells[6,1]:='';
               TableauDetailEcheancierPayement.Cells[7,1]:='';
               TableauDetailEcheancierPayement.Cells[8,1]:='Apport Global';
               R:=2;
          end
          else R:=1;
          DateDebut:=RParametreEcheancier.DateEcheancier;
          while(R<=TableauDetailEcheancierPayement.RowCount-1)do
          begin
               Application.ProcessMessages;
               PrevoirDateEcheancier(DateDebut,RParametreEcheancier.DureeTranche,RParametreEcheancier.NaturedureeTranche,DateFin);
               TableauDetailEcheancierPayement.Rows[R].Text:=inttostr(R);
               TableauDetailEcheancierPayement.Cells[1,R]:=DateDebut;
               TableauDetailEcheancierPayement.Cells[2,R]:=DateFin;
               if(R<TableauDetailEcheancierPayement.RowCount-1)
               then TableauDetailEcheancierPayement.Cells[3,R]:=Vergule(floattostr(CapitalTranche),'2','C','')
               else TableauDetailEcheancierPayement.Cells[3,R]:=Vergule(floattostr(Reste),'2','C','');
               TableauDetailEcheancierPayement.Cells[4,R]:='';
               TableauDetailEcheancierPayement.Cells[5,R]:='';
               TableauDetailEcheancierPayement.Cells[6,R]:='';
               TableauDetailEcheancierPayement.Cells[7,R]:='';
                ///////////////////////
               Penalite:=0;
               if(strtodate(DateFin)<Date)then
               begin
                    i:=0;
                    DateTeste:=DateFin;
                    while(strtodate(DateTeste)<>Date)do
                    begin
                         DateTeste:=datetostr(strtodate(DateTeste)+1);
                         i:=i+1;
                    end;
                    TableauDetailEcheancierPayement.Cells[8,R]:='Dépasser de: '+inttostr(i)+' jours';

                    if(PenaliteJour>0)then
                    begin
                         NbrJourDiffere:=DiffereInJour(DateFin,RParametreEcheancier.DureeDiffereApplicationPenalite,RParametreEcheancier.NatureDureeDiffereApplicationPenalite);
                         if(i>NbrJourDiffere)then
                         begin
                              Penalite:=PenaliteJour*i;
                              if(RParametreEcheancier.MontantMaxPenalite>0)then
                              begin
                                   if(Penalite>RParametreEcheancier.MontantMaxPenalite)then Penalite:=RParametreEcheancier.MontantMaxPenalite;
                              end;

                         TableauDetailEcheancierPayement.Cells[4,R]:=Vergule(floattostr(Penalite),'2','C','');
                         end;
                    end;
               end;
               
               TableauDetailEcheancierPayement.Cells[5,R]:=Vergule(floattostr(CapitalTranche+Penalite),'2','C','');

               if(strtodate(DateFin)>=Date)then
               begin
                    i:=0;
                    DateTeste:=DateFin;
                    while(strtodate(DateTeste)<>Date)do
                    begin
                         DateTeste:=datetostr(strtodate(DateTeste)-1);
                         i:=i+1;
                    end;
                    TableauDetailEcheancierPayement.Cells[8,R]:='Reste: '+inttostr(i)+' jours';
               end;
               //////////////////
               DateDebut:=DateFin;
          R:=R+1;
          end;

          TableauDetailEcheancierPayement.RowCount:=TableauDetailEcheancierPayement.RowCount+3;
          TableauDetailEcheancierPayement.Rows[TableauDetailEcheancierPayement.RowCount-1].Text:='';
          TableauDetailEcheancierPayement.Rows[TableauDetailEcheancierPayement.RowCount-2].Text:='';
          TableauDetailEcheancierPayement.Rows[TableauDetailEcheancierPayement.RowCount-3].Text:='';
          TableauDetailEcheancierPayement.Cells[2,TableauDetailEcheancierPayement.RowCount-2]:='Total:';
          TableauDetailEcheancierPayement.Cells[2,TableauDetailEcheancierPayement.RowCount-1]:='ŕ régler:';
          R:=1;
          while(R<=TableauDetailEcheancierPayement.RowCount-3)do
          begin
               Application.ProcessMessages;
               TableauDetailEcheancierPayement.Cells[3,TableauDetailEcheancierPayement.RowCount-2]:=Vergule(floattostr(strtoreal(TableauDetailEcheancierPayement.Cells[3,TableauDetailEcheancierPayement.RowCount-2])+
                                                                                                    strtoreal(TableauDetailEcheancierPayement.Cells[3,R])),'2','C','');
               TableauDetailEcheancierPayement.Cells[4,TableauDetailEcheancierPayement.RowCount-2]:=Vergule(floattostr(strtoreal(TableauDetailEcheancierPayement.Cells[4,TableauDetailEcheancierPayement.RowCount-2])+
                                                                                                    strtoreal(TableauDetailEcheancierPayement.Cells[4,R])),'2','C','');
               TableauDetailEcheancierPayement.Cells[5,TableauDetailEcheancierPayement.RowCount-2]:=Vergule(floattostr(strtoreal(TableauDetailEcheancierPayement.Cells[5,TableauDetailEcheancierPayement.RowCount-2])+
                                                                                                    strtoreal(TableauDetailEcheancierPayement.Cells[5,R])),'2','C','');

               if(Firstlaters(TableauDetailEcheancierPayement.Cells[8,R],8)='Dépasser')
               then TableauDetailEcheancierPayement.Cells[5,TableauDetailEcheancierPayement.RowCount-1]:=Vergule(floattostr(strtoreal(TableauDetailEcheancierPayement.Cells[5,TableauDetailEcheancierPayement.RowCount-1])+
                                                                                                    strtoreal(TableauDetailEcheancierPayement.Cells[5,R])),'2','C','');
          R:=R+1;
          end;
     end
     else
     begin
          if(OKEcheancierPayement=false)
          then AfficherMessage('Le numéro de l''Echéancier n''existe pas !')
          else AfficherMessage('Vérifier les données SVP !');
     end;

     AjusterColWidth(TableauDetailEcheancierPayement,'','');
end;

Procedure PrevoirDateEcheancier(DatePrincipale:string; delais:integer; UniteDelais:string; var DatePrevue:string);
var  JJ,mm,AAAA,Resultat,Reste:integer; DateTeste:string[10];
begin

DatePrevue:=DatePrincipale;

jj:=strtointeger(Midellaters(DatePrincipale,1,2));
mm:=strtointeger(Midellaters(DatePrincipale,4,5));
AAAA:=strtointeger(Midellaters(DatePrincipale,7,10));

if(UniteDelais='Année')then
begin
     AAAA:=AAAA+delais;
end;

if(UniteDelais='Mois')then
begin
     Division(mm+delais,12,Resultat,Reste);
     if(Reste=0)then begin Reste:=12; Resultat:=Resultat-1;end;
     mm:=Reste;
     AAAA:=AAAA+Resultat;
end;

if(UniteDelais='Jour')then
begin
     DateTeste:=datetostr(strtodate(DatePrincipale)+delais);
     jj:=strtointeger(firstlaters(DateTeste,2));
     mm:=strtointeger(firstlaters(lastlaters(DateTeste,7),2));
     AAAA:=strtointeger(lastlaters(DateTeste,4));
end;

DatePrevue:=Completezerogauche(inttostr(jj),'2')+'/'+Completezerogauche(inttostr(mm),'2')+'/'+Completezerogauche(inttostr(AAAA),'4');

end;

Function DiffereInJour(DatePrincipale:string; delais:integer; UniteDelais:string):integer;
var  d,JJ,mm,AAAA,Resultat,Reste:integer; DateFinale,DateTeste:string[10];
begin

DateFinale:=DatePrincipale;

jj:=strtointeger(Midellaters(DatePrincipale,1,2));
mm:=strtointeger(Midellaters(DatePrincipale,4,5));
AAAA:=strtointeger(Midellaters(DatePrincipale,7,10));

if(UniteDelais='Année')then
begin
     AAAA:=AAAA+delais;
end;

if(UniteDelais='Mois')then
begin
     Division(mm+delais,12,Resultat,Reste);
     if(Reste=0)then begin Reste:=12; Resultat:=Resultat-1;end;
     mm:=Reste;
     AAAA:=AAAA+Resultat;
end;

if(UniteDelais='Jour')then
begin
     DateTeste:=datetostr(strtodate(DatePrincipale)+delais);
     jj:=strtointeger(firstlaters(DateTeste,2));
     mm:=strtointeger(firstlaters(lastlaters(DateTeste,7),2));
     AAAA:=strtointeger(lastlaters(DateTeste,4));
end;

DateFinale:=Completezerogauche(inttostr(jj),'2')+'/'+Completezerogauche(inttostr(mm),'2')+'/'+Completezerogauche(inttostr(AAAA),'4');

d:=0;
if(strtodate(DatePrincipale)<=strtodate(DateFinale))then
begin      
     DateTeste:=DatePrincipale;
     while(strtodate(DateTeste)<>strtodate(DateFinale))do
     begin
          DateTeste:=datetostr(strtodate(DateTeste)+1);
          d:=d+1;
     end;
end;

DiffereInJour:=d;
end;

Procedure AfficheDetailReglementEcheancier(TableauDetailEcheancierPayement,TableauRecapitulatifEcheancierPaiement:TStringGrid; CodeTiers,ListeNumPlanificateur:string);
var  R,RowDetail,RowRecap:integer;   OKReglement:boolean;   ResteARegler,MontantRegler:real;
     DureeDiffereApplicationPenalite:integer; NatureDureeDiffereApplicationPenalite:string; CapitalTranche,MontantMaxPenalite,PenaliteJour:real; DateFin,DatePaiement:string; MontantPenalite:real; MessageEtat:string;
begin
     TableauRecapitulatifEcheancierPaiement.ColCount:=9;
     TableauRecapitulatifEcheancierPaiement.RowCount:=2;
     TableauRecapitulatifEcheancierPaiement.Rows[1].Text:='';
     TableauRecapitulatifEcheancierPaiement.Cols[0].Text:='Ordre';
     TableauRecapitulatifEcheancierPaiement.Cols[1].Text:='Date Début';
     TableauRecapitulatifEcheancierPaiement.Cols[2].Text:='Date Fin';
     TableauRecapitulatifEcheancierPaiement.Cols[3].Text:='Capital';
     TableauRecapitulatifEcheancierPaiement.Cols[4].Text:='Pénalité';
     TableauRecapitulatifEcheancierPaiement.Cols[5].Text:='Montant Global';
     TableauRecapitulatifEcheancierPaiement.Cols[6].Text:='Date Réglement';
     TableauRecapitulatifEcheancierPaiement.Cols[7].Text:='Montant Régler';
     TableauRecapitulatifEcheancierPaiement.Cols[8].Text:='Situation au: ';

     OpenFParc(RParc);
     ChDetailRubriqueFicheTechnique:=RParc.Parcours+'\'+Exercice+'FDetailRubriqueFicheTechnique';
     assignfile(FDetailRubriqueFicheTechnique,ChDetailRubriqueFicheTechnique);
     if FileExists(ChDetailRubriqueFicheTechnique)then
     Reset(FDetailRubriqueFicheTechnique)
     else Rewrite(FDetailRubriqueFicheTechnique);
     Seek(FDetailRubriqueFicheTechnique,0);
     RowRecap:=1;
     RowDetail:=1;
     TableauRecapitulatifEcheancierPaiement.Rows[RowRecap].Text:=TableauDetailEcheancierPayement.Rows[RowDetail].Text;
     MontantRegler:=0;
     ResteARegler:=0;
     DureeDiffereApplicationPenalite:=strtointeger(FSEcheancierPayement.TableauListeEcheancierPayement.Cells[12,FSEcheancierPayement.TableauListeEcheancierPayement.Row]);
     NatureDureeDiffereApplicationPenalite:=FSEcheancierPayement.TableauListeEcheancierPayement.Cells[13,FSEcheancierPayement.TableauListeEcheancierPayement.Row];
     MontantMaxPenalite:=strtoreal(FSEcheancierPayement.TableauListeEcheancierPayement.Cells[14,FSEcheancierPayement.TableauListeEcheancierPayement.Row]);
     PenaliteJour:=strtoreal(FSEcheancierPayement.EditPenaliteJour.Text);
     while not eof(FDetailRubriqueFicheTechnique)do
     begin
          read(FDetailRubriqueFicheTechnique,RDetailRubriqueFicheTechnique);
          
          if(RDetailRubriqueFicheTechnique.CodeTiers=CodeTiers)
          and(ExisteNumintexte(inttostr(RDetailRubriqueFicheTechnique.NumPlanificateur),ListeNumPlanificateur))
          then
          begin
               MontantRegler:=RDetailRubriqueFicheTechnique.Montant;
               DatePaiement:=RDetailRubriqueFicheTechnique.Date;

