procedure TFSEcheancierPayement.EditListeNumPlanificateurEnter(
  Sender: TObject);
var  C:integer; Quantite,Montant:real; NotCol:string;
begin
     FSEcheancierPayement.TableauSelection.Left:=FSEcheancierPayement.AfficheEcheancierPayement.Left+FSEcheancierPayement.EditListeNumPlanificateur.Left;
     FSEcheancierPayement.TableauSelection.Top:=FSEcheancierPayement.AfficheEcheancierPayement.Top+FSEcheancierPayement.EditListeNumPlanificateur.Top+20;

     ListePlanificateurTiers(FSEcheancierPayement.TableauSelection,'',FSEcheancierPayement.EditCodeTiers.Text,'',Quantite,Montant);
     FSEcheancierPayement.TableauSelection.Cells[0,0]:='Projet';
     FSEcheancierPayement.TableauSelection.ColCount:=13;
     FSEcheancierPayement.TableauSelection.Cols[12].Text:='OK';

     NotCol:='2;3;5;7;8;10';
     for C:=1 to FSEcheancierPayement.TableauSelection.ColCount-1 do
     begin
          if(ExisteNumInTexte(inttostr(C),NotCol))then FSEcheancierPayement.TableauSelection.ColWidths[C]:=0;
     end;

end;

procedure TFSEcheancierPayement.TableauSelectionKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  R,RApport:integer;  NumRubrique:string;   TotalApportBancaire,TotalApportInitial,ApportGlobal:real;
begin

     if key in[VK_RETURN]then
     begin
          if(FSEcheancierPayement.TableauSelection.Cells[0,0]='Projet')then
          begin
               R:=1;
               FSEcheancierPayement.EditListeNumPlanificateur.Text:='';
               FSEcheancierPayement.EditMontantGlobale.Text:='';
               while(R<=FSEcheancierPayement.TableauSelection.RowCount-1)do
               begin
                    if(FSEcheancierPayement.TableauSelection.Cells[12,R]='OK')then
                    begin
                         if(FSEcheancierPayement.EditListeNumPlanificateur.Text='')
                         then FSEcheancierPayement.EditListeNumPlanificateur.Text:=FSEcheancierPayement.TableauSelection.Cells[3,R]
                         else FSEcheancierPayement.EditListeNumPlanificateur.Text:=FSEcheancierPayement.EditListeNumPlanificateur.Text+';'+
                                                                                      FSEcheancierPayement.TableauSelection.Cells[3,R];

                         FSEcheancierPayement.EditMontantGlobale.Text:=floattostr(strtoreal(FSEcheancierPayement.EditMontantGlobale.Text)+
                                                                       strtoreal(FSEcheancierPayement.TableauSelection.Cells[9,R]));

                    end;
               R:=R+1;
               end;
               FSEcheancierPayement.EditMontantGlobale.Text:=Vergule(FSEcheancierPayement.EditMontantGlobale.Text,'2','C','');

               ///////////////////////   APPORT GLOBAL//////////////////////////
               FSEcheancierPayement.AfficheApportGlobal.Visible:=true;
               FSEcheancierPayement.TableauApportGlobal.ColCount:=5;
               FSEcheancierPayement.TableauApportGlobal.Cols[0].Text:='N°';
               FSEcheancierPayement.TableauApportGlobal.Cols[1].Text:='Structure';
               FSEcheancierPayement.TableauApportGlobal.Cols[2].Text:='Apport bancaire';
               FSEcheancierPayement.TableauApportGlobal.Cols[3].Text:='Apport Initial';
               FSEcheancierPayement.TableauApportGlobal.Cols[4].Text:='Total Apport';

               FSEcheancierPayement.TableauApportGlobal.RowCount:=2;
               FSEcheancierPayement.TableauApportGlobal.Rows[1].Text:='';

               RApport:=0;

               OpenFParc(RParc);
               ChFormulairePreselection:=RParc.Parcours+'\'+Exercice+'FFormulairePreselection';
               assignfile(FFormulairePreselection,ChFormulairePreselection);
               if FileExists(ChFormulairePreselection)then
               Reset(FFormulairePreselection)
               else Rewrite(FFormulairePreselection);
               Seek(FFormulairePreselection,0);
               TotalApportBancaire:=0;
               TotalApportInitial:=0;
               ApportGlobal:=0;
               while not eof(FFormulairePreselection)do
               begin
                    read(FFormulairePreselection,RFormulairePreselection);
                    R:=1;
                    while(R<=FSEcheancierPayement.TableauSelection.RowCount-1)do
                    begin
                         NumRubrique:=FSEcheancierPayement.TableauSelection.Cells[2,FSEcheancierPayement.TableauSelection.Row];
                         RubriqueArborescence('',NumRubrique,RRubriqueFicheTechnique,RFicheTechnique,RTypeAvis);
                         if(FSEcheancierPayement.TableauSelection.Cells[12,R]='OK')then
                         begin
                              if(RFormulairePreselection.CodeTier=FSEcheancierPayement.TableauSelection.Cells[5,R])
                              and(RFormulairePreselection.NumProjet=FSEcheancierPayement.TableauSelection.Cells[10,R])
                              and(RFormulairePreselection.OKReglementApportInitial=true)
                              then
                              begin
                                   RApport:=RApport+1;
                                   FSEcheancierPayement.TableauApportGlobal.Rows[RApport].Text:=inttostr(RApport);
                                   FSEcheancierPayement.TableauApportGlobal.Cells[1,RApport]:=RFormulairePreselection.DesignationProjet;
                                   FSEcheancierPayement.TableauApportGlobal.Cells[2,RApport]:=Vergule(floattostr(RFormulairePreselection.SimulationBanque),'2','C','');
                                   FSEcheancierPayement.TableauApportGlobal.Cells[3,RApport]:=Vergule(floattostr(RFormulairePreselection.ApportInitial),'2','C','');
                                   FSEcheancierPayement.TableauApportGlobal.Cells[4,RApport]:=Vergule(floattostr(RFormulairePreselection.SimulationBanque+RFormulairePreselection.ApportInitial),'2','C','');

                                   TotalApportBancaire:=TotalApportBancaire+RFormulairePreselection.SimulationBanque;
                                   TotalApportInitial:=TotalApportInitial+RFormulairePreselection.ApportInitial;
                                   ApportGlobal:=ApportGlobal+RFormulairePreselection.SimulationBanque+RFormulairePreselection.ApportInitial;
                              end;
                         end;
                    R:=R+1;
                    end;
               end;
               Closefile(FFormulairePreselection);
               /////////////////////////////////////////////////////////////////

               if(RApport>0)then
                            begin
                                 FSEcheancierPayement.TableauApportGlobal.RowCount:=RApport+3;
                                 FSEcheancierPayement.TableauApportGlobal.Rows[RApport+1].Text:='';
                                 FSEcheancierPayement.TableauApportGlobal.Rows[RApport+2].Text:='';
                                 FSEcheancierPayement.TableauApportGlobal.Cells[1,RApport+2]:='Total:';
                                 FSEcheancierPayement.TableauApportGlobal.Cells[2,RApport+2]:=Vergule(floattostr(TotalApportBancaire),'2','C','');
                                 FSEcheancierPayement.TableauApportGlobal.Cells[3,RApport+2]:=Vergule(floattostr(TotalApportInitial),'2','C','');
                                 FSEcheancierPayement.TableauApportGlobal.Cells[4,RApport+2]:=Vergule(floattostr(ApportGlobal),'2','C','');
                            end
                            else FSEcheancierPayement.TableauApportGlobal.RowCount:=2;

               FSEcheancierPayement.EditApportInitial.Text:=Vergule(floattostr(TotalApportInitial),'2','C','');
               FSEcheancierPayement.EditApportBancaire.Text:=Vergule(floattostr(TotalApportBancaire),'2','C','');
               AjusterColWidth(FSEcheancierPayement.TableauApportGlobal,'','');

               FSEcheancierPayement.EditApportInitial.SetFocus;
               FSEcheancierPayement.TableauSelection.Visible:=false;
          end;

          if(FSEcheancierPayement.TableauSelection.Cells[0,0]='Tiers')then
          begin
               FSEcheancierPayement.EditCodeTiers.Text:=FSEcheancierPayement.TableauSelection.Cells[1,FSEcheancierPayement.TableauSelection.Row];
               FSEcheancierPayement.EditTiers.Text:=FSEcheancierPayement.TableauSelection.Cells[2,FSEcheancierPayement.TableauSelection.Row];
               FSEcheancierPayement.TableauSelection.Visible:=false;
               FSEcheancierPayement.EditListeNumPlanificateur.SetFocus;
          end;

          if(FSEcheancierPayement.TableauSelection.Cells[0,0]='Pays')
          or(FSEcheancierPayement.TableauSelection.Cells[0,0]='Wylaia')
          or(FSEcheancierPayement.TableauSelection.Cells[0,0]='Daira')
          or(FSEcheancierPayement.TableauSelection.Cells[0,0]='Commune')
          or(FSEcheancierPayement.TableauSelection.Cells[0,0]='Zone')
          then
          begin
               FSEcheancierPayement.EditCodeLocalisationGeographique.Text:=FSEcheancierPayement.TableauSelection.Cells[1,FSEcheancierPayement.TableauSelection.Row];
               FSEcheancierPayement.EditEtablissementlegalisationsignature.Text:=FSEcheancierPayement.TableauSelection.Cells[2,FSEcheancierPayement.TableauSelection.Row];
               FSEcheancierPayement.TableauSelection.Visible:=false;
               FSEcheancierPayement.BitOperationEcheancierPayement.SetFocus;
          end;
     end;
end;

