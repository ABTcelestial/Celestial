Procedure ListeParametreEcheancier(TableauParametreEcheancier:TStringGrid);
var  R:integer;   OKParametreEcheancier:boolean;
begin
     TableauParametreEcheancier.ColCount:=21;
     TableauParametreEcheancier.RowCount:=2;
     TableauParametreEcheancier.Rows[1].Text:='';
