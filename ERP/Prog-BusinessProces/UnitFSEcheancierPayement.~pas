if(FSEcheancierPayement.BitOperationEcheancierPayement.Caption='Valider')then
begin
     OpenFParc(RParc);
     ChParametreEcheancier:=RParc.Parcours+'\'+Exercice+'FParametreEcheancier';
     assignfile(FParametreEcheancier,ChParametreEcheancier);
     if FileExists(ChParametreEcheancier)then
