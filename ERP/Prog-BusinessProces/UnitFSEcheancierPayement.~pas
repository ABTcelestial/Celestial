          begin
               FSEcheancierPayement.EditEcheancierTexte.Lines.Add('- Apport Initial:                        '+FSEcheancierPayement.TableauListeEcheancierPayement.Cells[7,FSEcheancierPayement.TableauListeEcheancierPayement.Row]+' DA');
          end;

