          begin
               FSEcheancierPayement.EditEcheancierTexte.Lines.Add('- Apport Bancaire:                    '+FSEcheancierPayement.TableauListeEcheancierPayement.Cells[8,FSEcheancierPayement.TableauListeEcheancierPayement.Row]+' DA');
