Procedure CalculePenalite(DureeDiffereApplicationPenalite:integer; NatureDureeDiffereApplicationPenalite:string; CapitalTranche,MontantMaxPenalite,PenaliteJour:real; DateFin,DatePaiement:string; Var MontantPenalite:real; var SituationEcheancier:string);
var iP:integer; Penalite:real;  DateTeste:string[10];   NbrJourDiffere:integer;
begin
     MontantPenalite:=0;
     SituationEcheancier:='';
     Penalite:=0;
     if(strtodate(DateFin)<strtodate(DatePaiement))then
     begin
          iP:=0;
          DateTeste:=DateFin;
          while(strtodate(DateTeste)<>strtodate(DatePaiement))do
          begin
               DateTeste:=datetostr(strtodate(DateTeste)+1);
               iP:=iP+1;
          end;

          if(strtodate(DatePaiement)<date)then SituationEcheancier:='Retard de: '+inttostr(iP)+' jours'
                                          else SituationEcheancier:='Dépasser de: '+inttostr(iP)+' jours';

          if(PenaliteJour>0)then
          begin
               NbrJourDiffere:=DiffereInJour(DateFin,DureeDiffereApplicationPenalite,NatureDureeDiffereApplicationPenalite);
               if(iP>NbrJourDiffere)then
               begin
                    Penalite:=PenaliteJour*iP;
                    if(MontantMaxPenalite>0)then
                    begin
                         if(Penalite>MontantMaxPenalite)then Penalite:=MontantMaxPenalite;
                    end;

               MontantPenalite:=Penalite;
               end;
          end;
          end;

          if(strtodate(DateFin)>=strtodate(DatePaiement))then
          begin
               iP:=0;
               DateTeste:=DateFin;
               while(strtodate(DateTeste)<>strtodate(DatePaiement))do
               begin
                    DateTeste:=datetostr(strtodate(DateTeste)-1);
                    iP:=iP+1;
               end;

               if(strtodate(DatePaiement)<date)then SituationEcheancier:='Avance de: '+inttostr(iP)+' jours'
                                               else SituationEcheancier:='Reste: '+inttostr(iP)+' jours'
          end;
end;

