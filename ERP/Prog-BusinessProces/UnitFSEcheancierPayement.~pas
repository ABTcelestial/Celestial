     TableauParametreEcheancier.Cols[20].Text:='Loc.Géo.';

     OpenFParc(RParc);
     ChParametreEcheancier:=RParc.Parcours+'\'+Exercice+'FParametreEcheancier';
     assignfile(FParametreEcheancier,ChParametreEcheancier);
     if FileExists(ChParametreEcheancier)then
     Reset(FParametreEcheancier)
     else Rewrite(FParametreEcheancier);
     Seek(FParametreEcheancier,0);
     R:=0;
     while not eof(FParametreEcheancier)do
     begin
          read(FParametreEcheancier,RParametreEcheancier);

          OKParametreEcheancier:=true;

          if(OKParametreEcheancier=true)then
          begin
               R:=R+1;
               TableauParametreEcheancier.Rows[R].Text:=inttostr(R);
               TableauParametreEcheancier.Cells[1,R]:=inttostr(RParametreEcheancier.NumEcheancier);
               TableauParametreEcheancier.Cells[2,R]:=RParametreEcheancier.DateEcheancier;
               TableauParametreEcheancier.Cells[3,R]:=RParametreEcheancier.CodeTiers;
               RTier:=ChercherTiers(FSEcheancierPayement.EditChargementTypeProces.Text,FSEcheancierPayement.EditChargementFichierConcerne.Text,RParametreEcheancier.CodeTiers,'');
               TableauParametreEcheancier.Cells[4,R]:=RTier.NomTiers+' '+RTier.PrenomTiers;
               TableauParametreEcheancier.Cells[5,R]:=RParametreEcheancier.ListeNumPlanificateur;
               TableauParametreEcheancier.Cells[6,R]:=Vergule(floattostr(RParametreEcheancier.MontantGlobal),'2','C','');
