     if(FSEcheancierPayement.RBActiveDureeEcheancier.Checked=true)
     and(strtoreal(FSEcheancierPayement.EditDureeEcheancier.Text)>0)
     and(strtoreal(FSEcheancierPayement.EditDureeTranche.Text)>0)then
     begin
          FSEcheancierPayement.EditMontantTranche.Text:=Vergule(floattostr(((strtoreal(FSEcheancierPayement.EditMontantGlobale.Text)-strtoreal(FSEcheancierPayement.EditApportInitial.Text)-strtoreal(FSEcheancierPayement.EditApportBancaire.Text))/strtoreal(FSEcheancierPayement.EditDureeEcheancier.Text))*strtoreal(FSEcheancierPayement.EditDureeTranche.Text)),'2','C','');

     end;
end;

