               TableauParametreEcheancier.Cells[8,R]:=Vergule(floattostr(RParametreEcheancier.ApportBancaire),'2','C','');
               TableauParametreEcheancier.Cells[9,R]:=inttostr(RParametreEcheancier.DureeTranche);
               TableauParametreEcheancier.Cells[10,R]:=RParametreEcheancier.NaturedureeTranche;
               TableauParametreEcheancier.Cells[11,R]:=Vergule(floattostr(RParametreEcheancier.MontantTranche),'2','C','');
               TableauParametreEcheancier.Cells[12,R]:=Vergule(floattostr(RParametreEcheancier.PourcentagePenalite),'2','C','%');
               TableauParametreEcheancier.Cells[13,R]:=inttostr(RParametreEcheancier.DureeDiffereApplicationPenalite);
               TableauParametreEcheancier.Cells[14,R]:=RParametreEcheancier.NatureDureeDiffereApplicationPenalite;
               TableauParametreEcheancier.Cells[15,R]:=Vergule(floattostr(RParametreEcheancier.MontantMaxPenalite),'2','C','');
               TableauParametreEcheancier.Cells[16,R]:=RParametreEcheancier.Domiciliation;
               TableauParametreEcheancier.Cells[17,R]:=RParametreEcheancier.CompteDomiciliation;
               TableauParametreEcheancier.Cells[18,R]:=RParametreEcheancier.FichierLocalisationGeographique;
               TableauParametreEcheancier.Cells[19,R]:=RParametreEcheancier.CodeLocalisationGeographique;
               TableauParametreEcheancier.Cells[20,R]:=ChercherLocalisationGeographique(RParametreEcheancier.CodeLocalisationGeographique,'F'+RParametreEcheancier.FichierLocalisationGeographique).IntitulleLocalisationGeographique;
          end
     end;

     if(R>0)then TableauParametreEcheancier.RowCount:=R+1
            else TableauParametreEcheancier.RowCount:=2;

     TableauParametreEcheancier.ColWidths[5]:=0;
     AjusterColWidth(TableauParametreEcheancier,'','5');
end;

