          if(FSImporteDetailMarcheExcel.TableauDonnees.ColWidths[C]>strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text))
          then FSImporteDetailMarcheExcel.TableauDonnees.ColWidths[C]:=strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text);
     end;

     FSImporteDetailMarcheExcel.TableauDetailMarche.Rows[1].Text:='';
end;

procedure TFSImporteDetailMarcheExcel.BitChargerExcelClick(Sender: TObject);
var  R,C,RBegin,REnd,CBegin,CEnd:integer;
begin
     FSImporteDetailMarcheExcel.BitPreparerTransfert.Enabled:=false;
     FSImporteDetailMarcheExcel.BitValiderTransfert.Enabled:=false;

     if(FSImporteDetailMarcheExcel.EditRBeginIn.Text='')then
     begin
          showmessage('Indiquer le numéro de la premičre ligne du tableau Excel SVP !');
          FSImporteDetailMarcheExcel.EditRBeginIn.SetFocus;
          Exit;
     end;

     if FSImporteDetailMarcheExcel.OuvrireFichier.Execute then
     begin
          RBegin:=strtointeger(FSImporteDetailMarcheExcel.EditRBeginIn.Text);
          CBegin:=strtointeger(FSImporteDetailMarcheExcel.EditCBeginIn.Text);

          ChargerRowColTableauExcel(FSImporteDetailMarcheExcel.OuvrireFichier.FileName,RBegin,CBegin,RBegin,REnd,CBegin,CEnd,True);

          FSImporteDetailMarcheExcel.EditRBegin.Text:=inttostr(RBegin);
          FSImporteDetailMarcheExcel.EditREnd.Text:=inttostr(REnd);

          FSImporteDetailMarcheExcel.EditCBegin.Text:=inttostr(CBegin);
          FSImporteDetailMarcheExcel.EditCEnd.Text:=inttostr(CEnd);

          ExcelToTableau(FSImporteDetailMarcheExcel.TableauDonnees,RBegin,REnd,CBegin,CEnd,FSImporteDetailMarcheExcel.OuvrireFichier.FileName,false);
     end;

     for C:= 1 to FSImporteDetailMarcheExcel.TableauDonnees.ColCount-1 do
     begin
          if(FSImporteDetailMarcheExcel.TableauDonnees.ColWidths[C]>strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text))
          then FSImporteDetailMarcheExcel.TableauDonnees.ColWidths[C]:=strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text);
     end;

     FSImporteDetailMarcheExcel.TableauDetailMarche.Rows[1].Text:='';

     FSImporteDetailMarcheExcel.BitPreparerTransfert.Enabled:=true;
end;

procedure TFSImporteDetailMarcheExcel.TableauDonneesDblClick(
  Sender: TObject);
var  C,CSelect,Incriment:integer;
begin
     if(FSImporteDetailMarcheExcel.EditEquivalenceColonne.Text<>'')then
     begin
          FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[strtointeger(FSImporteDetailMarcheExcel.EditEquivalenceColonne.Text),1]:=inttostr(FSImporteDetailMarcheExcel.TableauDonnees.Col);

          Incriment:=1;
          CSelect:=strtointeger(FSImporteDetailMarcheExcel.EditEquivalenceColonne.Text)+1;
          for C:= CSelect to FSImporteDetailMarcheExcel.TableauDetailMarche.ColCount-1 do
          begin
               FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[C,1]:=inttostr(FSImporteDetailMarcheExcel.TableauDonnees.Col+Incriment);
               Incriment:=Incriment+1;
          end;

          FSImporteDetailMarcheExcel.EditEquivalenceColonne.Text:='';
     end;

     if(FSImporteDetailMarcheExcel.EditEquivalenceLigne.Text<>'')then
     begin
          FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,strtointeger(FSImporteDetailMarcheExcel.EditEquivalenceLigne.Text)]:=inttostr(FSImporteDetailMarcheExcel.TableauDonnees.Row);
          FSImporteDetailMarcheExcel.EditEquivalenceLigne.Text:='';
     end;
end;

