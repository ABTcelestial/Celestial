procedure TFSImporteDetailMarcheExcel.TableauSelectionStructureClick(
  Sender: TObject);
var   R:integer;  OKStructure:boolean;
begin
     if(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,FSImporteDetailMarcheExcel.TableauSelectionStructure.Row]='')then
     begin
          R:=1;
          OKStructure:=false;
          while(R<=FSImporteDetailMarcheExcel.TableauDonnees.RowCount-1)and(OKStructure=false)do
          begin
               if(ExisteCharinString(AnsiUpperCase(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[4,FSImporteDetailMarcheExcel.TableauSelectionStructure.Row]),AnsiUpperCase(FSImporteDetailMarcheExcel.TableauDonnees.Cells[3,R])))
               or(ExisteCharinString(AnsiUpperCase(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[6,FSImporteDetailMarcheExcel.TableauSelectionStructure.Row]),AnsiUpperCase(FSImporteDetailMarcheExcel.TableauDonnees.Cells[3,R])))
               then
               begin
                    OKStructure:=true;
                    FSImporteDetailMarcheExcel.TableauDonnees.Row:=R;
                    FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,FSImporteDetailMarcheExcel.TableauSelectionStructure.Row]:=inttostr(R);
               end;
          R:=R+1;
          end;
     end
     else
     begin
          FSImporteDetailMarcheExcel.TableauDonnees.Row:=strtointeger(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,FSImporteDetailMarcheExcel.TableauSelectionStructure.Row]);
     end;
end;

procedure TFSImporteDetailMarcheExcel.BitPreparerTransfertClick(Sender: TObject);
var  im,R,RFirst,RNext,C,CVide,ColTransfert,IncrimenteCode,NumDetailMarche:integer;
     CodeLast:string;  OKStructure,OKValider:boolean;
begin

     FSImporteDetailMarcheExcel.TableauTransfert.ColCount:=FSImporteDetailMarcheExcel.TableauDetailMarche.ColCount;
     FSImporteDetailMarcheExcel.TableauTransfert.RowCount:=FSImporteDetailMarcheExcel.TableauDonnees.RowCount;

     OKValider:=false;
     C:=0;
     while(C<=FSImporteDetailMarcheExcel.TableauDetailMarche.ColCount-1)and(OKValider=false)do
     begin
          if(FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[C,1]<>'')then OKValider:=true;
     C:=C+1;
     end;

     if(OKValider=false)then
     begin
          C:=0;
          while(C<=FSImporteDetailMarcheExcel.TableauDetailMarche.ColCount-1)do
          begin
               FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[C,1]:=inttostr(C);
          C:=C+1;
          end;
     end;

     for C:=0 to FSImporteDetailMarcheExcel.TableauDetailMarche.ColCount-1 do
     begin
          if(FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[C,1]<>'')then
          begin
               ColTransfert:=strtointeger(FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[C,1]);
               for R:=0 to FSImporteDetailMarcheExcel.TableauDonnees.RowCount-1 do
               FSImporteDetailMarcheExcel.TableauTransfert.Cells[C,R]:=FSImporteDetailMarcheExcel.TableauDonnees.Cells[ColTransfert,R];
          end;
     end;

     FSImporteDetailMarcheExcel.TableauTransfert.Rows[0].Text:=FSImporteDetailMarcheExcel.TableauDetailMarche.Rows[0].Text;

     FSImporteDetailMarcheExcel.TableauDonnees.RowCount:=2;
     FSImporteDetailMarcheExcel.TableauDonnees.Rows[0].Text:='';
     FSImporteDetailMarcheExcel.TableauDonnees.Rows[1].Text:='';
     for C:=0 to FSImporteDetailMarcheExcel.TableauTransfert.ColCount-1 do
     begin
          for R:=0 to FSImporteDetailMarcheExcel.TableauTransfert.RowCount-1 do
          begin
               FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R]:='';
               FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R]:=FSImporteDetailMarcheExcel.TableauTransfert.Cells[C,R];
          end;
     end;
     FSImporteDetailMarcheExcel.TableauDonnees.ColCount:=FSImporteDetailMarcheExcel.TableauTransfert.ColCount;
     FSImporteDetailMarcheExcel.TableauDonnees.RowCount:=FSImporteDetailMarcheExcel.TableauTransfert.RowCount;

     im:=1;
     NumDetailMarche:=0;
     while(im<=FSImporteDetailMarcheExcel.TableauSelectionStructure.RowCount-1)do
     begin
          if(strtointeger(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,im])>0)then
          begin
               RFirst:=strtointeger(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,im]);
               if((im+1<=FSImporteDetailMarcheExcel.TableauSelectionStructure.RowCount-1)and(strtointeger(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,im+1])>0))
               then RNext:=strtointeger(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,im+1])-1
               else RNext:=FSImporteDetailMarcheExcel.TableauDonnees.RowCount-1;
          end;

          //FSImporteDetailMarcheExcel.TableauDonnees.Cells[7,RFirst]:=FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[7,i]+'00.00.00.00';
          //FSImporteDetailMarcheExcel.TableauDonnees.Cells[1,RFirst]:='';
          //R:=RFirst+1;
          R:=RFirst;
          CodeLast:='00.00.00';
          IncrimenteCode:=0;
          while(R<=RNext)do
          begin
                if ControleCodeArticleMarche(FSImporteDetailMarcheExcel.TableauDonnees.Cells[2,R],8)
                then
                begin
                     FSImporteDetailMarcheExcel.TableauDonnees.Cells[7,R]:=FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[7,im]+FSImporteDetailMarcheExcel.TableauDonnees.Cells[2,R]+'.00';
                     CodeLast:=FSImporteDetailMarcheExcel.TableauDonnees.Cells[2,R];
                     IncrimenteCode:=0;
                end
                else
                begin
                     IncrimenteCode:=IncrimenteCode+1;
                     FSImporteDetailMarcheExcel.TableauDonnees.Cells[7,R]:=FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[7,im]+CodeLast+'.'+completezerogauche(inttostr(IncrimenteCode),'2');
                end;
                FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R]:='72'+WithoutPoint(Lastlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[7,R],11));
                //FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R]:=NewArticle('72',Lastlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[7,R],11),Lastlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[7,R],11),FSImporteDetailMarcheExcel.TableauDonnees.Cells[3,R],FSImporteDetailMarcheExcel.TableauDonnees.Cells[4,R],FSImporteDetailMarcheExcel.TableauDonnees.Cells[6,R],FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R]);
                NumDetailMarche:=NumDetailMarche+1;
                FSImporteDetailMarcheExcel.TableauDonnees.Cells[1,R]:='';
           R:=R+1;
           end;
     im:=im+1;
     end; 

     AjusterColWidth(FSImporteDetailMarcheExcel.TableauDonnees,'','');

     for C:= 1 to FSImporteDetailMarcheExcel.TableauDonnees.ColCount-1 do
     begin
          if(FSImporteDetailMarcheExcel.TableauDonnees.ColWidths[C]>strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text))
          then FSImporteDetailMarcheExcel.TableauDonnees.ColWidths[C]:=strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text);
     end;

     for im:=1 to FSImporteDetailMarcheExcel.TableauSelectionStructure.RowCount-1 do
     begin
           if(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,im]='')then
           begin
                R:=1;
                OKStructure:=false;
                while(R<=FSImporteDetailMarcheExcel.TableauDonnees.RowCount-1)and(OKStructure=false)do
                begin
                     if(ExisteCharinString(AnsiUpperCase(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[4,im]),AnsiUpperCase(FSImporteDetailMarcheExcel.TableauDonnees.Cells[3,R])))
                     or(ExisteCharinString(AnsiUpperCase(FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[6,im]),AnsiUpperCase(FSImporteDetailMarcheExcel.TableauDonnees.Cells[3,R])))
                     then
                     begin
                          OKStructure:=true;
                          FSImporteDetailMarcheExcel.TableauDonnees.Row:=R;
                          FSImporteDetailMarcheExcel.TableauSelectionStructure.Cells[8,im]:=inttostr(R);
                     end;
                R:=R+1;
                end;
           end;
     end;

     for C:= 0 to FSImporteDetailMarcheExcel.TableauDetailMarche.ColCount-1 do
     begin
          FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[C,1]:=inttostr(C);
     end;

     FSImporteDetailMarcheExcel.BitValiderTransfert.Enabled:=true;
end;

