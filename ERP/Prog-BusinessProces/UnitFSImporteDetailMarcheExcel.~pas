procedure TFSImporteDetailMarcheExcel.BitValiderTransfertClick(Sender: TObject);
var   i,R,C,TailleCode:integer;  TypeComptabilite,TypePCN,TypeProces,FichierConcerne,Adresse:string; OK:boolean;
begin
     FSDetailMarche.TableauDetailMarche.ColCount:=FSImporteDetailMarcheExcel.TableauDonnees.ColCount;
     FSDetailMarche.TableauDetailMarche.RowCount:=FSImporteDetailMarcheExcel.TableauDonnees.RowCount;

     for C:=0 to FSImporteDetailMarcheExcel.TableauDonnees.ColCount-1 do
     begin
          for R:=0 to FSImporteDetailMarcheExcel.TableauDonnees.RowCount-1 do
          begin
               if(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R]<>'')then
               begin
                    FSDetailMarche.TableauDetailMarche.Cells[C,R]:=FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R];
               end;
          end;
     end;

     for C:= 1 to FSDetailMarche.TableauDetailMarche.ColCount-1 do
     begin
          if(FSDetailMarche.TableauDetailMarche.ColWidths[C]>strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text))
          then FSDetailMarche.TableauDetailMarche.ColWidths[C]:=strtointeger(FSImporteDetailMarcheExcel.EditColWidths.Text);
     end;

     TypeProces:='Comptabilité'; //TypePCN,TypeProces,FichierConcerne,Adresse:string;
     TypeComptabilite:='Marche';
     TypePCN:='';

     for R:=1 to FSImporteDetailMarcheExcel.TableauDonnees.RowCount-1 do
     begin
          if(FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R]<>'')then
          begin
               if(lastlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R],5)='00000')then
               begin
                    FichierConcerne:='FFamille'+TypeComptabilite;
                    TailleCode:=5;
               end
               else
               if(lastlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R],4)='0000')then
               begin
                    FichierConcerne:='FSousFamille'+TypeComptabilite;
                    TailleCode:=6;
               end
               else
               begin
                    FichierConcerne:='FStock'+TypeComptabilite;
                    TailleCode:=10;
               end;

               if(FichierConcerne<>'FStock'+TypeComptabilite)then
               begin
                     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                     begin
                          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
                     end;

                     ChRegistreCompte:=Adresse;
                     assignfile(FRegistreCompte,ChRegistreCompte);
                     if FileExists(ChRegistreCompte)
                     then Reset(FRegistreCompte)else Rewrite(FRegistreCompte);
                     Seek(FRegistreCompte,0);
                     i:=0;
                     OK:=false;
                     while not eof(FRegistreCompte)and(OK=false)do
                     begin
                          Read(FRegistreCompte,RRegistreCompte);
                          i:=i+1;
                          if(RRegistreCompte.CodeCompte=Firstlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R],TailleCode))then
                          begin
                               OK:=true;
                          end;
                     end;

                     if(OK=false)then
                     begin
                          Seek(FRegistreCompte,i);
                          RRegistreCompte.CodeCompte:=Firstlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R],TailleCode);
                          RRegistreCompte.Designation:=FSImporteDetailMarcheExcel.TableauDonnees.Cells[3,R];
                          RRegistreCompte.ContrePartie.UsesCompte:=false;
                          RRegistreCompte.ContrePartie.TypeUses:='Tous';
                          RRegistreCompte.Specificite:='1';
                          RRegistreCompte.Tiers:=false;
                          RRegistreCompte.Active:=true;
                          Write(FRegistreCompte,RRegistreCompte);
                     end;
               end
               else
               begin
                    TypeProces:='Commercial';
                    if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                     begin
                          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
                     end;

                     ChStock:=Adresse;
                     assignfile(FStock,ChStock);
                     if FileExists(ChStock)
                     then Reset(FStock)else Rewrite(FStock);
                     Seek(FStock,0);
                     i:=0;
                     OK:=false;
                     while not eof(FStock)and(OK=false)do
                     begin
                          Read(FStock,RStock);
                          i:=i+1;
                          if(RStock.Code=Firstlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R],TailleCode))then
                          begin
                               OK:=true;
                          end;
                     end;

                     if(OK=false)then
                     begin
                          Seek(FStock,i);
                          RStock.Code:=Firstlaters(FSImporteDetailMarcheExcel.TableauDonnees.Cells[8,R],TailleCode);
                          RStock.Design:=FSImporteDetailMarcheExcel.TableauDonnees.Cells[3,R];
                          RStock.Ref:='';
                          RStock.UM:=FSImporteDetailMarcheExcel.TableauDonnees.Cells[4,R];
                          RStock.QteEntree:=0;
                          RStock.QteSortie:=0;
                          RStock.QteStock:=0;
                          RStock.QteInitial:=0;
                          RStock.QteLimite:=0;
                          RStock.CoutUnitaire:=0;
                          RStock.PrixVenteDetaille:=strtoreal(FSImporteDetailMarcheExcel.TableauDonnees.Cells[6,R]);
                          RStock.PrixVenteGros:=0;
                          RStock.Observ:='';
                          RStock.Emplace:='';
                          RStock.FicheStock:='';
                          RStock.Formule:='';
                          RStock.enregistrement:=''; 
                          Write(FStock,RStock);
                     end;
               end;
          end;
     end;

     FSImporteDetailMarcheExcel.Close;

     FSDetailMarche.BRefaireMarche.Checked:=true;
     FSDetailMarche.Visible:=true;
end;

procedure TFSImporteDetailMarcheExcel.BitBtn3Click(Sender: TObject);
var  R,C:integer;  ColNumRodre,ColCodeArticle,ColDesignation,ColUniteM,ColQte,ColPrix:string;
begin
     ColNumRodre:='';
     ColCodeArticle:='';
     ColDesignation:='';
     ColUniteM:='';
     ColQte:='';
     ColPrix:='';

     for C:=0 to FSImporteDetailMarcheExcel.TableauDonnees.ColCount-1 do
     begin
          if(ColNumRodre='')then ColNumRodre:=inttostr(C);
          if(ColCodeArticle='')then ColCodeArticle:=inttostr(C);
          if(ColDesignation='')then ColDesignation:=inttostr(C);
          if(ColUniteM='')then ColUniteM:=inttostr(C);
          if(ColQte='')then ColQte:=inttostr(C);
          if(ColPrix='')then ColPrix:=inttostr(C);

          for R:=1 to FSImporteDetailMarcheExcel.TableauDonnees.RowCount-1 do
          begin
               if(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R]<>'')then
               begin
                    if(strtointeger(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R])=0)then ColNumRodre:='';
                    if(strtoreal(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R])=0)and(ColQte<>'')then ColPrix:='';
                    if(strtoreal(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R])=0)and(ColPrix<>'')then ColQte:='';
                    if(Longueur(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R])=8)then
                    begin
                         if(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][1]in['0'..'9']))
                         or(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][2]in['0'..'9']))
                         or(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][4]in['0'..'9']))
                         or(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][5]in['0'..'9']))
                         or(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][7]in['0'..'9']))
                         or(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][8]in['0'..'9']))
                         or(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][3]in['.']))
                         or(not(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R][6]in['.']))
                         then ColCodeArticle:='';
                    end
                    else ColCodeArticle:='';
                    if(strtoreal(FSImporteDetailMarcheExcel.TableauDonnees.Cells[C,R])>0)then begin ColCodeArticle:=''; ColDesignation:=''; ColUniteM:=''; end;
               end;
          end;
     end;

     if(ColNumRodre<>'')then FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[0,1]:=ColNumRodre;
     if(ColCodeArticle<>'')then FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[2,1]:=ColCodeArticle;
     if(ColDesignation<>'')then FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[3,1]:=ColDesignation;
     if(ColUniteM<>'')then FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[4,1]:=ColUniteM;
     if(ColQte<>'')then FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[5,1]:=ColQte;
     if(ColPrix<>'')then FSImporteDetailMarcheExcel.TableauDetailMarche.Cells[6,1]:=ColPrix;
end;

