procedure TFSImporteDetailMarcheExcel.BitBtn16Click(Sender: TObject);
var  C,RBegin,REnd,CBegin,CEnd:integer;
begin
     RBegin:=strtointeger(FSImporteDetailMarcheExcel.EditRBegin.Text);
     REnd:=strtointeger(FSImporteDetailMarcheExcel.EditREnd.Text);
     CBegin:=strtointeger(FSImporteDetailMarcheExcel.EditCBegin.Text);
     CEnd:=strtointeger(FSImporteDetailMarcheExcel.EditCEnd.Text);
     ExcelToTableau(FSImporteDetailMarcheExcel.TableauDonnees,RBegin,REnd,CBegin,CEnd,FSImporteDetailMarcheExcel.OuvrireFichier.FileName,false);

     for C:= 1 to FSImporteDetailMarcheExcel.TableauDonnees.ColCount-1 do
