               TableauDetailRubriqueFicheTechnique.Cells[4,R]:=inttostr(RDetailRubriqueFicheTechnique.NumRubrique);
               TableauDetailRubriqueFicheTechnique.Cells[5,R]:=RRubriqueFicheTechnique.DesignationRubrique;
