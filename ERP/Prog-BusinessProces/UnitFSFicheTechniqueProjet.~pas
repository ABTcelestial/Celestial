procedure TFSFicheTechniqueProjet.EditDomiciliationChange(Sender: TObject);
var    i,RowSerie,RSerie:integer; NumPiece:integer;  OKSerieCharger:boolean;
begin
FSFicheTechniqueProjet.EditNumPiece.Text:='';
if(FSFicheTechniqueProjet.EditModePaiement.Text<>'')then
begin
     if(FSFicheTechniqueProjet.EditDomiciliation.Text<>'')then
     begin
          FSFicheTechniqueProjet.TableauSeriePieceAvis.RowCount:=2;
          FSFicheTechniqueProjet.TableauSeriePieceAvis.Cols[0].Text:='Séries Pičce';
          FSFicheTechniqueProjet.TableauSeriePieceAvis.Cols[1].Text:='Sélection';
          FSFicheTechniqueProjet.TableauSeriePieceAvis.Rows[1].Text:='';

          RowSerie:=0;
          OpenFParc(RParc);
          ChAvis:=RParc.Parcours+'\'+Exercice+'FAvis';
          assignfile(FAvis,ChAvis);
          if FileExists(ChAvis)then
          Reset(FAvis)
          else Rewrite(FAvis);
          Seek(FAvis,0);
          NumPiece:=0;
          while not eof(FAvis)do
          begin
               read(FAvis,RAvis);
               if(RAvis.DomiciliationAvis=FSFicheTechniqueProjet.EditDomiciliation.Text)
               and(RAvis.DesignationTypeAvis=FSFicheTechniqueProjet.EditTypeAvis.Text)
               then
               begin
                    OKSerieCharger:=false;
                    RSerie:=1;
                    while(RSerie<=FSFicheTechniqueProjet.TableauSeriePieceAvis.RowCount-1)and(OKSerieCharger=false)do
                    begin
                         if(FSFicheTechniqueProjet.TableauSeriePieceAvis.Cells[0,RSerie]=firstlaters(RAvis.NumPiece,strtointeger(FSFicheTechniqueProjet.EditLongueureSeriePiece.Text)))
                         then OKSerieCharger:=true;
                    RSerie:=RSerie+1;
                    end;

                    if(OKSerieCharger=false)then
                    begin
                         RowSerie:=RowSerie+1;
                         FSFicheTechniqueProjet.TableauSeriePieceAvis.RowCount:=RowSerie+1;
                         FSFicheTechniqueProjet.TableauSeriePieceAvis.Cells[0,RowSerie]:=firstlaters(RAvis.NumPiece,strtointeger(FSFicheTechniqueProjet.EditLongueureSeriePiece.Text));
                         FSFicheTechniqueProjet.TableauSeriePieceAvis.Cells[1,RowSerie]:='';
                    end;
               end;
          end;
          CloseFile(FAvis);

          if(RowSerie>0)then
          begin
               FSFicheTechniqueProjet.AfficheSeriePieceAvis.Height:=300;
               FSFicheTechniqueProjet.TableauSeriePieceAvis.SetFocus;
          end
          else
          begin
               FSFicheTechniqueProjet.AfficheSeriePieceAvis.Height:=0;
          end;
     end
     else
     begin
          showmessage('Veuillez indiquer la Domiciliation SVP !');
          FSFicheTechniqueProjet.EditDomiciliation.SetFocus;
     end;
end;


end;

