     ExistePlanificationRubrique(FSFicheTechniqueProjet.EditNumRubrique.Text,'',OKPlanificationRubrique,OKPlanificationTiers,CodeTiers);
     if(OKPlanificationRubrique=true)
     and(FSFicheTechniqueProjet.EditNumPlanificateur.Text='')
