     FSFicheTechniqueProjet.EditModePaiement.ItemIndex:=0;
     FSFicheTechniqueProjet.EditDomiciliation.ItemIndex:=0;
     FSFicheTechniqueProjet.EditNumPiece.Text:='';

     if(OKPlanificationTiers=true)then
     begin
          FSFicheTechniqueProjet.EditCodeTiers.Text:=CodeTiers;
          RTier:=ChercherTiers(FSFicheTechniqueProjet.EditChargementTypeProces.Text,FSFicheTechniqueProjet.EditChargementFichierConcerne.Text,CodeTiers,'');
          FSFicheTechniqueProjet.EditTiers.Text:=RTier.NomTiers+' '+RTier.PrenomTiers;

