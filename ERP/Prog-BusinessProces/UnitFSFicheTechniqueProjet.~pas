          if(TTypeAvisChargement[TFicheTechniqueChargement[TRubriqueFicheTechniqueChargement[RDetailRubriqueFicheTechnique.NumRubrique].NumFicheTechnique].NumTypeAvis].DebitCredit='Débit')then
