                         Tableau.Cells[8,Tableau.RowCount-1]:=Vergule(floattostr((TotalCredit*strtoreal(SoldePourcentage)/100)-TotalDebit),'2','C','');
                    end
                    else
                    begin
                         Tableau.Cells[18,0]:='Solde ŕ '+SoldePourcentage+'%';
                         if(CumulSoldePourcentage>0)
                         then Tableau.Cells[18,Tableau.RowCount-1]:=Vergule(floattostr(CumulSoldePourcentage),'2','C','')
