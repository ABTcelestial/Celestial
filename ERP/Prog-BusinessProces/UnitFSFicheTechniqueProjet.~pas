               TableauDetailRubriqueFicheTechnique.Cells[11,R]:=ImporteDataProcesTiers(RTypeAvis.TypeProces,RTypeAvis.FichierConserne,RDetailRubriqueFicheTechnique.CodeTiers,PositionTiersRecherche);
               TableauDetailRubriqueFicheTechnique.Cells[12,R]:=Vergule(floattostr(RDetailRubriqueFicheTechnique.Quantite),'2','C','');

               if(RTypeAvis.DebitCredit='Débit')then
               begin
                    TableauDetailRubriqueFicheTechnique.Cells[13,R]:=Vergule(floattostr(RDetailRubriqueFicheTechnique.Quantite*RDetailRubriqueFicheTechnique.Montant),'2','C','');
