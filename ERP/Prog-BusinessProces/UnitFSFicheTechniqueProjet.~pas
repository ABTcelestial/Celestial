procedure TFSFicheTechniqueProjet.BitOperationDetailRubriqueClick(Sender: TObject);
var  i,NumDetailRubrique,RExistant,RSupprimer,RSauvgarder:integer;  OKDetailRubrique,OKConfirme:boolean;
begin
     if(FSFicheTechniqueProjet.BitOperationDetailRubrique.Caption='Valider')then
     begin
          OpenFParc(RParc);
          ChDetailRubriqueFicheTechnique:=RParc.Parcours+'\'+Exercice+'FDetailRubriqueFicheTechnique';
          assignfile(FDetailRubriqueFicheTechnique,ChDetailRubriqueFicheTechnique);
          if FileExists(ChDetailRubriqueFicheTechnique)then
          Reset(FDetailRubriqueFicheTechnique)
          else Rewrite(FDetailRubriqueFicheTechnique);
          Seek(FDetailRubriqueFicheTechnique,0);
          NumDetailRubrique:=1;
          i:=0;
          OKDetailRubrique:=false;
          while not eof(FDetailRubriqueFicheTechnique)and(OKDetailRubrique=false)do
          begin
               read(FDetailRubriqueFicheTechnique,RDetailRubriqueFicheTechnique);

               if(RDetailRubriqueFicheTechnique.NumDetailRubrique>=NumDetailRubrique)then NumDetailRubrique:=RDetailRubriqueFicheTechnique.NumDetailRubrique+1;

               if(RDetailRubriqueFicheTechnique.NumDetailRubrique=strtointeger(FSFicheTechniqueProjet.EditNumDetailRubrique.Text))then
               begin
                    OKDetailRubrique:=true;
                    NumDetailRubrique:=RDetailRubriqueFicheTechnique.NumDetailRubrique;
               end
               else i:=i+1;
          end;

          RDetailRubriqueFicheTechnique.NumDetailRubrique:=NumDetailRubrique;
          RDetailRubriqueFicheTechnique.NumRubrique:=strtointeger(FSFicheTechniqueProjet.EditNumRubrique.Text);
          RDetailRubriqueFicheTechnique.NumPlanificateur:=strtointeger(FSFicheTechniqueProjet.EditNumPlanificateur.Text);
          RDetailRubriqueFicheTechnique.Date:=datetostr(FSFicheTechniqueProjet.EditDate.Date);
          RDetailRubriqueFicheTechnique.ModePaiement:=FSFicheTechniqueProjet.EditModePaiement.Text;
          RDetailRubriqueFicheTechnique.Domiciliation:=FSFicheTechniqueProjet.EditDomiciliation.Text;
          RDetailRubriqueFicheTechnique.NumPiece:=FSFicheTechniqueProjet.EditNumPiece.Text;
          RDetailRubriqueFicheTechnique.CodeTiers:=FSFicheTechniqueProjet.EditCodeTiers.Text;
          RDetailRubriqueFicheTechnique.Quantite:=strtoreal(FSFicheTechniqueProjet.EditQuantiteOperation.Text);
          RDetailRubriqueFicheTechnique.Montant:=strtoreal(FSFicheTechniqueProjet.EditMontantOperation.Text);
          RDetailRubriqueFicheTechnique.Observation:=FSFicheTechniqueProjet.EditObservation.Text;
          Seek(FDetailRubriqueFicheTechnique,i);
          write(FDetailRubriqueFicheTechnique,RDetailRubriqueFicheTechnique);

          CloseFile(FDetailRubriqueFicheTechnique);
     end;

     if(FSFicheTechniqueProjet.BitOperationDetailRubrique.Caption='Supprimer')then
     begin
          if(SupprimerFDetailRubriqueFicheTechnique('','','',FSFicheTechniqueProjet.TableauDetailRubriqueFicheTechnique.Cells[1,FSFicheTechniqueProjet.TableauDetailRubriqueFicheTechnique.Row],RExistant,RSupprimer,RSauvgarder))then
          begin
               if(RSupprimer>0)
               then AfficherMessage('Suppression réussie ! FTotal: '+inttostr(RExistant)+' FSupprimer: '+inttostr(RSupprimer)+' FSauvgarder: '+inttostr(RSauvgarder))
               else AfficherMessage('Aucun Registre Supprimer ! FTotal: '+inttostr(RExistant)+' FSupprimer: '+inttostr(RSupprimer)+' FSauvgarder: '+inttostr(RSauvgarder));
          end;
     end;

AfficherDetailRubriqueFicheTechnique(FSFicheTechniqueProjet.TableauDetailRubriqueFicheTechnique,FSFicheTechniqueProjet.EditCodeProjet.Text,FSFicheTechniqueProjet.EditNumFiche.Text,FSFicheTechniqueProjet.EditNumRubrique.Text,FSFicheTechniqueProjet.EditNumPlanificateur.Text,datetostr(FSFicheTechniqueProjet.EditOFDateDebut.Date),datetostr(FSFicheTechniqueProjet.EditOFDateFin.Date));
FSFicheTechniqueProjet.AfficheOperationFicheTechnique.Visible:=false;
end;

