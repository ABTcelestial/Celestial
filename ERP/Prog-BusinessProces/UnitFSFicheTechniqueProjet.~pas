               end;

          end;
          finally
          CloseFile(FRubriqueFicheTechnique);
          end;
     end;

     if(R>0)then
            begin
                 TableauRubriqueFicheTechnique.RowCount:=R+3;
                 TableauRubriqueFicheTechnique.Rows[R+1].Text:='';
                 TableauRubriqueFicheTechnique.Rows[R+2].Text:='';
