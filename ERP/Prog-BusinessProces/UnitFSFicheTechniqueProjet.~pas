procedure TFSFicheTechniqueProjet.TableauTiersListeTiersKeyDown(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var  R,l,RowSelect:integer;   TousSelect:string;
begin

if key in[VK_RETURN]then
begin
     FSFicheTechniqueProjet.EditTiersCodeTiers.Text:='';
     FSFicheTechniqueProjet.EditTiersNomTiers.Text:='';
     R:=2;
     l:=0;
     RowSelect:=1;
     TousSelect:='';
     while(R<=FSFicheTechniqueProjet.TableauTiersListeTiers.RowCount-1)do
     begin
          if(FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[1,R]<>'')then
          begin
               if(TousSelect='')
               then TousSelect:=FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[1,R]
               else TousSelect:=TousSelect+';'+FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[1,R];
          end;

          if(FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[0,R]='Sélect.')then
          begin
               RowSelect:=R;
               l:=l+1;
               if(FSFicheTechniqueProjet.EditTiersCodeTiers.Text='')
               then FSFicheTechniqueProjet.EditTiersCodeTiers.Text:=FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[1,R]
               else FSFicheTechniqueProjet.EditTiersCodeTiers.Text:=FSFicheTechniqueProjet.EditTiersCodeTiers.Text+';'+FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[1,R]
          end;
     R:=R+1;
     end;

     if(l=0)then
     begin
          if(FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[2,FSFicheTechniqueProjet.TableauTiersListeTiers.Row]='Tous')then
          begin
               FSFicheTechniqueProjet.EditTiersCodeTiers.Text:=TousSelect;
               FSFicheTechniqueProjet.EditTiersNomTiers.Text:=FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[2,FSFicheTechniqueProjet.TableauTiersListeTiers.Row];
          end
          else
          begin
               FSFicheTechniqueProjet.EditTiersCodeTiers.Text:=FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[1,FSFicheTechniqueProjet.TableauTiersListeTiers.Row];
               FSFicheTechniqueProjet.EditTiersNomTiers.Text:=FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[2,FSFicheTechniqueProjet.TableauTiersListeTiers.Row];
          end;
     end
     else
     begin
          if(l=1)then FSFicheTechniqueProjet.EditTiersNomTiers.Text:=FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[2,RowSelect];
