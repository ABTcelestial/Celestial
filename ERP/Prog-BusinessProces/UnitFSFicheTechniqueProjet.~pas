Procedure ListeAvisFinance(Tableau:TStringGrid; DateDebut,DateFin,NumProjetFinance,NumFicheTechnique,NumRubrique,AvisConcerneTiers,CodeTiers,NomTiers:string; AfficheAvisAnnuler:boolean; iRowIn:integer; var iRowOut:integer);
var  i,R:integer;
     OKAvisFinance,OKTiers:boolean;
     TypeProcesAvis,FichierConcerneAvis,AdresseAvis,TypeProcesTypeAvis,FichierConcerneTypeAvis,AdresseTypeAvis:string;
begin
     i:=iRowIn;

     if(i=1)then
     begin
           Tableau.Cols[0].Text:='Or.';
           Tableau.Cols[1].Text:='N°Opération';
           Tableau.Cols[2].Text:='Date';
           Tableau.Cols[3].Text:='Date Exécut°';
           Tableau.Cols[4].Text:='Mode Paiement';
           Tableau.Cols[5].Text:='Domiciliation';
           if(NomTiers<>'Tous')and(firstlaters(NomTiers,9)<>'Plusieurs')then Tableau.Cols[6].Text:='Pičce'else Tableau.Cols[6].Text:='Solde au: '+datetostr(strtodate(DateDebut)-1);
           Tableau.Cols[7].Text:='M.Débit';
           Tableau.Cols[8].Text:='M.Crédit';
           Tableau.Cols[9].Text:='Code Tiers';
           Tableau.Cols[10].Text:='Tiers';
           Tableau.Cols[11].Text:='Observation';
           Tableau.Cols[12].Text:='Imputation';
           Tableau.Cols[13].Text:='Débit/Crédit';
           Tableau.Cols[14].Text:='Signataire';
           Tableau.Cols[15].Text:='Validitée';
           Tableau.Cols[16].Text:='Origine';
           Tableau.Cols[17].Text:='Tiers';
           Tableau.Cols[18].Text:='Structure';


           Tableau.RowCount:=2;
           Tableau.Rows[i].Text:='';

           Tableau.Rows[i].Text:=inttostr(i);
           Tableau.Cells[1,i]:='Solde au:';
           Tableau.Cells[2,i]:=datetostr(strtodate(DateDebut)-1);
           Tableau.Cells[3,i]:='';
           Tableau.Cells[4,i]:='';
           Tableau.Cells[5,i]:='';
           Tableau.Cells[6,i]:='';
           Tableau.Cells[7,i]:='';
           Tableau.Cells[8,i]:='';
           Tableau.Cells[9,i]:='';
           Tableau.Cells[10,i]:='';
           Tableau.Cells[11,i]:='';
           Tableau.Cells[12,i]:='';
           Tableau.Cells[13,i]:='';
           Tableau.Cells[14,i]:='';
           Tableau.Cells[15,i]:='Maintenu';
           Tableau.Cells[16,i]:='';
           Tableau.Cells[17,i]:='';
           Tableau.Cells[18,i]:='';
     end;

     TypeProcesAvis:='Business';
     FichierConcerneAvis:='FAvis';

     if not(FunctionAdresseProces(TypeProcesAvis,FichierConcerneAvis,'',AdresseAvis,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerneAvis+' recherché !');
     end;

     ChAvis:=AdresseAvis;
     assignfile(FAvis,ChAvis);
     if FileExists(ChAvis)then
     Reset(FAvis)
     else Rewrite(FAvis);
     Seek(FAvis,0);
     while not eof(FAvis)do
     begin
          read(FAvis,RAvis);

          OKAvisFinance:=RAvis.ValiditeAvis;

          if(OKAvisFinance=true)then
          begin
                if(RAvis.NumRubrique<>'')
                and((NumProjetFinance<>'')
                or(NumFicheTechnique<>'')
                or(NumRubrique<>''))
                then RubriqueArborescence('',RAvis.NumRubrique,RRubriqueFicheTechnique,RFicheTechnique,RTypeAvis)
                else
                begin
                     TypeProcesTypeAvis:='Business';
                     FichierConcerneTypeAvis:='FTypeAvis';

                     if not(FunctionAdresseProces(TypeProcesTypeAvis,FichierConcerneTypeAvis,'',AdresseTypeAvis,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                     begin
                          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerneTypeAvis+' recherché !');
                     end;
                     ChTypeAvis:=AdresseTypeAvis;
                     assignfile(FTypeAvis,ChTypeAvis);
                     if FileExists(ChTypeAvis)then
                     begin
                           Reset(FTypeAvis);
                           Seek(FTypeAvis,RAvis.PositionTypeAvis);
                           if not eof(FTypeAvis)then
                           begin
                                read(FTypeAvis,RTypeAvis);
                           end;
                           CloseFile(FTypeAvis);
                     end;
                end;
          end;

          if(OKAvisFinance=true)then
          begin
                if(NomTiers<>'')and(NomTiers<>'Tous')and(firstlaters(NomTiers,9)<>'Plusieurs')then
                begin
                     OKAvisFinance:=true;
                end
                else
                begin
                     if ExisteNuminTexte(RAvis.CodeTiers,CodeTiers)
                     then OKAvisFinance:=true
                     else OKAvisFinance:=false;
                end;
          end;

          if(OKAvisFinance=true)then
          begin
               if(NumProjetFinance<>'')
               then
               begin
                    if(Firstlaters(RFicheTechnique.CodeProjet,longueur(NumProjetFinance))=NumProjetFinance)
                    then OKAvisFinance:=true
                    else OKAvisFinance:=false;
               end
               else OKAvisFinance:=true;
          end;

          if(OKAvisFinance=true)then
          begin
               if(NumFicheTechnique<>'')
               then
               begin
                    if(RFicheTechnique.NumFicheTechnique=strtointeger(NumFicheTechnique))
                    then OKAvisFinance:=true
                    else OKAvisFinance:=false;
               end
               else OKAvisFinance:=true;
          end;

          if(OKAvisFinance=true)then
          begin
               if(NumRubrique<>'')
               then
               begin
                    if(RRubriqueFicheTechnique.NumRubrique=strtoint(NumRubrique))
                    then OKAvisFinance:=true
                    else OKAvisFinance:=false;
               end
               else OKAvisFinance:=true;
          end;

          if(OKAvisFinance=true)then
          begin
               if(AvisConcerneTiers<>'')
               and(AvisConcerneTiers<>'Tous')
               then
               begin
                    if(RTypeAvis.FichierConserne=AvisConcerneTiers)
                    then OKAvisFinance:=true
                    else OKAvisFinance:=false;
               end
               else OKAvisFinance:=true;
          end;

          if(OKAvisFinance=true)then
          begin
               if(NomTiers<>'Tous')and(firstlaters(NomTiers,9)<>'Plusieurs')then
               begin
                    if(NomTiers<>'')then
                    begin
                         if ExisteNuminTexte(RAvis.CodeTiers,CodeTiers)
                         then OKAvisFinance:=true
                         else OKAvisFinance:=false;
                    end
                    else OKAvisFinance:=true;
               end
               else
               if(strtodate(RAvis.DateAvis)<=strtodate(DateFin))
               and(ExisteNuminTexte(RAvis.CodeTiers,CodeTiers))
               then
               begin
                    OKTiers:=false;
                    R:=2;
                    while(R<=i)and(OKTiers=false)do
                    begin
                         if(RAvis.CodeTiers=Tableau.Cells[9,R])then
                         begin
                              OKTiers:=true;

                              if(strtodate(RAvis.DateAvis)<strtodate(DateDebut))then
                              begin
                                   if(RTypeAvis.DebitCredit='Débit')then
                                   begin
                                        Tableau.Cells[6,R]:=Vergule(floattostr(strtoreal(Tableau.Cells[6,R])-(RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                                   end;
                                   if(RTypeAvis.DebitCredit='Crédit')then
                                   begin
                                        Tableau.Cells[6,R]:=Vergule(floattostr(strtoreal(Tableau.Cells[6,R])+(RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                                   end;
                              end
                              else
                              begin
                                   if(RTypeAvis.DebitCredit='Débit')then
                                   begin
                                        Tableau.Cells[7,R]:=Vergule(floattostr(strtoreal(Tableau.Cells[7,R])+(RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                                   end;
                                   if(RTypeAvis.DebitCredit='Crédit')then
                                   begin
                                        Tableau.Cells[8,R]:=Vergule(floattostr(strtoreal(Tableau.Cells[8,R])+(RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                                   end;
                              end;
                         end;
                         R:=R+1;
                    end;
                    OKAvisFinance:=not OKTiers;
               end
               else OKAvisFinance:=true;
          end;

          if(OKAvisFinance=true)then
          begin
               if(strtodate(RAvis.DateAvis)<strtodate(DateDebut))then
               begin
                    OKAvisFinance:=false;
                    if(NomTiers<>'Tous')and(firstlaters(NomTiers,9)<>'Plusieurs')
                    then
                    begin
                         if(RTypeAvis.DebitCredit='Débit')then
                         begin
                              Tableau.Cells[7,1]:=Vergule(floattostr(strtoreal(Tableau.Cells[7,1])+(RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                         end;
                         if(RTypeAvis.DebitCredit='Crédit')then
                         begin
                              Tableau.Cells[8,1]:=Vergule(floattostr(strtoreal(Tableau.Cells[8,1])+(RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                         end;
                    end
                    else
                    begin
                         i:=i+1;
                         Tableau.Rows[i].Text:=inttostr(i);
                         Tableau.Cells[1,i]:=Completezerogauche(inttostr(RAvis.NumAvis),'5');
                         Tableau.Cells[2,i]:=RAvis.DateAvis;
                         Tableau.Cells[3,i]:=RAvis.DateAvis;
                         Tableau.Cells[4,i]:='';
                         Tableau.Cells[5,i]:='';
                         Tableau.Cells[6,i]:='';

                         if(RTypeAvis.DebitCredit='Débit')then
                         begin
                              Tableau.Cells[6,i]:=Vergule(floattostr((-1)*(RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                         end;
                         if(RTypeAvis.DebitCredit='Crédit')then
                         begin
                              Tableau.Cells[6,i]:=Vergule(floattostr((RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
                         end;

                         Tableau.Cells[9,i]:=RAvis.CodeTiers;

                         Tableau.Cells[10,i]:='';//ImporteDataProcesTiers(RTypeAvis.TypeProces,RTypeAvis.FichierConserne,RAvis.CodeTiers,PositionTiersRecherche);
                         Tableau.Cells[11,i]:='{Avis: }'+RAvis.NatureDepense;
                         Tableau.Cells[12,i]:=RTypeAvis.CompteImputation;
                         Tableau.Cells[13,i]:=RTypeAvis.DebitCredit;
                         Tableau.Cells[14,i]:=inttostr(RTypeAvis.SigneDebitCredit);
                         Tableau.Cells[15,i]:='Maintenu';
                         Tableau.Cells[16,i]:=RTypeAvis.TypeProces;
                         Tableau.Cells[17,i]:=RTypeAvis.FichierConserne;
                         Tableau.Cells[18,i]:=ChercherProjetFinance(RFicheTechnique.CodeProjet,PositionProjetFinancesRecherche).DesignationProjetFinance;
                    end;
               end
               else
               begin
                    if(strtodate(RAvis.DateAvis)>=strtodate(DateDebut))
                    and(strtodate(RAvis.DateAvis)<=strtodate(DateFin))
                    then
                    begin
                         OKAvisFinance:=true;
                    end
                    else OKAvisFinance:=false;
               end;
          end;

          if(OKAvisFinance=true)then
          begin
               i:=i+1;
               Tableau.Rows[i].Text:=inttostr(i);
               Tableau.Cells[1,i]:=Completezerogauche(inttostr(RAvis.NumAvis),'5');
               Tableau.Cells[2,i]:=RAvis.DateAvis;
               Tableau.Cells[3,i]:=RAvis.DateAvis;
               Tableau.Cells[4,i]:='';
               Tableau.Cells[5,i]:='';
               if(NomTiers<>'Tous')and(firstlaters(NomTiers,9)<>'Plusieurs')then Tableau.Cells[6,i]:='';

               if(RTypeAvis.DebitCredit='Débit')then
               begin
                    Tableau.Cells[7,i]:=Vergule(floattostr((RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
               end;
               if(RTypeAvis.DebitCredit='Crédit')then
               begin
                    Tableau.Cells[8,i]:=Vergule(floattostr((RAvis.Montant*RTypeAvis.SigneDebitCredit)),'2','C','');
               end;

               Tableau.Cells[9,i]:=RAvis.CodeTiers;

               Tableau.Cells[10,i]:='';//ImporteDataProcesTiers(RTypeAvis.TypeProces,RTypeAvis.FichierConserne,RAvis.CodeTiers,PositionTiersRecherche);
               Tableau.Cells[11,i]:='{Avis: }'+RAvis.NatureDepense;
               Tableau.Cells[12,i]:=RTypeAvis.CompteImputation;
               Tableau.Cells[13,i]:=RTypeAvis.DebitCredit;
               Tableau.Cells[14,i]:=inttostr(RTypeAvis.SigneDebitCredit);
               Tableau.Cells[15,i]:='Maintenu';
               Tableau.Cells[16,i]:=RTypeAvis.TypeProces;
               Tableau.Cells[17,i]:=RTypeAvis.FichierConserne;
               Tableau.Cells[18,i]:=ChercherProjetFinance(RFicheTechnique.CodeProjet,PositionProjetFinancesRecherche).DesignationProjetFinance;
          end;

     end;
     CloseFile(FAvis);

     if(i>0)then Tableau.RowCount:=i+1
            else Tableau.RowCount:=2;
     iRowOut:=i+1;
end;

