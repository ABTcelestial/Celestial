          MontantGlobale:=0;
          while not eof(FRubriqueFicheTechnique)do
          begin
               read(FRubriqueFicheTechnique,RRubriqueFicheTechnique);

               if(NumProjet<>'')then
               begin
                    if(firstlaters(TFicheTechniqueChargement[RRubriqueFicheTechnique.NumFicheTechnique].CodeProjet,longueur(NumProjet))=NumProjet)
                    then OKRubriqueFicheTechnique:=true
                    else OKRubriqueFicheTechnique:=false;
               end
               else OKRubriqueFicheTechnique:=false;

               if(OKRubriqueFicheTechnique=true)then
               begin
                    if(NumFicheTechnique<>'')then
                    begin
                         if(RRubriqueFicheTechnique.NumFicheTechnique=strtointeger(NumFicheTechnique))
                         then OKRubriqueFicheTechnique:=true
                         else OKRubriqueFicheTechnique:=false;
                    end
                    else OKRubriqueFicheTechnique:=true;
               end;

               if(OKRubriqueFicheTechnique=true)then
               begin
                    R:=R+1;
                    TableauRubriqueFicheTechnique.Cells[0,R]:=inttostr(R);
