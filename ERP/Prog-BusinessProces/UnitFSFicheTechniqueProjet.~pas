Procedure SoldeListeAvisFicheTechnique(Tableau:TStringGrid; CodeTiers,NomTiers,ModePaiement,Domiciliation,SoldePourcentage:string);
var   R,Nbr:integer;  Debit,Credit,TotalDebit,TotalCredit,Solde,SodeAnterieur,CumulSoldePourcentage,CumulPourcentage:real;  NotRow,NotCol:string;
begin
     TotalDebit:=0;
     TotalCredit:=0;
     Solde:=0;
     SodeAnterieur:=0;
     CumulSoldePourcentage:=0;
     CumulPourcentage:=0;
     Nbr:=0;
     Tableau.RowCount:=Tableau.RowCount+3;
     for R:=1 to Tableau.RowCount-4 do
     begin
          if(strtoreal(Tableau.Cells[7,R])<>0)and(strtoreal(Tableau.Cells[8,R])<>0)then
          begin
               Debit:=strtoreal(Tableau.Cells[7,R]);
               Credit:=strtoreal(Tableau.Cells[8,R]);

               Solde:=Valeprecis(Debit-Credit,2);

               if(Solde=0)then
               begin
                    Tableau.Cells[7,R]:='';
                    Tableau.Cells[8,R]:='';
               end;

               if(Solde>0)then
               begin
                    Tableau.Cells[7,R]:=Vergule(floattostr(Solde),'2','C','');
                    Tableau.Cells[8,R]:='';
               end;

               if(Solde<0)then
               begin
                    Tableau.Cells[7,R]:='';
                    Tableau.Cells[8,R]:=Vergule(floattostr((-1)*Solde),'2','C','');
               end;
          end
          else
          begin
               if strtoreal(Tableau.Cells[7,R])=0 then Tableau.Cells[7,R]:='';
               if strtoreal(Tableau.Cells[8,R])=0 then Tableau.Cells[8,R]:='';
          end;

          if(Tableau.Cells[15,R]='Maintenu')then
          begin
               if(NomTiers='Tous')or(firstlaters(NomTiers,9)='Plusieurs')then
               begin
                    SodeAnterieur:=SodeAnterieur+strtoreal(Tableau.Cells[6,R]);

                    if(SoldePourcentage<>'')then
                    begin
                         Tableau.Cells[18,R]:='';
                         if((Credit*(strtoreal(SoldePourcentage)/100))>Debit)then
                         begin
                              if(Solde<0)then
                                         begin
                                              Tableau.Cells[18,R]:=Vergule(floattostr((Credit*(strtoreal(SoldePourcentage)/100))-Debit),'2','C','');
                                              CumulSoldePourcentage:=CumulSoldePourcentage+(Credit*(strtoreal(SoldePourcentage)/100))-Debit;
                                         end
                                         else Tableau.Cells[18,R]:='';
                         end
                         else
                         begin
                              if(Credit>0)then
                              begin
                                   Tableau.Cells[18,R]:=Vergule(floattostr((Debit/Credit)*100),'2','C','')+'%';
                                   CumulPourcentage:=CumulPourcentage+((Debit/Credit)*100);
                                   Nbr:=Nbr+1;
                              end;
                         end;
                    end;
               end;
               TotalDebit:=TotalDebit+strtoreal(Tableau.Cells[7,R]);
               TotalCredit:=TotalCredit+strtoreal(Tableau.Cells[8,R]);
          end;
     end;

     if Nbr=0 then Nbr:=1;

     Tableau.Cells[5,Tableau.RowCount-2]:='Total:';
     if(NomTiers='Tous')or(firstlaters(NomTiers,9)='Plusieurs')then Tableau.Cells[6,Tableau.RowCount-2]:=Vergule(floattostr(SodeAnterieur),'2','C','');
     Tableau.Cells[7,Tableau.RowCount-2]:=Vergule(floattostr(TotalDebit),'2','C','');
     Tableau.Cells[8,Tableau.RowCount-2]:=Vergule(floattostr(TotalCredit),'2','C','');

     Solde:=ValePrecis(TotalCredit-TotalDebit,2);
     Tableau.Cells[5,Tableau.RowCount-1]:='Solde:';
     if(Solde<0)then
     begin
          Tableau.Cells[7,Tableau.RowCount-1]:=Vergule(floattostr((-1)*Solde),'2','C','');
     end
     else
     begin
          Tableau.Cells[8,Tableau.RowCount-1]:=Vergule(floattostr(Solde),'2','C','');

          if(SoldePourcentage<>'')then
          begin
               if((TotalCredit*(strtoreal(SoldePourcentage)/100))>TotalDebit)then
               begin
                    if(NomTiers<>'Tous')and(firstlaters(NomTiers,9)<>'Plusieurs')then
                    begin
                         Tableau.RowCount:=Tableau.RowCount+1;
