Procedure ListeFicheTechnique(TableauFicheTechnique:TStringGrid; CodeProjet:string; RowSelectFicheTechnique:integer; FicheProjetPrecis:boolean);
var  R:integer;  RTypeAvis:RTypeAviss;   OKFicheTechnique:boolean;
begin
     TableauFicheTechnique.ColCount:=6;
     TableauFicheTechnique.RowCount:=2;
     TableauFicheTechnique.Rows[1].Text:='';
     TableauFicheTechnique.Cols[0].Text:='N°';
     TableauFicheTechnique.Cols[1].Text:='Code Projet';
     TableauFicheTechnique.Cols[2].Text:='Num Fiche';
     TableauFicheTechnique.Cols[3].Text:='Désignation de la fiche technique';
     TableauFicheTechnique.Cols[4].Text:='Num Avis utilisé';
     TableauFicheTechnique.Cols[5].Text:='Avis utilisé';

     OpenFParc(RParc);
     ChFicheTechnique:=RParc.Parcours+'\'+Exercice+'FFicheTechnique';
     assignfile(FFicheTechnique,ChFicheTechnique);
     if FileExists(ChFicheTechnique)then
     Reset(FFicheTechnique)
     else Rewrite(FFicheTechnique);
     Seek(FFicheTechnique,0);
     R:=0;
     while not eof(FFicheTechnique)do
     begin
          read(FFicheTechnique,RFicheTechnique);

          if(CodeProjet<>'')then
          begin
               if(FicheProjetPrecis=false)then
               begin
                    if(firstlaters(RFicheTechnique.CodeProjet,longueur(CodeProjet))=CodeProjet)
                    then OKFicheTechnique:=true
                    else OKFicheTechnique:=false;
               end
               else
               begin
                    if(RFicheTechnique.CodeProjet=CodeProjet)
                    then OKFicheTechnique:=true
                    else OKFicheTechnique:=false;
               end;
          end
          else OKFicheTechnique:=false;

          if(OKFicheTechnique=true)then
          begin
               R:=R+1;
               TableauFicheTechnique.Cells[0,R]:=inttostr(R);
               TableauFicheTechnique.Cells[1,R]:=RFicheTechnique.CodeProjet;
               TableauFicheTechnique.Cells[2,R]:=inttostr(RFicheTechnique.NumFicheTechnique);
               TableauFicheTechnique.Cells[3,R]:=RFicheTechnique.DesignationFicheTechnique;
               TableauFicheTechnique.Cells[4,R]:=inttostr(RFicheTechnique.NumTypeAvis);

               ChercherTypeAvis(TableauFicheTechnique.Cells[4,R],'','','','','',RTypeAvis);
               TableauFicheTechnique.Cells[5,R]:=RTypeAvis.DesignationTypeAvis;
          end;

     end;
     CloseFile(FFicheTechnique);

     if(R>0)then TableauFicheTechnique.RowCount:=R+1
            else TableauFicheTechnique.RowCount:=2;

     TableauFicheTechnique.ColWidths[1]:=0;
     TableauFicheTechnique.ColWidths[2]:=0;
     TableauFicheTechnique.ColWidths[4]:=0;
     AjusterColWidth(TableauFicheTechnique,'','1;2;4');

     if(RowSelectFicheTechnique>0)and(RowSelectFicheTechnique<=TableauFicheTechnique.RowCount-1)
     then TableauFicheTechnique.Row:=RowSelectFicheTechnique;
     TableauFicheTechnique.Col:=3;
end;

