procedure TFSFicheTechniqueProjet.BitValiderSeriePieceAvisClick(
  Sender: TObject);
var  i,R,NumPiece,LMaxPiece:integer;   OKAvis:boolean;
begin

R:=1;
OKAvis:=false;
while(R<=FSFicheTechniqueProjet.TableauSeriePieceAvis.RowCount-1)and(OKAvis=false)do
begin
     if(FSFicheTechniqueProjet.TableauSeriePieceAvis.Cells[1,R]='OK')then
     begin
     OKAvis:=true;
     OpenFParc(RParc);
     ChAvis:=RParc.Parcours+'\'+Exercice+'FAvis';
     assignfile(FAvis,ChAvis);
     if FileExists(ChAvis)then
     Reset(FAvis)
     else Rewrite(FAvis);
     Seek(FAvis,0);
     i:=0;
     NumPiece:=0;
     LMaxPiece:=0;
     OKAvis:=false;
     while not eof(FAvis)do
     begin
          read(FAvis,RAvis);
          if(RAvis.DomiciliationAvis=FSFicheTechniqueProjet.EditDomiciliation.Text)
          and(Firstlaters(RAvis.NumPiece,longueur(FSFicheTechniqueProjet.TableauSeriePieceAvis.Cells[0,R]))=FSFicheTechniqueProjet.TableauSeriePieceAvis.Cells[0,R])
          then
          begin
               OKAvis:=true;
               if(longueur(RAvis.NumPiece)>=LMaxPiece)then LMaxPiece:=Longueur(RAvis.NumPiece);
               if(strtointeger(RAvis.NumPiece)>=NumPiece)then NumPiece:=strtointeger(RAvis.NumPiece)+1;
          end;
          i:=i+1;
     end;
     CloseFile(FAvis);

     end;
R:=R+1;
end;

if(OKAvis=true)
then FSFicheTechniqueProjet.EditNumPiece.Text:=Completezerogauche(inttostr(NumPiece),inttostr(LMaxPiece))
else FSFicheTechniqueProjet.EditNumPiece.Text:='';
FSFicheTechniqueProjet.EditNumPiece.SetFocus;
FSFicheTechniqueProjet.AfficheSeriePieceAvis.Height:=0;

end;

