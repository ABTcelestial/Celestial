Procedure ExistePlanificationRubrique(NumRubrique,NumPlanificateur:string; var OKPlanificationRubrique,OKPlanificationTiers:boolean; var CodeTiers:string);
begin
     OKPlanificationRubrique:=false;
     OKPlanificationTiers:=false;
     CodeTiers:='';

     OpenFParc(RParc);
     ChPlanificateur:=RParc.Parcours+'\'+Exercice+'FPlanificateur';
     assignfile(FPlanificateur,ChPlanificateur);
     if FileExists(ChPlanificateur)then
     Reset(FPlanificateur)
     else Rewrite(FPlanificateur);
     Seek(FPlanificateur,0);
     while not eof(FPlanificateur)do
     begin
          read(FPlanificateur,RPlanificateur);

          if(NumRubrique<>'')then
          begin
               if(RPlanificateur.NumRubrique=strtointeger(NumRubrique))then
               begin
                    OKPlanificationRubrique:=true;
               end;
          end;

          if(NumPlanificateur<>'')then
          begin
               if(RPlanificateur.NumPlanificateur=strtointeger(NumPlanificateur))then
               begin
                    OKPlanificationTiers:=true;
                    CodeTiers:=RPlanificateur.CodeTiers;
               end;
          end;
     end;
     CloseFile(FPlanificateur);

end;

Function ExistePlanificationTiers(CodeTiers,NomTiers,NumFicheTechnique,NumRubrique:string):boolean;
var  OkTiersPlanifier:boolean;
begin
     if(NomTiers<>'Tous')and(firstlaters(NomTiers,9)<>'Plusieurs')then
     begin
          OpenFParc(RParc);
          ChPlanificateur:=RParc.Parcours+'\'+Exercice+'FPlanificateur';
          assignfile(FPlanificateur,ChPlanificateur);
          if FileExists(ChPlanificateur)then
          Reset(FPlanificateur)
          else Rewrite(FPlanificateur);
          Seek(FPlanificateur,0);
          OkTiersPlanifier:=false;
          while not eof(FPlanificateur)and(OkTiersPlanifier=false)do
          begin
               read(FPlanificateur,RPlanificateur);

               RubriqueArborescence('',inttostr(RPlanificateur.NumRubrique),RRubriqueFicheTechnique,RFicheTechnique,RTypeAvis);

               if ExisteNuminTexte(RPlanificateur.CodeTiers,CodeTiers)then
               begin
                    if(NumFicheTechnique<>'')then
                    begin
                         if(RFicheTechnique.NumFicheTechnique=strtointeger(NumFicheTechnique))
                         then OkTiersPlanifier:=true
                         else OkTiersPlanifier:=false;
                    end
                    else OkTiersPlanifier:=true;

                    if(OkTiersPlanifier=true)then
                    begin
                         if(NumRubrique<>'')then
                         begin
                              if(RPlanificateur.NumRubrique=strtointeger(NumRubrique))
                              then OkTiersPlanifier:=true
                              else OkTiersPlanifier:=false;
                         end
                         else OkTiersPlanifier:=true;
                    end;
               end;
          end;
          CloseFile(FPlanificateur);
     end
     else OkTiersPlanifier:=true;

     ExistePlanificationTiers:=OkTiersPlanifier;
end;

Function NumPlanificationParTiers(NumRubrique,CodeTiers:string):integer;
var OcurenceTiers,NumPlanification:integer;  OKTiers:boolean;
begin
     OcurenceTiers:=0;
     if(CodeTiers<>'')then
     begin
          OpenFParc(RParc);
          ChPlanificateur:=RParc.Parcours+'\'+Exercice+'FPlanificateur';
          assignfile(FPlanificateur,ChPlanificateur);
          if FileExists(ChPlanificateur)then
          Reset(FPlanificateur)
          else Rewrite(FPlanificateur);
          Seek(FPlanificateur,0);
          OKTiers:=false;
          while not eof(FPlanificateur)do
          begin
               read(FPlanificateur,RPlanificateur);

               if(NumRubrique<>'')then
               begin
                    if(RPlanificateur.NumRubrique=strtointeger(NumRubrique))
                    then OKTiers:=true
                    else OKTiers:=false;
               end
               else OKTiers:=true;

               if(OKTiers=true)then
               begin
                    if(RPlanificateur.CodeTiers=CodeTiers)then
                    begin
                         NumPlanification:=RPlanificateur.NumPlanificateur;
                         OcurenceTiers:=OcurenceTiers+1;
                    end;
               end;
          end;
          CloseFile(FPlanificateur);
     end;

     if(OcurenceTiers=1)
     then NumPlanificationParTiers:=NumPlanification
     else NumPlanificationParTiers:=0;
end;

