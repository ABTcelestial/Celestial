Procedure AfficheCumulFicheTechniqueProjet(TableauProjet:TStringGrid; CodeStructureProjet:string; ColCountBegin:integer);
var  C,R,ColMax,Indice:integer; OKProjet,OKRowProjet,OKColProjet:boolean;
begin
     OpenFParc(RParc);
     ChRubriqueFicheTechnique:=RParc.Parcours+'\'+Exercice+'FRubriqueFicheTechnique';
     assignfile(FRubriqueFicheTechnique,ChRubriqueFicheTechnique);
     if FileExists(ChRubriqueFicheTechnique)then
     Reset(FRubriqueFicheTechnique)
     else Rewrite(FRubriqueFicheTechnique);
     Seek(FRubriqueFicheTechnique,0);
     ColMax:=ColCountBegin;
     while not eof(FRubriqueFicheTechnique)do
     begin
          read(FRubriqueFicheTechnique,RRubriqueFicheTechnique); 

          RubriqueArborescence('',inttostr(RRubriqueFicheTechnique.NumRubrique),RRubriqueFicheTechnique,RFicheTechnique,RTypeAvis);

          if(CodeStructureProjet<>'')then
          begin
               if(RFicheTechnique.CodeProjet=Firstlaters(CodeStructureProjet,longueur(RFicheTechnique.CodeProjet)))
               then OKProjet:=true
               else OKProjet:=false;
          end
          else OKProjet:=true;

          if(OKProjet=true)then
          begin
               R:=1;
               while(R<=TableauProjet.RowCount-1)do
               begin
                    if(TableauProjet.Cells[1,R]=Firstlaters(RFicheTechnique.CodeProjet,longueur(TableauProjet.Cells[1,R])))then
                    begin
                         C:=ColCountBegin+1;
                         OKColProjet:=false;
                         while(C<=ColMax)and(OKColProjet=false)do
                         begin
                              if(TableauProjet.Cells[C,0]='Cumul '+RFicheTechnique.DesignationFicheTechnique)then
                              begin
                                   OKColProjet:=true;
                                   if(RTypeAvis.DebitCredit='Débit')
                                   then Indice:=1
                                   else Indice:=-1;
                                   TableauProjet.Cells[C,R]:=Vergule(floattostr(strtoreal(TableauProjet.Cells[C,R])+(Indice*RRubriqueFicheTechnique.Montant)),'2','C','');
                              end;
                         C:=C+1;
                         end;

                         if(OKColProjet=false)then
                         begin
                              ColMax:=ColMax+1;
                              TableauProjet.Cols[ColMax].Text:='';
                              TableauProjet.Cells[ColMax,0]:='Cumul '+RFicheTechnique.DesignationFicheTechnique;
                              if(RTypeAvis.DebitCredit='Débit')
                              then Indice:=1
                              else Indice:=-1;
                              TableauProjet.Cells[ColMax,R]:=Vergule(floattostr(Indice*RRubriqueFicheTechnique.Montant),'2','C','');
                         end;
                    end;
               R:=R+1;
               end;
          end;
     end;
     CloseFile(FRubriqueFicheTechnique);

     TableauProjet.ColCount:=ColMax+2;
     TableauProjet.Cols[ColMax+1].Text:='';
     TableauProjet.Cells[ColMax+1,0]:='Solde Projet';
     R:=1;
     while(R<=TableauProjet.RowCount-1)do
     begin
          C:=ColCountBegin+1;
          while(C<=TableauProjet.ColCount-2)do
          begin
               TableauProjet.Cells[TableauProjet.ColCount-1,R]:=Vergule(floattostr(strtoreal(TableauProjet.Cells[TableauProjet.ColCount-1,R])+strtoreal(TableauProjet.Cells[C,R])),'2','C','');
               C:=C+1;
          end;
          R:=R+1;
     end;
     TableauProjet.ColWidths[1]:=0;
     AjusterColWidth(TableauProjet,'','1');
end;

