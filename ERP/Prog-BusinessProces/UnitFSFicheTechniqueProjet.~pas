procedure TFSFicheTechniqueProjet.BitBtn22Click(Sender: TObject);
var  R:integer; OKTiers:boolean;
begin
     if(FSFicheTechniqueProjet.TableauTiersListeTiers.Visible=true)then
     begin
           R:=1;
           While(R<=FSFicheTechniqueProjet.TableauTiersListeTiers.RowCount-1)do
           begin
                FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[0,R]:=inttostr(R);
           R:=R+1;
           end;

           OpenFParc(RParc);
           ChPlanificateur:=RParc.Parcours+'\'+Exercice+'FPlanificateur';
           assignfile(FPlanificateur,ChPlanificateur);
           if FileExists(ChPlanificateur)then
           Reset(FPlanificateur)
           else Rewrite(FPlanificateur);
           Seek(FPlanificateur,0);
           while not eof(FPlanificateur)do
           begin
                read(FPlanificateur,RPlanificateur);

                if(FSFicheTechniqueProjet.EditTiersNumProjetTraitement.Text<>'')then
                begin
                     if(Firstlaters(RPlanificateur.CodeStructureProjet,longueur(FSFicheTechniqueProjet.EditTiersNumProjetTraitement.Text))=FSFicheTechniqueProjet.EditTiersNumProjetTraitement.Text)
                     then OKTiers:=true
                     else OKTiers:=false;
                end
                else OKTiers:=true;

                if(OKTiers=true)then
                begin
                     RubriqueArborescence('',inttostr(RPlanificateur.NumRubrique),RRubriqueFicheTechnique,RFicheTechnique,RTypeAvis);

                     if(FSFicheTechniqueProjet.EditTiersNumFicheTechniqueTraitement.Text<>'')then
                     begin
                          if(RFicheTechnique.NumFicheTechnique=strtointeger(FSFicheTechniqueProjet.EditTiersNumFicheTechniqueTraitement.Text))
                          then OKTiers:=true
                          else OKTiers:=false;
                     end;
                end;
                
                if(OKTiers=true)then
                begin
                     if(FSFicheTechniqueProjet.EditTiersNumRubriqueTraitement.Text<>'')then
                     begin
                          if(RPlanificateur.NumRubrique=strtointeger(FSFicheTechniqueProjet.EditTiersNumRubriqueTraitement.Text))
                          then OKTiers:=true
                          else OKTiers:=false;
                     end;
                end;

                if(OKTiers=true)then
                begin
                     R:=1;
                     OKTiers:=false;
                     While(R<=FSFicheTechniqueProjet.TableauTiersListeTiers.RowCount-1)and(OKTiers=false)do
                     begin
                          if(RPlanificateur.CodeTiers=FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[1,R])then
                          begin
                               OKTiers:=true;
                               FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[0,R]:='Sélect.';
                          end;
                     R:=R+1;
                     end;
                end;
           end;
           CloseFile(FPlanificateur);
     end
     else
     begin
           FSFicheTechniqueProjet.EditTiersCodeTiers.Text:='';
           FSFicheTechniqueProjet.EditTiersNomTiers.Text:='';

           R:=1;
           While(R<=FSFicheTechniqueProjet.TableauTiersListeTiers.RowCount-1)do
           begin
                FSFicheTechniqueProjet.TableauTiersListeTiers.Cells[0,R]:=inttostr(R);
           R:=R+1;
           end;

           OpenFParc(RParc);
           ChPlanificateur:=RParc.Parcours+'\'+Exercice+'FPlanificateur';
           assignfile(FPlanificateur,ChPlanificateur);
           if FileExists(ChPlanificateur)then
           Reset(FPlanificateur)
           else Rewrite(FPlanificateur);
           Seek(FPlanificateur,0);
           R:=0;
           while not eof(FPlanificateur)do
           begin
                read(FPlanificateur,RPlanificateur);

                RubriqueArborescence('',inttostr(RPlanificateur.NumRubrique),RRubriqueFicheTechnique,RFicheTechnique,RTypeAvis);

                if(FSFicheTechniqueProjet.EditTiersNumProjetTraitement.Text<>'')then
                begin
                     if(Firstlaters(RPlanificateur.CodeStructureProjet,longueur(FSFicheTechniqueProjet.EditTiersNumProjetTraitement.Text))=FSFicheTechniqueProjet.EditTiersNumProjetTraitement.Text)
                     then OKTiers:=true
                     else OKTiers:=false;
                end
                else OKTiers:=true;

                if(OKTiers=true)then
                begin
                     if(FSFicheTechniqueProjet.EditTiersNumFicheTechniqueTraitement.Text<>'')then
                     begin
                          if(RFicheTechnique.NumFicheTechnique=strtointeger(FSFicheTechniqueProjet.EditTiersNumFicheTechniqueTraitement.Text))
                          then OKTiers:=true
                          else OKTiers:=false;
                     end;
                end;
                
                if(OKTiers=true)then
                begin
                     if(FSFicheTechniqueProjet.EditTiersNumRubriqueTraitement.Text<>'')then
                     begin
                          if(RPlanificateur.NumRubrique=strtointeger(FSFicheTechniqueProjet.EditTiersNumRubriqueTraitement.Text))
                          then OKTiers:=true
                          else OKTiers:=false;
                     end;
                end;

                if(OKTiers=true)then
                begin
                     R:=R+1;
                     if(FSFicheTechniqueProjet.EditTiersCodeTiers.Text='')then
                     begin
                          RClient:=ChercherTiers(RTypeAvis.TypeProces,RTypeAvis.FichierConserne,RPlanificateur.CodeTiers,'');
                          FSFicheTechniqueProjet.EditTiersCodeTiers.Text:=RPlanificateur.CodeTiers;
                          FSFicheTechniqueProjet.EditTiersNomTiers.Text:=RClient.NomTiers+' '+RClient.PrenomTiers;
                     end
                     else FSFicheTechniqueProjet.EditTiersCodeTiers.Text:=FSFicheTechniqueProjet.EditTiersCodeTiers.Text+';'+RPlanificateur.CodeTiers
                end;
           end;
           CloseFile(FPlanificateur);

           if(R=0)then
           begin
                FSFicheTechniqueProjet.EditTiersCodeTiers.Text:='';
