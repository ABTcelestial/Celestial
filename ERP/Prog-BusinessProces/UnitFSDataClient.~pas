procedure TFSDataClient.TableauAdresseDossierPartageReseauxDblClick(
  Sender: TObject);
var  NomDossierPartageOut,EmlacementLocalOuReseauxOut,NomDossierPartageOutClient,EmlacementLocalOuReseauxOutClient:string;
begin
     ProcAdresseDossierPartageReseaux('','Local',NomDossierPartageOut,EmlacementLocalOuReseauxOut);

     FSDataClient.EditNomDosierPartager.Text:=FSDataClient.TableauAdresseDossierPartageReseaux.Cells[2,FSDataClient.TableauAdresseDossierPartageReseaux.Row];

     ChMayMachine:=ProcAdresseDossierPartageReseaux(FSDataClient.EditNomDosierPartager.Text,'',NomDossierPartageOutClient,EmlacementLocalOuReseauxOutClient)+'\FAdresseIPMayMachine';

     assignfile(FMayMachine,ChMayMachine);
     if FileExists(ChMayMachine)then
     begin
          Reset(FMayMachine);
          Seek(FMayMachine,0);
          If not eof(FMayMachine)then
          begin
               read(FMayMachine,RMayMachine);
               if(RMayMachine.NomPosteReseauxConnexion=NomDossierPartageOut)then
               begin
                    FSDataClient.EditNomUtilisateurServeur.Text:=RMayMachine.NomUtilisateur;
                    FSDataClient.EditAdresseIPServeur.Text:=RMayMachine.AdresseIP;

                    ClientSocket1.Address:=FSDataClient.EditAdresseIPServeur.Text;
                    ClientSocket1.Active:=true;
               end
               else
               begin
                    showmessage('Connexion non autorisť !');
               end;
          end;
     CloseFile(FMayMachine);
     end;
     FSDataClient.AfficheAdresseDossierPartageReseaux.Visible:=false;

     FSDataClient.EditCommunicationClient.SetFocus;
end;

procedure TFSDataClient.BitConnecterClick(Sender: TObject);
begin
     if(FSDataClient.EditPort.Text<>'')then
     begin
          FSDataClient.ClientSocket1.Port:=strtointeger(FSDataClient.EditPort.Text);
     end
     else
     begin
          FSDataClient.EditPort.Text:=inttostr(FSDataClient.ClientSocket1.Port);
          FSDataClient.EditHost.Text:=FSDataClient.ClientSocket1.Host;
     end;

     if(FSDataClient.EditHost.Text<>'')then
     begin
          FSDataClient.ClientSocket1.Host:=FSDataClient.EditHost.Text;
     end
     else
     begin
          FSDataClient.EditHost.Text:=FSDataClient.ClientSocket1.Host;
     end;

     if(FSDataClient.EditAdresseIPServeur.Text<>'')and(FSDataClient.EditNomUtilisateurServeur.Text<>'')then
     begin
          ClientSocket1.Address:=EditAdresseIPServeur.Text;
          ClientSocket1.Active:=true;
     end
     else
     begin
          FSDataClient.EditNomUtilisateurServeur.SetFocus;
     end;

     if not ClientSocket1.Active then ClientSocket1.Host:=EditAdresseIPServeur.Text;
     ClientSocket1.Active:=not ClientSocket1.Active;
end;

