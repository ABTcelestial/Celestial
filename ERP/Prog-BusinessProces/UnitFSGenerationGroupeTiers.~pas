begin
     TableauListeGroupeTiers.ColCount:=7;
     TableauListeGroupeTiers.Cols[0].Text:='Ordre';
     TableauListeGroupeTiers.Cols[1].Text:='PositionGroupeTiers';
     TableauListeGroupeTiers.Cols[2].Text:='PositionListeGroupeTiers';
