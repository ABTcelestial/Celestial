procedure TFSArchivesPhotosCommentaires.BitOperationArchivesPhotosCommentairesClick(
  Sender: TObject);
var  i,iselect,OrdreArchivePhoto:integer; OKArchivePhotoCommentaire:boolean;   AdresseArchivePhoto,PositionSelect:string;
begin
     PositionSelect:='';

     if(FSArchivesPhotosCommentaires.BitOperationArchivesPhotosCommentaires.Caption='Valider')then
     begin
          OpenFParc(RParc);
          ChArchivePhotoCommentaire:=RParc.Parcours+'\'+Exercice+'FArchivePhotoCommentaire';
          assignfile(FArchivePhotoCommentaire,ChArchivePhotoCommentaire);
          if FileExists(ChArchivePhotoCommentaire)then
          Reset(FArchivePhotoCommentaire)
          else Rewrite(FArchivePhotoCommentaire);
          Seek(FArchivePhotoCommentaire,0);
          OKArchivePhotoCommentaire:=false;
          i:=0;
          iSelect:=0;
          OrdreArchivePhoto:=0;

          while not eof(FArchivePhotoCommentaire)and(OKArchivePhotoCommentaire=false)do
          begin
               read(FArchivePhotoCommentaire,RArchivePhotoCommentaire);

               if(RArchivePhotoCommentaire.TypeModuleArchivePhotoCommentaire=FSArchivesPhotosCommentaires.EditTypeModuleArchivePhotoCommentaire.Text)then
               begin
                    if(OrdreArchivePhoto<=RArchivePhotoCommentaire.OrdreArchivePhotoCommentaire)then OrdreArchivePhoto:=RArchivePhotoCommentaire.OrdreArchivePhotoCommentaire+1;
               end;

               if(inttostr(RArchivePhotoCommentaire.PositionArchivePhotoCommentaire)=FSArchivesPhotosCommentaires.EditPositionArchivePhotoCommentaire.Text)then
               begin
                    OKArchivePhotoCommentaire:=true;
                    iSelect:=i;
                    OrdreArchivePhoto:=RArchivePhotoCommentaire.OrdreArchivePhotoCommentaire;
               end;
          i:=i+1;
          end;

          if(OKArchivePhotoCommentaire=true)then i:=iSelect;
          PositionSelect:=inttostr(i);
          RArchivePhotoCommentaire.PositionArchivePhotoCommentaire:=i;
          RArchivePhotoCommentaire.OrdreArchivePhotoCommentaire:=OrdreArchivePhoto;
          RArchivePhotoCommentaire.TypeModuleArchivePhotoCommentaire:=FSArchivesPhotosCommentaires.EditTypeModuleArchivePhotoCommentaire.Text;
          RArchivePhotoCommentaire.CodeStructure:=FSArchivesPhotosCommentaires.EditCodeStructure.Text;
          RArchivePhotoCommentaire.DesignationStructure:=FSArchivesPhotosCommentaires.EditDesignationStructure.Text;
          RArchivePhotoCommentaire.OrdreGroupe:=strtointeger(FSArchivesPhotosCommentaires.EditOrdreGroupe.Text);
          RArchivePhotoCommentaire.CodeGroupe:=FSArchivesPhotosCommentaires.EditCodeGroupe.Text;
          RArchivePhotoCommentaire.DesignationGroupe:=FSArchivesPhotosCommentaires.EditDesignationGroupe.Text;
          RArchivePhotoCommentaire.CodeArticle:=FSArchivesPhotosCommentaires.EditCodeArticle.Text;
          RArchivePhotoCommentaire.DesignationArticle:=FSArchivesPhotosCommentaires.EditDesignationArticle.Text;
          RArchivePhotoCommentaire.ReferenceArticle:=FSArchivesPhotosCommentaires.EditReferenceArticle.Text;
          RArchivePhotoCommentaire.Commentaire:=FSArchivesPhotosCommentaires.EditCommentaire.Text;

          if(FSArchivesPhotosCommentaires.EditNomPhotoCharger.Text<>'')and(FSArchivesPhotosCommentaires.EditNomPhotoCharger.Text<>'???')then
          begin
               RArchivePhotoCommentaire.NomFichierArchive:='ArchivePhoto'+FSArchivesPhotosCommentaires.EditTypeModuleArchivePhotoCommentaire.Text+' '+inttostr(OrdreArchivePhoto)+'.jpg';
               AdresseArchivePhoto:=RParc.Parcours+'\'+Entreprise+'-'+RArchivePhotoCommentaire.NomFichierArchive;
               FSArchivesPhotosCommentaires.EditPhotoArchive.Picture.SaveToFile(AdresseArchivePhoto);
          end
          else RArchivePhotoCommentaire.NomFichierArchive:='';

          Seek(FArchivePhotoCommentaire,i);
          write(FArchivePhotoCommentaire,RArchivePhotoCommentaire);
          CloseFile(FArchivePhotoCommentaire);

     end;

     if(FSArchivesPhotosCommentaires.BitOperationArchivesPhotosCommentaires.Caption='Supprimer')then
     begin
          PositionSelect:=inttostr(strtointeger(FSArchivesPhotosCommentaires.EditPositionArchivePhotoCommentaire.Text)-1);
          DeleteFArchivePhotoCommentaire(FSArchivesPhotosCommentaires.EditPositionArchivePhotoCommentaire.Text,OKArchivePhotoCommentaire);
          if(OKArchivePhotoCommentaire=true)then
          begin
               AdresseArchivePhoto:=RParc.Parcours+'\'+Entreprise+'-'+FSArchivesPhotosCommentaires.EditNomFichierArchive.Text;
               DeleteFile(AdresseArchivePhoto);
          end;
     end;

     ListeArchivePhotosCommenatires(FSArchivesPhotosCommentaires.TableauArchivesPhotosCommentaire,FSArchivesPhotosCommentaires.EditTypeModuleArchivePhotoCommentaireAfficher.Text,FSArchivesPhotosCommentaires.EditListeStructure.Text,FSArchivesPhotosCommentaires.EditListeGroupe.Text,FSArchivesPhotosCommentaires.EditListeStructure,FSArchivesPhotosCommentaires.EditListeGroupe,false,FSArchivesPhotosCommentaires.EditAvecSansPhoto.Text,PositionSelect);

     FSArchivesPhotosCommentaires.AfficheOperationArchivesPhotosCommentaire.Visible:=false;

     FSArchivesPhotosCommentaires.TableauArchivesPhotosCommentaire.SetFocus;

     if(FSArchivesPhotosCommentaires.TableauArchivesPhotosCommentaire.Cells[13,FSArchivesPhotosCommentaires.TableauArchivesPhotosCommentaire.Row]<>'')then
     begin
          OpenFParc(RParc);
          AdresseArchivePhoto:=RParc.Parcours+'\'+Entreprise+'-'+FSArchivesPhotosCommentaires.TableauArchivesPhotosCommentaire.Cells[13,FSArchivesPhotosCommentaires.TableauArchivesPhotosCommentaire.Row];

          if FileExists(AdresseArchivePhoto)
          then FSArchivesPhotosCommentaires.PhotoArchive.Picture.LoadFromFile(AdresseArchivePhoto)
          else FSArchivesPhotosCommentaires.PhotoArchive.Picture:=FSArchivesPhotosCommentaires.PhotoVide.Picture;
     end
     else FSArchivesPhotosCommentaires.PhotoArchive.Picture:=FSArchivesPhotosCommentaires.PhotoVide.Picture;
end;

Procedure ListeArchivePhotosCommenatires(TableauArchivePhotosCommenatires:TStringGrid;  TypeModule,Structure,Groupe:string;  EditListeStructure,EditListeGroupe:TComboBox; OKReinitialiseBox:boolean; ArticleAvecSansPhoto,PositionArchivePhotoCommentaireSelect:string);
var  R,l,LStructure,LGroupe,RowSelect:integer;  OKArchivePhotoCommentaire,OKStructure,OKGroupe:boolean;    AdresseArchivePhoto:string;
begin
     TableauArchivePhotosCommenatires.ColCount:=14;
     TableauArchivePhotosCommenatires.Cols[1].Text:='Pｰ';
     TableauArchivePhotosCommenatires.Cols[2].Text:='OrdreArchive';
     TableauArchivePhotosCommenatires.Cols[3].Text:='Type Module';
     TableauArchivePhotosCommenatires.Cols[4].Text:='Code Structure';
     TableauArchivePhotosCommenatires.Cols[5].Text:='D駸ignation Structure';
     TableauArchivePhotosCommenatires.Cols[6].Text:='Ordre groupe';
     TableauArchivePhotosCommenatires.Cols[7].Text:='Code groupe';
     TableauArchivePhotosCommenatires.Cols[8].Text:='D駸ignation groupe';
     TableauArchivePhotosCommenatires.Cols[9].Text:='Code Article';
     TableauArchivePhotosCommenatires.Cols[10].Text:='D駸ignation Article';
     TableauArchivePhotosCommenatires.Cols[11].Text:='R馭 Article';
     TableauArchivePhotosCommenatires.Cols[12].Text:='Commentaire';
     TableauArchivePhotosCommenatires.Cols[13].Text:='Nom Fichier';

     TableauArchivePhotosCommenatires.RowCount:=2;
     TableauArchivePhotosCommenatires.Rows[1].Text:='';

     if(OKReinitialiseBox=true)then
     begin
          EditListeStructure.Items.Text:='Tous';
          EditListeGroupe.Items.Text:='Tous';
     end;

     OpenFParc(RParc);
     ChArchivePhotoCommentaire:=RParc.Parcours+'\'+Exercice+'FArchivePhotoCommentaire';
     assignfile(FArchivePhotoCommentaire,ChArchivePhotoCommentaire);
     if FileExists(ChArchivePhotoCommentaire)then
     Reset(FArchivePhotoCommentaire)
     else Rewrite(FArchivePhotoCommentaire);
     Seek(FArchivePhotoCommentaire,0);
     RowSelect:=1;
     R:=0;
     l:=0;
     LStructure:=0;
     LGroupe:=0;
     while not eof(FArchivePhotoCommentaire)do
     begin
          read(FArchivePhotoCommentaire,RArchivePhotoCommentaire);

          if(TypeModule<>'')and(TypeModule<>'Tous')then
          begin
               if(RArchivePhotoCommentaire.TypeModuleArchivePhotoCommentaire=TypeModule)
               then OKArchivePhotoCommentaire:=true
               else OKArchivePhotoCommentaire:=false;
          end
          else OKArchivePhotoCommentaire:=true;

          if(OKArchivePhotoCommentaire=true)and(OKReinitialiseBox=true)then
          begin
               l:=0;
               OKStructure:=false;
               while(l<=LStructure)and(OKStructure=false)do
               begin
                    if(EditListeStructure.Items.Strings[l]=RArchivePhotoCommentaire.DesignationStructure)then OKStructure:=true;
               l:=l+1;
               end;

               if(OKStructure=false)then
               begin
                    LStructure:=LStructure+1;
                    EditListeStructure.Items.Add(RArchivePhotoCommentaire.DesignationStructure);
               end;


               l:=0;
               OKGroupe:=false;
               while(l<=LGroupe)and(OKGroupe=false)do
               begin
                    if(EditListeGroupe.Items.Strings[l]=RArchivePhotoCommentaire.DesignationGroupe)then OKGroupe:=true;
               l:=l+1;
               end;

               if(OKGroupe=false)then
               begin
                    LGroupe:=LGroupe+1;
                    EditListeGroupe.Items.Add(RArchivePhotoCommentaire.DesignationGroupe);
               end;
          end;

          if(OKArchivePhotoCommentaire=true)then
          begin
               if(Structure<>'')and(Structure<>'Tous')then
               begin
                    if(RArchivePhotoCommentaire.DesignationStructure=Structure)
                    then OKArchivePhotoCommentaire:=true
                    else OKArchivePhotoCommentaire:=false;
               end;
          end;

          if(OKArchivePhotoCommentaire=true)then
          begin
               if(Groupe<>'')and(Groupe<>'Tous')then
               begin
                    if(RArchivePhotoCommentaire.DesignationGroupe=Groupe)
                    then OKArchivePhotoCommentaire:=true
                    else OKArchivePhotoCommentaire:=false;
               end;
          end;

          if(OKArchivePhotoCommentaire=true)then
          begin
               if(ArticleAvecSansPhoto='Avec')then
               begin
                    if(RArchivePhotoCommentaire.NomFichierArchive='')then
                    begin
                         OKArchivePhotoCommentaire:=false;
                    end
                    else
                    begin
                         OpenFParc(RParc);
                         AdresseArchivePhoto:=RParc.Parcours+'\'+Entreprise+'-'+RArchivePhotoCommentaire.NomFichierArchive;

                         if Not FileExists(AdresseArchivePhoto)then OKArchivePhotoCommentaire:=false;
                    end;
               end;

               if(ArticleAvecSansPhoto='Sans')then
               begin
                    if(RArchivePhotoCommentaire.NomFichierArchive<>'')then
                    begin
                         OpenFParc(RParc);
                         AdresseArchivePhoto:=RParc.Parcours+'\'+Entreprise+'-'+RArchivePhotoCommentaire.NomFichierArchive;

                         if FileExists(AdresseArchivePhoto)then OKArchivePhotoCommentaire:=false;
                    end;
               end;
          end;

          if(OKArchivePhotoCommentaire=true)then
          begin
               R:=R+1;
               TableauArchivePhotosCommenatires.Rows[R].Text:=inttostr(R);
               TableauArchivePhotosCommenatires.Cells[1,R]:=inttostr(RArchivePhotoCommentaire.PositionArchivePhotoCommentaire);
               TableauArchivePhotosCommenatires.Cells[2,R]:=inttostr(RArchivePhotoCommentaire.OrdreArchivePhotoCommentaire);
               TableauArchivePhotosCommenatires.Cells[3,R]:=RArchivePhotoCommentaire.TypeModuleArchivePhotoCommentaire;
               TableauArchivePhotosCommenatires.Cells[4,R]:=RArchivePhotoCommentaire.CodeStructure;
               TableauArchivePhotosCommenatires.Cells[5,R]:=RArchivePhotoCommentaire.DesignationStructure;
