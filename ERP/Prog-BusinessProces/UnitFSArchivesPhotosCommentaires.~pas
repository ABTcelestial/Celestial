Function IndiqueAdresseArchivePhoto(PositionArchivePhoto,DesignationStructure,CodeArticle,DesignationArticle:string;  TableauListePositionArchivePhoto:TStringGrid;  var AdresseArchivePhoto:string):boolean;
var  R:integer; OKArchivePhoto:boolean;
begin
     if(PositionArchivePhoto='')then
     begin
          TableauListePositionArchivePhoto.ColCount:=6;
          TableauListePositionArchivePhoto.Cols[0].Text:='Nｰ';
          TableauListePositionArchivePhoto.Cols[1].Text:='Pｰ';
          TableauListePositionArchivePhoto.Cols[2].Text:='Code';
          TableauListePositionArchivePhoto.Cols[3].Text:='D駸ignation';
          TableauListePositionArchivePhoto.Cols[4].Text:='R馭';
          TableauListePositionArchivePhoto.Cols[5].Text:='Nom Photo';

          TableauListePositionArchivePhoto.RowCount:=2;
          TableauListePositionArchivePhoto.Rows[1].Text:='';
     end;

     OpenFParc(RParc);
     ChArchivePhotoCommentaire:=RParc.Parcours+'\'+Exercice+'FArchivePhotoCommentaire';
     assignfile(FArchivePhotoCommentaire,ChArchivePhotoCommentaire);
     if FileExists(ChArchivePhotoCommentaire)then
     Reset(FArchivePhotoCommentaire)
     else Rewrite(FArchivePhotoCommentaire);
     Seek(FArchivePhotoCommentaire,0);
     AdresseArchivePhoto:='';
     R:=0;
     OKArchivePhoto:=false;
     while not eof(FArchivePhotoCommentaire)and(OKArchivePhoto=false)do
     begin
          read(FArchivePhotoCommentaire,RArchivePhotoCommentaire);

          OKArchivePhoto:=false;

          if(PositionArchivePhoto<>'')then
          begin
               if(inttostr(RArchivePhotoCommentaire.PositionArchivePhotoCommentaire)=PositionArchivePhoto)
               then OKArchivePhoto:=true
               else OKArchivePhoto:=false;
          end
          else
          begin
               if(DesignationStructure<>'')then
               begin
                    if(RArchivePhotoCommentaire.DesignationStructure=DesignationStructure)
                    then OKArchivePhoto:=true
                    else OKArchivePhoto:=false;
               end
               else OKArchivePhoto:=true;

               if(OKArchivePhoto=true)then
               begin
                    if(CodeArticle<>'')then
                    begin
                         if(RArchivePhotoCommentaire.CodeArticle=CodeArticle)
                         then OKArchivePhoto:=true
                         else OKArchivePhoto:=false;
                    end;
               end;

               if(OKArchivePhoto=true)then
               begin
                    if(DesignationArticle<>'')then
                    begin
                         if(RArchivePhotoCommentaire.DesignationArticle=DesignationArticle)
                         then OKArchivePhoto:=true
                         else OKArchivePhoto:=false;
                    end
                    else
                    if(DesignationStructure='')and(CodeArticle='')then OKArchivePhoto:=false;
               end;
          end;

          if(OKArchivePhoto=true)then
          begin
               OpenFParc(RParc);
               AdresseArchivePhoto:=RParc.Parcours+'\'+Entreprise+'-'+RArchivePhotoCommentaire.NomFichierArchive;

               if(PositionArchivePhoto='')then
               begin
                    R:=R+1;
                    TableauListePositionArchivePhoto.Rows[R].Text:=inttostr(R);
                    TableauListePositionArchivePhoto.Cells[1,R]:=inttostr(RArchivePhotoCommentaire.PositionArchivePhotoCommentaire);
                    TableauListePositionArchivePhoto.Cells[2,R]:=RArchivePhotoCommentaire.CodeArticle;
                    TableauListePositionArchivePhoto.Cells[3,R]:=RArchivePhotoCommentaire.DesignationArticle;
                    TableauListePositionArchivePhoto.Cells[4,R]:=RArchivePhotoCommentaire.ReferenceArticle;
                    TableauListePositionArchivePhoto.Cells[5,R]:=RArchivePhotoCommentaire.NomFichierArchive;

                    OKArchivePhoto:=false;
               end;
          end;
     end;
     CloseFile(FArchivePhotoCommentaire);

     if(R=0)then
     begin
          if(PositionArchivePhoto='')then
          begin
               OKArchivePhoto:=false;
               TableauListePositionArchivePhoto.Visible:=false;
          end;
     end
     else
     if(R=1)then
     begin
          OpenFParc(RParc);
          AdresseArchivePhoto:=RParc.Parcours+'\'+Entreprise+'-'+TableauListePositionArchivePhoto.Cells[5,1];
          OKArchivePhoto:=true;

          if not FileExists(AdresseArchivePhoto)then
          begin
               OKArchivePhoto:=false;
               AdresseArchivePhoto:='';
          end;
     end
     else
     if(PositionArchivePhoto='')then
     begin
          TableauListePositionArchivePhoto.RowCount:=R+1;
          AjusterColWidth(TableauListePositionArchivePhoto,'','');
          TableauListePositionArchivePhoto.Visible:=true;
          TableauListePositionArchivePhoto.SetFocus;
          OKArchivePhoto:=false;
     end;

     IndiqueAdresseArchivePhoto:=OKArchivePhoto;
end;

