                    end;
               end;
          end;
     end
     else
     begin
          FSListePrelevement.TableauListePrelevement.Cells[1,FSListePrelevement.TableauListePrelevement.Row]:='';
          Showmessage('La Période est sélectionné !, Veuillez confirmer votre requette SVP');
     end;
end;

end;

