                    and(RArchiveRegistreEtatStockPrelevement.Matricule=RArchiveRegistreEtatStockPrelevementCopie.Matricule)
                    and(RArchiveRegistreEtatStockPrelevement.CodeStructureStock=RArchiveRegistreEtatStockPrelevementCopie.CodeStructureStock)
                    and(RArchiveRegistreEtatStockPrelevement.CodeArticle=RArchiveRegistreEtatStockPrelevementCopie.CodeArticle)
                    and(RArchiveRegistreEtatStockPrelevement.QuantiteInitiale=RArchiveRegistreEtatStockPrelevementCopie.QuantiteInitiale)
                    and(RArchiveRegistreEtatStockPrelevement.QuantiteEntree=RArchiveRegistreEtatStockPrelevementCopie.QuantiteEntree)
                    and(RArchiveRegistreEtatStockPrelevement.QuantiteSortie=RArchiveRegistreEtatStockPrelevementCopie.QuantiteSortie)
                    and(RArchiveRegistreEtatStockPrelevement.QuantiteStock=RArchiveRegistreEtatStockPrelevementCopie.QuantiteStock)
                    and(RArchiveRegistreEtatStockPrelevement.CoutUnitaire=RArchiveRegistreEtatStockPrelevementCopie.CoutUnitaire)
                    and(RArchiveRegistreEtatStockPrelevement.PrixUnitaire=RArchiveRegistreEtatStockPrelevementCopie.PrixUnitaire)
                    then
                    begin
                         OKDouble:=true;
                         ValeurEcarter:=ValeurEcarter+MontantOperation;
                    end;
               end;
          end
          else OKDouble:=false;

          if(OKDouble=false)then
          begin
               ValeurSauvgarder:=ValeurSauvgarder+MontantOperation;
               Seek(FArchiveRegistreEtatStockPrelevementCopie,i);
               write(FArchiveRegistreEtatStockPrelevementCopie,RArchiveRegistreEtatStockPrelevement);
               i:=i+1;
          end;
     end;
     CloseFile(FArchiveRegistreEtatStockPrelevement);
     CloseFile(FArchiveRegistreEtatStockPrelevementCopie);

     FSOperationPrelevement.AffichePatienterSVPRegistreEtatStockPrelevement.Visible:=false;

     FSOperationPrelevement.EditValeurGlobaleRegistreEtatStockPrelevement.Text:=Vergule(floattostr(ValeurGlobale),'2','C','');
     FSOperationPrelevement.EditValeurEcarterRegistreEtatStockPrelevement.Text:=Vergule(floattostr(ValeurEcarter),'2','C','');
     FSOperationPrelevement.EditValeurSauvgarderRegistreEtatStockPrelevement.Text:=Vergule(floattostr(ValeurSauvgarder),'2','C','');

     FSOperationPrelevement.EditValeurPerteRegistreEtatStockPrelevement.Text:=Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','');

     if(ValeurEcarter=0)then
     begin
          FSOperationPrelevement.AfficheResultatRegistreEtatStockPrelevement.Color:=clAqua;
          FSOperationPrelevement.AfficheResultatRegistreEtatStockPrelevement.Caption:='Aucun Transfert !';
          FSOperationPrelevement.BitRegistreEtatStockPrelevement.Visible:=false;
     end
     else
     if(ValeurGlobale-ValeurEcarter-ValeurSauvgarder=0)then
     begin
          FSOperationPrelevement.AfficheResultatRegistreEtatStockPrelevement.Color:=clLime;
          FSOperationPrelevement.AfficheResultatRegistreEtatStockPrelevement.Caption:='Transfert réussi !';
          FSOperationPrelevement.BitRegistreEtatStockPrelevement.Visible:=true;
     end
     else
     begin
          FSOperationPrelevement.AfficheResultatRegistreEtatStockPrelevement.Color:=clRed;
          FSOperationPrelevement.AfficheResultatRegistreEtatStockPrelevement.Caption:='Anomalie ! Perte de '+Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','')+' !';
          FSOperationPrelevement.BitRegistreEtatStockPrelevement.Visible:=false;
     end;
end;

Procedure ControleDoubleMoyenTransport(NumPrelevement:integer; Matricule:string; var ValeurGlobale,ValeurEcarter,ValeurSauvgarder:real);
var i:integer;  PositionPrelevement:string;   QteOperation,MontantOperation:real; OKDouble:boolean;
begin
     FSOperationPrelevement.ProgressPatienterMoyenTransport.Position:=0;

     OpenFParc(RParc);
     ChArchiveMoyenTransport:=RParc.Parcours+'\'+Exercice+'FArchiveMoyenTransportPrélčvement';
     assignfile(FArchiveMoyenTransport,ChArchiveMoyenTransport);
     if FileExists(ChArchiveMoyenTransport)then
     Reset(FArchiveMoyenTransport)
     else Rewrite(FArchiveMoyenTransport);
     Seek(FArchiveMoyenTransport,0);
     i:=0;
     while not eof(FArchiveMoyenTransport)do
     begin
          read(FArchiveMoyenTransport,RArchiveMoyenTransport);  Application.ProcessMessages;
          i:=i+1;
     end;
     CloseFile(FArchiveMoyenTransport);
     FSOperationPrelevement.ProgressPatienterMoyenTransport.Max:=i;

     ValeurGlobale:=0;
     ValeurEcarter:=0;
     ValeurSauvgarder:=0;

     OpenFParc(RParc);
     ChArchiveMoyenTransportCopie:=RParc.Parcours+'\'+Exercice+'FArchiveMoyenTransportPrélčvement '+FSOperationPrelevement.EditTypeAnalyse.Text+' Prelevement '+inttostr(NumPrelevement)+' '+Matricule;
     assignfile(FArchiveMoyenTransportCopie,ChArchiveMoyenTransportCopie);
     if FileExists(ChArchiveMoyenTransportCopie)then
     Reset(FArchiveMoyenTransportCopie)
     else Rewrite(FArchiveMoyenTransportCopie);
     Seek(FArchiveMoyenTransportCopie,0);
     Truncate(FArchiveMoyenTransportCopie);

     OpenFParc(RParc);
     ChArchiveMoyenTransport:=RParc.Parcours+'\'+Exercice+'FArchiveMoyenTransportPrélčvement';
     assignfile(FArchiveMoyenTransport,ChArchiveMoyenTransport);
     if FileExists(ChArchiveMoyenTransport)then
     Reset(FArchiveMoyenTransport)
     else Rewrite(FArchiveMoyenTransport);
     Seek(FArchiveMoyenTransport,0);
     i:=0;
     while not eof(FArchiveMoyenTransport)do
     begin
          read(FArchiveMoyenTransport,RArchiveMoyenTransport);   Application.ProcessMessages;
          FSOperationPrelevement.ProgressPatienterMoyenTransport.StepIt;

          ValeurGlobale:=ValeurGlobale+1;

          if(RArchiveMoyenTransport.NumMovementPrelevement=NumPrelevement)
          and(RArchiveMoyenTransport.MatriculeEffectif=Matricule)
          then
          begin
               Seek(FArchiveMoyenTransportCopie,0);
               OKDouble:=false;
               while not eof(FArchiveMoyenTransportCopie)and(OKDouble=false)do
               begin
                    read(FArchiveMoyenTransportCopie,RArchiveMoyenTransportCopie); Application.ProcessMessages;
                    if (RArchiveMoyenTransport.TypeFiche=RArchiveMoyenTransportCopie.TypeFiche)
                    and(RArchiveMoyenTransport.NumMovementPrelevement=RArchiveMoyenTransportCopie.NumMovementPrelevement)
                    and(RArchiveMoyenTransport.MatriculeEffectif=RArchiveMoyenTransportCopie.MatriculeEffectif)
                    and(RArchiveMoyenTransport.NumFiche=RArchiveMoyenTransportCopie.NumFiche)
                    and(RArchiveMoyenTransport.CodeTiers=RArchiveMoyenTransportCopie.CodeTiers)
                    and(RArchiveMoyenTransport.MoyenTransport=RArchiveMoyenTransportCopie.MoyenTransport)
                    and(RArchiveMoyenTransport.MatriculeTransport=RArchiveMoyenTransportCopie.MatriculeTransport)
                    and(RArchiveMoyenTransport.NomChauffeur=RArchiveMoyenTransportCopie.NomChauffeur)
                    and(RArchiveMoyenTransport.PrenomChauffeur=RArchiveMoyenTransportCopie.PrenomChauffeur)
                    and(RArchiveMoyenTransport.PieceIdentite=RArchiveMoyenTransportCopie.PieceIdentite)
                    then
                    begin
                         OKDouble:=true;
                         ValeurEcarter:=ValeurEcarter+1;
                    end;
               end;
          end
          else OKDouble:=false;

          if(OKDouble=false)then
          begin
               ValeurSauvgarder:=ValeurSauvgarder+1;
               Seek(FArchiveMoyenTransportCopie,i);
               write(FArchiveMoyenTransportCopie,RArchiveMoyenTransport);
               i:=i+1;
          end;
     end;
     CloseFile(FArchiveMoyenTransport);
     CloseFile(FArchiveMoyenTransportCopie);
     
     FSOperationPrelevement.AffichePatienterSVPMoyenTransport.Visible:=false;

     FSOperationPrelevement.EditValeurGlobaleMoyenTransport.Text:=Vergule(floattostr(ValeurGlobale),'0','N','');
     FSOperationPrelevement.EditValeurEcarterMoyenTransport.Text:=Vergule(floattostr(ValeurEcarter),'0','N','');
     FSOperationPrelevement.EditValeurSauvgarderMoyenTransport.Text:=Vergule(floattostr(ValeurSauvgarder),'0','N','');

     FSOperationPrelevement.EditValeurPerteMoyenTransport.Text:=Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','');

     if(ValeurEcarter=0)then
     begin
          FSOperationPrelevement.AfficheResultatMoyenTransport.Color:=clAqua;
          FSOperationPrelevement.AfficheResultatMoyenTransport.Caption:='Aucun Transfert !';
          FSOperationPrelevement.BitMoyenTransport.Visible:=false;
     end
     else
     if(ValeurGlobale-ValeurEcarter-ValeurSauvgarder=0)then
     begin
          FSOperationPrelevement.AfficheResultatMoyenTransport.Color:=clLime;
          FSOperationPrelevement.AfficheResultatMoyenTransport.Caption:='Transfert réussi !';
          FSOperationPrelevement.BitMoyenTransport.Visible:=true;
     end
     else
     begin
          FSOperationPrelevement.AfficheResultatMoyenTransport.Color:=clRed;
          FSOperationPrelevement.AfficheResultatMoyenTransport.Caption:='Anomalie ! Perte de '+Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','')+' !';
          FSOperationPrelevement.BitMoyenTransport.Visible:=false;
     end;
end;

