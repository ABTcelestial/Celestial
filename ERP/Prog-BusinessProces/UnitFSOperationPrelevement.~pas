Procedure EcartirePrelevementCompteur(NumPrelevement:integer; Matricule:string; var ValeurGlobale,ValeurEcarter,ValeurSauvgarder:real);
var i:integer;  PositionPrelevement:string;   QteOperation,MontantOperation:real;
begin
     FSOperationPrelevement.ProgressPatienterPrelevementCompteur.Position:=0;

     OpenFParc(RParc);
     ChArchivePrelevementCompteur:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementCompteur';
     assignfile(FArchivePrelevementCompteur,ChArchivePrelevementCompteur);
     if FileExists(ChArchivePrelevementCompteur)then
     Reset(FArchivePrelevementCompteur)
     else Rewrite(FArchivePrelevementCompteur);
     Seek(FArchivePrelevementCompteur,0);
     i:=0;
     while not eof(FArchivePrelevementCompteur)do
     begin
          read(FArchivePrelevementCompteur,RArchivePrelevementCompteur);  Application.ProcessMessages;
          i:=i+1;
     end;
     CloseFile(FArchivePrelevementCompteur);
     FSOperationPrelevement.ProgressPatienterPrelevementCompteur.Max:=i;

     ValeurGlobale:=0;
     ValeurEcarter:=0;
     ValeurSauvgarder:=0;

     OpenFParc(RParc);
     ChArchivePrelevementCompteurCopie:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementCompteur '+FSOperationPrelevement.EditTypeAnalyse.Text+' Prelevement '+inttostr(NumPrelevement)+' '+Matricule;
     assignfile(FArchivePrelevementCompteurCopie,ChArchivePrelevementCompteurCopie);
     if FileExists(ChArchivePrelevementCompteurCopie)then
     Reset(FArchivePrelevementCompteurCopie)
     else Rewrite(FArchivePrelevementCompteurCopie);
     Seek(FArchivePrelevementCompteurCopie,0);
     Truncate(FArchivePrelevementCompteurCopie);

     OpenFParc(RParc);
     ChArchivePrelevementCompteur:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementCompteur';
     assignfile(FArchivePrelevementCompteur,ChArchivePrelevementCompteur);
     if FileExists(ChArchivePrelevementCompteur)then
     Reset(FArchivePrelevementCompteur)
     else Rewrite(FArchivePrelevementCompteur);
     Seek(FArchivePrelevementCompteur,0);
     i:=0;
     while not eof(FArchivePrelevementCompteur)do
     begin
          read(FArchivePrelevementCompteur,RArchivePrelevementCompteur); Application.ProcessMessages;

          FSOperationPrelevement.ProgressPatienterPrelevementCompteur.StepIt;

          RCompteur:=ChercherCompteur(RArchivePrelevementCompteur.NumCompteur);
          CalculeCompteurPrelevement(RCompteur.TypeIndicePrelevement,RArchivePrelevementCompteur.PrixPrelevement,RArchivePrelevementCompteur.ValeurInitiale,RArchivePrelevementCompteur.ValeurMouvement,RArchivePrelevementCompteur.ValeurPrelevement,QteOperation,MontantOperation);
          ValeurGlobale:=ValeurGlobale+MontantOperation;

          if(RArchivePrelevementCompteur.NumPrelevement=NumPrelevement)
          and(RArchivePrelevementCompteur.Matricule=Matricule)
          then
          begin
               ValeurEcarter:=ValeurEcarter+MontantOperation;
          end
          else
          begin
               ValeurSauvgarder:=ValeurSauvgarder+MontantOperation;
               Seek(FArchivePrelevementCompteurCopie,i);
               write(FArchivePrelevementCompteurCopie,RArchivePrelevementCompteur);
          i:=i+1;
          end;
     end;
     CloseFile(FArchivePrelevementCompteur);
     CloseFile(FArchivePrelevementCompteurCopie);
     
     FSOperationPrelevement.AffichePatienterSVPPrelevementCompteur.Visible:=false;

     FSOperationPrelevement.EditValeurGlobalePrelevementCompteur.Text:=Vergule(floattostr(ValeurGlobale),'2','C','');
     FSOperationPrelevement.EditValeurEcarterPrelevementCompteur.Text:=Vergule(floattostr(ValeurEcarter),'2','C','');
     FSOperationPrelevement.EditValeurSauvgarderPrelevementCompteur.Text:=Vergule(floattostr(ValeurSauvgarder),'2','C','');

     FSOperationPrelevement.EditValeurPertePrelevementCompteur.Text:=Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','');

     if(ValeurEcarter=0)then
     begin
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Color:=clAqua;
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Caption:='Aucun Transfert !';
          FSOperationPrelevement.BitPrelevementCompteur.Visible:=false;
     end
     else
     if(ValeurGlobale-ValeurEcarter-ValeurSauvgarder=0)then
     begin
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Color:=clLime;
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Caption:='Transfert réussi !';
          FSOperationPrelevement.BitPrelevementCompteur.Visible:=true;
     end
     else
     begin
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Color:=clRed;
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Caption:='Anomalie ! Perte de '+Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','')+' !';
          FSOperationPrelevement.BitPrelevementCompteur.Visible:=false;
     end;
end;

procedure TFSOperationPrelevement.AfficheResultatPrelevementCompteurDblClick(
  Sender: TObject);
begin
     if(FSOperationPrelevement.AfficheResultatPrelevementCompteur.Color=clRed)then
     begin
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Color:=clYellow;
          FSOperationPrelevement.AfficheResultatPrelevementCompteur.Caption:='Forcer le transfert !';
          FSOperationPrelevement.BitPrelevementCompteur.Visible:=true;
     end;

     FSOperationPrelevement.AffichePrelevementNonArchiver.Visible:=AfficheBitPrelevementNonArchiver;
end;

procedure TFSOperationPrelevement.TimerPrelevementCompteurTimer(
  Sender: TObject);
var ValeurGlobale,ValeurEcarter,ValeurSauvgarder:real;
begin
     FSOperationPrelevement.TimerPrelevementCompteur.Enabled:=false;

     if(FSOperationPrelevement.EditTypeAnalyse.Text='Ecartement')then
     begin
          EcartirePrelevementCompteur(strtointeger(FSOperationPrelevement.EditNumPrelevementTransfert.Text),FSOperationPrelevement.EditMatriculeTransfert.Text,ValeurGlobale,ValeurEcarter,ValeurSauvgarder);
     end
     else
     if(FSOperationPrelevement.EditTypeAnalyse.Text='Double')then
     begin
          ControleDoublePrelevementCompteur(strtointeger(FSOperationPrelevement.EditNumPrelevementTransfert.Text),FSOperationPrelevement.EditMatriculeTransfert.Text,ValeurGlobale,ValeurEcarter,ValeurSauvgarder);
     end;

     FSOperationPrelevement.AffichePrelevementNonArchiver.Visible:=AfficheBitPrelevementNonArchiver;
end;

Procedure EcartirePrelevementUniteFonds(NumPrelevement:integer; Matricule:string; var ValeurGlobale,ValeurEcarter,ValeurSauvgarder:real);
var i:integer;  PositionPrelevement:string;   QteOperation,MontantOperation:real;
begin
     FSOperationPrelevement.ProgressPatienterPrelevementUniteFonds.Position:=0;

     OpenFParc(RParc);
     ChArchivePrelevementUniteFonds:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementUniteFonds';
     assignfile(FArchivePrelevementUniteFonds,ChArchivePrelevementUniteFonds);
     if FileExists(ChArchivePrelevementUniteFonds)then
     Reset(FArchivePrelevementUniteFonds)
     else Rewrite(FArchivePrelevementUniteFonds);
     Seek(FArchivePrelevementUniteFonds,0);
     i:=0;
     while not eof(FArchivePrelevementUniteFonds)do
     begin
          read(FArchivePrelevementUniteFonds,RArchivePrelevementUniteFonds);  Application.ProcessMessages;
          i:=i+1;
     end;
     CloseFile(FArchivePrelevementUniteFonds);
     FSOperationPrelevement.ProgressPatienterPrelevementUniteFonds.Max:=i;

     ValeurGlobale:=0;
     ValeurEcarter:=0;
     ValeurSauvgarder:=0;

     OpenFParc(RParc);
     ChArchivePrelevementUniteFondsCopie:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementUniteFonds '+FSOperationPrelevement.EditTypeAnalyse.Text+' Prelevement '+inttostr(NumPrelevement)+' '+Matricule;
     assignfile(FArchivePrelevementUniteFondsCopie,ChArchivePrelevementUniteFondsCopie);
     if FileExists(ChArchivePrelevementUniteFondsCopie)then
     Reset(FArchivePrelevementUniteFondsCopie)
     else Rewrite(FArchivePrelevementUniteFondsCopie);
     Seek(FArchivePrelevementUniteFondsCopie,0);
     Truncate(FArchivePrelevementUniteFondsCopie);

     OpenFParc(RParc);
     ChArchivePrelevementUniteFonds:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementUniteFonds';
     assignfile(FArchivePrelevementUniteFonds,ChArchivePrelevementUniteFonds);
     if FileExists(ChArchivePrelevementUniteFonds)then
     Reset(FArchivePrelevementUniteFonds)
     else Rewrite(FArchivePrelevementUniteFonds);
     Seek(FArchivePrelevementUniteFonds,0);
     i:=0;
     while not eof(FArchivePrelevementUniteFonds)do  
     begin
          read(FArchivePrelevementUniteFonds,RArchivePrelevementUniteFonds);   Application.ProcessMessages;
          FSOperationPrelevement.ProgressPatienterPrelevementUniteFonds.StepIt;

          MontantOperation:=0;
          if(RArchivePrelevementUniteFonds.ValeurPrecise=false)then
          begin
               if(RArchivePrelevementUniteFonds.CodeTiers<>'Divers')
               then MontantOperation:=RArchivePrelevementUniteFonds.ValeurPrelevement;
          end
          else
          begin
               RUniteFonds:=ChercherUniteFonds(inttostr(RArchivePrelevementUniteFonds.NumUniteFonds));
               MontantOperation:=RArchivePrelevementUniteFonds.ValeurPrelevement*RUniteFonds.ValeurMonetaireUnitaire;
          end;

          ValeurGlobale:=ValeurGlobale+MontantOperation;

          if(RArchivePrelevementUniteFonds.NumPrelevement=NumPrelevement)
          and(RArchivePrelevementUniteFonds.Matricule=Matricule)
          then
          begin
               ValeurEcarter:=ValeurEcarter+MontantOperation;
          end
          else
          begin
               ValeurSauvgarder:=ValeurSauvgarder+MontantOperation;
               Seek(FArchivePrelevementUniteFondsCopie,i);
               write(FArchivePrelevementUniteFondsCopie,RArchivePrelevementUniteFonds);
               i:=i+1;
          end;
     end;
     CloseFile(FArchivePrelevementUniteFonds);
     CloseFile(FArchivePrelevementUniteFondsCopie);
     
     FSOperationPrelevement.AffichePatienterSVPPrelevementUniteFonds.Visible:=false;

     FSOperationPrelevement.EditValeurGlobalePrelevementUniteFonds.Text:=Vergule(floattostr(ValeurGlobale),'2','C','');
     FSOperationPrelevement.EditValeurEcarterPrelevementUniteFonds.Text:=Vergule(floattostr(ValeurEcarter),'2','C','');
     FSOperationPrelevement.EditValeurSauvgarderPrelevementUniteFonds.Text:=Vergule(floattostr(ValeurSauvgarder),'2','C','');

     FSOperationPrelevement.EditValeurPertePrelevementUniteFonds.Text:=Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','');

     if(ValeurEcarter=0)then
     begin
          FSOperationPrelevement.AfficheResultatPrelevementUniteFonds.Color:=clAqua;
          FSOperationPrelevement.AfficheResultatPrelevementUniteFonds.Caption:='Aucun Transfert !';
          FSOperationPrelevement.BitPrelevementUniteFonds.Visible:=false;
     end
     else
     if(ValeurGlobale-ValeurEcarter-ValeurSauvgarder=0)then
     begin
          FSOperationPrelevement.AfficheResultatPrelevementUniteFonds.Color:=clLime;
          FSOperationPrelevement.AfficheResultatPrelevementUniteFonds.Caption:='Transfert réussi !';
          FSOperationPrelevement.BitPrelevementUniteFonds.Visible:=true;
     end
     else
     begin
          FSOperationPrelevement.AfficheResultatPrelevementUniteFonds.Color:=clRed;
          FSOperationPrelevement.AfficheResultatPrelevementUniteFonds.Caption:='Anomalie ! Perte de '+Vergule(floattostr(ValeurGlobale-ValeurEcarter-ValeurSauvgarder),'2','C','')+' !';
          FSOperationPrelevement.BitPrelevementUniteFonds.Visible:=false;
     end;
end;

