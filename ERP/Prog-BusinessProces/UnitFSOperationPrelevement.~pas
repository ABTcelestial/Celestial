     FSOperationPrelevement.EditMatriculeTransfert.Text:=FSListePrelevement.TableauListePrelevement.Cells[5,FSListePrelevement.TableauListePrelevement.Row];

     RPrelevement:=ChercherPrelevement(strtointeger(FSOperationPrelevement.EditNumPrelevementTransfert.Text),ExerciceAnnee,FSOperationPrelevement.EditMatriculeTransfert.Text,PositionPrelevement);
     FSOperationPrelevement.EditPositionPrelevementTransfert.Text:=PositionPrelevement;

