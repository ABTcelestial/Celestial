          showmessage('FileSize: '+inttostr(iCount));
     end
     else Rewrite(FMouvement);

     Seek(FMouvement,0);
     i:=0;
     while not eof(FMouvement)do
     begin
          l:=FilePos(FMouvement);
          showmessage('avant Read i: '+inttostr(i)+' l: '+inttostr(l));

          read(FMouvement,RMouvement);          

          l:=FilePos(FMouvement);
