Procedure ListeDataRepertoireActuel(AdresseSource:string; ListeBaseDonnees:TShellListView; EditRepertoireActuel,EditExerciceRepertoireActuel:TComboBox);
var  i,l,iMax:integer; RepertoireFichier,NomFichier,AnneeFichier,TypeData,TypeTrie:string;  OKData:boolean;
begin
     EditRepertoireActuel.Items.Text:='';
     EditExerciceRepertoireActuel.Items.Text:='';

     if(AdresseSource='')then AdresseSource:=GetCurrentDir;
     ListeBaseDonnees.Root:=AdresseSource;
     ListeBaseDonnees.Refresh;

     i:=0;
     iMax:=ListeBaseDonnees.Items.Count-1;
     while(i<=iMax)do
     begin
          IdentificationFichier(ListeBaseDonnees,i,AdresseFile,RepertoireFichier,NomFichier,AnneeFichier);

          if(RepertoireFichier<>'')
          and(NomFichier<>'')
          and(AnneeFichier<>'')
          then
          begin
                l:=0;
                OKData:=false;
                while(l<=EditRepertoireActuel.Items.Count-1)and(OKData=false)do
                begin
                     if(EditRepertoireActuel.Items[l]=RepertoireFichier)then
                     begin
                          OKData:=true
                     end;
                l:=l+1;
                end;

                if(OKData=false)then
                begin
                     EditRepertoireActuel.Items.Add(RepertoireFichier);
                end;

                l:=0;
                OKData:=false;
                while(l<=EditExerciceRepertoireActuel.Items.Count-1)and(OKData=false)do
                begin
                     if(EditExerciceRepertoireActuel.Items[l]=AnneeFichier)then
                     begin
                          OKData:=true
                     end;
                l:=l+1;
                end;

                if(OKData=false)then
                begin
                     EditExerciceRepertoireActuel.Items.Add(AnneeFichier);
                end;
          end;
     i:=i+1;
     end;

     EditRepertoireActuel.ItemIndex:=0;
     EditExerciceRepertoireActuel.ItemIndex:=0;

     TrieTComboBox(EditRepertoireActuel,'','+');
     TrieTComboBox(EditExerciceRepertoireActuel,'Num','+');    
end;

