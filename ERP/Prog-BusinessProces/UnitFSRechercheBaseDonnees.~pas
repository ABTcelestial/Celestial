Procedure ProcRechercheBaseDonnees(TableauListeBaseDonnees:TStringGrid; ExerciceActuel,TypeOctets,RubriqueTrieCol,TypeData,TypeTrie:string);
var  i,R:integer;  RepertoireFichier,NomFichier,AnneeFichier:string;  OKFichier:boolean;
begin
     FSRechercheBaseDonnees.TableauListeFichier.Refresh;
     OpenFParc(RParc);
     FSRechercheBaseDonnees.TableauListeFichier.Root:=RParc.Parcours;
     FSRechercheBaseDonnees.EditExerciceActuel.Enabled:=false;
     FSRechercheBaseDonnees.IncrimenteExerciceActuel.Enabled:=false;

     TableauListeBaseDonnees.ColCount:=10;
     TableauListeBaseDonnees.Cols[0].Text:='N°';
     TableauListeBaseDonnees.Cols[1].Text:='Répertoir';
     TableauListeBaseDonnees.Cols[2].Text:='Année';
     TableauListeBaseDonnees.Cols[3].Text:='Nom Fichier';
     TableauListeBaseDonnees.Cols[4].Text:='Validation';
     TableauListeBaseDonnees.Cols[5].Text:='Réouverture effectué';
     TableauListeBaseDonnees.Cols[6].Text:='Nombre de registre';
     TableauListeBaseDonnees.Cols[7].Text:='Tille (Octets)';
     TableauListeBaseDonnees.Cols[8].Text:='IsFileInUse';
     TableauListeBaseDonnees.Cols[9].Text:='Adresse';

     TableauListeBaseDonnees.RowCount:=2;
     TableauListeBaseDonnees.Rows[1].Text:='';

     R:=0;
     for i:=0 to FSRechercheBaseDonnees.TableauListeFichier.Items.Count-1 do
     begin
          IdentificationFichier(FSRechercheBaseDonnees.TableauListeFichier,i,AdresseFile,RepertoireFichier,NomFichier,AnneeFichier);

          if(ExerciceActuel<>'')then
          begin
               if(AnneeFichier=ExerciceActuel)and(ControleOKTexteVide(NomFichier)=false)
               then OKFichier:=true
               else OKFichier:=false;
          end
          else OKFichier:=true;

          if(OKFichier=true)then
          begin
               R:=R+1;
               TableauListeBaseDonnees.Rows[R].Text:=inttostr(R);
               TableauListeBaseDonnees.Cells[1,R]:=RepertoireFichier;
               TableauListeBaseDonnees.Cells[2,R]:=AnneeFichier;
               TableauListeBaseDonnees.Cells[3,R]:=NomFichier;
               TableauListeBaseDonnees.Cells[4,R]:='Non';
               TableauListeBaseDonnees.Cells[5,R]:='';
               TableauListeBaseDonnees.Cells[6,R]:='';
               TableauListeBaseDonnees.Cells[7,R]:=ConvertOctets(TailleFichier(FSRechercheBaseDonnees.TableauListeFichier.Folders[i].PathName),TypeOctets,'2');
               TableauListeBaseDonnees.Cells[8,R]:=booleantostr(IsFileInUse(AdresseFile));
               TableauListeBaseDonnees.Cells[9,R]:=AdresseFile;
          end;
     end;

     if(R>0)then TableauListeBaseDonnees.RowCount:=R+1
            else TableauListeBaseDonnees.RowCount:=2;

     AjusterColWidth(TableauListeBaseDonnees,'','');

     TrierTableauARowSpecial(TableauListeBaseDonnees,1,TableauListeBaseDonnees.RowCount-1,1,RubriqueTrieCol,TypeData,TypeTrie);
end;

Procedure ProcEffectueBaseDonnee(TableauListeBaseDonnees:TStringGrid; RepertoireFichier,NomFichier,AnneeFichier,TypeProcesControleReseaux:string; NbrRegistre:integer);
var  Rp:integer;  OKBaseDonnee:boolean;
begin
     if(TypeProcesControleReseaux='Réseaux')
     then FSTravauxFinAnnee.MemoRapportReouverture.Lines.Add('Réseaux '+NomFichier)
     else FSTravauxFinAnnee.MemoRapportReouverture.Lines.Add('Réouverture '+NomFichier);
     Rp:=1;
     OKBaseDonnee:=false;
     while(Rp<=TableauListeBaseDonnees.RowCount-1)and(OKBaseDonnee=false)do
     begin
          if(TableauListeBaseDonnees.Cells[1,Rp]=RepertoireFichier)
          //and(TableauListeBaseDonnees.Cells[2,R]=AnneeFichier)
          and(TableauListeBaseDonnees.Cells[3,Rp]=NomFichier)
          then
          begin
               OKBaseDonnee:=true;
               if(TypeProcesControleReseaux='Réseaux')then
               begin
                    TableauListeBaseDonnees.Cells[4,Rp]:='OK';
                    TableauListeBaseDonnees.Cells[5,Rp]:='Réseaux';
                    TableauListeBaseDonnees.Cells[6,Rp]:='';

                    showmessage(NomFichier+': Emplacement '+TableauListeBaseDonnees.Cells[5,Rp]);
               end
               else
               begin
                    TableauListeBaseDonnees.Cells[4,Rp]:='OK';
                    TableauListeBaseDonnees.Cells[5,Rp]:='Effectué avec succčs';
                    TableauListeBaseDonnees.Cells[6,Rp]:=inttostr(NbrRegistre);

                    showmessage(NomFichier+': Emplacement '+TableauListeBaseDonnees.Cells[5,Rp]);
               end;
          end;
     Rp:=Rp+1;
     end;

     if(OKBaseDonnee=false)then
     begin
          TableauListeBaseDonnees.Cells[4,Rp]:='Non';
          TableauListeBaseDonnees.Cells[5,Rp]:='Répertoir ou nom du fichier introuvable !';
          TableauListeBaseDonnees.Cells[6,Rp]:=inttostr(NbrRegistre);

          showmessage(NomFichier+': Emplacement '+TableauListeBaseDonnees.Cells[5,Rp]);
     end;

     AjusterColWidth(TableauListeBaseDonnees,'','');
end;

Procedure ProcAnomalieBaseDonnee(TableauListeBaseDonnees:TStringGrid; RepertoireFichier,NomFichier,AnneeFichier,TypeProcesControleReseaux:string; NbrRegistre:integer);
var  Rp:integer;  OKBaseDonnee:boolean;
begin
     if(TypeProcesControleReseaux='Réseaux')
     then FSTravauxFinAnnee.MemoRapportReouverture.Lines.Add('Anomalie, Réseaux '+NomFichier)
     else FSTravauxFinAnnee.MemoRapportReouverture.Lines.Add('Anomalie, Réouverture '+NomFichier);
     Rp:=1;
     OKBaseDonnee:=false;
     while(Rp<=TableauListeBaseDonnees.RowCount-1)and(OKBaseDonnee=false)do
     begin
          if(TableauListeBaseDonnees.Cells[1,Rp]=RepertoireFichier)
          //and(TableauListeBaseDonnees.Cells[2,R]=AnneeFichier)
          and(TableauListeBaseDonnees.Cells[3,Rp]=NomFichier)
          then
          begin
               OKBaseDonnee:=true;
               if(TypeProcesControleReseaux='Réseaux')then
               begin
                    TableauListeBaseDonnees.Cells[4,Rp]:='Anomalie';
                    TableauListeBaseDonnees.Cells[5,Rp]:='Réseaux';
                    TableauListeBaseDonnees.Cells[6,Rp]:='';
               end
               else
               begin
                    TableauListeBaseDonnees.Cells[4,Rp]:='Anomalie';
                    TableauListeBaseDonnees.Cells[5,Rp]:='Non Effectué';
                    TableauListeBaseDonnees.Cells[6,Rp]:=inttostr(NbrRegistre);
               end;
          end;
     Rp:=Rp+1;
     end;

     AjusterColWidth(TableauListeBaseDonnees,'','');

end;

