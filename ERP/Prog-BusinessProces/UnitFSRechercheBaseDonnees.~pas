Function ConvertOctets(TailleOctets:integer; TypeOctets,NbrChiffreApresVergule:string):string;
var Resultat,Reste:integer;
begin
     if(TypeOctets='')then
     begin
           Division(TailleOctets,1024,Resultat,Reste);

           if(Resultat>=0)and(Resultat<100)then
           begin
                ConvertOctets:=Vergule(floattostr(TailleOctets),NbrChiffreApresVergule,'C','')+' Octets.'
           end;
           if(Resultat>=100)and(Resultat<1000)then
           begin
                ConvertOctets:=Vergule(floattostr(TailleOctets/1024),NbrChiffreApresVergule,'C','')+' KOctets.'
           end;
           if(Resultat>=1000)and(Resultat<10000)then
           begin
                ConvertOctets:=Vergule(floattostr(TailleOctets/1024/1024),NbrChiffreApresVergule,'C','')+' MOctets.'
           end;
           if(Resultat>=10000)then
           begin
                ConvertOctets:=Vergule(floattostr(TailleOctets/1024/1024/1024),NbrChiffreApresVergule,'C','')+' GOctets.'
           end;
     end
     else
     begin
          if(TypeOctets='Octets')then
          begin
               ConvertOctets:=Vergule(floattostr(TailleOctets),NbrChiffreApresVergule,'C','')+' Octets.'
          end;

          if(TypeOctets='KOctets')then
          begin
               ConvertOctets:=Vergule(floattostr(TailleOctets/1024),NbrChiffreApresVergule,'C','')+' KOctets.'
          end;

          if(TypeOctets='MOctets')then
          begin
               ConvertOctets:=Vergule(floattostr(TailleOctets/1024/1024),NbrChiffreApresVergule,'C','')+' MOctets.'
          end;

          if(TypeOctets='GOctets')then
          begin
               ConvertOctets:=Vergule(floattostr(TailleOctets/1024/1024/1024),NbrChiffreApresVergule,'C','')+' GOctets.'
          end;
     end;
end;

procedure IdentificationFichier(ListeFichier:TShellListView; Index:integer; var  AdresseFichierOut,RepertoireFichier,NomFichier,AnneeFichier:string);
var  i:integer; OKChargement:boolean;  AdresseFichier:string;
begin

AdresseFichier:='';
RepertoireFichier:='';
NomFichier:='';
AnneeFichier:='';

if(Index>=0)then
begin
     AdresseFichier:=ListeFichier.Folders[Index].DisplayName;
     AdresseFichierOut:=ListeFichier.Folders[Index].PathName;
end
else
begin
     AdresseFichier:='';       
     AdresseFichierOut:='';
end;

i:=1;
OKChargement:=false;
while(i<=longueur(AdresseFichier))and(OKChargement=false)do
begin
     if(AdresseFichier[i]='.')then
     begin
          OKChargement:=true;
          AdresseFichier:='';
     end;
i:=i+1;
end;

RepertoireFichier:='';
NomFichier:='';
i:=1;
OKChargement:=false;
while(i<=longueur(AdresseFichier))do
begin
     if(OKChargement=true)then
     begin
          NomFichier:=NomFichier+AdresseFichier[i];
     end;

     if(AdresseFichier[i]='-')then
     begin
          OKChargement:=true;
     end;

     if(OKChargement=false)then
     begin
          RepertoireFichier:=RepertoireFichier+AdresseFichier[i];
     end;

i:=i+1;
end;

if(strtointeger(Firstlaters(NomFichier,4))>0)then
begin
     AnneeFichier:=Firstlaters(NomFichier,4);
     NomFichier:=lastlaters(NomFichier,longueur(NomFichier)-4);
end
else
begin
     AnneeFichier:='';
end;
end;

