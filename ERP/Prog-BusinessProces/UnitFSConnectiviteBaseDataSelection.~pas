procedure TFSConnectiviteBaseDataSelection.SourceMouseUp(Sender: TObject;
  Button: TMouseButton; Shift: TShiftState; X, Y: Integer);
var  ExtractAnnee:string;
begin

if(FSConnectiviteBaseDataSelection.ListeFichierSource.Items.Count>0)then
begin
     FSConnectiviteBaseDataSelection.EditAdresseBaseDonnee.Text:=FSConnectiviteBaseDataSelection.Source.Path;
     FSConnectiviteBaseDataSelection.EditParcours.Text:=ExtractParcours(FSConnectiviteBaseDataSelection.ListeFichierSource.Folders[0].DisplayName,ExtractAnnee);
     FSConnectiviteBaseDataSelection.EditExerciceExtract.Text:=ExtractAnnee;

     if(FSConnectiviteBaseDataSelection.EditParcours.Text<>'')and(FSConnectiviteBaseDataSelection.EditExerciceExtract.Text<>'')then
     begin
          FSConnectiviteBaseDataSelection.AfficheBaseValide.Enabled:=true;
          FSConnectiviteBaseDataSelection.AfficheBaseValide.Color:=clLime;
     end
     else
     begin
          FSConnectiviteBaseDataSelection.AfficheBaseValide.Enabled:=false;
          FSConnectiviteBaseDataSelection.AfficheBaseValide.Color:=clRed;
     end;
end
else
begin
     FSConnectiviteBaseDataSelection.EditAdresseBaseDonnee.Text:='';
     FSConnectiviteBaseDataSelection.EditParcours.Text:='';
     FSConnectiviteBaseDataSelection.EditExerciceExtract.Text:='';

     FSConnectiviteBaseDataSelection.AfficheBaseValide.Enabled:=false;
     FSConnectiviteBaseDataSelection.AfficheBaseValide.Color:=clRed;
end;

end;

