procedure TFSConnectiviteBaseDataSelection.BitChargerClick(
  Sender: TObject);
var  i:integer; OKChargement:boolean;   Adresse:string;
begin
ChEnregistrement:=FSConnectiviteBaseDataSelection.EditFichierChargement.Text;
i:=1;
OKChargement:=false;
while(i<=longueur(ChEnregistrement))and(OKChargement=false)do
begin
     if(ChEnregistrement[i]='.')then
     begin
          OKChargement:=true;
          showmessage('Sélectionnez le fichier de données approprié SVP!');
          Exit;
     end;
i:=i+1;
end;

if FileExists(ChEnregistrement)then
begin
     assignfile(FParc,ChEnregistrement);
     reset(FParc);
     Seek(FParc,0);
     Read(FParc,RParc);

     if(FSConnectiviteBaseDataSelection.EditParcoursInstall.Text='')then FSConnectiviteBaseDataSelection.EditParcoursInstall.Text:=RParc.Parcours;
     if(FSConnectiviteBaseDataSelection.EditMotPasse.Text='')then FSConnectiviteBaseDataSelection.EditMotPasse.Text:=RParc.MotPasse;
     if(FSConnectiviteBaseDataSelection.EditDateAvancement.Text='')then FSConnectiviteBaseDataSelection.EditDateAvancement.Text:=RParc.DateAvancement;
     if(FSConnectiviteBaseDataSelection.EditDateExp.Text='')then FSConnectiviteBaseDataSelection.EditDateExp.Text:=RParc.DateExp;
     if(FSConnectiviteBaseDataSelection.EditHeureExp.Text='')then FSConnectiviteBaseDataSelection.EditHeureExp.Text:=RParc.HeureExp;

     FSConnectiviteBaseDataSelection.MemoRapport.Text:='';
     FSConnectiviteBaseDataSelection.EditText1.Text:=RParc.Text1;
     FSConnectiviteBaseDataSelection.EditText2.Text:=RParc.Text2;
     FSConnectiviteBaseDataSelection.EditText3.Text:=RParc.Text3;
     FSConnectiviteBaseDataSelection.EditText4.Text:=RParc.Text4;
     FSConnectiviteBaseDataSelection.EditText5.Text:=RParc.Text5;
     FSConnectiviteBaseDataSelection.EditText6.Text:=RParc.Text6;
     FSConnectiviteBaseDataSelection.EditText7.Text:=RParc.Text7;
     FSConnectiviteBaseDataSelection.EditText8.Text:=RParc.Text8;
     FSConnectiviteBaseDataSelection.EditText9.Text:=RParc.Text9;
     FSConnectiviteBaseDataSelection.EditText10.Text:=RParc.Text10;
     FSConnectiviteBaseDataSelection.EditNomLogo.Text:=RParc.NomLogo;
     FSConnectiviteBaseDataSelection.EditNomLabel.Text:=RParc.NomLabel;

     Adresse:=RParc.Parcours+'\'+ExtractFileName(RParc.Parcours)+RParc.NomLogo;
     if FileExists(Adresse)
     then FSConnectiviteBaseDataSelection.Logo.Picture.LoadFromFile(Adresse)
     else FSConnectiviteBaseDataSelection.Logo.Picture:=FSConnectiviteBaseDataSelection.PhotoVide.Picture;

     Adresse:=RParc.Parcours+'\'+ExtractFileName(RParc.Parcours)+RParc.NomLabel;
     if FileExists(Adresse)
     then FSConnectiviteBaseDataSelection.LabelISO.Picture.LoadFromFile(Adresse)
     else FSConnectiviteBaseDataSelection.LabelISO.Picture:=FSConnectiviteBaseDataSelection.PhotoVide.Picture;

     FSConnectiviteBaseDataSelection.AfficheChargementDonnes.Visible:=false;
end
else
begin
     showmessage('Sélectionnez le fichier de données approprié SVP!');
end;
end;

