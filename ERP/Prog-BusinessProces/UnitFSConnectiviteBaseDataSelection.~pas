procedure TFSConnectiviteBaseDataSelection.BitValiderDataInstallClick(Sender: TObject);
var  ChEnregistrement:string;
begin
     if Not FileExists('C:\WinBus.File')then
     begin
          assignfile(FRegistre,'C:\WinBus.File');
          rewrite(FRegistre);
          assignfile(FRegistre,'C:\WinBus.File');
          reset(FRegistre);
          Seek(FRegistre,0);
          RRegistre.Adresse:=FSConnectiviteBaseDataSelection.EditAdresseBaseDonnee.Text+'\'+FSConnectiviteBaseDataSelection.EditParcours.Text;
          RRegistre.Repertoire:=FSConnectiviteBaseDataSelection.EditParcours.Text;
          RRegistre.Exercice:=FSConnectiviteBaseDataSelection.EditExerciceExtract.Text;
          Write(FRegistre,RRegistre);
     end
     else
     begin
          assignfile(FRegistre,'C:\WinBus.File');
          reset(FRegistre);
          Seek(FRegistre,0);
          RRegistre.Adresse:=FSConnectiviteBaseDataSelection.EditAdresseBaseDonnee.Text+'\'+FSConnectiviteBaseDataSelection.EditParcours.Text;
          RRegistre.Repertoire:=FSConnectiviteBaseDataSelection.EditParcours.Text;
          RRegistre.Exercice:=FSConnectiviteBaseDataSelection.EditExerciceExtract.Text;
          Write(FRegistre,RRegistre);
     end;

     ChEnregistrement:=RRegistre.Adresse;

     assignfile(FParc,ChEnregistrement);
     rewrite(FParc);
     assignfile(FParc,ChEnregistrement);
     reset(FParc);
     RParc.Parcours:=FSConnectiviteBaseDataSelection.EditParcoursInstall.Text;
     RParc.MotPasse:=FSConnectiviteBaseDataSelection.EditMotPasse.Text;
     RParc.DateAvancement:=FSConnectiviteBaseDataSelection.EditDateAvancement.Text;
     RParc.DateExp:=FSConnectiviteBaseDataSelection.EditDateExp.Text;
     RParc.HeureExp:=FSConnectiviteBaseDataSelection.EditHeureExp.Text;
     RParc.NomLogo:=FSConnectiviteBaseDataSelection.EditNomLogo.Text;
     RParc.NomLabel:=FSConnectiviteBaseDataSelection.EditNomLabel.Text;
     RParc.Text1:=FSConnectiviteBaseDataSelection.EditText1.Text;
     RParc.Text2:=FSConnectiviteBaseDataSelection.EditText2.Text;
     RParc.Text3:=FSConnectiviteBaseDataSelection.EditText3.Text;
     RParc.Text4:=FSConnectiviteBaseDataSelection.EditText4.Text;
     RParc.Text5:=FSConnectiviteBaseDataSelection.EditText5.Text;
     RParc.Text6:=FSConnectiviteBaseDataSelection.EditText6.Text;
     RParc.Text7:=FSConnectiviteBaseDataSelection.EditText7.Text;
     RParc.Text8:=FSConnectiviteBaseDataSelection.EditText8.Text;
     RParc.Text9:=FSConnectiviteBaseDataSelection.EditText9.Text;
     RParc.Text10:=FSConnectiviteBaseDataSelection.EditText10.Text;

     Write(FParc,RParc);

     OpenFParc(RParc);

     {*********************************************************************}
     FSMenuPrincipal.Caption:=RRegistre.Repertoire+' - Exercice '+RRegistre.Exercice+' - Menu Principal';
     {*******************************************************************}

     FSMenuPrincipal.TimerSaisieFiches.Enabled:=true;
     FSMenuPrincipal.TimerControleSoldeDomiciliation.Enabled:=true;

     FSConnectiviteBaseDataSelection.AfficheDataInstall.Visible:=false;
     FSConnectiviteBaseDataSelection.Close;     
end;

