var ARow:integer;  i,R:integer;
begin//D0
ARow:=FSGenerateurEtats.TableauRubriqueEtat.Row;
if(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow]<>'')
and(FSGenerateurEtats.TableauRubriqueEtat.Cells[3,ARow]='')
then
begin
FSGenerateurEtats.TableauFormule.Visible:=true;

OpenFParc(RParc);
ChFormule:=RParc.Parcours+'\'+Exercice+FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text;
assignfile(FFormule,ChFormule);
if FileExists(ChFormule)then
Reset(FFormule)
else begin Rewrite(FFormule); exit end;
seek(FFormule,0);
k:=0;
while not eof(FFormule)do
begin//D1
    OK:=true;
    Read(FFormule,RFormule);
    if(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow]<>'')then
    for i:=1 to Longueur(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow])do
    begin//D2
        if(RFormule.CodeFormule[i]<>FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow][i])then OK:=false;
    end;//F2

    if(OK=true)then
    begin//D3
         k:=k+1;
         FSGenerateurEtats.TableauFormule.Cells[0,k]:=inttostr(RFormule.PositionFormule);
         FSGenerateurEtats.TableauFormule.Cells[1,k]:=RFormule.CodeFormule;
         FSGenerateurEtats.TableauFormule.Cells[2,k]:=RFormule.Libelle;
    end;//F3
end;//F1

if(k>=1)then FSGenerateurEtats.TableauFormule.RowCount:=k+1
        else
        begin//D4
             FSGenerateurEtats.TableauFormule.RowCount:=2;
             FSGenerateurEtats.TableauFormule.Rows[1].Text:='';
        end;//F4

if(((k+1)*21)<280)
    then FSGenerateurEtats.TableauFormule.Height:=(k+1)*21
    else FSGenerateurEtats.TableauFormule.Height:=280;

if(k=0)
then
begin
     FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow]:='';
     FSGenerateurEtats.TableauFormule.Visible:=false;
end;

if(k=1)then
begin//D5
OK:=true;
for R:=1 to ARow-1 do
          begin
               if(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,R]=FSGenerateurEtats.TableauFormule.Cells[1,1])
               then
               begin
                   OK:=false;
                   FSGenerateurEtats.TableauRubriqueEtat.Rows[ARow].Text:='';
                   FSGenerateurEtats.TableauFormule.Visible:=false;
               end;
          end;
if(OK=true)then
begin
if(FSGenerateurEtats.TableauRubriqueEtat.Cells[0,ARow]='')
then FSGenerateurEtats.TableauRubriqueEtat.Rows[ARow].Text:='';
FSGenerateurEtats.TableauRubriqueEtat.Cells[1,ARow]:=FSGenerateurEtats.TableauFormule.Cells[0,1];
