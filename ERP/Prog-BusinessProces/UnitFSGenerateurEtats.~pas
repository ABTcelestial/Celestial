procedure TFSGenerateurEtats.BitBtn8Click(Sender: TObject);
var i,R:Integer;    OKTypeFormules,Confirme:boolean;
begin

R:=1;
while(R<=FSGenerateurEtats.TableauAutoImporteFormules.RowCount-1)do
begin
     if(FSGenerateurEtats.TableauAutoImporteFormules.Cells[0,R]='OK')then
     begin
          OpenFParc(RParc);
          ChAutoImporteFormuleEtat:=RParc.Parcours+'\'+Exercice+'FAutoImporteFormuleEtat';
          assignfile(FAutoImporteFormuleEtat,ChAutoImporteFormuleEtat);
          if FileExists(ChAutoImporteFormuleEtat)then
          Reset(FAutoImporteFormuleEtat)
          else Rewrite(FAutoImporteFormuleEtat);
          seek(FAutoImporteFormuleEtat,0);
          OKTypeFormules:=false;
          i:=0;
          while not eof(FAutoImporteFormuleEtat)do
          begin
               Read(FAutoImporteFormuleEtat,RAutoImporteFormuleEtat);
               i:=i+1;
               if(RAutoImporteFormuleEtat.PositionEtat=strtointeger(FSGenerateurEtats.TableauListeEtats.Cells[1,FSGenerateurEtats.TableauListeEtats.Row]))
               and(RAutoImporteFormuleEtat.TypeFormule=FSGenerateurEtats.TableauAutoImporteFormules.Cells[1,R])
               then
               begin
                    OKTypeFormules:=true;
               end;
          end;

          if(OKTypeFormules=false)then
          begin
               seek(FAutoImporteFormuleEtat,i);
               RAutoImporteFormuleEtat.PositionEtat:=strtointeger(FSGenerateurEtats.TableauListeEtats.Cells[1,FSGenerateurEtats.TableauListeEtats.Row]);
               RAutoImporteFormuleEtat.TypeFormule:=FSGenerateurEtats.TableauAutoImporteFormules.Cells[1,R];
               write(FAutoImporteFormuleEtat,RAutoImporteFormuleEtat);
          end;
          Closefile(FAutoImporteFormuleEtat);
     end
     else
     begin
          DeleteFAutoImporteFormuleEtat(strtointeger(FSGenerateurEtats.TableauListeEtats.Cells[1,FSGenerateurEtats.TableauListeEtats.Row]),FSGenerateurEtats.TableauAutoImporteFormules.Cells[1,R],Confirme);
     end;
R:=R+1;
end;

ListeAutoImporteFormuleEtat(FSGenerateurEtats.TableauAutoImporteFormules,FSGenerateurEtats.TableauListeEtats.Cells[1,FSGenerateurEtats.TableauListeEtats.Row]);
end;

