Procedure ListeAutoImporteFormuleEtat(TableauTypeFormules:TStringGrid; PositionEtat:string);
var  R,ARow:integer;  OKTypeFormule:boolean;
begin
     if(PositionEtat='')then Exit;

     ImporteTypeFormules(TableauTypeFormules);

     OpenFParc(RParc);
     ChAutoImporteFormuleEtat:=RParc.Parcours+'\'+Exercice+'FAutoImporteFormuleEtat';
     assignfile(FAutoImporteFormuleEtat,ChAutoImporteFormuleEtat);
     if FileExists(ChAutoImporteFormuleEtat)then
     Reset(FAutoImporteFormuleEtat)
     else Rewrite(FAutoImporteFormuleEtat);
     seek(FAutoImporteFormuleEtat,0);
     ARow:=TableauTypeFormules.RowCount-1;
     while not eof(FAutoImporteFormuleEtat)do
     begin
          Read(FAutoImporteFormuleEtat,RAutoImporteFormuleEtat);
          if(RAutoImporteFormuleEtat.PositionEtat=strtointeger(PositionEtat))then
          begin
               R:=1;
               OKTypeFormule:=false;
               while(R<=ARow)and(OKTypeFormule=false)do
               begin
                    if(RAutoImporteFormuleEtat.TypeFormule=TableauTypeFormules.Cells[1,R])then
                    begin
                         OKTypeFormule:=true;
                         TableauTypeFormules.Cells[0,R]:='OK';
                    end;
               R:=R+1;
               end;

               if(OKTypeFormule=false)then
               begin
                    ARow:=ARow+1;
                    TableauTypeFormules.Cells[0,ARow]:='OK';
                    TableauTypeFormules.Cells[1,ARow]:=RFormule.TypeAffichage;
                    if(RFormule.TypeAffichage='C')then TableauTypeFormules.Cells[2,ARow]:='Calculé';
                    if(RFormule.TypeAffichage='P')then TableauTypeFormules.Cells[2,ARow]:='Prime';
                    if(RFormule.TypeAffichage='V')then TableauTypeFormules.Cells[2,ARow]:='Variable';
                    if(RFormule.TypeAffichage='A')then TableauTypeFormules.Cells[2,ARow]:='Pointage';
                    if(RFormule.TypeAffichage='S')then TableauTypeFormules.Cells[2,ARow]:='Systčme';                    
               end;
          end;
     end;
     CloseFile(FAutoImporteFormuleEtat);

     TableauTypeFormules.RowCount:=ARow+1;
end;

Procedure ImporteTypeFormules(TableauTypeFormules:TStringGrid);
var   R,ARow:integer;  OKTypeFormule:boolean;
begin
     TableauTypeFormules.RowCount:=2;
     TableauTypeFormules.Rows[1].Text:='';

     TableauTypeFormules.Cols[0].Text:='Sélection !';
     TableauTypeFormules.Cols[1].Text:='Type';
     TableauTypeFormules.Cols[2].Text:='Désignation';
     
     OpenFParc(RParc);
     ChFormule:=RParc.Parcours+'\'+Exercice+FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text;  
     assignfile(FFormule,ChFormule);
     if FileExists(ChFormule)then
     Reset(FFormule)
     else Rewrite(FFormule);
     seek(FFormule,0);
     ARow:=0;
     while not eof(FFormule)do
     begin
         Read(FFormule,RFormule);
         OKTypeFormule:=false;
         R:=1;
         while(R<=ARow)and(OKTypeFormule=false)do
         begin
              if RFormule.TypeAffichage=TableauTypeFormules.Cells[1,R]then OKTypeFormule:=true;
         R:=R+1;
         end;

         if(OKTypeFormule=false)then
         begin
              ARow:=ARow+1;
              TableauTypeFormules.Rows[ARow].Text:='';
              TableauTypeFormules.Cells[0,ARow]:='';
              TableauTypeFormules.Cells[1,ARow]:=RFormule.TypeAffichage;
              if(RFormule.TypeAffichage='C')then TableauTypeFormules.Cells[2,ARow]:='Calculé';
              if(RFormule.TypeAffichage='P')then TableauTypeFormules.Cells[2,ARow]:='Prime';
              if(RFormule.TypeAffichage='V')then TableauTypeFormules.Cells[2,ARow]:='Variable';
              if(RFormule.TypeAffichage='A')then TableauTypeFormules.Cells[2,ARow]:='Pointage';
              if(RFormule.TypeAffichage='S')then TableauTypeFormules.Cells[2,ARow]:='Systčme';              
         end;
     end;
     CloseFile(FFormule);

     if(ARow>0)then TableauTypeFormules.RowCount:=ARow+1
               else TableauTypeFormules.RowCount:=2;
end;

Procedure SelectionEtat(Etat:string);
begin
     if(Etat='Etat')then
     begin
          FSGenerateurEtats.BitNouvelEtat.Visible:=true;
          FSGenerateurEtats.BitModifierEtat.Visible:=true;
          FSGenerateurEtats.BitSupprimerEtat.Visible:=true;

          FSGenerateurEtats.BitValiderRubriqueEtat.Visible:=false;
          FSGenerateurEtats.BitSupprimerRubriqueEtat.Visible:=false;
     end;

     if(Etat='Rubrique Etat')then
     begin
          FSGenerateurEtats.BitNouvelEtat.Visible:=false;
          FSGenerateurEtats.BitModifierEtat.Visible:=false;
          FSGenerateurEtats.BitSupprimerEtat.Visible:=false;

          FSGenerateurEtats.BitValiderRubriqueEtat.Visible:=true;
          FSGenerateurEtats.BitSupprimerRubriqueEtat.Visible:=true;
     end;

FSGenerateurEtats.AfficheOperationsAutoImporteFormules.Height:=41;
end;

Procedure ProcAfficheEtat;
var    R:integer;
begin
FSGenerateurEtats.TableauListeEtats.Cols[0].Text:='N°.';
