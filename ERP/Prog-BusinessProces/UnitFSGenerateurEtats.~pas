OpenFParc(RParc);
ChEtat:=RParc.Parcours+'\'+Exercice+'FEtat'+FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text;
assignfile(FEtat,ChEtat);
if FileExists(ChEtat)then
Reset(FEtat)
else begin Rewrite(FEtat);end;
seek(FEtat,0);
R:=0;
while not eof(FEtat)do
begin
    Read(FEtat,REtat);
    R:=R+1;
    FSGenerateurEtats.TableauListeEtats.Rows[R].Text:='';
    FSGenerateurEtats.TableauListeEtats.Cells[0,R]:=inttostr(R);
    FSGenerateurEtats.TableauListeEtats.Cells[1,R]:=inttostr(REtat.PositionEtat);
    FSGenerateurEtats.TableauListeEtats.Cells[2,R]:=REtat.CodeEtat;
    FSGenerateurEtats.TableauListeEtats.Cells[3,R]:=REtat.NomEtat;
    FSGenerateurEtats.TableauListeEtats.Cells[4,R]:=REtat.DateEtatDebut;
    FSGenerateurEtats.TableauListeEtats.Cells[5,R]:=REtat.DateEtatFin;
    FSGenerateurEtats.TableauListeEtats.Cells[6,R]:=REtat.OrganismeConcerne;
    FSGenerateurEtats.TableauListeEtats.Cells[7,R]:=REtat.CodeOrganisme;
    FSGenerateurEtats.TableauListeEtats.Cells[8,R]:=REtat.Imprime;
end;
if(R>0)then FSGenerateurEtats.TableauListeEtats.RowCount:=R+1
       else FSGenerateurEtats.TableauListeEtats.RowCount:=2;
end;

procedure TFSGenerateurEtats.TableauRubriqueEtatKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  ARow,ACol,NbrRub,R:integer;  OK,OKUnite:boolean;
begin//D0
ARow:=FSGenerateurEtats.TableauRubriqueEtat.Row;
ACol:=FSGenerateurEtats.TableauRubriqueEtat.Col;
if(ACol>1)then FSGenerateurEtats.TableauRubriqueEtat.Col:=2;

if(key=VK_INSERT)then
begin
FSGenerateurEtats.TableauFormule.Visible:=true;

OpenFParc(RParc);
ChFormule:=RParc.Parcours+'\'+Exercice+FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text;
assignfile(FFormule,ChFormule);
if FileExists(ChFormule)then
Reset(FFormule)
else begin Rewrite(FFormule); exit end;
seek(FFormule,0);
k:=0;
while not eof(FFormule)do
begin//D1
    Read(FFormule,RFormule);
    k:=k+1;
    FSGenerateurEtats.TableauFormule.Cells[1,k]:=inttostr(RFormule.PositionFormule);
    FSGenerateurEtats.TableauFormule.Cells[2,k]:=RFormule.CodeFormule;
    FSGenerateurEtats.TableauFormule.Cells[3,k]:=RFormule.Libelle;
end;//F1

if(k>=1)then FSGenerateurEtats.TableauFormule.RowCount:=k+1
        else
        begin//D4
             FSGenerateurEtats.TableauFormule.RowCount:=2;
             FSGenerateurEtats.TableauFormule.Rows[1].Text:='';
        end;//F4

if(((k+1)*21)<280)
    then FSGenerateurEtats.TableauFormule.Height:=(k+1)*21
    else FSGenerateurEtats.TableauFormule.Height:=280;
FSGenerateurEtats.TableauFormule.SetFocus;
end;

if(key=VK_DOWN)
and((FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow]='')
or(ARow=FSGenerateurEtats.TableauRubriqueEtat.RowCount-1))
then key:=VK_RETURN;

if key in[VK_RETURN] then
begin//D1
OK:=true;
     for R:=1 to ARow-1 do
          begin
               if(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,R]=FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow])
               then
               begin
                   OK:=false;
                   FSGenerateurEtats.TableauRubriqueEtat.Rows[ARow].Text:='';
               end;
          end;

     if(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,FSGenerateurEtats.TableauRubriqueEtat.Row]<>'')then
     begin
     OK:=false;
          if(FSGenerateurEtats.TableauFormule.Visible=true)
          and(FSGenerateurEtats.TableauFormule.Cells[2,FSGenerateurEtats.TableauFormule.Row]<>'')
          then
          begin
               FSGenerateurEtats.TableauFormule.SetFocus;
          end
          else
          begin
               if(FSGenerateurEtats.TableauRubriqueEtat.Row=FSGenerateurEtats.TableauRubriqueEtat.RowCount-1)
               then
               begin
                    FSGenerateurEtats.TableauRubriqueEtat.RowCount:=
                    FSGenerateurEtats.TableauRubriqueEtat.RowCount+1;
                    FSGenerateurEtats.TableauRubriqueEtat.Row:=
                    FSGenerateurEtats.TableauRubriqueEtat.Row+1;
                    FSGenerateurEtats.TableauRubriqueEtat.Rows[FSGenerateurEtats.TableauRubriqueEtat.Row].Text:='';
                    FSGenerateurEtats.TableauRubriqueEtat.Col:=2;
               end
               else
               begin
                    FSGenerateurEtats.TableauRubriqueEtat.Row:=
                    FSGenerateurEtats.TableauRubriqueEtat.Row+1;
                    FSGenerateurEtats.TableauRubriqueEtat.Col:=2;
               end;
          end;
     end;

     if(OK=true)
     and(FSGenerateurEtats.TableauRubriqueEtat.RowCount>2)
     and(FSGenerateurEtats.TableauRubriqueEtat.Row=FSGenerateurEtats.TableauRubriqueEtat.RowCount-1)
     //and(FSGenerateurEtats.TableauRubriqueEtat.Cells[0,ARow-1]<>'')
     then
     begin//D5

     FSGenerateurEtats.TableauFormule.Visible:=false;
     FSGenerateurEtats.TableauRubriqueEtat.RowCount:=
     FSGenerateurEtats.TableauRubriqueEtat.RowCount-1;

     end;//F5

end;//F1

if(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow]='')
and(key=VK_UP)
then key:=VK_DELETE;

if key in[VK_DELETE] then
begin
     ARow:=FSGenerateurEtats.TableauRubriqueEtat.RowCount-1;
     if(FSGenerateurEtats.TableauRubriqueEtat.RowCount>2)
     and(FSGenerateurEtats.TableauRubriqueEtat.Cells[2,ARow]='')
     then
     begin
     FSGenerateurEtats.TableauRubriqueEtat.RowCount:=
     FSGenerateurEtats.TableauRubriqueEtat.RowCount-1;
     FSGenerateurEtats.TableauRubriqueEtat.Col:=2;
     end;
end;

end;

