procedure TFSGenerateurEtats.BitOuiOptionListeEtatsClick(Sender: TObject);
var  R,PositionEtat:integer; OKEtat,Confirme:boolean;
begin

if(FSGenerateurEtats.EditOptionListeEtats.Text='Modifier')then
begin
     for R:=1 to FSGenerateurEtats.TableauListeEtats.RowCount-1 do
     begin
          OpenFParc(RParc);
          ChEtat:=RParc.Parcours+'\'+Exercice+'FEtat'+FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text;
          assignfile(FEtat,ChEtat);
          if FileExists(ChEtat)then
          Reset(FEtat)
          else Rewrite(FEtat);
          seek(FEtat,0);
          i:=0;
          OKEtat:=false;
          while not eof(FEtat)and(OKEtat=false)do
          begin
               Read(FEtat,REtat);
               if(REtat.PositionEtat=strtointeger(FSGenerateurEtats.TableauListeEtats.Cells[1,R]))then
               begin
                    OKEtat:=true;
                    Seek(FEtat,i);
                    REtat.PositionEtat:=strtointeger(FSGenerateurEtats.TableauListeEtats.Cells[1,R]);
                    REtat.CodeEtat:=FSGenerateurEtats.TableauListeEtats.Cells[2,R];
                    REtat.NomEtat:=FSGenerateurEtats.TableauListeEtats.Cells[3,R];
                    REtat.DateEtatDebut:=FSGenerateurEtats.TableauListeEtats.Cells[4,R];
                    REtat.DateEtatFin:=FSGenerateurEtats.TableauListeEtats.Cells[5,R];
                    REtat.OrganismeConcerne:=FSGenerateurEtats.TableauListeEtats.Cells[6,R];
                    REtat.CodeOrganisme:=FSGenerateurEtats.TableauListeEtats.Cells[7,R];
                    REtat.Imprime:=FSGenerateurEtats.TableauListeEtats.Cells[8,R];

                    write(FEtat,REtat);
               end;
               i:=i+1;
          end;
          CloseFile(FEtat);
     end;
end;

if(FSGenerateurEtats.EditOptionListeEtats.Text='Supprimer')then
begin
     PositionEtat:=strtointeger(FSGenerateurEtats.TableauListeEtats.Cells[1,FSGenerateurEtats.TableauListeEtats.Row]);
     DeleteFEtat(PositionEtat,FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text,Confirme);
end;

if(FSGenerateurEtats.EditOptionListeEtats.Text='Nouveau')then
begin
FSGenerateurEtats.BitNouvelEtat.Caption:='Nouvel';
OpenFParc(RParc);
ChEtat:=RParc.Parcours+'\'+Exercice+'FEtat'+FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text;
assignfile(FEtat,ChEtat);
if FileExists(ChEtat)then
Reset(FEtat)
else Rewrite(FEtat);
seek(FEtat,0);
i:=0;
while not eof(FEtat)do
begin
    Read(FEtat,REtat);
    i:=i+1;
end;
Seek(FEtat,i);
REtat.PositionEtat:=i-1;
REtat.CodeEtat:=FSGenerateurEtats.TableauListeEtats.Cells[2,1];
REtat.NomEtat:=FSGenerateurEtats.TableauListeEtats.Cells[3,1];
REtat.DateEtatDebut:=FSGenerateurEtats.TableauListeEtats.Cells[4,1];
REtat.DateEtatFin:=FSGenerateurEtats.TableauListeEtats.Cells[5,1];
REtat.OrganismeConcerne:=FSGenerateurEtats.TableauListeEtats.Cells[6,1];
REtat.CodeOrganisme:=FSGenerateurEtats.TableauListeEtats.Cells[7,1];
REtat.Imprime:=FSGenerateurEtats.TableauListeEtats.Cells[8,1];

write(FEtat,REtat);
CloseFile(FEtat);
end;

ProcAfficheEtat;
FSGenerateurEtats.EditOptionListeEtats.Text:='';
FSGenerateurEtats.AfficheOptionListeEtats.Visible:=false;
end;

