procedure TFSGenerateurEtats.BitValiderModificationFormuleClick(Sender: TObject);
var  OKFormule:boolean;
begin

if(FSGenerateurEtats.EditPositionFormule.Text<>'')then
begin
   OpenFParc(RParc);
ChFormule:=RParc.Parcours+'\'+Exercice+FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text;
assignfile(FFormule,ChFormule);
if FileExists(ChFormule)then
Reset(FFormule)
else Rewrite(FFormule);
seek(FFormule,0);
i:=0;
OKFormule:=false;
while not eof(FFormule)and(OKFormule=false)do
begin
     Read(FFormule,RFormule);
     if(RFormule.PositionFormule=strtointeger(FSGenerateurEtats.EditPositionFormule.Text))then
     begin
          OKFormule:=true;
          RFormule.PositionFormule:=strtointeger(FSGenerateurEtats.EditPositionFormule.Text);
          RFormule.CodeFormule:=FSGenerateurEtats.EditCodeFormule.Text;
          RFormule.Libelle:=FSGenerateurEtats.EditLibelleFormule.Text;
          RFormule.FormuleTexte:=FSGenerateurEtats.EditFormule.Text;
          RFormule.Condition:=FSGenerateurEtats.EditConditionFormule.Text;
          RFormule.Accumuler:=FSGenerateurEtats.EditCummuleFormule.Text;
          RFormule.TypeAffichage:=FSGenerateurEtats.EditTypeFormule.Text;
          RFormule.Sens:=FSGenerateurEtats.EditSensFormule.Text;
          RFormule.Base:=FSGenerateurEtats.EditBaseFormule.Text;
          RFormule.Taux:=FSGenerateurEtats.EditTauxFormule.Text;
          RFormule.Debit:=FSGenerateurEtats.EditDebitFormule.Text;
          RFormule.Credit:=FSGenerateurEtats.EditCreditFormule.Text;
          RFormule.Active:=strtobool(FSGenerateurEtats.EditEtatFormule.Text);
          seek(FFormule,i);
          write(FFormule,RFormule);
     end;
     i:=i+1;
end;
CloseFile(FFormule);

FSGenerateurEtats.EditDebitFormule.Color:=clWindow;
FSGenerateurEtats.EditCreditFormule.Color:=clWindow;

ProcAfficheRubriqueEtat(FSGenerateurEtats.TableauRubriqueEtat,strtointeger(FSGenerateurEtats.TableauListeEtats.Cells[1,FSGenerateurEtats.TableauListeEtats.Row]),FSGenerateurEtats.EditCodeTypeFormuleAfficher.Text);
