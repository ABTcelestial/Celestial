begin
     FSAgenceBanque.EditTrier.Text:='';
     TypeData:='';
     TypeTrie:=FSAgenceBanque.EditTypeTrie.Text;
     TrierTableauARowSpecial(FSAgenceBanque.TableauAgence,1,FSAgenceBanque.TableauAgence.RowCount-1,1,inttostr(FSAgenceBanque.TableauAgence.Col),TypeData,TypeTrie);
end;

