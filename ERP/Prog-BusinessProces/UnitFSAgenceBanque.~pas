               if firstlaters(RBanqueGlobal.CodeBanque,longueur(CodeBanque))=CodeBanque
               then OKBanque:=true
               else OKBanque:=false;
          end
          else OKBanque:=true;

          if(OKBanque=true)then
          begin
               R:=R+1;
               TableauBanque.Rows[R].Text:=inttostr(R);
               TableauBanque.Cells[1,R]:=inttostr(RBanqueGlobal.PositionBanque);
               TableauBanque.Cells[2,R]:=RBanqueGlobal.CodeBanque;
               TableauBanque.Cells[3,R]:=RBanqueGlobal.LibelleBanque;
               TableauBanque.Cells[4,R]:=RBanqueGlobal.AdresseBanque;
               TableauBanque.Cells[5,R]:=RBanqueGlobal.TelephoneBanque;
               TableauBanque.Cells[6,R]:=RBanqueGlobal.AdresseLogoBanque;
               TableauBanque.Cells[7,R]:=RBanqueGlobal.AdresseLogoBanqueLong;

               if(RBanqueGlobal.CodeBanque=CodeBanqueSelect)then RowSelect:=inttostr(R);
          end;
     end;
     CloseFile(FBanqueGlobal);

     if(R>0)then TableauBanque.RowCount:=R+1
            else TableauBanque.RowCount:=2;

     AjusterColWidth(TableauBanque,'','');

     if(strtointeger(RowSelect)>0)then TableauBanque.Row:=strtointeger(RowSelect);
     ProcAffichePhoto(TableauBanque.Cells[2,TableauBanque.Row],TableauBanque.Cells[6,TableauBanque.Row],'LogoBanque',AdresseLogoBanque);
     ProcAffichePhoto(TableauBanque.Cells[2,TableauBanque.Row],TableauBanque.Cells[7,TableauBanque.Row],'LogoBanqueLong',AdresseLogoBanque);
end;

procedure TFSAgenceBanque.BitOperationAgenceClick(Sender: TObject);
var RExistant,RSupprimer,RSauvgarder:integer;  OKRemise:boolean; CodeAgenceSelect,TypeProces,FichierConcerne,Adresse:string;
begin
     if(FSAgenceBanque.BitOperationAgence.Caption='Valider')then
     begin
          TypeProces:='Paie';
          FichierConcerne:='FAgence';
          Adresse:='';
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
          end;

          ChAgence:=Adresse;
          assignfile(FAgence,ChAgence);
          if FileExists(ChAgence)
          then Reset(FAgence)
          else Rewrite(FAgence);
          RAgence.PositionAgence:=strtointeger(FSAgenceBanque.EditPositionAgence.Text);
          RAgence.CodeBanque:=FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row];
          RAgence.CodeAgence:=FSAgenceBanque.EditCodeAgence.Text;
          RAgence.LibelleAgence:=FSAgenceBanque.EditLibelleAgence.Text;
          RAgence.AdresseAgence:=FSAgenceBanque.EditAdresseAgence.Text;
          RAgence.TelephoneAgence:=FSAgenceBanque.EditTelephoneAgence.Text;
          Seek(FAgence,RAgence.PositionAgence);
          write(FAgence,RAgence);

     CloseFile(FAgence);
     CodeAgenceSelect:=FSAgenceBanque.EditCodeAgence.Text;
     end;

     if(FSAgenceBanque.BitOperationAgence.Caption='Supprimer')then
     begin
          CodeAgenceSelect:='';
          if SupprimerFAgence(FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row],FSAgenceBanque.EditCodeAgence.Text,RExistant,RSupprimer,RSauvgarder)then
          begin
               if(RSupprimer>0)
               then AfficherMessage('Suppression réussie ! FTotal: '+inttostr(RExistant)+', FSupprimer: '+inttostr(RSupprimer)+', FSauvgarder: '+inttostr(RSauvgarder))
               else AfficherMessage('Aucun Registre Supprimer ! FTotal: '+inttostr(RExistant)+', FSupprimer: '+inttostr(RSupprimer)+', FSauvgarder: '+inttostr(RSauvgarder));
          end;
     end;

ListeAgence(FSAgenceBanque.TableauAgence,FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row],CodeAgenceSelect);

FSAgenceBanque.AfficheAgence.Visible:=false;

FSAgenceBanque.TableauAgence.SetFocus;
end;

