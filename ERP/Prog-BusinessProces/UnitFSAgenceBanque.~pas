begin
     FSAgenceBanque.OuvrirPhotos.Execute;

     if FileExists(FSAgenceBanque.OuvrirPhotos.FileName)then
     begin
          FSAgenceBanque.NouvellePhoto.Picture.LoadFromFile(FSAgenceBanque.OuvrirPhotos.FileName);
          FSAgenceBanque.EditFichiersource.Text:=FSAgenceBanque.OuvrirPhotos.FileName;
          NewFilNameLogoBanque:=FSAgenceBanque.EditLogoBanque.Text+' ('+FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row]+').'+ExtentionFichier(FSAgenceBanque.EditFichiersource.Text);
          FichierConcerne:=NewFilNameLogoBanque;
          Adresse:='';
          TypeProces:='Paie';
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
          end;
          FSAgenceBanque.EditAdresseLogoBanqueCree.Text:=Adresse;
     end
     else
     begin
          FSAgenceBanque.NouvellePhoto.Picture:=FSMenuPrincipal.PhotoVide.Picture;
          FSAgenceBanque.EditFichiersource.Text:='';
          FSAgenceBanque.EditAdresseLogoBanqueCree.Text:='';
     end;
end;

procedure TFSAgenceBanque.BitValiderPhotoClick(Sender: TObject);
var TypeProces,FichierConcerne,Adresse,AdresseLogoBanque,CodeBanqueSelect:string;
begin
     AdresseLogoBanque:=FSAgenceBanque.EditAdresseLogoBanqueCree.Text;

     if(FSAgenceBanque.BitValiderPhoto.Caption='Modifier')then
     begin
          FSAgenceBanque.NouvellePhoto.Picture.SaveToFile(AdresseLogoBanque);
     end;

     if(FSAgenceBanque.BitValiderPhoto.Caption='Valider')then
     begin
          if not FileExists(AdresseLogoBanque)then
          begin
               FSAgenceBanque.NouvellePhoto.Picture.SaveToFile(AdresseLogoBanque);
          end
          else
          begin
               showmessage('Un logo est enregistré pour la banque sélectionner');
          end;
     end;

     if(FSAgenceBanque.BitValiderPhoto.Caption='Supprimer')then
     begin
          if FileExists(AdresseLogoBanque)then
          begin
               deleteFile(AdresseLogoBanque);
          end;

          FSAgenceBanque.EditAdresseLogoBanqueCree.Text:='';
          AdresseLogoBanque:=FSAgenceBanque.EditAdresseLogoBanqueCree.Text;
     end;

     TypeProces:='Business';
     FichierConcerne:='FBanqueGlobal';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChBanqueGlobal:=Adresse;
     assignfile(FBanqueGlobal,ChBanqueGlobal);
     if FileExists(ChBanqueGlobal)
     then Reset(FBanqueGlobal)
     else Rewrite(FBanqueGlobal);
     Seek(FBanqueGlobal,strtointeger(FSAgenceBanque.TableauBanque.Cells[1,FSAgenceBanque.TableauBanque.Row]));
     read(FBanqueGlobal,RBanqueGlobal);
     RBanqueGlobal.PositionBanque:=strtointeger(FSAgenceBanque.TableauBanque.Cells[1,FSAgenceBanque.TableauBanque.Row]);
     RBanqueGlobal.CodeBanque:=FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row];
     RBanqueGlobal.LibelleBanque:=FSAgenceBanque.TableauBanque.Cells[3,FSAgenceBanque.TableauBanque.Row];
     RBanqueGlobal.AdresseBanque:=FSAgenceBanque.TableauBanque.Cells[4,FSAgenceBanque.TableauBanque.Row];
     RBanqueGlobal.TelephoneBanque:=FSAgenceBanque.TableauBanque.Cells[5,FSAgenceBanque.TableauBanque.Row];
     if(FSAgenceBanque.EditLogoBanque.Text='LogoBanque')then RBanqueGlobal.AdresseLogoBanque:=AdresseLogoBanque;
     if(FSAgenceBanque.EditLogoBanque.Text='LogoBanqueLong')then RBanqueGlobal.AdresseLogoBanqueLong:=AdresseLogoBanque;

     Seek(FBanqueGlobal,RBanqueGlobal.PositionBanque);
     write(FBanqueGlobal,RBanqueGlobal);

     CloseFile(FBanqueGlobal);
     CodeBanqueSelect:=FSAgenceBanque.EditCodeBanque.Text;

     ListeBanque(FSAgenceBanque.TableauBanque,'',CodeBanqueSelect);
     ListeAgence(FSAgenceBanque.TableauAgence,FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row],'');

ProcAffichePhoto(FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row],FSAgenceBanque.TableauBanque.Cells[6,FSAgenceBanque.TableauBanque.Row],'LogoBanque',AdresseLogoBanque);
ProcAffichePhoto(FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row],FSAgenceBanque.TableauBanque.Cells[7,FSAgenceBanque.TableauBanque.Row],'LogoBanqueLong',AdresseLogoBanque);
FSAgenceBanque.AfficheNewPhoto.Visible:=false;
end;

