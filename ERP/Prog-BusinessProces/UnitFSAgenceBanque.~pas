procedure TFSAgenceBanque.BitBtn5Click(Sender: TObject);
var i,CodeBanque:integer;   TypeProces,FichierConcerne,Adresse:string;
begin
     TypeProces:='Paie';
     FichierConcerne:='FBanqueGlobal';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChBanqueGlobal:=Adresse;
     assignfile(FBanqueGlobal,ChBanqueGlobal);
     if FileExists(ChBanqueGlobal)
     then Reset(FBanqueGlobal)
     else Rewrite(FBanqueGlobal);
     Seek(FBanqueGlobal,0);
     i:=0;
     CodeBanque:=1;
     while not eof(FBanqueGlobal)do
     begin
          read(FBanqueGlobal,RBanqueGlobal);
          if(CodeBanque<=strtointeger(RBanqueGlobal.CodeBanque))then CodeBanque:=strtointeger(RBanqueGlobal.CodeBanque)+1;
          i:=i+1;
     end;
     CloseFile(FBanqueGlobal);

     FSAgenceBanque.AfficheBanque.Visible:=true;
     FSAgenceBanque.BitOperationBanque.Kind:=bkAll;
     FSAgenceBanque.BitOperationBanque.Caption:='Valider';
     FSAgenceBanque.EditPositionBanque.Text:=inttostr(i);
     FSAgenceBanque.EditCodeBanque.Text:=Completezerogauche(inttostr(CodeBanque),'3');
     FSAgenceBanque.EditLibelleBanque.Text:='';
     FSAgenceBanque.EditAdresseBanque.Text:='';
