procedure TFSAgenceBanque.BitOperationBanqueClick(Sender: TObject);
var RExistant,RSupprimer,RSauvgarder:integer;  OKRemise:boolean; CodeBanqueSelect,TypeProces,FichierConcerne,Adresse:string;
begin
     if(FSAgenceBanque.BitOperationBanque.Caption='Valider')then
     begin
          TypeProces:='Paie';
          FichierConcerne:='FBanqueGlobal';
          Adresse:='';
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
          end;

          ChBanqueGlobal:=Adresse;
          assignfile(FBanqueGlobal,ChBanqueGlobal);
          if FileExists(ChBanqueGlobal)
          then Reset(FBanqueGlobal)
          else Rewrite(FBanqueGlobal);
          RBanqueGlobal.PositionBanque:=strtointeger(FSAgenceBanque.EditPositionBanque.Text);
          RBanqueGlobal.CodeBanque:=FSAgenceBanque.EditCodeBanque.Text;
          RBanqueGlobal.LibelleBanque:=FSAgenceBanque.EditLibelleBanque.Text;
          RBanqueGlobal.AdresseBanque:=FSAgenceBanque.EditAdresseBanque.Text;
          RBanqueGlobal.TelephoneBanque:=FSAgenceBanque.EditTelephoneBanque.Text;
          RBanqueGlobal.AdresseLogoBanque:=FSAgenceBanque.EditAdresseLogoBanque.Text;
          RBanqueGlobal.AdresseLogoBanqueLong:=FSAgenceBanque.EditAdresseLogoBanqueLong.Text;
          Seek(FBanqueGlobal,RBanqueGlobal.PositionBanque);
          write(FBanqueGlobal,RBanqueGlobal);

     CloseFile(FBanqueGlobal);
     CodeBanqueSelect:=FSAgenceBanque.EditCodeBanque.Text;
     end;

     if(FSAgenceBanque.BitOperationBanque.Caption='Supprimer')then
     begin
          CodeBanqueSelect:='';
          if SupprimerFAgence(FSAgenceBanque.EditCodeBanque.Text,'',RExistant,RSupprimer,RSauvgarder)then
          begin
               if(RSupprimer>0)
               then AfficherMessage('Suppression réussie ! FTotal: '+inttostr(RExistant)+', FSupprimer: '+inttostr(RSupprimer)+', FSauvgarder: '+inttostr(RSauvgarder))
               else AfficherMessage('Aucun Registre Supprimer ! FTotal: '+inttostr(RExistant)+', FSupprimer: '+inttostr(RSupprimer)+', FSauvgarder: '+inttostr(RSauvgarder));

               if SupprimerFBanqueGlobal(FSAgenceBanque.EditCodeBanque.Text,RExistant,RSupprimer,RSauvgarder)then
               begin
                    if(RSupprimer>0)
                    then AfficherMessage('Suppression réussie ! FTotal: '+inttostr(RExistant)+', FSupprimer: '+inttostr(RSupprimer)+', FSauvgarder: '+inttostr(RSauvgarder))
                    else AfficherMessage('Aucun Registre Supprimer ! FTotal: '+inttostr(RExistant)+', FSupprimer: '+inttostr(RSupprimer)+', FSauvgarder: '+inttostr(RSauvgarder));
               end;
          end;
     end;

ListeBanque(FSAgenceBanque.TableauBanque,'',CodeBanqueSelect);
ListeAgence(FSAgenceBanque.TableauAgence,FSAgenceBanque.TableauBanque.Cells[2,FSAgenceBanque.TableauBanque.Row],'');

FSAgenceBanque.AfficheBanque.Visible:=false;

FSAgenceBanque.TableauBanque.SetFocus;
end;

procedure ListeAgence(TableauAgence:TStringGrid; CodeBanque,CodeAgenceSelect:string);
var R:integer;  OKBanque:boolean;  Rowselect,TypeProces,FichierConcerne,Adresse:string;
begin
     TableauAgence.ColCount:=7;
     TableauAgence.Cols[0].Text:='N°';
     TableauAgence.Cols[1].Text:='P°';
     TableauAgence.Cols[2].Text:='Code Banque';
     TableauAgence.Cols[3].Text:='Code Agence';
     TableauAgence.Cols[4].Text:='Libellé';
     TableauAgence.Cols[5].Text:='Adresse';
     TableauAgence.Cols[6].Text:='Téléphone';
     TableauAgence.RowCount:=2;
     TableauAgence.Rows[1].Text:='';

     TypeProces:='Paie';
     FichierConcerne:='FAgence';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChAgence:=Adresse;
     assignfile(FAgence,ChAgence);
     if FileExists(ChAgence)
     then Reset(FAgence)
     else Rewrite(FAgence);
     Seek(FAgence,0);
     R:=0;
     while not eof(FAgence)do
     begin
          read(FAgence,RAgence);

          if(CodeBanque<>'')then
          begin
               if firstlaters(RAgence.CodeBanque+RAgence.CodeAgence,longueur(CodeBanque))=CodeBanque
               then OKBanque:=true
               else OKBanque:=false;
          end
          else OKBanque:=true;

          if(OKBanque=true)then
          begin
               R:=R+1;
               TableauAgence.Rows[R].Text:=inttostr(R);
               TableauAgence.Cells[1,R]:=inttostr(RAgence.PositionAgence);
               TableauAgence.Cells[2,R]:=RAgence.CodeBanque;
               TableauAgence.Cells[3,R]:=RAgence.CodeAgence;
               TableauAgence.Cells[4,R]:=RAgence.LibelleAgence;
               TableauAgence.Cells[5,R]:=RAgence.AdresseAgence;
               TableauAgence.Cells[6,R]:=RAgence.TelephoneAgence;

               if(RAgence.CodeAgence=CodeAgenceSelect)then RowSelect:=inttostr(R);
          end;
     end;
     CloseFile(FAgence);

     if(R>0)then TableauAgence.RowCount:=R+1
            else TableauAgence.RowCount:=2;

     AjusterColWidth(TableauAgence,'','');

     if(strtointeger(RowSelect)>0)then TableauAgence.Row:=strtointeger(RowSelect);
end;

