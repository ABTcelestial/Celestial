Procedure ProcAffichePhoto(CodeBanqueGlobal,AdresseFichierCible,LogoBanque:string; var AdresseFichierCibleOut:string);
var TypeProces,FichierConcerne,Adresse:string;
begin

if(AdresseFichierCible='Vide')then
begin
     if(FSAgenceBanque.Photo.Visible=true)then
     begin
          if(LogoBanque='LogoBanqueLong')then FSAgenceBanque.LogoBanqueLong.Picture:=FSMenuPrincipal.PhotoVide.Picture;
          if(LogoBanque='LogoBanque')then FSAgenceBanque.Photo.Picture:=FSMenuPrincipal.PhotoVide.Picture;
          FSAgenceBanque.LibelleBanque.Caption:='Pas de Photo!: '
     end;

     if(FSAgenceBanque.AfficheNewPhoto.Visible=true)then
     begin
          FSAgenceBanque.NouvellePhoto.Picture:=FSMenuPrincipal.PhotoVide.Picture;
          FSAgenceBanque.LibelleBanqueNew.Caption:='Pas de Photo!: '
     end;

     if(FSAvis.AfficheOptionImpression.Visible=true)or(FSAvis.AffichePrelevementUniteFonds.Visible=true)then
     begin
          if(FSAvis.BitPrintType.Caption='Virement')then
          begin
               PrintOrdreVirement.TitreLogoBanque.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               PrintOrdreVirement.TitreLogoBanqueX.Picture:=FSMenuPrincipal.PhotoVide.Picture;
          end;

          if(FSAvis.BitPrintType.Caption='Espčce')then
          begin
               PrintOrdreVersementEspece.TitreLogoBanque.Picture:=FSMenuPrincipal.PhotoVide.Picture;
          end;
     end;

     if(FSAvis.AfficheTaxesAvisBanque.Visible=true)then
     begin
          if(FSAvis.EtatPrintType.Caption='Avis Banque')then
          begin
               if(LogoBanque='LogoBanque')then
               begin
                    PrintAvisBanque1.TitreLogoBanque.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                    PrintAvisBanque1.TitreLogoBanqueX.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               end;

               if(LogoBanque='LogoBanqueLong')then
               begin
                    PrintAvisBanque1.TitreLogoLong.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                    PrintAvisBanque1.TitreLogoLongX.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               end;
          end;
     end;
end
else
begin
     if(AdresseFichierCible<>'')then
     begin
          FichierConcerne:=AdresseFichierCible;
          Adresse:=AdresseFichierCible;
     end
     else
     begin
          TypeProces:='Paie';
          FichierConcerne:=LogoBanque+' ('+CodeBanqueGlobal+').JPG';
          Adresse:='';
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
          end;

          AdresseFichierCibleOut:=Adresse;
     end;

     if(FSAgenceBanque.Photo.Visible=true)then
     begin
          {if FileExists(Adresse)then
          begin
               if(LogoBanque='LogoBanqueLong')then FSAgenceBanque.LogoBanqueLong.Picture.LoadFromFile(Adresse);
               if(LogoBanque='LogoBanque')then FSAgenceBanque.Photo.Picture.LoadFromFile(Adresse);
               FSAgenceBanque.LibelleBanque.Caption:='';
          end
          else}
          begin
               if(LogoBanque='LogoBanqueLong')then FSAgenceBanque.LogoBanqueLong.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               if(LogoBanque='LogoBanque')then FSAgenceBanque.Photo.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               FSAgenceBanque.LibelleBanque.Caption:='Pas de Photo!: '
          end;
     end;

     if(FSAgenceBanque.AfficheNewPhoto.Visible=true)then
     begin
          if FileExists(Adresse)then
          begin
               FSAgenceBanque.NouvellePhoto.Picture.LoadFromFile(Adresse);
               FSAgenceBanque.LibelleBanqueNew.Caption:=''
          end
          else
          begin
               FSAgenceBanque.NouvellePhoto.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               FSAgenceBanque.LibelleBanqueNew.Caption:='Pas de Photo!: '
          end;
     end;

     if(FSAvis.AfficheOptionImpression.Visible=true)or(FSAvis.AffichePrelevementUniteFonds.Visible=true)then
     begin
          if(FSAvis.BitPrintType.Caption='Virement')then
          begin
               if FileExists(Adresse)then
               begin
                    PrintOrdreVirement.TitreLogoBanque.Picture.LoadFromFile(Adresse);
                    PrintOrdreVirement.TitreLogoBanqueX.Picture.LoadFromFile(Adresse);
               end
               else
               begin
                    PrintOrdreVirement.TitreLogoBanque.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                    PrintOrdreVirement.TitreLogoBanqueX.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               end;
          end;

          if(FSAvis.BitPrintType.Caption='Chčque')then
          begin
               if FileExists(Adresse)then
               begin
                    PrintRemiseCheque.TitreLogoBanque.Picture.LoadFromFile(Adresse);
                    PrintRemiseCheque.TitreLogoBanqueX.Picture.LoadFromFile(Adresse);
               end
               else
               begin
                    PrintRemiseCheque.TitreLogoBanque.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                    PrintRemiseCheque.TitreLogoBanqueX.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               end;
          end;

          if(FSAvis.BitPrintType.Caption='Espčce')then
          begin
               if FileExists(Adresse)then
               begin
                    PrintOrdreVersementEspece.TitreLogoBanque.Picture.LoadFromFile(Adresse);
               end
               else
               begin
                    PrintOrdreVersementEspece.TitreLogoBanque.Picture:=FSMenuPrincipal.PhotoVide.Picture;
               end;
          end;
     end;

     if(FSAvis.AfficheTaxesAvisBanque.Visible=true)then
     begin
          if(FSAvis.EtatPrintType.Caption='Avis Banque')then
          begin
               if FileExists(Adresse)then
               begin
                    if(LogoBanque='LogoBanque')then
                    begin
                         PrintAvisBanque1.TitreLogoBanque.Picture.LoadFromFile(Adresse);
                         PrintAvisBanque1.TitreLogoBanqueX.Picture.LoadFromFile(Adresse);
                    end;

                    if(LogoBanque='LogoBanqueLong')then
                    begin
                         PrintAvisBanque1.TitreLogoLong.Picture.LoadFromFile(Adresse);
                         PrintAvisBanque1.TitreLogoLongX.Picture.LoadFromFile(Adresse);
                    end;
               end
               else
               begin
                    if(LogoBanque='LogoBanque')then
                    begin
                         PrintAvisBanque1.TitreLogoBanque.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                         PrintAvisBanque1.TitreLogoBanqueX.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                    end;

                    if(LogoBanque='LogoBanqueLong')then
                    begin
                         PrintAvisBanque1.TitreLogoLong.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                         PrintAvisBanque1.TitreLogoLongX.Picture:=FSMenuPrincipal.PhotoVide.Picture;
                    end;
               end;
          end;
     end;
end;
end;

procedure TFSAgenceBanque.BitOuvrirPhotoClick(Sender: TObject);
