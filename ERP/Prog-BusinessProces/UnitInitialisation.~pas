Function ExisteCharinString(Char,StringListe:string):boolean;
var  ie,je:integer;  OKChar:boolean;
begin
     ie:=1;
     OKChar:=false;
     while(ie<=longueur(StringListe))and(OKChar=false)do
     begin
          je:=1;
          OKChar:=true;
          while((je<=longueur(Char))and(OKChar=true))do
          begin
               if(ie<=longueur(StringListe))then
               begin
                    if(Char[je]=StringListe[ie])then
                    begin
                         ie:=ie+1;
                         je:=je+1;
                    end
                    else OKChar:=false;
               end
               else OKChar:=false;
          end;
     ie:=ie+1;
     end;

     ExisteCharinString:=OKChar;
end;

Function ExisteNuminTexte(Num,ListeNum:string):boolean;
var iENT:integer; NumTesteD,NumTesteF:string; OKNum:boolean;
begin
     iENT:=1;
     OKNum:=false;
     NumTesteD:='';
     while(iENT<=longueur(ListeNum))and(OKNum=false)do
     begin
          if(ListeNum[iENT]<>';')and(ListeNum[iENT]<>'-')
          then
          begin
               NumTesteD:=NumTesteD+ListeNum[iENT];
          end;

          if(iENT=longueur(ListeNum))or(ListeNum[iENT]=';')or(ListeNum[iENT]='-')then
          begin
               if(ListeNum[iENT]=';')or(iENT=longueur(ListeNum))then
               begin
                    if(Num=NumTesteD)then OKNum:=true;
               end;

               if(ListeNum[iENT]='-')then
               begin
                    NumTesteF:='';
                    iENT:=iENT+1;
                    while(iENT<=longueur(ListeNum))and(ListeNum[iENT]<>';')do
                    begin
                         NumTesteF:=NumTesteF+ListeNum[iENT];
                         iENT:=iENT+1;
                    end;

                    if(strtointeger(Num)>=strtointeger(NumTesteD))
                    and(strtointeger(Num)<=strtointeger(NumTesteF))
                    then OKNum:=true;
               end;
          NumTesteD:='';
          NumTesteF:='';
          end;
     iENT:=iENT+1;
     end;

ExisteNuminTexte:=OKNum;
end;

Function ExisteNumAvisinTexte(BaseAvisPrincipal,Num,ListeNum:string):boolean;
var iENT:integer; NumTesteD,NumTesteF,BaseAvisTrouver:string; OKNum,IndexBaseDebut,IndexBaseFin,IndexBaseReboot:boolean;
begin
     iENT:=1;
     OKNum:=false;
     NumTesteD:='';
     IndexBaseDebut:=false;
     IndexBaseFin:=false;
     IndexBaseReboot:=true;
     BaseAvisTrouver:='';
     while(iENT<=longueur(ListeNum))and(OKNum=false)do
     begin
          if(ListeNum[iENT]='{')then
          begin
               IndexBaseDebut:=true;
               IndexBaseFin:=false;
               iENT:=iENT+1;
               IndexBaseReboot:=false;
          end;

          if(ListeNum[iENT]='}')then
          begin
               IndexBaseFin:=true;
               IndexBaseDebut:=false;
               iENT:=iENT+1;
          end;

          if(IndexBaseDebut=true)and(IndexBaseFin=false)then
          begin
               BaseAvisTrouver:=BaseAvisTrouver+ListeNum[iENT];
          end;
          
          if(IndexBaseReboot=true)then
          begin
               IndexBaseDebut:=false;
               IndexBaseFin:=true;
               BaseAvisTrouver:=BaseAvisPrincipal;
          end;

          if(IndexBaseDebut=false)and(IndexBaseFin=true)and(FunctionFichierInclu(BaseAvisTrouver,BaseAvisPrincipal))then
          begin
               if(ListeNum[iENT]<>';')and(ListeNum[iENT]<>'{')
               then
               begin
                    NumTesteD:=NumTesteD+ListeNum[iENT];
               end;

               if(iENT=longueur(ListeNum))or(ListeNum[iENT]=';')then
               begin
                    if(Num=NumTesteD)then OKNum:=true;
                    IndexBaseDebut:=false;
                    IndexBaseFin:=false;
                    IndexBaseReboot:=true;
                    NumTesteD:='';
                    NumTesteF:='';
                    BaseAvisTrouver:='';
               end;
          end;
     iENT:=iENT+1;
     end;
ExisteNumAvisinTexte:=OKNum;
end;

