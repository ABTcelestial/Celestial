Function ValePrecis(Chiffre:real; Decimale:cardinal):real;
var Signe:integer; ValeurNet,ValeurDec,Arondi:string;
begin
     Signe:=Decimale;
     Decimale:=1;
     for i:=1 to Signe do
     begin
          Decimale:=Decimale*10;
     end;

     if(Chiffre<0)then Signe:=-1 else Signe:=1;
     Chiffre:=Chiffre*Signe;

     Chiffre:=Chiffre*Decimale;

     i:=1;
     ValeurNet:='';
     while((i<=longueur(floattostr(Chiffre)))and(floattostr(Chiffre)[i]<>','))do
     begin
          ValeurNet:=ValeurNet+floattostr(Chiffre)[i];
          i:=i+1;
     end;

     i:=i+1;
     ValeurDec:='';
     Arondi:='?';
     while((i<=longueur(floattostr(Chiffre)))and(Arondi='?'))do
     begin
          if(strtofloat(floattostr(Chiffre)[i])<5)then Arondi:='0';
          if(strtofloat(floattostr(Chiffre)[i])>5)then Arondi:='1';
          i:=i+1;
     end;

     if(Arondi='?')then Arondi:='0';

     ValePrecis:=(strtofloat(ValeurNet)+strtointeger(Arondi))*(1/Decimale)*Signe;
end;

Procedure Division(Nombre,Diviseur:integer; var Resultat,Reste:integer);
var R:integer; Chiffre:integer;
begin
     Chiffre:=Nombre;
     R:=0;
     if(Diviseur<>0)then
     begin
          while(Chiffre>=Diviseur)do
          begin
               Chiffre:=Chiffre-Diviseur;
               R:=R+1;
          end;
     end;
     Resultat:=R;
     Reste:=Chiffre;
end;

Function  Strtoreal(Text:string):real;
var  iSR,NbrSigne:integer;  OKReal:boolean;  Multiple:real;  memo:string;
begin
memo:=Text;
     NbrSigne:=0;
     Text:=WithoutPoint(Text);
     if(Text<>'')and(Text<>' ')then
     begin
          Multiple:=1;
          if(lastlaters(Text,1)='%')then
          begin
               Text:=Firstlaters(Text,longueur(Text)-1);
               Multiple:=1/100;
          end;
          iSR:=1;
          OKReal:=true;
          while(iSR<=longueur(Text))and(OKReal=true)do
          begin
               if not(Text[iSR]in['0'..'9',decimalseparator,'-','+'])then OKReal:=false;
               if(Text[iSR]in['-','+'])then
               begin
                    NbrSigne:=NbrSigne+1;
                    if(iSR>1)then OKReal:=false;
               end;
               iSR:=iSR+1;
          end;
     end
     else OKReal:=false;
     if(NbrSigne>0)and(longueur(Text)=1)then OKReal:=false;
     if(OKReal=true)and(NbrSigne<=1)then StrtoReal:=strtofloat(verguletonum(Text))*Multiple
                                    else StrtoReal:=0;
end;

