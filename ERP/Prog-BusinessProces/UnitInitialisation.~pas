     ChRegistreReseaux,TypeProces,FichierConcerne,Adresse,TypeProcesPlanComptable,AdressePlanComptable,AdresseReseaux,NomDossierPartageOut,DossierPartageCible,EmlacementLocalOuReseauxOut,
     ExerciceReseauxCible,ExerciceReseauxSource,AdresseReseauxSource,AdresseReseauxCible,FichierConcernePlanComptableTeste,TypeComptabilite:string;
     TableauListeFPR:ArrayListeFichierPartageReseaux;
     OKPlanComptablePublication,OKPlanComptable:boolean;
begin
     FSMenuPrincipal.EditDetailRapport.Lines.Text:='';
     FSMenuPrincipal.EditDetailRapport.Lines.Add('Enregistrement PlanComptable');

     AdresseReseaux:=ProcAdresseDossierPartageReseaux('','Local',NomDossierPartageOut,EmlacementLocalOuReseauxOut);

     if(AdresseDossierPartageReseaux<>'')then
     begin
          if(AdresseDossierPartageReseaux=AdresseReseaux)
          then DossierPartageCible:=NomDossierPartageOut
          else DossierPartageCible:=ChercherDossierPartageReseaux('','',AdresseDossierPartageReseaux).NomPosteReseaux;
          AdresseReseaux:=AdresseDossierPartageReseaux;
     end
     else DossierPartageCible:=NomDossierPartageOut;

     AdresseReseauxCible:=AdresseReseaux;

     if(AdresseReseauxCible<>'')then
     begin
          ChRegistreReseaux:=AdresseReseauxCible+'\WinBus'+DataIdentificateurReseaux+' '+DossierPartageCible+'.File';
          assignfile(FRegistre,ChRegistreReseaux);
          if FileExists(ChRegistreReseaux)then
          begin
               try
               Reset(FRegistre);
               Seek(FRegistre,0);
               read(FRegistre,RRegistre);
               ExerciceReseauxCible:=RRegistre.Exercice;
               finally
               CloseFile(FRegistre);
               end;
          end
          else ExerciceReseauxCible:=ExerciceAnnee;
     end;
     ExerciceReseauxCible:=AjusterExercicePublication(ExerciceReseauxCible,TypeProcesReseaux);

     TypePCN:=1;
     OKPlanComptable:=false;
     while(TypePCN<=6)and(OKPlanComptable=false)do
     begin
          if(TypeComptabilite='')then
          begin
               Boucle:=1;
               TypeComptabilite:='PlanComptable';
          end
          else Boucle:=2;

          while(Boucle<=2)do
          begin
               if(FichierConcerne='FPlanComptable')or(FichierConcerne='')then
               begin
                     if(TypePCN=1)then FichierConcernePlanComptableTeste:='FClasse'+TypeComptabilite;
                     if(TypePCN=2)then FichierConcernePlanComptableTeste:='FSousClasse'+TypeComptabilite;
                     if(TypePCN=3)then FichierConcernePlanComptableTeste:='FCategorie'+TypeComptabilite;
                     if(TypePCN=4)then FichierConcernePlanComptableTeste:='FSousCategorie'+TypeComptabilite;
                     if(TypePCN=5)then FichierConcernePlanComptableTeste:='FFamille'+TypeComptabilite;
                     if(TypePCN=6)then begin FichierConcernePlanComptableTeste:='FSousFamille'+TypeComptabilite; OKPlanComptable:=true; end;
               end
               else
               begin
                    FichierConcernePlanComptableTeste:=FichierConcerne+TypeComptabilite;
                    OKPlanComptable:=true;
               end;

               if(FichierConcernePlanComptable<>'')then
               begin
                     if(FichierConcernePlanComptableTeste=FichierConcernePlanComptable)
                     then OKPlanComptablePublication:=true
                     else OKPlanComptablePublication:=false;
               end
               else
               begin
                     OKPlanComptablePublication:=true;
               end;

               if(OKPlanComptablePublication=true)then
               begin
                     TypeProcesPlanComptable:='Business';
                     if not(FunctionAdresseProces(TypeProcesPlanComptable,FichierConcernePlanComptableTeste,'',AdressePlanComptable,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                     begin
                           FSMenuPrincipal.EditDetailRapport.Lines.Add('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché !'+' {'+FichierConcernePlanComptableTeste+'}');
                     end;

                     ExerciceReseauxCible:=ExerciceAnnee;
                     if(NomDossierPartageReseauxOut<>'')then
                     begin
                          ChRegistreReseaux:=AdresseReseauxCible+'\WinBus'+DataIdentificateurReseaux+' '+NomDossierPartageReseauxOut+'.File';
                          assignfile(FRegistre,ChRegistreReseaux);
                          if FileExists(ChRegistreReseaux)then
                          begin
                               try
                               Reset(FRegistre);
                               Seek(FRegistre,0);
                               read(FRegistre,RRegistre);
                               ExerciceReseauxCible:=RRegistre.Exercice;
                               finally
                               CloseFile(FRegistre);
                               end;
                          end
                          else ExerciceReseauxCible:=ExerciceAnnee;
                     end;
                     ExerciceReseauxCible:=AjusterExercicePublication(ExerciceReseauxCible,TypeProcesReseaux);

                     if(AdressePublicationChoisis<>'')then
                     begin
                          AdresseReseauxSource:=AdressePublicationChoisis;

                          if(TypeProcesReseaux='Réseaux')then
                          begin
                               ChPlanComptablePublication:=AdresseReseauxSource+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceReseauxCible+FichierConcernePlanComptableTeste+' '+NomDossierPartageReseauxOut;
                               ChPlanComptableCopiePublication:=AdresseReseauxCible+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceReseauxCible+FichierConcernePlanComptableTeste+' '+DossierPartageCible;

