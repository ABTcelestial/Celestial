Procedure OptionsImpressionDynamique(TableauDynamique:TStringGrid; AlignementTitre:string; DebutRowIn,FixedRow:integer; TitreEtat:string; AjustePrint:boolean; OrintationPapier:string; FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol:string; ImprimeEtat:boolean; EcartTableau:integer; ApercuAvantImpression:boolean; var DebutRowOut:integer);
var CTeste:integer;  IndiceWidth,ColCountTeste:real;
begin
     if(OrintationPapier='Automatique')then
     begin
          IndiceWidth:=10/TableauDynamique.Font.Size;
          ColCountTeste:=0;
          for CTeste:=0 to TableauDynamique.ColCount-1 do
          begin
               if(TableauDynamique.ColWidths[CTeste]>10)then
               ColCountTeste:=ColCountTeste+(TableauDynamique.ColWidths[CTeste]*IndiceWidth);
          end;

          if(PrintEtatPortraitDynamique.PageTitreEtat.Width>=ColCountTeste)
          then ImprimerTableauDynamiquePortrait(TableauDynamique,AlignementTitre,DebutRowIn,FixedRow,TitreEtat,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,ApercuAvantImpression,DebutRowOut)
          else ImprimerTableauDynamique(TableauDynamique,AlignementTitre,DebutRowIn,FixedRow,TitreEtat,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,ApercuAvantImpression,DebutRowOut);
     end
     else
     if(OrintationPapier='Portrait')
     then ImprimerTableauDynamiquePortrait(TableauDynamique,AlignementTitre,DebutRowIn,FixedRow,TitreEtat,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,ApercuAvantImpression,DebutRowOut)
     else ImprimerTableauDynamique(TableauDynamique,AlignementTitre,DebutRowIn,FixedRow,TitreEtat,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,ApercuAvantImpression,DebutRowOut);
end;

Procedure AjusterImprimeEtatPortraitDynamique(ARow,ACol,L,C:integer; Tableau:TStringGrid; AjustePrint:boolean; FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol:string; EcartTableau:integer);
var   MaxRow:integer;  IndiceWidth:real; Rubrique,RubriqueNext,RubriqueNextRow:TQRRichText;
      CTeste:integer;  ColCountTeste:real;
begin
     IndiceWidth:=10/Tableau.Font.Size;

     ColCountTeste:=0;
     for CTeste:=0 to Tableau.ColCount-1 do
     begin
          if(Tableau.ColWidths[CTeste]>10)then
          ColCountTeste:=ColCountTeste+(Tableau.ColWidths[CTeste]*IndiceWidth);
     end;

     if(AjustePrint)then
     begin
          IndiceWidth:=IndiceWidth*(PrintEtatPortraitDynamique.PageDonnees.Width/ColCountTeste);
     end;

     MaxRow:=Tableau.RowCount-1;
     IdentificationRubriquePortraitDynamique(L,C,Rubrique,RubriqueNext,RubriqueNextRow);

     Rubrique.Height:=Tableau.RowHeights[ARow];
     if(L=0)then Rubrique.Top:=0
     else Rubrique.Top:=RubriqueNextRow.Top+RubriqueNextRow.Height-1;

     Rubrique.Width:=ValeAbsolue(Tableau.ColWidths[ACol]*IndiceWidth*(1+4/100)); 
     if(C=0)then Rubrique.Left:=0
     else Rubrique.Left:=RubriqueNext.Left+RubriqueNext.Width-1;

     if(ExisteNuminTexte(inttostr(ARow),FontGrasARow))
     or(ExisteNuminTexte(inttostr(ACol),FontGrasACol))
     then
     begin
          Rubrique.Font.Style:=[fsBold];
     end
     else
     begin
          Rubrique.Font.Style:=[];
     end;

     if(ExisteNuminTexte(inttostr(ARow),AlignementCenterARow))
     or(ExisteNuminTexte(inttostr(ACol),AlignementCenterACol))
     then
     begin
          Rubrique.Alignment:=taCenter;
     end
     else
     if(ExisteNuminTexte(inttostr(ARow),AlignementRightARow))
     or(ExisteNuminTexte(inttostr(ACol),AlignementRightACol))
     then
     begin
          Rubrique.Alignment:=taRightJustify;
     end
     else
     begin
          Rubrique.Alignment:=taLeftJustify;
     end;

     if(EcartTableau=0)then Rubrique.Enabled:=false;
     Rubrique.Font.Size:=ValeAbsolue(Tableau.Font.Size*IndiceWidth*8/10);
     //Rubrique.Font.Size:=MaxInt(ValeAbsolue(Tableau.Font.Size*IndiceWidth),10);
     //Rubrique.Font.Size:=MinInt(Rubrique.Font.Size,16);
     Rubrique.Lines.Add(Tableau.Cells[ACol,ARow]);
end;

Procedure CleanImprimeEtatPortraitDynamique(L,C:integer; Visible:boolean);
var  Rubrique,RubriqueNext,RubriqueNextRow:TQRRichText;
begin
     IdentificationRubriquePortraitDynamique(L,C,Rubrique,RubriqueNext,RubriqueNextRow);
     Rubrique.Lines.Text:='';
     Rubrique.Enabled:=Visible;
end;

