Function FunctionPatienter(ProgressMax:integer; OrdreProgress:boolean):boolean;
begin
     if(ProgressMax>=0)then
     begin
          if(OrdreProgress=false)then
          begin
               FSPatienter.Show;
               FSPatienter.ProgressCDL.Max:=ProgressMax;
               FSPatienter.ProgressCDL.Position:=0;
               FSPatienter.ProgressCDL.StepIt;
          end
          else
          begin
               FSPatienter.ProgressCDL.StepIt;                                    
               if(FSPatienter.ProgressCDL.Position>=(FSPatienter.ProgressCDL.Max*(0.995)))then FSPatienter.Close;
          end;

          FSPatienter.Pourcentage.Caption:=Vergule(floattostr(FSPatienter.ProgressCDL.Position/FSPatienter.ProgressCDL.Max),'2','C','%');
     end
     else FSPatienter.Close;
end;

