Function CodageTexteX(Texte:string):string;
var  L:char; T,TexteCodage:string; R,C,S:Integer; MatriceCodage,MatriceDeCodage:Matrice;
begin
for C:=0 to 8 do
begin
     for R:=0 to 9 do
     begin
          MatriceCodage[C,R]:='';
          MatriceDeCodage[C,R]:='';
     end;
end;

C:=0;
R:=0;
for L:=' ' to 'z' do
begin
     if(L<>'$')then
     begin
          MatriceCodage[C,R]:=L;
          MatriceDeCodage[C,R]:=L;
          C:=C+1;
          if(C=9)then begin R:=R+1; C:=0; end;
     end;
end;

C:=0;
R:=0;
for C:=0 to 8 do
begin
     for R:=0 to 4 do
     begin
          T:=MatriceDeCodage[C,R];
          MatriceDeCodage[C,R]:=MatriceDeCodage[8-C,9-R];
          MatriceDeCodage[8-C,9-R]:=T;
     end;
end;

TexteCodage:='';
for S:=1 to longueur(Texte)do
begin
     R:=0;
     OK:=false;
     while(R<=9)and(OK=false)do
     begin
          C:=0;
          while(C<=8)and(OK=false)do
          begin
               if(Texte[S]=MatriceCodage[C,R])then
               begin
                    TexteCodage:=TexteCodage+MatriceDeCodage[C,R];
                    OK:=true;
               end;
          C:=C+1;
          end;
     R:=R+1;
     end;
end;

CodageTexteX:='§'+TexteCodage;
end;

