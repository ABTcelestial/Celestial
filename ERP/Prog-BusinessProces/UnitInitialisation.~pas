Function RechercheSequenceParMotsCle(MotsCle,SequenceSource:string):boolean;
var iRPMC,lRPMC:integer;   TableauMotsCle:TableauMotsCles; Teste:string;  OKMotsCle:boolean;
begin
     MotsCle:=AnsiUpperCase(MotsCle);
     SequenceSource:=AnsiUpperCase(SequenceSource);

     for iRPMC:=1 to 10 do TableauMotsCle[iRPMC]:='';
     Teste:='';
     lRPMC:=0;

     iRPMC:=1;
     while(iRPMC<=longueur(MotsCle))do
     begin
          if(MotsCle[iRPMC]<>' ')then
          begin
               Teste:=Teste+MotsCle[iRPMC];
          end
          else
          if(Teste<>'')then
          begin
               lRPMC:=lRPMC+1;
               TableauMotsCle[lRPMC]:=Teste;
               Teste:='';
          end;
     iRPMC:=iRPMC+1;
     end;

     if(Teste<>'')then
     begin
          lRPMC:=lRPMC+1;
          TableauMotsCle[lRPMC]:=Teste;
          Teste:='';
     end;

     OKMotsCle:=true;
     iRPMC:=1;
     while(iRPMC<=lRPMC)and(OKMotsCle=true)do
     begin
          OKMotsCle:=ExisteCharInString(TableauMotsCle[iRPMC],SequenceSource);
          iRPMC:=iRPMC+1;
     end;

     RechercheSequenceParMotsCle:=OKMotsCle;
end;

Function ProcAdresseDossierPartageReseaux(NomDossierPartageIn,EmlacementLocalOuReseauxIn:string; var NomDossierPartageOut,EmlacementLocalOuReseauxOut:string):string;
