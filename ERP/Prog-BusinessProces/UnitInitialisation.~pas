Function RubriqueArborescence(NumFicheTechnique,NumRubrique:string; var RRubriqueFicheTechniqueCopie:RRubriqueFicheTechniques; var RFicheTechniqueCopie:RFicheTechniques; var RTypeAvis:RTypeAviss):boolean;
