     ChercherMouvement.MouvementeFinance:=false;
     ChercherMouvement.EtatUtilise:='';
     ChercherMouvement.AvecDateExecution:=false;
     ChercherMouvement.AvecLocalisationGeographique:=false;
     ChercherMouvement.ListeAppartenanceCodeMouvement:='';
     ChercherMouvement.PositionListeMouvementBegin:=0;
     ChercherMouvement.PositionListeMouvementEnd:=999999999;

     for iA:=2010 to 2050 do
     for iMois:=1 to 12 do
     begin
          ChercherMouvement.RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementBegin:=0;
          ChercherMouvement.RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementEnd:=999999999;
     end;


     TypeProces:='Business';   FichierConserne:='FMouvement';
