Function ExtentionFichier(FileName:string):string;
var  iFN:integer;   OKExtention:boolean; ExtentionVerso,Extention:string;
begin
     OKExtention:=false;
     iFN:=longueur(FileName);
     ExtentionVerso:='';
     Extention:='';
     while(iFN>0)and(OKExtention=false)do
     begin
          if(FileName[iFN]<>'.')then
          begin
               ExtentionVerso:=ExtentionVerso+FileName[iFN];
          end
          else OKExtention:=true;
     iFN:=iFN-1;
     end;

     for iFN:=longueur(ExtentionVerso)downto 1 do Extention:=Extention+ExtentionVerso[iFN];

     ExtentionFichier:=Extention;
end;

Function ImporterDetailMarche(NSMarche,NStructureMarche,NStatistiqueMarche:integer; CodeArticle,DesignationArticle:string; var TDetailMarche:TDetailMarches):integer;
var OK:boolean;   TI:integer;
begin
          SetLength(TDetailMarche,0);
          TI:=0;
          TypeProces:='Business'; FichierConcerne:='FDetail'+ChercherMarche(NSMarche).TypeProjet+' '+inttostr(NSMarche);
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               //if(<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché !'+' {'+FichierConcerne+'}');
          end;
          ChDetailMarche:=Adresse;    FSDetailMarche.AdresseDetailMarche.Caption:=ChDetailMarche;
          assignfile(FDetailMarche,ChDetailMarche);
          try
          if FileExists(ChDetailMarche)then
          Reset(FDetailMarche)
          else Rewrite(FDetailMarche);
          Seek(FDetailMarche,0);
          while not eof(FDetailMarche) do
          begin
               Read(FDetailMarche,RDetailMarche);

               if(strtointeger(DTrie('M',RDetailMarche.CodeTrie))=NSMarche)then
               begin
                    if(NStructureMarche<>0)then
                    begin
                         if(strtointeger(DTrie('S',RDetailMarche.CodeTrie))=NStructureMarche)
                         then OK:=true
                         else OK:=false;
                    end
                    else OK:=true;

                    if(OK=true)then
                    begin
                         if(NStatistiqueMarche<>0)then
                         begin
                              if(strtointeger(DTrie('T',RDetailMarche.CodeTrie))=NStatistiqueMarche)
                              then OK:=true
                              else OK:=false;
                         end;
                    end;
               end
               else OK:=false;

               if(OK=true)then
               begin
                    if(CodeArticle<>'')then
                    begin
                         if(firstlaters(DTrie('K',RDetailMarche.CodeTrie),longueur(CodeArticle))=CodeArticle)
                         then OK:=true
                         else OK:=false;
                    end;
               end;

               if(OK=true)then
               begin
                    if(DesignationArticle<>'')then
                    begin
                         if(firstlaters(RDetailMarche.DesignationArticle,longueur(DesignationArticle))=DesignationArticle)
                         then OK:=true
                         else OK:=false;
                    end;
               end;

               if(OK=true)then
               begin
                    TI:=TI+1;
                    SetLength(TDetailMarche,TI);
                    TDetailMarche[TI-1].NDetailMarche:=RDetailMarche.NDetailMarche;
                    TDetailMarche[TI-1].NArticle:=RDetailMarche.NArticle;
                    TDetailMarche[TI-1].DesignationArticle:=RDetailMarche.DesignationArticle;
                    TDetailMarche[TI-1].UniteM:=RDetailMarche.UniteM;
                    TDetailMarche[TI-1].QuantiteGlobale:=RDetailMarche.QuantiteGlobale;
                    TDetailMarche[TI-1].PrixUnitaire:=RDetailMarche.PrixUnitaire;
                    TDetailMarche[TI-1].CodeTrie:=RDetailMarche.CodeTrie;
                    TDetailMarche[TI-1].CodeStock:=RDetailMarche.CodeStock;
               end;
          end;
          finally
          closefile(FDetailMarche);
          end;
          TDetailMarche:=OrganiseDetailMarche(TDetailMarche,TI,TI);
          ImporterDetailMarche:=TI;
end;

Function OrganiseDetailMarche(TDetailMarche:TDetailMarches; TORGIn:integer; var TORGOut:integer):TDetailMarches;
var OKCode:boolean;
begin
if(TORGIn>0)then
begin
R:=0;
TORGOut:=TORGIn;
while(R<=TORGOut-1)do
begin
     if((TDetailMarche[R].CodeTrie<>'')
     and((DTrie('S',TDetailMarche[R].CodeTrie)<>'')or(DTrie('T',TDetailMarche[R].CodeTrie)<>''))
     and(Lastlaters(TDetailMarche[R].CodeTrie,11)<>'00.00.00.00')
     and(FirstLaters(TDetailMarche[R].CodeTrie,3)<>'ZZZ'))
     then
     begin
          OKCode:=false;
          i:=0;
          while((i<=TORGOut-1)and(OKCode=false))do
          begin
               if TDetailMarche[i].CodeTrie=FirstLaters(TDetailMarche[R].CodeTrie,15)+'00.00.00.00'
               then
               begin
                    OKCode:=true;
               end;
          i:=i+1;
          end;

          if(OKCode=false)then
          begin
               TORGOut:=TORGOut+1;
               Setlength(TDetailMarche,TORGOut);
               RStructureMarche:=ChercherStructureMarche(strtointeger(DTrie('M',TDetailMarche[R].CodeTrie)),strtointeger(DTrie('S',TDetailMarche[R].CodeTrie)));
               RStatistiqueMarche:=ChercherStatistiqueMarche(strtointeger(DTrie('M',TDetailMarche[R].CodeTrie)),strtointeger(DTrie('T',TDetailMarche[R].CodeTrie)));

               TDetailMarche[TORGOut-1].NDetailMarche:=0;
               TDetailMarche[TORGOut-1].NArticle:='';
               TDetailMarche[TORGOut-1].DesignationArticle:=RStructureMarche.StructureMarche+': '+RStatistiqueMarche.StatistiqueMarche;
               TDetailMarche[TORGOut-1].CodeTrie:=FirstLaters(TDetailMarche[R].CodeTrie,15)+'00.00.00.00';
               TDetailMarche[TORGOut-1].UniteM:='';
               TDetailMarche[TORGOut-1].QuantiteGlobale:=0;
               TDetailMarche[TORGOut-1].PrixUnitaire:=0;
               TDetailMarche[TORGOut-1].NArticle:='';
          end;
     end;
R:=R+1;
end;
OrganiseDetailMarche:=TrierDetailMarche(TDetailMarche,TORGOut);
end;
end;

Function TrierDetailMarche(TDetailMarche:TDetailMarches; TTrie:integer):TDetailMarches;
var OK:boolean; ARow,VarA,VarB,TailleTrie:integer;
begin
if(TTrie>0)then
begin
     TailleTrie:=TTrie+1;
     Setlength(TDetailMarche,TailleTrie);
     OK:=true;
     while(OK=true)do
     begin
          OK:=false;
          for i:=0 to TailleTrie-2 do
          begin
               if(TDetailMarche[i].CodeTrie>TDetailMarche[i+1].CodeTrie)then
               begin
                    OK:=true;
                    ARow:=1;
                    while(ARow<=3)do
                    begin
                         if(ARow=1)then begin VarA:=TailleTrie-1; VarB:=i; end;
                         if(ARow=2)then begin VarA:=i; VarB:=i+1; end;
                         if(ARow=3)then begin VarA:=i+1; VarB:=TailleTrie-1; end;

                         TDetailMarche[VarA].NDetailMarche:=TDetailMarche[VarB].NDetailMarche;
                         TDetailMarche[VarA].NArticle:=TDetailMarche[VarB].NArticle;
                         TDetailMarche[VarA].DesignationArticle:=TDetailMarche[VarB].DesignationArticle;
                         TDetailMarche[VarA].UniteM:=TDetailMarche[VarB].UniteM;
                         TDetailMarche[VarA].QuantiteGlobale:=TDetailMarche[VarB].QuantiteGlobale;
                         TDetailMarche[VarA].PrixUnitaire:=TDetailMarche[VarB].PrixUnitaire;
                         TDetailMarche[VarA].CodeTrie:=TDetailMarche[VarB].CodeTrie;
                         TDetailMarche[VarA].NArticle:=TDetailMarche[VarB].NArticle;
                    ARow:=ARow+1;
                    end;
               end;
          end;
     end;
Setlength(TDetailMarche,TTrie);
TrierDetailMarche:=TDetailMarche;
end;
end;

