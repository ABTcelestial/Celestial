Procedure ImprimerTableau(Tableau:TStringGrid; AlignementTitre:string; DebutRowIn,FixedRow:integer; TitreEtat:string; AjustePrint:boolean; FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol:string; ImprimeEtat:boolean; EcartTableau:integer; ImageCodebarre:TImage; ApercuAvantImpression:boolean; var DebutRowOut:integer);
var  NbrRowActif,ARow,ACol,L,LClean,C,LMax,CMax,LMaxDefaut,CMaxDefaut,m,NbrPage,LFixed:integer;
begin
OpenFParc(RParc);
if(AlignementTitre='Left')then PrintEtatTraitementDonnees.TitreEtatLong.Alignment:=taLeftJustify;
if(AlignementTitre='Center')then PrintEtatTraitementDonnees.TitreEtatLong.Alignment:=taCenter;
if(AlignementTitre='Right')then PrintEtatTraitementDonnees.TitreEtatLong.Alignment:=taRightJustify;
PrintEtatTraitementDonnees.TitreEtatLong.Lines.Text:=TitreEtat;
PrintEtatTraitementDonnees.DataEntreprise.Lines.Text:='';
PrintEtatTraitementDonnees.DataEntreprise.Lines.Add(RParc.Text1);
PrintEtatTraitementDonnees.DataEntreprise.Lines.Add(RParc.Text2);
PrintEtatTraitementDonnees.DataEntreprise.Lines.Add(RParc.Text3);
PrintEtatTraitementDonnees.DataEntreprise.Lines.Add(RParc.Text4);

PrintEtatTraitementDonnees.ImageCodebarre.Picture:=ImageCodebarre.Picture;

LMaxDefaut:=25;
CMaxDefaut:=44;

LMax:=ValeurConfigurationTableauPrint('Paysage').RowMax;
CMax:=ValeurConfigurationTableauPrint('Paysage').ColMax;

NbrRowActif:=0;
ARow:=0;
while ARow<=Tableau.RowCount-1 do
begin
     if(Tableau.RowHeights[ARow]>10)then
     begin
          NbrRowActif:=NbrRowActif+1;
     end;
ARow:=ARow+1;
end;

Division(NbrRowActif,LMax,NbrPage,m);
if(m>0)then NbrPage:=NbrPage+1;

for LClean:=DebutRowIn to LMaxDefaut do
for C:=0 to CMaxDefaut do
CleanImprimeEtatTD(LClean,C,False);

ARow:=0;
ACol:=0;
//L:=DebutRowIn;
LFixed:=0;
C:=0;
m:=1;
while ARow<=Tableau.RowCount-1 do
begin

     if(Tableau.RowHeights[ARow]>10)then
     begin
          //L:=DebutRowIn;
          while(DebutRowIn<=LMax)and(ARow<=Tableau.RowCount-1)do//............
          begin
               if(Tableau.RowHeights[ARow]>10)then
               begin
                    if(DebutRowIn=0)and(ARow<>0)then //............
                    begin
                         LFixed:=1;
                         while(LFixed<=FixedRow)do
                         begin
                              C:=0;
                              ACol:=0;
                              while(ACol<=Tableau.ColCount-1)do
                              begin
                                   if(Tableau.ColWidths[ACol]>10)then
                                   begin
                                        CleanImprimeEtatTD(DebutRowIn,C,True);//.........
                                        AjusterImprimeEtatTD(DebutRowIn,ACol,DebutRowIn,C,Tableau,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,EcartTableau);//..........
                                        C:=C+1;
                                   end;
                              ACol:=ACol+1;
                              end;
                              LFixed:=LFixed+1;
                              DebutRowIn:=DebutRowIn+1;//...............
                         end;
                    end
                    else
                    begin
                         C:=0;
                         ACol:=0;
                         while(ACol<=Tableau.ColCount-1)do
                         begin
                              if(Tableau.ColWidths[ACol]>10)then
                              begin
                                   CleanImprimeEtatTD(DebutRowIn,C,True);//..........
                                   AjusterImprimeEtatTD(ARow,ACol,DebutRowIn,C,Tableau,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,EcartTableau);//..........
                                   C:=C+1;
                              end;
                         ACol:=ACol+1;
                         end;
                    DebutRowIn:=DebutRowIn+1;//........
                    ARow:=ARow+1;
                    end;

                    if(DebutRowIn-1=LMax)or(ARow-1=Tableau.RowCount-1)then //...........
                    begin
                         if(ImprimeEtat=true)or(DebutRowIn-1=LMax)then//.........
                         begin
                              PrintEtatTraitementDonnees.NumPage.Caption:='Page N°: '+CompleteZeroGauche(inttostr(m),'2')+'/'+CompleteZeroGauche(inttostr(NbrPage),'2');
                              if(ApercuAvantImpression=true)
                              then PrintEtatTraitementDonnees.Preview
                              else PrintEtatTraitementDonnees.Print;
                              for LClean:=0 to LMax do
                              for C:=0 to CMax do
                              CleanImprimeEtatTD(LClean,C,False);
                              m:=m+1;
                              DebutRowIn:=0;
                         end;

                    if(ARow-1=Tableau.RowCount-1)then
                    begin
                         if(DebutRowIn=0)then EcartTableau:=0;
                         if(DebutRowIn+EcartTableau>LMax)
                         then
                         begin
                              PrintEtatTraitementDonnees.NumPage.Caption:='Page N°: '+CompleteZeroGauche(inttostr(m),'2')+'/'+CompleteZeroGauche(inttostr(NbrPage),'2');
                              if(ApercuAvantImpression=true)
                              then PrintEtatTraitementDonnees.Preview
                              else PrintEtatTraitementDonnees.Print;
                              for LClean:=0 to LMax do
                              for C:=0 to CMax do
                              CleanImprimeEtatTD(LClean,C,False);
                              m:=m+1;
                              DebutRowIn:=0;
                              DebutRowOut:=0;
                              EcartTableau:=0;
                         end
                         else
                         begin
                              if(EcartTableau>=0)then DebutRowOut:=DebutRowIn+EcartTableau
                                                 else DebutRowOut:=DebutRowIn;
                         end;

                    end;

                    end;
               end
               else
               begin
                    if(ARow=Tableau.RowCount-1)then
                    begin
                         PrintEtatTraitementDonnees.NumPage.Caption:='Page N°: '+CompleteZeroGauche(inttostr(m),'2')+'/'+CompleteZeroGauche(inttostr(NbrPage),'2');
                         if(ApercuAvantImpression)
                         then PrintEtatTraitementDonnees.Preview
                         else PrintEtatTraitementDonnees.Print;
                         for LClean:=0 to LMax do
                         for C:=0 to CMax do
                         CleanImprimeEtatTD(LClean,C,False);
                         m:=m+1;
                         DebutRowIn:=0;
                    end;
                    ARow:=ARow+1;
               end;
          end;
     end
     else
     begin
          if(ARow=Tableau.RowCount-1)then
          begin
               PrintEtatTraitementDonnees.NumPage.Caption:='Page N°: '+CompleteZeroGauche(inttostr(m),'2')+'/'+CompleteZeroGauche(inttostr(NbrPage),'2');
               if(ApercuAvantImpression=true)
               then PrintEtatTraitementDonnees.Preview
               else PrintEtatTraitementDonnees.Print;
               for LClean:=0 to LMax do
               for C:=0 to CMax do
               CleanImprimeEtatTD(LClean,C,False);
               m:=m+1;
               DebutRowIn:=0;
          end;
          ARow:=ARow+1;
     end;
end;

end;

