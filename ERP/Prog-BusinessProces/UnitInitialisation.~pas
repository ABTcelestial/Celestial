Function SoldeDomiciliationAvis(TableauListeAvisNotifier:TStringGrid; RBegin:integer; NumDomiciliation,Domiciliation,DateFin:string; OKRemplireTableauListeAvisNotifier:boolean;  var EtatSoldePlanifier,EtatSoldeTrouver:string; var REnd:integer):real;
var  R,RSolde,RApres,ColDebitCredit,FinControleRow:integer;   TotalDebit,TotalCredit,MontantDebitCredit,SoldeAvis:real;
     OKDomiciliation:boolean;  EtatSoldeDebitCredit,Notification,TypeData,DateBegin,DateEnd,TypeProcesSDA,FichierConcerneSDA,AdresseSDA,AdresseBaseAvis:string;
     PositionTypeAvis,NumTypeAvis,SigneDebitCredit:integer; CompteImputation,DebitCredit,JourneauxAuxiliaireUtilise,TypeProcesRecherche,FichierconcerneRecherche,DebitCreditAvis:string;
     TTypeAvisChargement:TTypeAviss;
begin

     DateBegin:=datetostr(FSMenuPrincipal.EditDateDebut.Date);
     DateEnd:=datetostr(FSMenuPrincipal.EditDateFin.Date);

     if(OKRemplireTableauListeAvisNotifier=true)then
     begin
           TableauListeAvisNotifier.ColCount:=9;
           TableauListeAvisNotifier.Cols[0].Text:='N°';
           TableauListeAvisNotifier.Cols[1].Text:='N° Avis';
           TableauListeAvisNotifier.Cols[2].Text:='Date Avis';
           TableauListeAvisNotifier.Cols[3].Text:='N° Pičce';
           TableauListeAvisNotifier.Cols[4].Text:='Tičrs';
           TableauListeAvisNotifier.Cols[5].Text:='Domiciliation';
           TableauListeAvisNotifier.Cols[6].Text:='Libellé';
           TableauListeAvisNotifier.Cols[7].Text:='Montant Débit';
           TableauListeAvisNotifier.Cols[8].Text:='Montant Crédit';

           TableauListeAvisNotifier.RowCount:=2;
           TableauListeAvisNotifier.Rows[1].Text:='';
           R:=RBegin;

           RSolde:=R+1;
           TableauListeAvisNotifier.Rows[RSolde].Text:='';
           TableauListeAvisNotifier.Cells[1,RSolde]:='000000';
           TableauListeAvisNotifier.Cells[2,RSolde]:='';
           TableauListeAvisNotifier.Cells[3,RSolde]:='';
           TableauListeAvisNotifier.Cells[4,RSolde]:='';
           TableauListeAvisNotifier.Cells[5,RSolde]:='';
           TableauListeAvisNotifier.Cells[6,RSolde]:='Solde au '+datetostr(FSMenuPrincipal.EditDateDebut.Date-1);
           TableauListeAvisNotifier.Cells[7,RSolde]:='';
           TableauListeAvisNotifier.Cells[8,RSolde]:='';

           RApres:=R+2;
           TableauListeAvisNotifier.Rows[RApres].Text:='';
           TableauListeAvisNotifier.Cells[1,RApres]:='999999';
           TableauListeAvisNotifier.Cells[2,RApres]:='';
           TableauListeAvisNotifier.Cells[3,RApres]:='';
           TableauListeAvisNotifier.Cells[4,RApres]:='';
           TableauListeAvisNotifier.Cells[5,RApres]:='';
           TableauListeAvisNotifier.Cells[6,RApres]:='Cumul du '+datetostr(FSMenuPrincipal.EditDateFin.Date+1);
           TableauListeAvisNotifier.Cells[7,RApres]:='';
           TableauListeAvisNotifier.Cells[8,RApres]:='';

           R:=R+2;
     end;

     Notification:='';
     MontantDebitCredit:=0;
     TotalDebit:=0;
     TotalCredit:=0;
     SoldeAvis:=0;
     SigneDebitCredit:=1;
     EtatSoldePlanifier:='';
     EtatSoldeTrouver:='';

     TypeProcesSDA:='Business';
     FichierConcerneSDA:='FDomiciliation';
     if not(FunctionAdresseProces(TypeProcesSDA,FichierConcerneSDA,'',AdresseSDA,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcerneSDA<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConcerneSDA+'} recherché !');
     end;

     ChDomiciliation:=AdresseSDA;
     assignfile(FDomiciliation,ChDomiciliation);
     try
     if FileExists(ChDomiciliation)then
     Reset(FDomiciliation)
     else Rewrite(FDomiciliation);
     Seek(FDomiciliation,0);
     OKDomiciliation:=false;
     while not eof(FDomiciliation)and(OKDomiciliation=false)do
     begin
          read(FDomiciliation,RDomiciliation); Application.ProcessMessages;

          if(NumDomiciliation<>'')then
          begin
               if(RDomiciliation.NumDomiciliation=NumDomiciliation)
               then OKDomiciliation:=true
               else OKDomiciliation:=false;
          end
          else
          if(Domiciliation<>'')then
          begin
               if(RDomiciliation.DesignationDomiciliation=Domiciliation)
               then OKDomiciliation:=true
               else OKDomiciliation:=false;
          end
          else OKDomiciliation:=false;

          if(OKDomiciliation=true)then EtatSoldePlanifier:=RDomiciliation.EtatSoldeDebitCredit;

     end;
     finally
     CloseFile(FDomiciliation);
     end;

     if(OKDomiciliation=true)then
     begin
          TTypeAvisChargement:=RemplireTableauTypeAvis;

          if not(FunctionAdresseProces('Business','FBaseAvis','',AdresseBaseAvis,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               if('FBaseAvis'<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+'FBaseAvis'+' recherché !');
          end;
          ChBaseAvisControle:=AdresseBaseAvis;
          assignfile(FBaseAvisControle,ChBaseAvisControle);
          try
          if FileExists(ChBaseAvisControle)then
          Reset(FBaseAvisControle)
          else Rewrite(FBaseAvisControle);
          Seek(FBaseAvisControle,0);
          while not eof(FBaseAvisControle)do
          begin
               Read(FBaseAvisControle,RBaseAvisControle);  Application.ProcessMessages;
               if(RBaseAvisControle.DesignationBaseAvis<>'')then
               begin
                    TypeProcesSDA:='Business';
                    FichierConcerneSDA:=RBaseAvisControle.DesignationBaseAvis;
                    if not(FunctionAdresseProces(TypeProcesSDA,FichierConcerneSDA,'',AdresseSDA,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                    begin
                         if(FichierConcerneSDA<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché !'+' {'+FichierConcerneSDA+'}');
                    end;

                    ChAvisControle:=AdresseSDA;
                    assignfile(FAvisControle,ChAvisControle);
                    try
                    if FileExists(ChAvisControle)then
                    Reset(FAvisControle)
                    else Rewrite(FAvisControle);
                    Seek(FAvisControle,0);
                    while not eof(FAvisControle)do
                    begin
                         read(FAvisControle,RAvisControle);  Application.ProcessMessages;

                         DebitCreditAvis:=RAvisControle.DebitCredit;

                         if(DebitCreditAvis='')then
                         begin
                              //IndiqueTypeAvis(RAvisControle.DesignationTypeAvis,PositionTypeAvis,NumTypeAvis,SigneDebitCredit,CompteImputation,DebitCreditAvis,TypeProcesRecherche,FichierconcerneRecherche,JourneauxAuxiliaireUtilise);
                              NumTypeAvis:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].NumTypeAvis;
                              SigneDebitCredit:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].SigneDebitCredit;
                              CompteImputation:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].CompteImputation;
                              DebitCreditAvis:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].DebitCredit;
                              TypeProcesRecherche:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].TypeProces;
                              FichierconcerneRecherche:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].FichierConserne;
                              JourneauxAuxiliaireUtilise:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].JourneauxAuxiliaireUtilise;
                         end;

                         OKDomiciliation:=RAvisControle.ValiditeAvis;

                         if(OKDomiciliation=true)then
                         begin
                              if(strtodate(RAvisControle.DateAvis)<=strtodate(DateFin))
                              then OKDomiciliation:=true
                              else OKDomiciliation:=false;
                         end;

                         if(OKDomiciliation=true)then
                         begin
                              if(NumDomiciliation<>'')then
                              begin
                                   if(RAvisControle.NumDomiciliationAvis=NumDomiciliation)
                                   then OKDomiciliation:=true
                                   else OKDomiciliation:=false;
                              end
                              else
                              if(Domiciliation<>'')then
                              begin
                                   if(RAvisControle.DomiciliationAvis=Domiciliation)
                                   then OKDomiciliation:=true
                                   else OKDomiciliation:=false;
                              end
                              else OKDomiciliation:=false;
                         end;

                         if(OKDomiciliation=true)then
                         begin
                              if(FunctionSoldeDomiciliationRisqueZero=true)then
                              begin
                                   if((DebitCreditAvis=EtatSoldePlanifier)and(DateCorrecte(RAvisControle.DateExecute)=false))
                                   then OKDomiciliation:=false;
                              end;
                         end;

                         if(OKDomiciliation=true)then
                         begin
                              //IndiqueTypeAvis(RAvisControle.DesignationTypeAvis,PositionTypeAvis,NumTypeAvis,SigneDebitCredit,CompteImputation,DebitCredit,TypeProcesRecherche,FichierconcerneRecherche,JourneauxAuxiliaireUtilise);
                              NumTypeAvis:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].NumTypeAvis;
                              SigneDebitCredit:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].SigneDebitCredit;
                              CompteImputation:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].CompteImputation;
                              DebitCredit:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].DebitCredit;
                              TypeProcesRecherche:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].TypeProces;
                              FichierconcerneRecherche:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].FichierConserne;
                              JourneauxAuxiliaireUtilise:=TTypeAvisChargement[RAvisControle.PositionTypeAvis].JourneauxAuxiliaireUtilise;

                              if(DebitCreditAvis='Débit')then
                              begin

                                   TotalDebit:=TotalDebit+(RAvisControle.Montant*SigneDebitCredit);
                                   ColDebitCredit:=7;
                              end
                              else
                              if(DebitCreditAvis='Crédit')then
                              begin
                                   TotalCredit:=TotalCredit+(RAvisControle.Montant*SigneDebitCredit);
                                   ColDebitCredit:=8;
                              end
                              else
                              begin
                                   MontantDebitCredit:=MontantDebitCredit+(RAvisControle.Montant*SigneDebitCredit);
                                   if(Notification='')
                                   then Notification:='{Avis N°: '+inttostr(RAvisControle.NumAvis)+'}'
                                   else Notification:=Notification+' '+'{Avis N°: '+inttostr(RAvisControle.NumAvis)+'}';
                              end;

                              SoldeAvis:=TotalDebit-TotalCredit;

                              if(OKRemplireTableauListeAvisNotifier=true)then
                              begin
                                    if(strtodate(RAvisControle.DateAvis)<strtodate(DateBegin))then
                                    begin
                                         TableauListeAvisNotifier.Cells[ColDebitCredit,RSolde]:=Vergule(floattostr(strtoreal(TableauListeAvisNotifier.Cells[ColDebitCredit,RSolde])+(RAvisControle.Montant*SigneDebitCredit)),'2','C','');
                                    end
                                    else
                                    if(strtodate(RAvisControle.DateAvis)>strtodate(DateEnd))then
                                    begin
                                         TableauListeAvisNotifier.Cells[ColDebitCredit,RApres]:=Vergule(floattostr(strtoreal(TableauListeAvisNotifier.Cells[ColDebitCredit,RApres])+(RAvisControle.Montant*SigneDebitCredit)),'2','C','');
                                    end
                                    else
                                    begin
                                         R:=R+1;
                                         TableauListeAvisNotifier.Rows[R].Text:=inttostr(R);
                                         TableauListeAvisNotifier.Cells[1,R]:=inttostr(RAvisControle.NumAvis);
                                         TableauListeAvisNotifier.Cells[2,R]:=RAvisControle.DateAvis;
                                         TableauListeAvisNotifier.Cells[3,R]:=RAvisControle.NumPiece;
                                         RTiers:=ChercherTiers(RAvisControle.TypeProces,RAvisControle.AvisConcerneTiers,RAvisControle.CodeTiers,'');
                                         TableauListeAvisNotifier.Cells[4,R]:=RTiers.NomTiers+' '+RTiers.PrenomTiers;
                                         TableauListeAvisNotifier.Cells[5,R]:=RAvisControle.NumDomiciliationAvis+' '+RAvisControle.DomiciliationAvis;
                                         TableauListeAvisNotifier.Cells[6,R]:=RAvisControle.NatureDepense;
                                         TableauListeAvisNotifier.Cells[ColDebitCredit,R]:=Vergule(floattostr(RAvisControle.Montant*SigneDebitCredit),'2','C','');
                                    end;
                              end;
                         end;
                    end;
                    finally
                    CloseFile(FAvisControle);
                    end;
               end;
          end;
          finally
          CloseFile(FBaseAvisControle);
          end;

          if(SoldeAvis>=0)then
          begin
               EtatSoldeTrouver:='Débit';
               ColDebitCredit:=7;
               SigneDebitCredit:=1;
          end
          else
          begin
               EtatSoldeTrouver:='Crédit';
               ColDebitCredit:=8;
               SigneDebitCredit:=-1;
          end;
     end;
     if(Notification<>'')then AfficherMessage('Attention ! '+Notification);

     SoldeDomiciliationAvis:=SoldeAvis*SigneDebitCredit;

     if(OKRemplireTableauListeAvisNotifier=true)then
     begin
           if(R>0)then
           begin
                REnd:=R+3;
                TableauListeAvisNotifier.RowCount:=R+4;
                TableauListeAvisNotifier.Rows[R+1].Text:='';
                TableauListeAvisNotifier.Rows[R+2].Text:='';
                TableauListeAvisNotifier.Rows[R+3].Text:='';

                TableauListeAvisNotifier.Cells[6,R+2]:='Totaux';
                TableauListeAvisNotifier.Cells[6,R+3]:='Solde';

                TableauListeAvisNotifier.Cells[7,R+2]:=Vergule(floattostr(TotalDebit),'2','C','');
                TableauListeAvisNotifier.Cells[8,R+2]:=Vergule(floattostr(TotalCredit),'2','C','');
                TableauListeAvisNotifier.Cells[ColDebitCredit,R+3]:=Vergule(floattostr(SoldeAvis*SigneDebitCredit),'2','C','');
           end
           else TableauListeAvisNotifier.RowCount:=2;

           AjusterColWidth(TableauListeAvisNotifier,'','');

           TypeData:='';

           if(FSMenuPrincipal.EditRubriqueTrie.Text='2')
           then
           begin
                TypeData:='Date';
           end;

           if(FSMenuPrincipal.EditRubriqueTrie.Text='1')
           or(FSMenuPrincipal.EditRubriqueTrie.Text='7')
           or(FSMenuPrincipal.EditRubriqueTrie.Text='8')
           then
           begin
                TypeData:='Num';
           end;

           if(FSMenuPrincipal.TableauLiseAvisNotifier.RowCount-4>1)
           then FinControleRow:=FSMenuPrincipal.TableauLiseAvisNotifier.RowCount-4
           else FinControleRow:=FSMenuPrincipal.TableauLiseAvisNotifier.RowCount-1;
           TrierTableauARowSpecial(FSMenuPrincipal.TableauLiseAvisNotifier,2,FinControleRow,1,FSMenuPrincipal.EditRubriqueTrie.Text,TypeData,'+');
     end;
end;

Function ControleSoldeAllDomiciliations(TableauControleSoldeDomiciliation,TableauListeAvisNotifier:TStringGrid; AfficherTous:boolean; var LastRow:integer):boolean;
var   RCSAD,RBegin:integer; EtatSoldePlanifier,EtatSoldeTrouver,TypeProces,FichierConserne,Adresse:string;  Solde:real;  OKDomiciliation:boolean;
begin
     AccelerationAffichageTableau(TableauControleSoldeDomiciliation,true);
     ControleSoldeAllDomiciliations:=false;
     TableauControleSoldeDomiciliation.ColCount:=7;
     TableauControleSoldeDomiciliation.Cols[0].Text:='N°';
     TableauControleSoldeDomiciliation.Cols[1].Text:='Num';
     TableauControleSoldeDomiciliation.Cols[2].Text:='Domiciliation';
     TableauControleSoldeDomiciliation.Cols[3].Text:='Identificateur';
     TableauControleSoldeDomiciliation.Cols[4].Text:='Information de base';
     TableauControleSoldeDomiciliation.Cols[5].Text:='Information analysé';
     TableauControleSoldeDomiciliation.Cols[6].Text:='Notification';

     TableauControleSoldeDomiciliation.RowCount:=2;
     TableauControleSoldeDomiciliation.Rows[1].Text:='';
     

     TypeProces:='Business';   FichierConserne:='FDomiciliation';
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConserne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConserne+'} recherché !');
     end;
     ChDomiciliationCopie:=Adresse;
     assignfile(FDomiciliationCopie,ChDomiciliationCopie);
     try
     if FileExists(ChDomiciliationCopie)then
     Reset(FDomiciliationCopie)
     else Rewrite(FDomiciliationCopie);
     Seek(FDomiciliationCopie,0);
     RCSAD:=0;
     RBegin:=0;
     while not eof(FDomiciliationCopie)do
     begin
          read(FDomiciliationCopie,RDomiciliationCopie); Application.ProcessMessages;
          if(RDomiciliationCopie.EtatSoldeDebitCredit='Débit')or(RDomiciliationCopie.EtatSoldeDebitCredit='Crédit')then
          begin
               Solde:=SoldeDomiciliationAvis(TableauListeAvisNotifier,RBegin,RDomiciliationCopie.NumDomiciliation,'',datetostr(Date),true,EtatSoldePlanifier,EtatSoldeTrouver,RBegin);
               if(AfficherTous=true)then
               begin
                    OKDomiciliation:=true;
               end
               else
               begin
                    if(EtatSoldePlanifier<>EtatSoldeTrouver)
                    then OKDomiciliation:=true
                    else OKDomiciliation:=false;
               end;
          end
          else OKDomiciliation:=false;

          if(OKDomiciliation=true)then
          begin
               RCSAD:=RCSAD+1;
               TableauControleSoldeDomiciliation.Rows[RCSAD].Text:=inttostr(RCSAD);
               TableauControleSoldeDomiciliation.Cells[1,RCSAD]:=RDomiciliationCopie.NumDomiciliation;
               TableauControleSoldeDomiciliation.Cells[2,RCSAD]:=RDomiciliationCopie.DesignationDomiciliation;
               TableauControleSoldeDomiciliation.Cells[3,RCSAD]:=RDomiciliationCopie.Identificateur;
               TableauControleSoldeDomiciliation.Cells[4,RCSAD]:='Nature du Solde: '+RDomiciliationCopie.EtatSoldeDebitCredit;
               TableauControleSoldeDomiciliation.Cells[5,RCSAD]:='Etat du Solde: '+EtatSoldeTrouver;
               TableauControleSoldeDomiciliation.Cells[6,RCSAD]:='Montant du Solde: '+Vergule(floattostr(Solde),'2','C','');
          end;
     end;
     finally
     CloseFile(FDomiciliationCopie);
     end;

     if(RCSAD>0)then
     begin
          TableauControleSoldeDomiciliation.RowCount:=RCSAD+1;
          ControleSoldeAllDomiciliations:=true;
          LastRow:=RCSAD;
     end
     else
     begin
          TableauControleSoldeDomiciliation.RowCount:=2;
          ControleSoldeAllDomiciliations:=false;
          LastRow:=0;
     end;

     AjusterColWidth(TableauControleSoldeDomiciliation,'','');

     AccelerationAffichageTableau(TableauControleSoldeDomiciliation,false);
end;

Function ControlePieceAllDomiciliations(TableauControleDomiciliation:TStringGrid; LastRow:integer; AfficherTous:boolean):boolean;
