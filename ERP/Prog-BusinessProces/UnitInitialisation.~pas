Procedure AccelerationAffichageTableau(Tableau:TStringGrid; OKBegin:Boolean);
begin
     if(OKBegin=true)then LockGrid(Tableau) else UnLockGrid(Tableau);
end;

procedure LockGrid(Tableau: TStringGrid);
//   Blocage de la mise ŕ jour de l'affichage de la StringGrid 
begin 
     Tableau.Perform(WM_SETREDRAW, 0, 0);
end; 
{ ====================================================================== } 
procedure UnLockGrid(Tableau: TStringGrid);
//   Déblocage de la mise ŕ jour de l'affichage de la StringGrid
begin
     Tableau.Perform(WM_SETREDRAW, 1, 0);
     Tableau.Invalidate;
end; 
