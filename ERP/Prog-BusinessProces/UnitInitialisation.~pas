     RRubriqueFicheTechniqueCopie.NumFicheTechnique:=0;
     RRubriqueFicheTechniqueCopie.DesignationRubrique:='';
     RRubriqueFicheTechniqueCopie.Quantite:=0;
     RRubriqueFicheTechniqueCopie.TypeUnite:='';
     RRubriqueFicheTechniqueCopie.PrixUnitaire:=0;
     RRubriqueFicheTechniqueCopie.Montant:=0;

     RFicheTechniqueCopie.NumFicheTechnique:=0;
     RFicheTechniqueCopie.CodeProjet:='';
     RFicheTechniqueCopie.DesignationFicheTechnique:='';
     RFicheTechniqueCopie.NumTypeAvis:=0;

     if(NumRubrique<>'')and(NumFicheTechnique='')then
     begin
          TypeProces:='Business'; FichierConcerne:='FRubriqueFicheTechnique';
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
