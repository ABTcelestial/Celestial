procedure IndiquerAdresseIPAuxClientReseaux(NomPosteReseauxConnexionCible,DatePublication,HeurePublication:string);
var  NomDossierPartageOut,EmlacementLocalOuReseauxOut,AdresseReseauxCible,AdresseReseauxLocal,DatePublicationWrite,HeurePublicationWrite:string;
