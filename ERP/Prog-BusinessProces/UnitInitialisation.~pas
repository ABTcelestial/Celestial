Function ChercherPrelevementLastSpecial(DatePrelevement,HeurePrelevement:string; var OKPrelevementLSExiste:boolean):string;
var  TypeProcesPrelevementLS,FichierConcernePrelevementLS,AdressePrelevementLS:string;
     OKTraitement:boolean;
     NumPrelevementLast,DatePrelevementLast,HeurePrelevementLast:string;
begin
     NumPrelevementLast:='';
     DatePrelevementLast:=DatePrelevement;
     HeurePrelevementLast:=HeurePrelevement;

     TypeProcesPrelevementLS:='Business';
     FichierConcernePrelevementLS:='FPrelevement';
     AdressePrelevementLS:='';
     if not(FunctionAdresseProces(TypeProcesPrelevementLS,FichierConcernePrelevementLS,'',AdressePrelevementLS,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcernePrelevementLS<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConcernePrelevementLS+'} recherché !');
     end;

     ChPrelevement:=AdressePrelevementLS;
     assignfile(FPrelevement,ChPrelevement);
     if FileExists(ChPrelevement)then
     begin
           try
           Reset(FPrelevement);
           Seek(FPrelevement,0);
           OKPrelevementLSExiste:=false;
           while(not eof(FPrelevement))and(OKPrelevementLSExiste=false)do
           begin
                Read(FPrelevement,RPrelevement);  Application.ProcessMessages;
                OKTraitement:=false;

                if datecorrecte(RPrelevement.DatePrelevement)and TimeCorrecte(RPrelevement.HeurePrelevement)then
                begin
                     if(strtodate(RPrelevement.DatePrelevement)<strtodate(DatePrelevement))then
                     begin
                          OKTraitement:=true
                     end
                     else
                     if(strtodate(RPrelevement.DatePrelevement)=strtodate(DatePrelevement))
                     and(strtotime(RPrelevement.HeurePrelevement)<strtotime(HeurePrelevement))then
                     begin
                          OKTraitement:=true
                     end
                     else
                     if(strtodate(RPrelevement.DatePrelevement)=strtodate(DatePrelevement))
                     and(strtotime(RPrelevement.HeurePrelevement)=strtotime(HeurePrelevement))then
                     begin
                          OKPrelevementLSExiste:=true
                     end;
                end;

                if(OKTraitement=true)then
                begin
                     NumPrelevementLast:=inttostr(RPrelevement.NumPrelevement);
                     DatePrelevementLast:=RPrelevement.DatePrelevement;
                     HeurePrelevementLast:=RPrelevement.HeurePrelevement;
                end;
           end;
           Finally
           CloseFile(FPrelevement);
           end;
     end;

     ChercherPrelevementLastSpecial:=NumPrelevementLast;
end;

