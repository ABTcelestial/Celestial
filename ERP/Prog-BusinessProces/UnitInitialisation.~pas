     NbrAExecute,NbrRStockArticleExecute,Nbr:integer;
begin
     NbrAExecute:=NombreOptimaleBufferSize('RStock');;
     SetLength(TableauRStockArticle,NbrAExecute);

     IndexSousFamilleStock:=1;
     setlength(ArrayIndexSousFamilleStock,IndexSousFamilleStock);
     ArrayIndexSousFamilleStock[IndexSousFamilleStock-1]:='';

     IndiceTableauMax:=0;
