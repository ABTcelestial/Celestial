Procedure MiseAjourCaptionMenuPrincipal(TableauAdresseDossierPartageReseaux:TStringGrid);
var  R,l,NbrPoste:integer;   ListePosteDataSource,ListePosteConnecteReseaux:string;   OKAdresseProcesCopie,OKSousReseaux:boolean;
begin
     if(FSMenuPrincipal.RBAutoriseConectiviteRepertoireActuel.Checked=false)then
     begin
          FSMenuPrincipal.AfficheSessionOuverte.Caption:=RRegistre.Repertoire+' - Exercice '+RRegistre.Exercice+' - '+'Menu Principal';
     end
     else
     begin
          FSMenuPrincipal.AfficheSessionOuverte.Caption:=FSMenuPrincipal.EditRepertoireActuel.Text+' - Exercice '+FSMenuPrincipal.EditExerciceRepertoireActuel.Text+' - '+'Menu Principal';
     end;

     if(FSMenuPrincipal.AfficheSessionOuverte.Caption<>'')then
     begin
           R:=1;
           l:=0;
           ListePosteDataSource:='                              Data source: ';
           ListePosteConnecteReseaux:='';
           NbrPoste:=0;
           OKSousReseaux:=false;
           while(R<=TableauAdresseDossierPartageReseaux.RowCount-1)do
           begin
                if(Firstlaters(TableauAdresseDossierPartageReseaux.Cells[5,R],8)='Connecté')then
                begin
                     NbrPoste:=NbrPoste+1;
                     if(ListePosteConnecteReseaux='')
                     then ListePosteConnecteReseaux:=ExtractFileDir(TableauAdresseDossierPartageReseaux.Cells[3,R])
                     else ListePosteConnecteReseaux:=ListePosteConnecteReseaux+', '+ExtractFileDir(TableauAdresseDossierPartageReseaux.Cells[3,R]);

                     OpenFParc(RParc);
                     ChAdresseProcesCopie:=RParc.Parcours+'\'+Exercice+'FAdresseProces';
                     assignfile(FAdresseProcesCopie,ChAdresseProcesCopie);
                     if FileExists(ChAdresseProcesCopie)then
                     begin
                          try
                          Reset(FAdresseProcesCopie);
                          Seek(FAdresseProcesCopie,0);
                          OKAdresseProcesCopie:=false;
                          while not eof(FAdresseProcesCopie)and(OKAdresseProcesCopie=false)do
                          begin
                               read(FAdresseProcesCopie,RAdresseProcesCopie);
                               if(RAdresseProcesCopie.TypeProces='Réseaux')
                               and(RAdresseProcesCopie.AdresseProces=TableauAdresseDossierPartageReseaux.Cells[3,R])
                               then
                               begin
                                    OKAdresseProcesCopie:=true;
                                    ListePosteDataSource:=ListePosteDataSource+ExtractFileDir(RAdresseProcesCopie.AdresseProces)+'. ';
                                    l:=l+1;
                               end;
                          end;
                          finally
                          CloseFile(FAdresseProcesCopie);
                          end;
                     end;
                end;        
           R:=R+1;
           end;

           if(l=0)then
           begin
                FSMenuPrincipal.AfficheSessionOuverte.Caption:=FSMenuPrincipal.AfficheSessionOuverte.Caption+ListePosteDataSource+'Local';
           end
           else
           begin
                FSMenuPrincipal.AfficheSessionOuverte.Caption:=FSMenuPrincipal.AfficheSessionOuverte.Caption+ListePosteDataSource;
           end;

           if(ListePosteConnecteReseaux='')then
           begin
                FSMenuPrincipal.AfficheSessionOuverte.Caption:=FSMenuPrincipal.AfficheSessionOuverte.Caption+'         Aucun Poste Connecté';
                FSMenuPrincipal.RBConnectiviteReseaux.Checked:=false;
           end
           else
           begin
                FSMenuPrincipal.AfficheSessionOuverte.Caption:=FSMenuPrincipal.AfficheSessionOuverte.Caption+'         '+inttostr(NbrPoste)+' Poste Connectés: '+ListePosteConnecteReseaux;
                FSMenuPrincipal.RBConnectiviteReseaux.Checked:=true;
           end;
     end;
end;    //FIN TableauAdresseDossierPartageReseaux

