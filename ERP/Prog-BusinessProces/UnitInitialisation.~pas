Procedure PositionAffichage(FicheSaisie:TForm; Affiche:TPanel; PositionHorizontale,PositionVerticale,EcartHorizontal,EcartVertical:string);
begin
     if(EcartHorizontal='')then EcartHorizontal:='10';

     if(PositionHorizontale='')then
     begin
          Affiche.Left:=strtointeger(EcartHorizontal);
     end;

     if(PositionHorizontale='Midel')then
     begin
          Affiche.Left:=ValeAbsolue(FicheSaisie.Width/2)-ValeAbsolue(Affiche.Width/2)+strtointeger(EcartHorizontal);
     end;

     if(PositionHorizontale='Left')then
     begin
          Affiche.Left:=strtointeger(EcartHorizontal);
     end;

     if(PositionHorizontale='Right')then
     begin
          Affiche.Left:=FicheSaisie.Width-Affiche.Width-strtointeger(EcartHorizontal);
     end;

     ///////////////////////////////////////////////////////////////////////////

     if(EcartVertical='')then EcartVertical:='10';

     if(PositionVerticale='')then
     begin
          Affiche.Top:=strtointeger(EcartVertical);
     end;

     if(PositionVerticale='Midel')then
     begin
          Affiche.Top:=ValeAbsolue(FicheSaisie.Height/2)-ValeAbsolue(Affiche.Height/2)+strtointeger(EcartVertical);
     end;

     if(PositionVerticale='Left')then
     begin
          Affiche.Top:=strtointeger(EcartVertical);
     end;

     if(PositionVerticale='Right')then
     begin
          Affiche.Top:=FicheSaisie.Height-Affiche.Height-strtointeger(EcartVertical);
     end;
end;

