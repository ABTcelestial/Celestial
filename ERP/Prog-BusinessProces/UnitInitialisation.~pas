Procedure IndiquerPositionListeMouvement(PositionMouvement:integer; PositionTypeMouvement,ExerciceAnneeConserne:string;  var PBegin,PEnd:integer; var RegistrePositionListeMouvementParPeriode:RegistrePositionListeMouvementParPeriodeS);
var  iA,iMois,iLM:integer; TypeProcesLM,FichierConserneLM,AdresseLM:string;  OKListeMouvement:boolean;
begin
     for iA:=2010 to 2050 do
     for iMois:=1 to 12 do
     begin
          RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementBegin:=999999999;
          RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementEnd:=0;
     end;

     TypeProcesLM:='Business';   FichierConserneLM:='FListeMouvement ';
     AdresseLM:='';
     if not(FunctionAdresseProces(TypeProcesLM,FichierConserneLM,'',AdresseLM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConserneLM<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConserneLM+'} recherché !');
     end;

     ChListeMouvement:=IndiqueAdresseListeMouvement(PositionTypeMouvement,TypeProcesReseauxListeMouvement);//AdresseLM;
     ChListeMouvement:=ConvertirAdresseExerciceAnnee(ChListeMouvement,ExerciceAnnee,ExerciceAnneeConserne);
     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
     Seek(FListeMouvement,0);
     PBegin:=999999999;
     PEnd:=0;
     iLM:=0;
     while not eof(FListeMouvement)do
     begin
          read(FListeMouvement,RListeMouvement);

          OKListeMouvement:=RListeMouvement.ValidationListeMouvement;

          if(OKListeMouvement=true)then
          begin
               if(RListeMouvement.PositionMouvement=PositionMouvement)
               then OKListeMouvement:=true
               else OKListeMouvement:=false;
          end;

          if(OKListeMouvement=true)then
          begin
               if(PBegin>iLM)then PBegin:=iLM;
               if(PEnd<iLM)then PEnd:=iLM;

               iAnnee:=strtointeger(MidelLaters(RListeMouvement.DateMouvement,7,10));
               iMois:=strtointeger(MidelLaters(RListeMouvement.DateMouvement,4,5));
               if(RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin>iLM)then RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin:=iLM;
               if(RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd<iLM)then RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd:=iLM;
          end;

          iLM:=iLM+1;
     end;
     finally
     CloseFile(FListeMouvement);
     end;

     if(PBegin=999999999)and(PEnd=0)then begin PBegin:=0; PEnd:=0; end;

     for iA:=2010 to 2050 do
     for iMois:=1 to 12 do if(RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementBegin=999999999)and(RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementEnd=0)then begin RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementBegin:=0; RegistrePositionListeMouvementParPeriode[iA,iMois].PositionListeMouvementEnd:=0; end;
end;

Procedure IndiquePositionBeginMinEndMaxFMouvementExportation(NomDossierPartageLocalExportation:string; RMouvementCopie:Rmouvements; var PositionBeginMin,PositionEndMax:integer; var RegistrePositionListeMouvementParPeriode:RegistrePositionListeMouvementParPeriodeS; var OKPositionExportation,OKPositionTrouver:boolean);
var   iMois:integer; ChRegistreReseaux,NomDossierPartageOut,EmlacementLocalOuReseauxOut,ExerciceReseauxPosition,FichierConcerneDetailMouvementRecherche:string;
      TableauListeFPR:ArrayListeFichierPartageReseaux; var TailTFPR:integer;
begin

     PositionBeginMin:=999999999;
     PositionEndMax:=0;
     iAnnee:=Strtointeger(ExerciceAnnee);
     for iMois:=1 to 12 do
     begin
          RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin:=999999999;
          RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd:=0;
     end;

     OKPositionExportation:=false;
     OKPositionTrouver:=false;

     OpenFParc(RParc);
     ChAdresseDossierPartageReseauxPosition:=RParc.Parcours+'\'+Exercice+'FAdresseDossierPartageReseaux';
     assignfile(FAdresseDossierPartageReseauxPosition,ChAdresseDossierPartageReseauxPosition);
     try
     if FileExists(ChAdresseDossierPartageReseauxPosition)then
     Reset(FAdresseDossierPartageReseauxPosition)
     else Rewrite(FAdresseDossierPartageReseauxPosition);
     Seek(FAdresseDossierPartageReseauxPosition,0);
     while not eof(FAdresseDossierPartageReseauxPosition)do
     begin
          read(FAdresseDossierPartageReseauxPosition,RAdresseDossierPartageReseauxPosition);

          RTypeMouvement:=ChercherTypeMouvement(RMouvementCopie.PositionTypeMouvement,ExerciceAnnee,AdresseFichierConcerne);
          FichierConcerneDetailMouvementRecherche:='DétailMouvement '+RTypeMouvement.DesignationTypeMouvement;

          if(RAdresseDossierPartageReseauxPosition.EmlacementLocalOuReseaux='Réseaux')
          and not(ExisteFichierConcernePartageReseauxInListeClient(RAdresseDossierPartageReseauxPosition.NomPosteReseaux,NomDossierPartageLocalExportation,FichierConcerneDetailMouvementRecherche,RListeFichierConcernePartageReseauxCopie,TableauListeFPR,TailTFPR,TypeProcesReseauxFichier))
          then
          begin
               OKPositionExportation:=true;

               ChRegistreReseaux:=RAdresseDossierPartageReseauxPosition.AdresseDossierPartageReseaux+'\WinBus'+DataIdentificateurReseaux+' '+NomDossierPartageOut+'.File';
               assignfile(FRegistre,ChRegistreReseaux);
               if FileExists(ChRegistreReseaux)then
               begin
                    try
                    Reset(FRegistre);
                    Seek(FRegistre,0);
                    read(FRegistre,RRegistre);
                    ExerciceReseauxPosition:=RRegistre.Exercice;

                    finally
                    closefile(FRegistre);
                    end;
               end
               else ExerciceReseauxPosition:=ExerciceAnnee;

               ChMouvementPosition:=RAdresseDossierPartageReseauxPosition.AdresseDossierPartageReseaux+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceReseauxPosition+'FMouvement'+' '+RAdresseDossierPartageReseauxPosition.NomPosteReseaux;
               assignfile(FMouvementPosition,ChMouvementPosition);
               if FileExists(ChMouvementPosition)then
               begin
                    try
                    Reset(FMouvementPosition) ;
                    Seek(FMouvementPosition,0);
                    while not eof(FMouvementPosition)do
                    begin
                         read(FMouvementPosition,RMouvementPosition);
                         if(RMouvementPosition.PositionMouvement=RMouvementCopie.PositionMouvement)
                         then
                         begin
                              OKPositionTrouver:=true;

                              if(PositionBeginMin>RMouvementPosition.PositionListeMouvementBegin)then PositionBeginMin:=RMouvementPosition.PositionListeMouvementBegin;
                              if(PositionEndMax<RMouvementPosition.PositionListeMouvementEnd)then PositionEndMax:=RMouvementPosition.PositionListeMouvementEnd;

                              iAnnee:=Strtointeger(ExerciceAnnee);
                              for iMois:=1 to 12 do
                              begin
                                   if(RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin>RMouvementPosition.RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin)then RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin:=RMouvementPosition.RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin;
                                   if(RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd<RMouvementPosition.RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd)then RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd:=RMouvementPosition.RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd;
                              end;
                         end;
                    end;
               finally
               CloseFile(FMouvementPosition);
               end;
               end;
          end;
     end;
     finally
     CloseFile(FAdresseDossierPartageReseauxPosition);
     end;

     if(OKPositionTrouver=true)then
     begin
          if(PositionBeginMin=999999999)then PositionBeginMin:=0;
          if(PositionEndMax=0)then PositionEndMax:=999999999;

          iAnnee:=Strtointeger(ExerciceAnnee);
          for iMois:=1 to 12 do
          begin
               if(RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin=999999999)then RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin:=0;
               if(RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd=0)then RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd:=999999999;
          end;
     end
     else
     begin
          PositionBeginMin:=RMouvementCopie.PositionListeMouvementBegin;
          PositionEndMax:=RMouvementCopie.PositionListeMouvementEnd;
          RegistrePositionListeMouvementParPeriode:=RMouvementCopie.RegistrePositionListeMouvementParPeriode;
     end;

     AffichageProgressif(FSAffichage.AfficheTexte4,'***** Chercher P° dans: '+booleantostr(OKPositionExportation)+' '+booleantostr(OKPositionTrouver)+' '+ChMouvementPosition,false,false);
end;

Function ChercherDossierPartageReseaux(NumAdresseDossierPartageReseaux,NomPosteReseaux,AdresseDossierPartageReseaux:string):RAdresseDossierPartageReseauxs;
var  OKAdresseDossierPartageReseauxChercher,OKTrouver,OKTrouverNum,OKTrouverNom,OKTrouverAdresse:boolean;
begin
     ChercherDossierPartageReseaux.NumAdresseDossierPartageReseaux:=0;
     ChercherDossierPartageReseaux.NomPosteReseaux:='';
     ChercherDossierPartageReseaux.AdresseDossierPartageReseaux:='';
     ChercherDossierPartageReseaux.EmlacementLocalOuReseaux:='';
     ChercherDossierPartageReseaux.Port:='';
     ChercherDossierPartageReseaux.AdresseIP:='';

     OpenFParc(RParc);
     ChAdresseDossierPartageReseauxChercher:=RParc.Parcours+'\'+Exercice+'FAdresseDossierPartageReseaux';
     assignfile(FAdresseDossierPartageReseauxChercher,ChAdresseDossierPartageReseauxChercher);
     try
     if FileExists(ChAdresseDossierPartageReseauxChercher)then
     Reset(FAdresseDossierPartageReseauxChercher)
     else Rewrite(FAdresseDossierPartageReseauxChercher);
     Seek(FAdresseDossierPartageReseauxChercher,0);
     OKAdresseDossierPartageReseauxChercher:=false;
     while not eof(FAdresseDossierPartageReseauxChercher)and(OKAdresseDossierPartageReseauxChercher=false)do
     begin
          read(FAdresseDossierPartageReseauxChercher,RAdresseDossierPartageReseauxChercher);

          if(NumAdresseDossierPartageReseaux<>'')then
          begin
               if(inttostr(RAdresseDossierPartageReseauxChercher.NumAdresseDossierPartageReseaux)=NumAdresseDossierPartageReseaux)
               then OKTrouverNum:=true
               else OKTrouverNum:=false;
          end
          else OKTrouverNum:=true;

          if(OKTrouverNum=true)then
          begin
               if(NomPosteReseaux<>'')then
               begin
                    if(RAdresseDossierPartageReseauxChercher.NomPosteReseaux=NomPosteReseaux)
                    then OKTrouverNom:=true
                    else OKTrouverNom:=false;
               end
               else OKTrouverNom:=true;
          end;

          if(OKTrouverNum=true)and(OKTrouverNom=true)then
          begin
               if(AdresseDossierPartageReseaux<>'')then
               begin
                    if(RAdresseDossierPartageReseauxChercher.AdresseDossierPartageReseaux=AdresseDossierPartageReseaux)
                    then OKTrouverAdresse:=true
                    else OKTrouverAdresse:=false;
               end
               else OKTrouverAdresse:=true;
          end;

          if(OKTrouverNum=true)and(OKTrouverNom=true)and(OKTrouverAdresse=true)then
          begin
               if(NumAdresseDossierPartageReseaux='')or(NomPosteReseaux='')or(AdresseDossierPartageReseaux='')
               then OKTrouver:=true
               else OKTrouver:=false;
          end
          else OKTrouver:=false;

          if(OKTrouver=true)
          then
          begin
               ChercherDossierPartageReseaux:=RAdresseDossierPartageReseauxChercher;
          end;
     end;
     finally
     CloseFile(FAdresseDossierPartageReseauxChercher);
     end;
end;

Procedure TrieTComboBox(EditComboBox:TComboBox; TypeData,TypeTrie:string);
var  i:integer;
begin
     PointeurTableauTriePointeur:=TList.Create;

     for i:=0 to EditComboBox.Items.Count-1 do
     begin
          TableauTriePointeur:=TTableauTriePointeur.Create;
          TableauTriePointeur.Rubrique:=EditComboBox.Items[i];
          TableauTriePointeur.RowPosition:=i;
          PointeurTableauTriePointeur.Add(TableauTriePointeur);
     end;

     TypeData:='';
     TypeTrie:='+';

     if(TypeData='')then
     begin
          if(TypeTrie='+')
          then PointeurTableauTriePointeur.Sort(TriePointeurStringPlus)
          else PointeurTableauTriePointeur.Sort(TriePointeurStringMoin);
     end;

     if(TypeData='Num')then
     begin
          if(TypeTrie='+')
          then PointeurTableauTriePointeur.Sort(TriePointeurNumPlus)
          else PointeurTableauTriePointeur.Sort(TriePointeurNumMoin);
     end;

     if(TypeData='Date')then
     begin
          if(TypeTrie='+')
          then PointeurTableauTriePointeur.Sort(TriePointeurDatePlus)
          else PointeurTableauTriePointeur.Sort(TriePointeurDateMoin);
     end;

     EditComboBox.Items.Text:='';
     for i:=0 to PointeurTableauTriePointeur.Count-1 do
     begin
          EditComboBox.Items.Add(TTableauTriePointeur(PointeurTableauTriePointeur[i]).Rubrique);
     end;

     for i:=0 to PointeurTableauTriePointeur.Count-1 do TTableauTriePointeur(PointeurTableauTriePointeur.Items[i]).Free;
     PointeurTableauTriePointeur.Free;
end;

