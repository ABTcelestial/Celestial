Function ExisteJournalListe(WithSolde,CodeJournal,Formule:string):boolean;
var REJL:integer; CodeExiste:string; OKJournalExiste:boolean;
begin
     OKJournalExiste:=false;
     if(WithSolde<>'')then Formule:=Formule+'{'+WithSolde+'}';
     REJL:=1;     
     while(REJL<=longueur(Formule))and(OKJournalExiste=false)do
     begin
          if(Formule[REJL]in['{'])then
          begin
               REJL:=REJL+1;
               CodeExiste:='';
               while not(Formule[REJL]in['}'])and(REJL<=longueur(Formule))do
               begin
                    CodeExiste:=CodeExiste+Formule[REJL];
                    REJL:=REJL+1;
               end;
               if(Formule[REJL]in['}'])then
               if(CodeJournal=CodeExiste)then OKJournalExiste:=true;
          end;
     REJL:=REJL+1;
     end;
     ExisteJournalListe:=OKJournalExiste;
end;

