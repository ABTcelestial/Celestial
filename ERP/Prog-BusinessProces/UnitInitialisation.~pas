Function NombreOptimaleBufferSize(NomRegistre:string):integer;
var  BufferSize,NbrOptimaleBufferSize:integer;
begin
     NbrOptimaleBufferSize:=50;

     BufferSize:=64;

     if(NomRegistre='RTiers')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RTiers));
     if(NomRegistre='RStock')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RStock));
     if(NomRegistre='RListeMouvement')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RListeMouvement));
     if(NomRegistre='RDetailMouvement')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RDetailMouvement));
     if(NomRegistre='RDetailArticlePrelevementUniteFonds')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RDetailArticlePrelevementUniteFonds));
     if(NomRegistre='RAvis')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RAvis));
     if(NomRegistre='RPrelevementUniteFonds')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RPrelevementUniteFonds));
     if(NomRegistre='RListeMouvement')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RListeMouvement));
     if(NomRegistre='RSituationMarche')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RSituationMarche));
     if(NomRegistre='RTypeMouvement')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RTypeMouvement));
     if(NomRegistre='RTypeMouvement')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RTypeMouvement));
     if(NomRegistre='RMouvement')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf(RMouvement));

     //if(NomRegistre='')then NbrOptimaleBufferSize:=Round((BufferSize*1024)/SizeOf());

     if(NbrOptimaleBufferSize<=0)
     then NombreOptimaleBufferSize:=1
     else NombreOptimaleBufferSize:=NbrOptimaleBufferSize;

end;

Procedure ComboBoxFormule(CodeTypeFormule:string; EditRubriqueFormule:TComboBox; RubriqueSelect:string);
var  i,iSelect:integer;
     TypeProces,Adresse:string;
begin
     EditRubriqueFormule.Items.Text:='';
     iSelect:=-1;

     TypeProces:='Business';
     if not(FunctionAdresseProces(TypeProces,CodeTypeFormule,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(CodeTypeFormule<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+CodeTypeFormule+' recherché !');
     end;

     ChFormuleCopie:=Adresse;
     assignfile(FFormuleCopie,ChFormuleCopie);
     if FileExists(ChFormuleCopie)then
     begin
          try
          Reset(FFormuleCopie);
          Seek(FFormuleCopie,0);
          i:=0;
          while(not eof(FFormuleCopie))do
          begin
               Read(FFormuleCopie,RFormuleCopie);

               EditRubriqueFormule.Items.Add(RFormuleCopie.Libelle);

               if(RFormuleCopie.Libelle=RubriqueSelect)then iSelect:=i;
          i:=i+1;
          end;
          finally
          CloseFile(FFormuleCopie);
          end;
     end;

     EditRubriqueFormule.ItemIndex:=iSelect;
end;

end.



