                    begin
                         try
                         Reset(FRegistre);
                         Seek(FRegistre,0);
                         read(FRegistre,RRegistre);
                         ExerciceReseauxSource:=RRegistre.Exercice;
                         finally
                         CloseFile(FRegistre);
                         end;
                    end
                    else ExerciceReseauxSource:=ExerciceAnnee;
                    ExerciceReseauxSource:=AjusterExercicePublication(ExerciceReseauxSource,TypeProcesReseaux);
                    ////////////////////////////////////////////////////////////

                    ////////////////////////////////////////////////////////////
                    ChRegistreReseaux:=AdresseReseaux+'\WinBus'+DataIdentificateurReseaux+' '+RAdresseDossierPartageReseauxTraitement.NomPosteReseaux+'.File';
                    assignfile(FRegistre,ChRegistreReseaux);
                    if FileExists(ChRegistreReseaux)then
                    begin
                         try
                         Reset(FRegistre);
                         Seek(FRegistre,0);
                         read(FRegistre,RRegistre);
                         ExerciceReseauxCible:=RRegistre.Exercice;
                         finally
                         CloseFile(FRegistre);
                         end;
                    end
                    else ExerciceReseauxCible:=ExerciceAnnee;
                    ExerciceReseauxCible:=AjusterExercicePublication(ExerciceReseauxCible,TypeProcesReseaux);
                    ////////////////////////////////////////////////////////////  

                    if(DirectoryExists(AdresseReseaux)=true)then
                    begin
                         if(AdressePublicationChoisis<>'')
                         then AdresseReseauxSource:=AdressePublicationChoisis
                         else AdresseReseauxSource:=ProcAdresseDossierPartageReseaux('','Local',NomDossierPartageOut,EmlacementLocalOuReseauxOut);
                         ChTypeMouvementPublication:=AdresseReseauxSource+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceReseauxSource+FichierConcerne+' '+NomDossierPartageOut;
                         AdresseReseauxCible:=AdresseReseaux;
                         ChTypeMouvementCopiePublication:=AdresseReseauxCible+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceReseauxCible+FichierConcerne+' '+DossierPartageCible;

                         if(AdresseReseauxCible<>'')and(ChTypeMouvementPublication<>ChTypeMouvementCopiePublication)and(DirectoryExists(AdresseReseauxCible))then
                         begin
                              assignfile(FTypeMouvementCopiePublication,ChTypeMouvementCopiePublication);
                              try
                              if FileExists(ChTypeMouvementCopiePublication)then
                              Reset(FTypeMouvementCopiePublication)
                              else Rewrite(FTypeMouvementCopiePublication);
                              Seek(FTypeMouvementCopiePublication,0);

                              i:=0;

                              assignfile(FTypeMouvementPublication,ChTypeMouvementPublication);
                              if FileExists(ChTypeMouvementPublication)then
                              begin
                                   try
                                   Reset(FTypeMouvementPublication) ;
                                   Seek(FTypeMouvementPublication,0);
                                   while not eof(FTypeMouvementPublication)do
                                   begin
                                        read(FTypeMouvementPublication,RTypeMouvementPublication); Application.ProcessMessages;

                                        Seek(FTypeMouvementCopiePublication,i);
                                        write(FTypeMouvementCopiePublication,RTypeMouvementPublication);
                                   i:=i+1;
                                   end;
                                   finally
                                   CloseFile(FTypeMouvementPublication);
                                   end;

                              Seek(FTypeMouvementCopiePublication,i);
                              Truncate(FTypeMouvementCopiePublication);
                              end;                               
                              finally
                              CloseFile(FTypeMouvementCopiePublication);
                              end;

                              FSMenuPrincipal.EditRapport.Lines.Add('Enregistrement '+CompleteCharDroite(FichierConcerne+' '+DossierPartageCible,' ',FSMenuPrincipal.IncrimenteTaileFichierConcerne.Position)+' efféctué avec succés ! {'+CompleteCharGauche(inttostr(i),' ',FSMenuPrincipal.IncrimenteNbrRegistre.Position)+' Enregistrements} "Source: '+CompleteCharDroite(ExtractFileDir(ChTypeMouvementPublication),' ',FSMenuPrincipal.IncrimenteAdresse.Position)+'"'+' *****'+ChTypeMouvementPublication+' => '+ChTypeMouvementCopiePublication+'*****');
                         end
                         else
                         if(AdresseReseauxSource=ChTypeMouvementCopiePublication)then
                         begin
                              FSMenuPrincipal.EditRapport.Lines.Add('Enregistrement '+CompleteCharDroite(FichierConcerne+' '+DossierPartageCible,' ',FSMenuPrincipal.IncrimenteTaileFichierConcerne.Position)+' Aucune source        ! {'+CompleteCharGauche(' ',' ',83)+'" *****'+ChTypeMouvementPublication+' => '+ChTypeMouvementCopiePublication+'*****');
                         end
                         else
                         if(AdresseReseauxCible='')then
                         begin
                              //showmessage('Aucun emplacement réseaux planifié !');
                         end;
                    end
                    else FSMenuPrincipal.EditRapport.Lines.Add('Enregistrement '+CompleteCharDroite(FichierConcerne+' '+DossierPartageCible,' ',FSMenuPrincipal.IncrimenteTaileFichierConcerne.Position)+' Aucune source        ! {'+CompleteCharGauche(' ',' ',83)+'" *****'+ChTypeMouvementPublication+' => '+ChTypeMouvementCopiePublication+'*****');
                    ////////////////////////////////////////////////////////////
               end;
         end;
         finally
         CloseFile(FAdresseDossierPartageReseauxTraitement);
         end;
     end;
end;

