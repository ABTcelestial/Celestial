     end
     else
     if(valeT[Num]in['0'..'9'])then
     begin
          j:=strtoint(valeT[Num]);

          if Pointeur in[1,4,7,10,13]then
          case j of
          0:  T[Pointeur]:='';
          1 : T[Pointeur]:='.';
          2 : T[Pointeur]:='DEUX';
          3 : T[Pointeur]:= 'TROIS';
          4 : T[Pointeur]:='QUATRE';
          5 : T[Pointeur]:='CINQ';
          6 : T[Pointeur]:='SIX';
          7 : T[Pointeur]:='SEPT';
          8 : T[Pointeur]:='HUIT';
          9 : T[Pointeur]:='NEUF';
          end;

          if(Pointeur in[2,5,8,11,14,17])then
          case j of
          0: T[Pointeur]:='';
          1 : T[Pointeur]:='.';
          2 : T[Pointeur]:='VINGT';
          3 : T[Pointeur]:='TRENTE';
          4 : T[Pointeur]:='QUARANTE';
