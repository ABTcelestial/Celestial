               if(HeurePublication='')then HeurePublicationWrite:=RClientMachine.HeurePublication;
          end;
          Seek(FMayMachine,0);
          Truncate(FMayMachine);
          RMayMachine.NomMachine:=NomReseau;
          RMayMachine.NomUtilisateur:=NomUtilisateur;
          RMayMachine.AdresseIP:=IndiqueAdresseIPMayMachine;
          RMayMachine.NomPosteReseauxConnexion:=NomPosteReseauxConnexionCible;
          RMayMachine.DatePublication:=DatePublicationWrite;
          RMayMachine.HeurePublication:=HeurePublicationWrite;
