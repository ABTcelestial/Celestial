Function ChercherStockArticle(TypeStock,NumProjetFinance,CodeStockArticle,TypeCodeRecherche:string; var OKStockArticleRecherche:boolean; var RubriqueRecherche:string):RStocks;
var  TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut,Codebarre:string;
begin
     ChercherStockArticle.QteEntree:=0;
     ChercherStockArticle.QteSortie:=0;
     ChercherStockArticle.QteStock:=0;
     ChercherStockArticle.QteInitial:=0;
     ChercherStockArticle.QteLimite:=0;
     ChercherStockArticle.CoutUnitaire:=0;
     ChercherStockArticle.PrixVenteDetaille:=0;
     ChercherStockArticle.PrixVenteGros:=0;
     ChercherStockArticle.Design:='';
     ChercherStockArticle.Ref:='';
     ChercherStockArticle.Observ:='';
     ChercherStockArticle.Emplace:='';
     ChercherStockArticle.CodeBarre:='';
     ChercherStockArticle.Code:='';
     ChercherStockArticle.UM:='';
     ChercherStockArticle.Formule:='';
     ChercherStockArticle.enregistrement:='';

     TypeProces:='Commercial';   FichierConcerne:='FStock'+TypeStock+NumProjetFinance;
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcerne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConcerne+'} recherché !');
     end;

     ChStockArticleRecherche:=Adresse;
     assignfile(FStockArticleRecherche,ChStockArticleRecherche);
     if FileExists(ChStockArticleRecherche)then
     begin
          try
          Reset(FStockArticleRecherche);
          Seek(FStockArticleRecherche,0);
          OKStockArticleRecherche:=false;
          i:=0;
          RubriqueRecherche:='';
          while(not eof(FStockArticleRecherche)and(OKStockArticleRecherche=false))do
          begin
               Read(FStockArticleRecherche,RStockArticleRecherche);

               if(TypeCodeRecherche='CodeBarre')then
               begin
                    Codebarre:=RStockArticleRecherche.CodeBarre;
                    if(Codebarre=CodeStockArticle)then
                    begin
                         OKStockArticleRecherche:=true;
                         ChercherStockArticle:=RStockArticleRecherche;
                         RubriqueRecherche:='CodeBarre';
                    end
                    else
                    if(RStockArticleRecherche.Code=CodeStockArticle)then
                    begin
                         OKStockArticleRecherche:=true;
                         ChercherStockArticle:=RStockArticleRecherche;
                         RubriqueRecherche:='CodeArticle';
                    end;
               end
               else
               begin
                    if(RStockArticleRecherche.Code=CodeStockArticle)then
                    begin
                         OKStockArticleRecherche:=true;
                         ChercherStockArticle:=RStockArticleRecherche;
                         if(TypeCodeRecherche<>'')
                         then RubriqueRecherche:=TypeCodeRecherche
                         else RubriqueRecherche:='CodeArticle';
                    end;
               end;
          i:=i+1;
          end;
          finally
          CloseFile(FStockArticleRecherche);
          end;
     end;
end;

