                    TTravauxRestant[TI-1].DesignationArticle:=RDetailMarche.DesignationArticle;
                    TTravauxRestant[TI-1].UniteM:=RDetailMarche.UniteM;

                    SoldeAttachement(RDetailMarche.CodeTrie,QteMarche,QteAvenant,QteRealiserMarche,QteRealiserAvenant,QteRestanteMarche,QteRestanteAvenant);

                    if(FSDetailMarche.RBRemplireQuantite.Checked=true)
                    then
                    begin
                         TTravauxRestant[TI-1].QuantiteMarcheAvenant:=QteMarche+QteAvenant;
                         TTravauxRestant[TI-1].QuantiteOM:=QteMarche;
                         TTravauxRestant[TI-1].QuantiteOA:=QteAvenant;
                         TTravauxRestant[TI-1].QuantiteRealiser:=QteRealiserMarche+QteRealiserAvenant;
                         TTravauxRestant[TI-1].QuantiteRealiserOM:=QteRealiserMarche;
                         TTravauxRestant[TI-1].QuantiteRealiserOA:=QteRealiserAvenant;
