    OKDetailMouvement,OKMiseAJour:boolean;
    SigneMouvementAOperer,SigneMouvementFormuleComposition,CodeArticleAOperer,CodeStockConcerneSource,CodeStockConcerneCible:string;
    QteAOperer,PrixAOperer:real;
begin

if(OrdreListeMouvement='')then
begin
     showmessage('Veuillez indiquer le numéro du mouvement ŕ supprimer !');
     exit;
end;

PreparationFormuleComposition(FSFicheSaisie.EditPositionTypeMouvement.Text,FSFicheSaisie.EditPositionMouvement.Text,FSFicheSaisie.EditOrdreListeMouvement.Text,FSFicheSaisie.EditNumListeMouvement.Text,FSFicheSaisie.EditDesignationMouvement.Text,datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),FSFicheSaisie.EditCodeTiersConserne.Text,FSFicheSaisie.EditTiersConserne.Text,'Régularisation '+FSFicheSaisie.EditDesignationMouvement.Text,RowEditing);

RTypeMouvementCopie:=ChercherDesignationTypeMouvement(DesignationTypeMouvement,AdresseFichierConcerne);

OpenFParc(RParc);
ChDetailMouvement:=RParc.Parcours+'\'+Exercice+'DétailMouvement '+DesignationTypeMouvement;
assignfile(FDetailMouvement,ChDetailMouvement);
try
if FileExists(ChDetailMouvement)then
Reset(FDetailMouvement)
else Rewrite(FDetailMouvement);
Seek(FDetailMouvement,0);
Confirme:=false;
d:=0;
while not eof(FDetailMouvement)do
begin//D1
     read(FDetailMouvement,RDetailMouvement);

     OKDetailMouvement:=RDetailMouvement.ValidationDetailMouvement;

     if(OKDetailMouvement=true)then
     begin
          if(OrdreListeMouvement<>'')then
          begin
               if(RDetailMouvement.OrdreListeMouvement=strtointeger(OrdreListeMouvement))
               then
               begin
                    if(PositionDetailMouvement<>'')then
                    begin
                         if ExisteNumInTexte(inttostr(RDetailMouvement.PositionDetailMouvement),PositionDetailMouvement)
                         then OKDetailMouvement:=true
                         else OKDetailMouvement:=false;
                    end
                    else OKDetailMouvement:=true;
               end
               else OKDetailMouvement:=false;
          end
          else OKDetailMouvement:=false;
     end;

     if(OKDetailMouvement=true)then
     begin
          CodeArticleAOperer:=RDetailMouvement.CodeArticle;
          QteAOperer:=RDetailMouvement.Quantite*(-1);
          PrixAOperer:=RDetailMouvement.PrixUnitaire;

          RListeMouvementCopie:=ChercherListeMouvement(inttostr(RTypeMouvementCopie.PositionTypeMouvement),OrdreListeMouvement);
