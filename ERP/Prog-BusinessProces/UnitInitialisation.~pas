                                end;
                           end;
                           finally
                           CloseFile(FAvisCopie);
                           end;
                     end;
                end;
           end;
           finally
           CloseFile(FBaseAvisRecherche);
           end;
     end;

     if(R>0)then
     begin
          TableauListeAvis.RowCount:=R+1;
          ChercherAvis:=true;
     end
     else
     begin
          TableauListeAvis.RowCount:=2;
