          6 : T[Pointeur]:='SOIXANTE';
          7 : T[Pointeur]:='SOIXANTE-';
          8 : T[Pointeur]:='QUATRE-VINGT';
          9 : T[Pointeur]:='QUATRE-VINGT-';
          end;

          if Pointeur in[3,6,9,12,15,18]then
          begin
               if(T[Pointeur-1]='.')or(T[Pointeur-1]='SOIXANTE-')or(T[Pointeur-1]='QUATRE-VINGT-')then
               begin
                    case j of
                    0 : if(T[Pointeur-1]<>'')and(T[Pointeur-1]<>'*')then T[Pointeur]:='DIX';
                    1 : T[Pointeur]:='ONZE';
                    2 : T[Pointeur]:='DOUZE';
                    3 : T[Pointeur]:='TREIZE';
                    4 : T[Pointeur]:='QUATORZE';
                    5 : T[Pointeur]:='QUINZE';
                    6 : T[Pointeur]:='SEIZE';
                    7 : T[Pointeur]:='DIX-SEPT';
                    8 : T[Pointeur]:='DIX-HUIT';
                    9 : T[Pointeur]:='DIX-NEUF';
                    end;
               end
               else
               begin
                    case j of
                    0 : T[Pointeur]:='';
                    1 : begin
                             if Pointeur in[12]then
                             begin
                                  l:=Pointeur-1;
                                  OKPointeur:=false;
                                  while(l>9)and(OKPointeur=false)do
                                  begin
                                       if not(l in[3,6,9,12,15,18])then
                                       begin
                                            if(T[l]<>'0')and(T[l]<>'')and(T[l]<>'*')then OKPointeur:=true;
                                       end;
                                  l:=l-1;
                                  end;
                             end
                             else
                             begin
                                  OKPointeur:=true;
                             end;

                        if(OKPointeur=true)then T[Pointeur]:='UN' else T[Pointeur]:='.';
                        end;
                    2 : T[Pointeur]:='DEUX';
                    3 : T[Pointeur]:='TROIS';
                    4 : T[Pointeur]:='QUATRE';
                    5 : T[Pointeur]:='CINQ';
                    6 : T[Pointeur]:='SIX';
                    7 : T[Pointeur]:='SEPT';
                    8 : T[Pointeur]:='HUIT';
                    9 : T[Pointeur]:='NEUF';
                    end;
               end;
          end;
     end;
end;

            {**********Début de la lecture du tableau T**********}

for i:=1 to MaxArrayChiffre do
begin
               if(T[i]<>'*')then
               begin
                    if(T[i]<>'')and(T[i]<>'.')then
