                          if(RPrelevementRecherche.RegistrePositionDetailArticlePrelevementUniteFonds.PositionArchiveEnd>RPrelevementCopie.RegistrePositionDetailArticlePrelevementUniteFonds.PositionArchiveEnd)then;

