begin
     iENT:=1;
     OKNum:=false;
     NumTesteD:='';
     NumTesteF:='';
     IndexTrouver:='';
     NumTrouver:='';
     IndexTrouverF:='';
     NumTrouverF:='';
     while(iENT<=longueur(ListeNum))and(OKNum=false)do
     begin
          if(ListeNum[iENT]<>';')and(ListeNum[iENT]<>'-')
          then   
          begin
               NumTesteD:=NumTesteD+ListeNum[iENT];
          end;

          if(iENT=longueur(ListeNum))or(ListeNum[iENT]=';')or(ListeNum[iENT]='-')then
          begin
               if(Index<>'')then
               begin
                    IndexTrouver:=Firstlaters(NumTesteD,2);
                    NumTrouver:=Lastlaters(NumTesteD,longueur(NumTesteD)-2);
               end
               else
               begin
                    IndexTrouver:='';
                    NumTrouver:=NumTesteD;
               end;

               if(ListeNum[iENT]=';')or(iENT=longueur(ListeNum))then
               begin
                    if(IndexTrouver=Index)and(NumTrouver=Num)then OKNum:=true;
               end;

               if(ListeNum[iENT]='-')then
               begin
                    NumTesteF:='';
                    iENT:=iENT+1;
