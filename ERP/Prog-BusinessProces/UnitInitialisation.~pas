Procedure ProceTrieBaseAvisLocalReseaux;
var  i:integer; AdresseTeste,AdresseTBA,TypeData,TypeTrie:string;
begin
     TypeData:='Num';
     TypeTrie:='+';
     PointeurTableauTriePointeur:=TList.Create;

     if not(FunctionAdresseProces('Business','FBaseAvis','',AdresseTBA,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if('FBaseAvis'<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché '+'FBaseAvis'+' !');
     end;

     ChBaseAvisCopie:=AdresseTBA+' Trie';
     assignfile(FBaseAvisCopie,ChBaseAvisCopie);
     try
     if FileExists(ChBaseAvisCopie)then
     Reset(FBaseAvisCopie)
     else Rewrite(FBaseAvisCopie);
     Seek(FBaseAvisCopie,0);
     Truncate(FBaseAvisCopie);

     ChBaseAvis:=AdresseTBA;
     assignfile(FBaseAvis,ChBaseAvis);
     try
     if FileExists(ChBaseAvis)then
     Reset(FBaseAvis)
     else Rewrite(FBaseAvis);
     Seek(FBaseAvis,0);
     i:=0;
     while not eof(FBaseAvis)do
     begin
          read(FBaseAvis,RBaseAvis);

          TableauTriePointeur:=TTableauTriePointeur.Create;

          FunctionAdresseProces('Business',RBaseAvis.DesignationBaseAvis,'',AdresseTeste,TypeProcesReseaux,NomDossierPartageReseauxOut);
          if(TypeProcesReseaux='Réseaux')
          then TableauTriePointeur.Rubrique:='1'
          else TableauTriePointeur.Rubrique:='0';
          TableauTriePointeur.RowPosition:=i;
          PointeurTableauTriePointeur.Add(TableauTriePointeur);
     i:=i+1;
     end;

     if(TypeData='')then
     begin
          if(TypeTrie='+')
          then PointeurTableauTriePointeur.Sort(TriePointeurStringPlus)
          else PointeurTableauTriePointeur.Sort(TriePointeurStringMoin);
     end;

     if(TypeData='Num')then
     begin
          if(TypeTrie='+')
          then PointeurTableauTriePointeur.Sort(TriePointeurNumPlus)
          else PointeurTableauTriePointeur.Sort(TriePointeurNumMoin);
     end;

     if(TypeData='Date')then
     begin
          if(TypeTrie='+')
          then PointeurTableauTriePointeur.Sort(TriePointeurDatePlus)
          else PointeurTableauTriePointeur.Sort(TriePointeurDateMoin);
     end;

     for i:=0 to PointeurTableauTriePointeur.Count-1 do
     begin
          Seek(FBaseAvis,TTableauTriePointeur(PointeurTableauTriePointeur[i]).RowPosition);
          read(FBaseAvis,RBaseAvis);
          RBaseAvis.PositionBaseAvis:=i;
          Seek(FBaseAvisCopie,i);
          write(FBaseAvisCopie,RBaseAvis);
     end;

     Seek(FBaseAvis,0);
     Truncate(FBaseAvis);

     Seek(FBaseAvisCopie,0);
     i:=0;
     while not eof(FBaseAvisCopie)do
     begin
          read(FBaseAvisCopie,RBaseAvisCopie);
          Seek(FBaseAvis,i);
          write(FBaseAvis,RBaseAvisCopie);
     i:=i+1;
     end;

     finally
     CloseFile(FBaseAvis);
     end;

     finally
     CloseFile(FBaseAvisCopie);
     end;

     for i:=0 to PointeurTableauTriePointeur.Count-1 do TTableauTriePointeur(PointeurTableauTriePointeur.Items[i]).Free;
     PointeurTableauTriePointeur.Free;
end;

