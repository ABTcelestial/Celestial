     NumProjetFinanceRecherche:='';
     while not eof(FArchiveRegistreAffectationEffectifEquipe)and(i<=RPrelevementCopie.RegistrePositionRegistreAffectationEffectifEquipe.PositionArchiveEnd)and(OKNumProjetFinance=false)do
     begin
          read(FArchiveRegistreAffectationEffectifEquipe,RArchiveRegistreAffectationEffectifEquipe);

          if(inttostr(RArchiveRegistreAffectationEffectifEquipe.NumPrelevement)=NumPrelevement)
          and(RArchiveRegistreAffectationEffectifEquipe.Matricule=Matricule)then
          begin
               if(RArchiveRegistreAffectationEffectifEquipe.ValeurAffecter>0)then
               begin
                    OKNumProjetFinance:=true;
                    NumProjetFinanceRecherche:=ChercherAffectationCompteur(strtointeger(RArchiveRegistreAffectationEffectifEquipe.RCompteurAffecter.NumAffectationCompteur)).NumProjetFinance;
               end;
          end;
     end;
     finally
