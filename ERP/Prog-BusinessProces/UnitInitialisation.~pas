Function ExtractNomFichier(FileName:string):string;
var  iENF:integer;   TexteTest:string;  OKNomFichier:boolean;
begin
     FileName:=ExtractFileName(FileName);

     OKNomFichier:=false;
     TexteTest:='';

     for iENF:=1 to longueur(FileName)do
     begin
          if(OKNomFichier=true)then
          begin
               TexteTest:=TexteTest+FileName[iENF];
          end
          else
          begin
               if FileName[iENF]in['0'..'9']then
               begin
                    TexteTest:=TexteTest+FileName[iENF];
               end
               else
               if(longueur(TexteTest)=4)and((FileName[iENF]in['a'..'z'])or(FileName[iENF]in['A'..'Z']))then
               begin
                    TexteTest:=FileName[iENF];
                    OKNomFichier:=true;
               end
               else TexteTest:='';
          end;
     end;

     ExtractNomFichier:=TexteTest;
end;

