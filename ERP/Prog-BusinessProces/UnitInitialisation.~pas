Function IndiquerIEndMax(RBaseAvisCopie:RBaseAviss; DateBegin,DateFin:string):integer;
var  IEndTeste,iAnnee,AnneeDateBegin,AnneeDateFin,iMois:integer;
begin
     AnneeDateBegin:=2010;
     AnneeDateFin:=2050;
     if(DateBegin<>'')then AnneeDateBegin:=strtointeger(lastlaters(DateBegin,4));
     if(DateFin<>'')then AnneeDateFin:=strtointeger(lastlaters(DateFin,4));
     IEndTeste:=0;
     for iAnnee:=AnneeDateBegin to AnneeDateFin do
     begin
          for iMois:=1 to 12 do
          begin
               if(RBaseAvisCopie.RegistrePositionAvisParPeriode[iAnnee,iMois].PositionAvisEnd<>999999999)then
               begin
                    if(IEndTeste<RBaseAvisCopie.RegistrePositionAvisParPeriode[iAnnee,iMois].PositionAvisEnd)then
                    IEndTeste:=RBaseAvisCopie.RegistrePositionAvisParPeriode[iAnnee,iMois].PositionAvisEnd;
               end;
          end;
     end;

     if(IEndTeste=0)then IEndTeste:=999999999;

     IndiquerIEndMax:=IEndTeste;
end;

