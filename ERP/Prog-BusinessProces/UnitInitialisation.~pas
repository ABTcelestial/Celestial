     TStockArticlePointeur[IndiceTableauMax].QteSortie:=0;
     TStockArticlePointeur[IndiceTableauMax].QteStock:=0;
     TStockArticlePointeur[IndiceTableauMax].QteInitial:=0;
     TStockArticlePointeur[IndiceTableauMax].QteLimite:=0;
     TStockArticlePointeur[IndiceTableauMax].CoutUnitaire:=0;
     TStockArticlePointeur[IndiceTableauMax].PrixVenteDetaille:=0;
     TStockArticlePointeur[IndiceTableauMax].PrixVenteDemiGros:=0;
     TStockArticlePointeur[IndiceTableauMax].PrixVenteGros:=0;
     TStockArticlePointeur[IndiceTableauMax].Design:='';
     TStockArticlePointeur[IndiceTableauMax].Ref:='';
     TStockArticlePointeur[IndiceTableauMax].Observ:='';
     TStockArticlePointeur[IndiceTableauMax].Emplace:='';
     TStockArticlePointeur[IndiceTableauMax].CodeBarre:='';
     TStockArticlePointeur[IndiceTableauMax].Code:='';
     TStockArticlePointeur[IndiceTableauMax].UM:='';
     TStockArticlePointeur[IndiceTableauMax].Formule:='';
     TStockArticlePointeur[IndiceTableauMax].enregistrement:='';

     TypeProces:='Commercial';   FichierConcerne:='FStock'+TypeStock+NumProjetFinance;
