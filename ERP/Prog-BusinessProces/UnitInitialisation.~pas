                               ChPersonnel:=AdresseReseauxSource+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceReseauxCible+FichierConcernePlanComptableTeste+' '+NomDossierPartageReseauxOut;
