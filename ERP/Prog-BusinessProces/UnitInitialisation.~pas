Function IndiquerNotCol(TableauIndique:TStringGrid):string;
var  C:integer; NotColCollect:string;
begin
     NotColCollect:='';
     for C:=0 to TableauIndique.ColCount-1 do
     begin
          if(TableauIndique.ColWidths[C]<=10)then
          begin
               TableauIndique.ColWidths[C]:=0;
               if(NotColCollect='')
               then NotColCollect:=inttostr(C)
               else NotColCollect:=NotColCollect+';'+inttostr(C);
          end;
     end;

     IndiquerNotCol:=NotColCollect;
end;

