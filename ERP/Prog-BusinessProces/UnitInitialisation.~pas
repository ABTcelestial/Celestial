Procedure OpenForm(NameForm:string);
var  iNoComponent : integer;
     LeHandle:HWND;
begin
     for iNoComponent := 0 to Application.ComponentCount - 1 do
     begin
          if Application.Components[iNoComponent] is TForm then
          begin
               if (Application.Components[iNoComponent] as TForm).Name = NameForm then
               begin
                    (Application.Components[iNoComponent] as TForm).Show;
                    LeHandle:=GetForegroundWindow();  // Obtenir le HWND de la fenętre active:
                    ShowWindow(LeHandle,SW_MAXIMIZE); // Agrandir la fenętre:

                    FSMenuPrincipal.TableauNomFormActive.Cells[0,0]:=inttostr(strtointeger(FSMenuPrincipal.TableauNomFormActive.Cells[0,0])-1);
                    if(strtointeger(FSMenuPrincipal.TableauNomFormActive.Cells[0,0])<=1)
                    then FSMenuPrincipal.TableauNomFormActive.Cells[0,0]:=inttostr(FSMenuPrincipal.TableauNomFormActive.RowCount-1);
               end;
          end;
     end;
end;

Procedure ActiverNomForm(Action:Integer; NomForm:string);
var  R,l,Row,RExitForm:integer;  OKForm:boolean;  //(Sender as TComponent).Name
begin
     Row:=FSMenuPrincipal.TableauNomFormActive.RowCount-1;
     RExitForm:=0;

     if(Row=1)and(FSMenuPrincipal.TableauNomFormActive.Cells[1,1]='')then
     begin
          Row:=0;
          FSMenuPrincipal.TableauNomFormActive.ColCount:=2;
          FSMenuPrincipal.TableauNomFormActive.Cols[0].Text:='Num';
          FSMenuPrincipal.TableauNomFormActive.Cols[1].Text:='Form';


          FSMenuPrincipal.TableauNomFormActive.RowCount:=2;
          FSMenuPrincipal.TableauNomFormActive.Rows[1].Text:='';
     end;

     R:=1;
     OKForm:=false;
     while(R<=FSMenuPrincipal.TableauNomFormActive.RowCount-1)and(OKForm=false)do
     begin
          if(FSMenuPrincipal.TableauNomFormActive.Cells[1,R]=NomForm)then
          begin
               OKForm:=true;
               RExitForm:=R;
          end;
     R:=R+1;
     end;

     if(Action=0)then  //Suppression
     begin
          if(RExitForm>0)then
          begin
               FSMenuPrincipal.TableauNomFormActive.Cells[1,RExitForm]:='';
               if(Row>1)then
               begin
                    l:=RExitForm;
                    while(l<=FSMenuPrincipal.TableauNomFormActive.RowCount-2)do
                    begin
                         FSMenuPrincipal.TableauNomFormActive.Cells[1,l]:='';
                         FSMenuPrincipal.TableauNomFormActive.Cells[1,l]:=FSMenuPrincipal.TableauNomFormActive.Cells[1,l+1];
                    l:=l+1;
                    end;
                         
                    Row:=Row-1;
                    OpenForm(FSMenuPrincipal.TableauNomFormActive.Cells[1,Row]);
               end;
          end;
     end;

     if(Action=1)then  //Ajout
     begin
          if(OKForm=false)then
          begin
               Row:=Row+1;
               FSMenuPrincipal.TableauNomFormActive.Rows[Row].Text:=inttostr(Row);
               FSMenuPrincipal.TableauNomFormActive.Cells[1,Row]:=NomForm;
          end;
     end;

     if(Row>0)then FSMenuPrincipal.TableauNomFormActive.RowCount:=Row+1
              else
              begin
                   FSMenuPrincipal.TableauNomFormActive.RowCount:=2;
                   FSMenuPrincipal.TableauNomFormActive.Rows[1].Text:='';
              end;

     AjusterColWidth(FSMenuPrincipal.TableauNomFormActive,'','');

     FSMenuPrincipal.TableauNomFormActive.Cells[0,0]:=inttostr(FSMenuPrincipal.TableauNomFormActive.RowCount-1);
end;

function IsFileInUse(fName: string) : boolean;
var  HFileRes: HFILE;
begin
     Result := False;
     if not FileExists(fName) then
     begin
          Exit;
     end;

     HFileRes := CreateFile(PChar(fName)
     ,GENERIC_READ or GENERIC_WRITE
     ,0
     ,nil
     ,OPEN_EXISTING
     ,FILE_ATTRIBUTE_NORMAL
     ,0);

     Result := (HFileRes = INVALID_HANDLE_VALUE);

     if not(Result) then
     begin
          CloseHandle(HFileRes);
     end;
end;

