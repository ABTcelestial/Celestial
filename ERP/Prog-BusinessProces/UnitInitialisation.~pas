Procedure CalculeApprovisionnement(TApprovisionnement:TApprovisionnements; RowCountSource:integer);
var   k,R,RowCount:integer; OKMat:boolean;
begin
FSApprovisionnement.Show;
FSApprovisionnement.TableauApprovisionnement.Cells[0,0]:='N°';
FSApprovisionnement.TableauApprovisionnement.Cells[1,0]:='Code Mat.';
FSApprovisionnement.TableauApprovisionnement.Cells[2,0]:='Désignation Mat.';
FSApprovisionnement.TableauApprovisionnement.Cells[3,0]:='UM';
FSApprovisionnement.TableauApprovisionnement.Cells[4,0]:='Quantité';
FSApprovisionnement.TableauApprovisionnement.Cells[5,0]:='Côut Unit.';
FSApprovisionnement.TableauApprovisionnement.Cells[6,0]:='Montant';
FSApprovisionnement.TableauApprovisionnement.Cells[7,0]:='Imprimer';

RowCount:=0;

for k:=1 to RowCountSource do
begin
     if((TApprovisionnement[k-1].CodeStock<>'')
     and(TApprovisionnement[k-1].Quantite<>0))
     then
     begin
          OpenFParc(RParc);
          ChFormuleComposition:=RParc.Parcours+'\'+Exercice+'FFormuleComposition';
          assignfile(FFormuleComposition,ChFormuleComposition);
          try
          if FileExists(ChFormuleComposition)then
          Reset(FFormuleComposition)
          else Rewrite(FFormuleComposition);
          Seek(FFormuleComposition,0);
          while not eof(FFormuleComposition)do
          begin
               read(FFormuleComposition,RFormuleComposition);
               if(RFormuleComposition.CodeProd=TApprovisionnement[k-1].CodeStock)
               then
               begin
                    OKMat:=false;
                    R:=1;
                    while(R<=RowCount)and(OKMat=false)do
                    begin
                         if(FSApprovisionnement.TableauApprovisionnement.Cells[1,R]=RFormuleComposition.CodeMat)
                         then
                         begin
                              OKMat:=true;
                              FSApprovisionnement.TableauApprovisionnement.Cells[4,R]:=floattostr(strtoreal(FSApprovisionnement.TableauApprovisionnement.Cells[4,R])+
                              (RFormuleComposition.CoefficientComposition*TApprovisionnement[k-1].Quantite)+(RFormuleComposition.CoefficientPerte*TApprovisionnement[k-1].Quantite));
                         end;
                    R:=R+1;
                    end;

                    if(OKMat=false)then
                    begin
                         RowCount:=RowCount+1;
                         FSApprovisionnement.TableauApprovisionnement.Rows[RowCount].Text:='';
                         FSApprovisionnement.TableauApprovisionnement.Cells[0,RowCount]:=inttostr(RowCount);
                         FSApprovisionnement.TableauApprovisionnement.Cells[1,RowCount]:=RFormuleComposition.CodeMat;
                         FSApprovisionnement.TableauApprovisionnement.Cells[2,RowCount]:=RFormuleComposition.DesignMat;
                         FSApprovisionnement.TableauApprovisionnement.Cells[3,RowCount]:=RFormuleComposition.UMMat;
                         FSApprovisionnement.TableauApprovisionnement.Cells[4,RowCount]:=floattostr((RFormuleComposition.CoefficientComposition*TApprovisionnement[k-1].Quantite)+(RFormuleComposition.CoefficientPerte*TApprovisionnement[k-1].Quantite));
                    end;
               end;
          end;
          finally
          closefile(FFormuleComposition);
          end;
     end;
end;
if(RowCount>0)then
              begin
                   FSApprovisionnement.TableauApprovisionnement.RowCount:=RowCount+3;
                   FSApprovisionnement.TableauApprovisionnement.Rows[FSApprovisionnement.TableauApprovisionnement.RowCount-1].Text:='';
                   FSApprovisionnement.TableauApprovisionnement.Cells[5,FSApprovisionnement.TableauApprovisionnement.RowCount-1]:='   Total: ';
              end
              else
              begin
                   FSApprovisionnement.TableauApprovisionnement.RowCount:=2;
                   FSApprovisionnement.TableauApprovisionnement.Rows[1].Text:='';
              end;

for R:=1 to FSApprovisionnement.TableauApprovisionnement.RowCount-3 do
begin
     TypeProces:='Business'; FichierConcerne:='FStockArticle';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          //if(<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché !'+' {'+FichierConcerne+'}');
     end;
     ChStock:=Adresse;
     assignfile(FStock,ChStock);
     try
     if FileExists(ChStock)then
     Reset(FStock)
     else Rewrite(FStock);
     Seek(FStock,0);
     OKMat:=false;
     while not eof(FStock)and(OKMat=false)do
     begin
          read(FStock,RStock);
          if(RStock.Code=FSApprovisionnement.TableauApprovisionnement.Cells[1,R])then
          begin
               OKMat:=true;
               FSApprovisionnement.TableauApprovisionnement.Cells[4,R]:=vergule(FSApprovisionnement.TableauApprovisionnement.Cells[4,R],'2','N','');
               FSApprovisionnement.TableauApprovisionnement.Cells[5,R]:=vergule(floattostr(RStock.CoutUnitaire),'2','C','');
               FSApprovisionnement.TableauApprovisionnement.Cells[6,R]:=vergule(floattostr(RStock.CoutUnitaire*strtoreal(FSApprovisionnement.TableauApprovisionnement.Cells[4,R])),'2','C','');
               FSApprovisionnement.TableauApprovisionnement.Cells[7,R]:='OK';
               FSApprovisionnement.TableauApprovisionnement.Cells[6,FSApprovisionnement.TableauApprovisionnement.RowCount-1]:=vergule(floattostr(strtoreal(FSApprovisionnement.TableauApprovisionnement.Cells[6,FSApprovisionnement.TableauApprovisionnement.RowCount-1])+strtoreal(FSApprovisionnement.TableauApprovisionnement.Cells[6,R])),'2','C','');
               FSApprovisionnement.TableauApprovisionnement.Cells[4,R]:=vergule(FSApprovisionnement.TableauApprovisionnement.Cells[4,R],'2','C','');
          end;
     end;
     finally
     closefile(FStock);
     end;
end;

end;

Function ImporterDevisQE(NSMarche,NStructureMarche,NStatistiqueMarche,NAvenantMarche:integer; CumuleArticle:boolean; var TDevisQE:TDevisQEs):integer;
var OK:boolean;   TI,RChoix,icumule:integer;
begin
          SetLength(TDevisQE,0);
          TI:=0;

          TypeProces:='Business'; FichierConcerne:='FDetail'+ChercherMarche(NSMarche).TypeProjet+' '+inttostr(NSMarche);
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               //if(<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché !'+' {'+FichierConcerne+'}');
          end;
          ChDetailMarche:=Adresse;
          assignfile(FDetailMarche,ChDetailMarche);
          try
          if FileExists(ChDetailMarche)then
          Reset(FDetailMarche)
          else Rewrite(FDetailMarche);
          Seek(FDetailMarche,0);
          while not eof(FDetailMarche) do
          begin
               Read(FDetailMarche,RDetailMarche);

               {***** Chois par Lots *****}
               if(FSDetailMarche.RBListelots.Checked=true)then
               begin
                    OK:=false;
                    RChoix:=1;
                    while(RChoix<=FSDetailMarche.TableauChoixLots.RowCount-1)and(OK=false)do
                    begin
                         if((FSDetailMarche.TableauChoixLots.Cells[3,RChoix]='OK')
                         and(firstlaters(Lastlaters(RDetailMarche.CodeTrie,11),2)=firstlaters(FSDetailMarche.TableauChoixLots.Cells[1,RChoix],2)))
                         then
                         begin
                              OK:=true;
                         end;
                    RChoix:=RChoix+1;
                    end;
               end
               else OK:=true;
               {***** Chois par Lots *****}

               if(strtointeger(DTrie('M',RDetailMarche.CodeTrie))=NSMarche)then
               begin
                    if(strtointeger(DTrie('A',RDetailMarche.CodeTrie))=NAvenantMarche)then
                    begin
                         if(NStructureMarche<>0)then
                         begin
                              if(strtointeger(DTrie('S',RDetailMarche.CodeTrie))=NStructureMarche)then
                              begin
                                   OK:=true;
                              end
                              else OK:=false;
                         end
                         else OK:=true;

                         if(OK=true)then
                         begin
                         if(NStatistiqueMarche<>0)then
                         begin
                              if(strtointeger(DTrie('T',RDetailMarche.CodeTrie))=NStatistiqueMarche)then
                              begin
                                   OK:=true;
                              end
                              else OK:=false;
                         end
                         else
                         OK:=true;
                         end;
                    end
                    else OK:=false;
               end
               else OK:=false;

               if(OK=true)then
               begin
                    if(CumuleArticle=true)then
                    begin
                         icumule:=1;
                         while(icumule<=TI)and(OK=true)do
                         begin
                              if(RDetailMarche.CodeStock=TDevisQE[icumule-1].CodeProduit)then
                              begin
                                   OK:=false;
                                   if(FSDetailMarche.RBRemplirePrixU.Checked=true)and(RDetailMarche.PrixUnitaire<>0)
                                   then
                                   begin
                                        TDevisQE[icumule-1].PrixUnitaire:=((TDevisQE[icumule-1].PrixUnitaire*TDevisQE[icumule-1].QuantiteGlobale)+(RDetailMarche.PrixUnitaire*RDetailMarche.QuantiteGlobale))/(TDevisQE[icumule-1].QuantiteGlobale+RDetailMarche.QuantiteGlobale);
                                   end;

                                   if(FSDetailMarche.RBRemplireQuantite.Checked=true)and(RDetailMarche.QuantiteGlobale<>0)
                                   then TDevisQE[icumule-1].QuantiteGlobale:=TDevisQE[icumule-1].QuantiteGlobale+RDetailMarche.QuantiteGlobale;
                              end;
                         icumule:=icumule+1;
                         end;
                    end;
               end;

               if(OK=true)then
               begin
                         TI:=TI+1;
                         SetLength(TDevisQE,TI);
                         TDevisQE[TI-1].NDetailMarche:=RDetailMarche.NDetailMarche;
                         TDevisQE[TI-1].NArticle:=RDetailMarche.NArticle;
                         TDevisQE[TI-1].DesignationArticle:=RDetailMarche.DesignationArticle;
                         TDevisQE[TI-1].UniteM:=RDetailMarche.UniteM;

                         if(FSDetailMarche.RBRemplireQuantite.Checked=true)
                         then TDevisQE[TI-1].QuantiteGlobale:=RDetailMarche.QuantiteGlobale
                         else TDevisQE[TI-1].QuantiteGlobale:=0;

                         if(FSDetailMarche.RBRemplirePrixU.Checked=true)
                         then TDevisQE[TI-1].PrixUnitaire:=RDetailMarche.PrixUnitaire
                         else TDevisQE[TI-1].PrixUnitaire:=0;

                         if(FSDetailMarche.RBRemplireMontantG.Checked=true)
                         then TDevisQE[TI-1].Montant:=TDevisQE[TI-1].QuantiteGlobale*TDevisQE[TI-1].PrixUnitaire
                         else TDevisQE[TI-1].Montant:=0;

                         TDevisQE[TI-1].CodeTrie:=RDetailMarche.CodeTrie;
                         TDevisQE[TI-1].CodeProduit:=RDetailMarche.CodeStock;
               end;
          end;
          finally
          closefile(FDetailMarche);
          end;
          TDevisQE:=OrganiseDevisQE(TDevisQE,TI,CumuleArticle,TI);
          ImporterDevisQE:=TI;
end;

Function ChargementDevisQE(CumuleArticle:boolean; var TDevisQE:TDevisQEs):integer;
var  TC,RChoix,icumule:integer; OKChoix:boolean;
begin
     SetLength(TDevisQE,0);
     TC:=0;
     for R:= 1 to FSDetailMarche.TableauDetailMarche.RowCount-1 do
     begin

     {***** Chois par Lots *****}
               if(FSDetailMarche.RBListelots.Checked=true)then
               begin
                    OKChoix:=false;
                    RChoix:=1;
                    while(RChoix<=FSDetailMarche.TableauChoixLots.RowCount-1)and(OKChoix=false)do
                    begin
                         if((FSDetailMarche.TableauChoixLots.Cells[3,RChoix]='OK')
                         and(firstlaters(Lastlaters(FSDetailMarche.TableauDetailMarche.Cells[7,R],11),2)=firstlaters(FSDetailMarche.TableauChoixLots.Cells[1,RChoix],2)))
                         then
                         begin
                              OKChoix:=true;
                         end;
                         RChoix:=RChoix+1;
                    end;
               end
               else OKChoix:=true;
               {***** Chois par Lots *****}

               if(OKChoix=true)then
               begin
                    if(CumuleArticle=true)then
                    begin
                         icumule:=1;
                         while(icumule<=TC)and(OKChoix=true)do
                         begin
                              if(FSDetailMarche.TableauDetailMarche.Cells[8,R]=TDevisQE[icumule-1].CodeProduit)
                              then
                              begin
                                   OKChoix:=false;
                                   if(FSDetailMarche.RBRemplirePrixU.Checked=true)and(strtoreal(FSDetailMarche.TableauDetailMarche.Cells[6,R])<>0)
                                   then
                                   begin
                                        TDevisQE[icumule-1].PrixUnitaire:=((TDevisQE[icumule-1].PrixUnitaire*TDevisQE[icumule-1].QuantiteGlobale)+(strtoreal(FSDetailMarche.TableauDetailMarche.Cells[6,R])*strtoreal(FSDetailMarche.TableauDetailMarche.Cells[5,R])))/(TDevisQE[icumule-1].QuantiteGlobale+strtoreal(FSDetailMarche.TableauDetailMarche.Cells[5,R]));
                                   end;

                                   if(FSDetailMarche.RBRemplireQuantite.Checked=true)and(strtoreal(FSDetailMarche.TableauDetailMarche.Cells[5,R])<>0)
                                   then TDevisQE[icumule-1].QuantiteGlobale:=TDevisQE[icumule-1].QuantiteGlobale+strtoreal(FSDetailMarche.TableauDetailMarche.Cells[5,R]);
                              end;
                         icumule:=icumule+1;
                         end;
                    end;
               end;

          if(OKChoix=true)
          and(FSDetailMarche.TableauDetailMarche.Cells[7,R]<>'')
          and(Lastlaters(FSDetailMarche.TableauDetailMarche.Cells[7,R],11)<>'00.00.00.00')
          then
          begin
                    TC:=TC+1;
                    SetLength(TDevisQE,TC);
                    TDevisQE[TC-1].NDetailMarche:=strtointeger(FSDetailMarche.TableauDetailMarche.Cells[1,R]);
                    TDevisQE[TC-1].NArticle:=FSDetailMarche.TableauDetailMarche.Cells[2,R];
                    TDevisQE[TC-1].DesignationArticle:=FSDetailMarche.TableauDetailMarche.Cells[3,R];
                    TDevisQE[TC-1].UniteM:=FSDetailMarche.TableauDetailMarche.Cells[4,R];

                    if(FSDetailMarche.RBRemplireQuantite.Checked)
                    then TDevisQE[TC-1].QuantiteGlobale:=strtoreal(FSDetailMarche.TableauDetailMarche.Cells[5,R])
                    else TDevisQE[TC-1].QuantiteGlobale:=0;

                    if(FSDetailMarche.RBRemplirePrixU.Checked)
                    then TDevisQE[TC-1].PrixUnitaire:=strtoreal(FSDetailMarche.TableauDetailMarche.Cells[6,R])
                    else TDevisQE[TC-1].PrixUnitaire:=0;

                    if(FSDetailMarche.RBRemplireMontantG.Checked)
                    then TDevisQE[TC-1].Montant:=strtoreal(FSDetailMarche.TableauDetailMarche.Cells[5,R])*
                                                 strtoreal(FSDetailMarche.TableauDetailMarche.Cells[6,R])
                    else TDevisQE[TC-1].Montant:=0;

                    TDevisQE[TC-1].CodeTrie:=FSDetailMarche.TableauDetailMarche.Cells[7,R];
                    TDevisQE[TC-1].CodeProduit:=FSDetailMarche.TableauDetailMarche.Cells[8,R];
          end;
     end;
     TDevisQE:=OrganiseDevisQE(TDevisQE,TC,CumuleArticle,TC);
     ChargementDevisQE:=TC;
end;

Function ImporterTravauxRestant(NSMarche,NStructureMarche,NStatistiqueMarche:integer; var TTravauxRestant:TTravauxRestants):integer;
