               if(RCompteur.TypeIndicePrelevement='Stock Sortant.')then
               begin
                    MontantCompteur:=MontantCompteur+(RPrelevementCompteur.ValeurPrelevement*RPrelevementCompteur.PrixPrelevement);
               end;
          end;
     end;
     finally
     CloseFile(FPrelevementCompteur);
     end;
     ///////////////////////////////////////////////////////////////////////////

     FichierConcerne:='FArchivePrelevementUniteFonds';
     OpenFParc(RParc);
     ChPrelevementUniteFonds:=RParc.Parcours+'\'+Exercice+FichierConcerne;
     assignfile(FPrelevementUniteFonds,ChPrelevementUniteFonds);
     try
     if FileExists(ChPrelevementUniteFonds)then
     Reset(FPrelevementUniteFonds)
     else Rewrite(FPrelevementUniteFonds);
     Seek(FPrelevementUniteFonds,0);
     MontantUniteFonds:=0;
     while not eof(FPrelevementUniteFonds)do
     begin
          read(FPrelevementUniteFonds,RPrelevementUniteFonds);

          FSTravauxFinAnnee.AfficherDetailleReouverture.Lines.Add('Calcule PUF n° '+inttostr(RPrelevementUniteFonds.NumPrelevementUniteFonds)+' du '+RPrelevementUniteFonds.DatePrelevement);

          if(datecorrecte(DateBegin)and(datecorrecte(DateEnd)))then
          begin
              if (datecorrecte(RPrelevementUniteFonds.DatePrelevement)=true)
              and(strtodate(RPrelevementUniteFonds.DatePrelevement)>=strtodate(DateBegin))
              and(strtodate(RPrelevementUniteFonds.DatePrelevement)<=strtodate(DateEnd))
              then OKData:=true
              else OKData:=false;
          end
          else OKData:=false;

          if(OKData=true)then
          begin
               RUniteFonds:=ChercherUniteFonds(inttostr(RPrelevementUniteFonds.NumUniteFonds));
               MontantUniteFonds:=MontantUniteFonds+(RPrelevementUniteFonds.ValeurPrelevement*RUniteFonds.ValeurMonetaireUnitaire);
          end;
     end;
     finally
     CloseFile(FPrelevementUniteFonds);
     end;
     ///////////////////////////////////////////////////////////////////////////

     FichierConcerne:='FArchiveRegistreAffectationEffectifEquipe';
     OpenFParc(RParc);
     ChRegistreAffectationEffectifEquipe:=RParc.Parcours+'\'+Exercice+FichierConcerne;
     assignfile(FRegistreAffectationEffectifEquipe,ChRegistreAffectationEffectifEquipe);
     try
     if FileExists(ChRegistreAffectationEffectifEquipe)then
     Reset(FRegistreAffectationEffectifEquipe)
     else Rewrite(FRegistreAffectationEffectifEquipe);
     Seek(FRegistreAffectationEffectifEquipe,0);
     MontantFondRoulement:=0;
     while not eof(FRegistreAffectationEffectifEquipe)do
     begin
          read(FRegistreAffectationEffectifEquipe,RRegistreAffectationEffectifEquipe);

          FSTravauxFinAnnee.AfficherDetailleReouverture.Lines.Add('Calcule RAEE n° '+inttostr(RRegistreAffectationEffectifEquipe.NumAffectationEffectifEquipe)+'/'+RRegistreAffectationEffectifEquipe.Matricule);

          if(datecorrecte(DateBegin)and datecorrecte(DateEnd))then
          begin
               RPrelevement:=ChercherPrelevement(RRegistreAffectationEffectifEquipe.NumPrelevement,ExerciceAnnee,'',PositionPrelevement);
               if (datecorrecte(RPrelevement.DatePrelevement)=true)
               and(strtodate(RPrelevement.DatePrelevement)>=strtodate(DateBegin))
               and(strtodate(RPrelevement.DatePrelevement)<=strtodate(DateEnd))
               then OKData:=true
               else OKData:=false;
          end
          else OKData:=false;

          if(OKData=true)then
          begin
               RUniteFonds:=ChercherUniteFonds(inttostr(RRegistreAffectationEffectifEquipe.RUniteFondsAffecter.NumUniteFonds));
               MontantFondRoulement:=MontantFondRoulement+(RRegistreAffectationEffectifEquipe.ValeurAffecter*RUniteFonds.ValeurMonetaireUnitaire);
          end;
     end;
     finally
     CloseFile(FRegistreAffectationEffectifEquipe);
     end;
     ///////////////////////////////////////////////////////////////////////////
     SoldePrelevement:=ValePrecis(MontantUniteFonds-MontantFondRoulement-MontantCompteur,2)
end;

Function OKArchivePrelevement(NumPrelevement,Matricule:string; var  PositionPrelevement:string):boolean;
var i:integer;  OKPrelevementTrouver,OKPrelevementExiste:boolean;  TypeProcesPrelevement,FichierConcernePrelevement,AdressePrelevement:string;
begin
     TypeProcesPrelevement:='Business';
     FichierConcernePrelevement:='FPrelevement';
     AdressePrelevement:='';
     if not(FunctionAdresseProces(TypeProcesPrelevement,FichierConcernePrelevement,'',AdressePrelevement,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcernePrelevement<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConcernePrelevement+'} recherché !');
     end;

     ChPrelevement:=AdressePrelevement;
     assignfile(FPrelevement,ChPrelevement);
     try
     if FileExists(ChPrelevement)then
     Reset(FPrelevement)
     else Rewrite(FPrelevement);
     Seek(FPrelevement,0);
     OKPrelevementTrouver:=false;
     OKArchivePrelevement:=false;
     PositionPrelevement:='';
     i:=0;
     while not eof(FPrelevement)and(OKPrelevementTrouver=false)do
     begin
          read(FPrelevement,RPrelevement);

          if(NumPrelevement<>'')then
          begin
               if(RPrelevement.NumPrelevement=strtointeger(NumPrelevement))
               then OKPrelevementExiste:=true
               else OKPrelevementExiste:=false;
          end
          else OKPrelevementExiste:=true;

          if(OKPrelevementExiste=true)then
          begin
               if(Matricule<>'')then
               begin
                    if(RPrelevement.Matricule=Matricule)
                    then OKPrelevementExiste:=true
                    else OKPrelevementExiste:=false;
               end
               else if(NumPrelevement='')then OKPrelevementExiste:=false;
          end;

          if(OKPrelevementExiste=true)then
          begin
               OKPrelevementTrouver:=true;
               OKArchivePrelevement:=RPrelevement.Archiver;
               PositionPrelevement:=inttostr(i);
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FPrelevement);
     end;
end;

Function FunctionAdresseProces(TypeProces,FichierConcerne,AdressePublicationChoisis:string; var AdresseProces:string; var TypeProcesReseaux,NomDossierPartageReseauxSource:string):boolean;
var  OKAdresseProcesFAP,OKFichierConcerne,OKRegistre,OKExtention,OKProcece:boolean;  A,B:integer;
     ExerciceProces:string[4];  ChRegistreReseaux,AdresseTypeProces,NomDossierPartageOut,RechercheNomDossierPartageReseaux,EmlacementLocalOuReseauxOut:string;
     TableauListeFPR:ArrayListeFichierPartageReseaux; TailTFPR:integer;
     OKFunctionAdresseProces:boolean;
     label debutFunctionAdresseProces;
begin
     FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+'.....');
     FSMenuPrincipal.AfficheRapport.Visible:=FunctAfficherRapportPublicationReseaux;

     if not(IncrementationFunctionAdresseProces in[0..3])then IncrementationFunctionAdresseProces:=0;
     debutFunctionAdresseProces:
     IncrementationFunctionAdresseProces:=IncrementationFunctionAdresseProces+1;
     OKFunctionAdresseProces:=true;

     try

     A:=GetTickCount;

     NomDossierPartageReseauxSource:='';
     TypeProcesReseaux:='';
     AdresseProces:='';
     RechercheNomDossierPartageReseaux:='';

     if((TypeProces<>'Réseaux')and(TypeProces<>'Business')and(TypeProces<>'Comptabilité')and(TypeProces<>'Commercial')and(TypeProces<>'Social')and(TypeProces<>'Paie'))then
     begin // Réseaux
          AdresseProces:=ProcAdresseDossierPartageReseaux(TypeProces,'',NomDossierPartageOut,EmlacementLocalOuReseauxOut)+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceAnnee+FichierConcerne+' '+NomDossierPartageOut;
          ExerciceProces:=ExerciceAnnee;
          RechercheNomDossierPartageReseaux:=NomDossierPartageOut;

          if(AdresseProces<>'')and(ExisteDossierPartagerReseaux(AdresseProces,false,false)=true)
          then OKAdresseProcesFAP:=true
          else OKAdresseProcesFAP:=false;
     end
     else
     begin// Proces
           OpenFParc(RParc);
           ChAdresseProcesFunction:=RParc.Parcours+'\'+Exercice+'FAdresseProces';
           assignfile(FAdresseProcesFunction,ChAdresseProcesFunction);
           if FileExists(ChAdresseProcesFunction)and(FuctionFichierDisponible(ChAdresseProcesFunction)=0)then
           begin
                 try
                 Reset(FAdresseProcesFunction);
                 Seek(FAdresseProcesFunction,0);
                 OKAdresseProcesFAP:=false;
                 OKFichierConcerne:=false;
                 while(not eof(FAdresseProcesFunction))and(OKAdresseProcesFAP=false)do
                 begin
                      read(FAdresseProcesFunction,RAdresseProcesFunction);

                      OKProcece:=false;

                      if(FichierConcerne<>'')and(RAdresseProcesFunction.FichierConcerne<>'')then
                      begin
                           if ExisteFichierConcernePartageReseauxInListeServeur(inttostr(RAdresseProcesFunction.NumAdresseProces),FichierConcerne,RListeFichierConcernePartageReseauxCopie,TableauListeFPR,TailTFPR)then
                           begin
                                OKProcece:=true;
                                TypeProces:=RAdresseProcesFunction.TypeProces;
                                ExerciceProces:=RAdresseProcesFunction.Exercice;
                                RechercheNomDossierPartageReseaux:=RAdresseProcesFunction.Repertoire;
                           end;
                      end
                      else
                      if(FichierConcerne='')and(RAdresseProcesFunction.FichierConcerne='')then
                      begin
                           if(RAdresseProcesFunction.TypeProces=TypeProces)or(RAdresseProcesFunction.TypeProces='Business')or(RAdresseProcesFunction.TypeProces='Réseaux')then
                           begin
                                OKProcece:=true;
                                TypeProces:=RAdresseProcesFunction.TypeProces;
                                ExerciceProces:=RAdresseProcesFunction.Exercice;
                                RechercheNomDossierPartageReseaux:=RAdresseProcesFunction.Repertoire;
                           end;
                      end
                      else
                      if(FichierConcerne='')and(RAdresseProcesFunction.FichierConcerne<>'')then
                      begin
                           OKProcece:=false;
                      end
                      else
                      if(FichierConcerne<>'')and(RAdresseProcesFunction.FichierConcerne='')then
                      begin
                           if(RAdresseProcesFunction.TypeProces=TypeProces)or(RAdresseProcesFunction.TypeProces='Business')or(RAdresseProcesFunction.TypeProces='Réseaux')then
                           begin
                                OKProcece:=true;
                                TypeProces:=RAdresseProcesFunction.TypeProces;
                                ExerciceProces:=RAdresseProcesFunction.Exercice;
                                RechercheNomDossierPartageReseaux:=RAdresseProcesFunction.Repertoire;
                           end;
                      end;

                      if(OKProcece=true)then
                      begin
                           OKAdresseProcesFAP:=true;
                           if(TypeProces<>'Réseaux')then
                           begin
                                 ChEnregistrement:=RAdresseProcesFunction.AdresseProces;
                                 if FileExists(ChEnregistrement)then
                                 begin
                                      Assignfile(FParc,ChEnregistrement);
                                      try
                                      reset(FParc);
                                      Seek(FParc,0);
                                      if not eof(FParc)then
                                      begin
                                           Read(FParc,RParc);
                                           if(RAdresseProcesFunction.Exercice<>'Auto')then
                                           begin
                                                ExerciceProces:=RAdresseProcesFunction.Exercice;
                                           end
                                           else
                                           begin
                                                if(TypeProces='Business')then AdresseTypeProces:='C:\WinBuss.dll';
                                                if(TypeProces='Comptabilité')then AdresseTypeProces:='C:\WinComptas.dll';
                                                if(TypeProces='Commercial')then AdresseTypeProces:='C:\Windll.dll';
                                                if(TypeProces='Social')then AdresseTypeProces:='C:\WinSCdll.dll';
                                                if(TypeProces='Paie')then AdresseTypeProces:='C:\WinPaies.dll';

                                                ExerciceProces:=Lastlaters(datetostr(date),4);
                                                if FileExists(AdresseTypeProces)then
                                                begin
                                                     assignfile(FRegistre,AdresseTypeProces);
                                                     try
                                                     reset(FRegistre);
                                                     Seek(FRegistre,0);
                                                     OKRegistre:=false;
                                                     while not eof(FRegistre)and(OKRegistre=false)do
                                                     begin
                                                          Read(FRegistre,RRegistre);
                                                          if(AnsiUpperCase(RRegistre.Repertoire)=AnsiUpperCase(RAdresseProcesFunction.Repertoire))
                                                          and(AnsiUpperCase(RRegistre.Adresse)=AnsiUpperCase(RAdresseProcesFunction.AdresseProces))
                                                          then
                                                          begin
                                                               OKRegistre:=true;
                                                               ExerciceProces:=RRegistre.Exercice;
                                                          end;
                                                     end;
                                                     finally
                                                     CloseFile(FRegistre);
                                                     end;
                                                end;
                                           end;

                                           if(TypeProces='Social')then AdresseProces:=RParc.Parcours+'\'+RAdresseProcesFunction.Repertoire+'-'+FichierConcerne;
                                           if(TypeProces='Paie')then AdresseProces:=RParc.Parcours+'\'+RAdresseProcesFunction.Repertoire+'-'+FichierConcerne;
                                           if(TypeProces='Commercial')then AdresseProces:=RParc.Parcours+'\'+RAdresseProcesFunction.Repertoire+'-'+ExerciceProces+FichierConcerne;
                                           if(TypeProces='Comptabilité')then AdresseProces:=RParc.Parcours+'\'+RAdresseProcesFunction.Repertoire+'-'+ExerciceProces+FichierConcerne;
                                           if(TypeProces='Business')then AdresseProces:=RParc.Parcours+'\'+RAdresseProcesFunction.Repertoire+'-'+ExerciceProces+FichierConcerne;

                                           if(FichierConcerne<>'')then
                                           begin
                                                if(ExisteCharinString(AnsiUpperCase(ExtentionFichier(AdresseProces)),AnsiUpperCase('.Bmp ;.Dib ;.Jpg ;.Jpeg ;.Jpe ;.Jfif ;.Gif ;.Tif ;.Tiff ;.png')))
                                                then OKExtention:=true
                                                else OKExtention:=false;

                                                if not FileExists(AdresseProces)and(OKExtention=false)then
                                                begin
                                                     Assignfile(FParcCopie,AdresseProces);
                                                     try
                                                     Rewrite(FParcCopie);
                                                     finally
                                                     closefile(FParcCopie);
                                                     end;
                                                end;

                                                if FileExists(AdresseProces)or(OKExtention=true)
                                                then OKFichierConcerne:=true
                                                else OKFichierConcerne:=false;
                                           end
                                           else OKFichierConcerne:=true;
                                      end;
                                      finally
                                      CloseFile(FParc)
                                      end;
                                 end;

                                 if(OKFichierConcerne=true)then RechercheNomDossierPartageReseaux:=RAdresseProcesFunction.Repertoire;
                           end
                           else
                           begin
                                if(ExerciceProces='Auto')then
                                begin
                                     if(FunctionUtiliseExerciceLocalPourLectureSousReseaux=false)then
                                     begin
                                          ChRegistreReseaux:=RAdresseProcesFunction.AdresseProces+'\WinBus'+DataIdentificateurReseaux+' '+RAdresseProcesFunction.Repertoire+'.File';
                                          assignfile(FRegistre,ChRegistreReseaux);
                                          if FileExists(ChRegistreReseaux)then
                                          begin
                                               try
                                               Reset(FRegistre);
                                               Seek(FRegistre,0);
                                               read(FRegistre,RRegistre);
                                               ExerciceProces:=RRegistre.Exercice;
                                               finally
                                               CloseFile(FRegistre);
                                               end;
                                          end
                                          else ExerciceProces:=ExerciceAnnee;
                                     end
                                     else ExerciceProces:=ExerciceAnnee;
                                end
                                else ExerciceProces:=ExerciceAnnee;

                                RechercheNomDossierPartageReseaux:=RAdresseProcesFunction.Repertoire;
                                //if(ExisteMachineSousReseaux(ExtractFileDir(RAdresseProcesFunction.AdresseProcesFunction),true,false)=false)then
                                if(ExisteDossierPartagerReseaux(RAdresseProcesFunction.AdresseProces,true,false)=false)then
                                begin
                                     AdresseProces:=ProcAdresseDossierPartageReseaux('','Local',NomDossierPartageOut,EmlacementLocalOuReseauxOut)+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceProces+FichierConcerne+' '+NomDossierPartageOut;
                                end
                                else
                                begin
                                     if(not FileExists(RAdresseProcesFunction.AdresseProces+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceProces+FichierConcerne+' '+RAdresseProcesFunction.Repertoire))then
                                     begin
                                          AdresseProces:=ProcAdresseDossierPartageReseaux('','Local',NomDossierPartageOut,EmlacementLocalOuReseauxOut)+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceProces+FichierConcerne+' '+NomDossierPartageOut;
                                     end
                                     else
                                     begin
                                          AdresseProces:=RAdresseProcesFunction.AdresseProces+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceProces+FichierConcerne+' '+RAdresseProcesFunction.Repertoire;
                                     end;
                                end;

                                OKAdresseProcesFAP:=true;
                                OKFichierConcerne:=true;
                           end;
                      end;
                 end;
                 Finally
                 //CloseFile(FAdresseProcesFunction);//A Voir
                 end;
                 
           end;

           if(OKFichierConcerne=false)then
           begin
                OpenFParc(RParc);
                AdresseProces:=RParc.Parcours+'\'+Exercice+FichierConcerne;
                RechercheNomDossierPartageReseaux:='';

                if(FichierConcerne<>'')then
                begin
                     if FileExists(AdresseProces)
                     then
                     begin
                          OKAdresseProcesFAP:=true;
                          OKFichierConcerne:=true
                     end
                     else
                     begin
                          OKAdresseProcesFAP:=false;
                          OKFichierConcerne:=false;
                     end;
                end
                else OKFichierConcerne:=true;
           end;
     end;
     FunctionAdresseProces:=OKAdresseProcesFAP;
     TypeProcesReseaux:=TypeProces;
     NomDossierPartageReseauxSource:=RechercheNomDossierPartageReseaux;

     B:=GetTickCount;

     if(FSAffichage.AfficheTexte3.Lines.Count>=500)then AffichageProgressif(FSAffichage.AfficheTexte3,'',true,false);
     AffichageProgressif(FSAffichage.AfficheTexte3,'Fichier             : '+FichierConcerne,false,false);
     AffichageProgressif(FSAffichage.AfficheTexte3,'Type Proces   : '+TypeProces,false,false);
     AffichageProgressif(FSAffichage.AfficheTexte3,'Adress            : '+AdresseProces,false,false);
     AffichageProgressif(FSAffichage.AfficheTexte3,'Dossier           : '+NomDossierPartageReseauxSource,false,false);
     AffichageProgressif(FSAffichage.AfficheTexte3,'*************** Ligne: '+inttostr(FSAffichage.AfficheTexte3.Lines.Count+1)+'; temps: '+inttostr(B-A)+' ms.'+' ***************',false,false);
     AffichageProgressif(FSAffichage.AfficheTexte3,'',false,false);

     except
           FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+'');
           FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+' Fonction Adresse Proces '+FichierConcerne+' interrompu '+inttostr(IncrementationFunctionAdresseProces)+' fois !');
           FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+'');
           OKFunctionAdresseProces:=false;
     end;

     if(OKFunctionAdresseProces=false)
     and(IncrementationFunctionAdresseProces<3)
     then goto DebutFunctionAdresseProces
     else
     begin
          FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+'');
          if(OKFunctionAdresseProces=false)
          then FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+' Attention: Fonction Adresse Proces '+FichierConcerne+' non achevé aprčs '+inttostr(IncrementationFunctionAdresseProces)+' tentatives !')
          else FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+' Fonction Adresse Proces '+FichierConcerne+' terminé avec succčs !');
          FSMenuPrincipal.EditDetailRapport.Lines.Add(inttostr(FSMenuPrincipal.EditDetailRapport.Lines.Count)+'');

          IncrementationFunctionAdresseProces:=0;
     end;

     if(FuctionFichierDisponible(AdresseProces)<>0)then FunctionAdresseProces:=false;
end;

Function ChercherTypeAvis(NumTypeAvis,DesignationTypeAvis,CompteImputation,DebitCredit,TypeProces,AvisConcerneTiers:string;  var RTypeAvis:RTypeAviss):string;
var   OKTypeAvis,OKNumTypeAvis,OKDesignationTypeAvis,OKCompteImputation,OKDebitCredit,OKTypeProces,OKAvisConcerneTiers:string[1];
      TypeProcesTypeAvis,FichierConserneTypeAvis,AdresseTypeAvis:string;
begin
     RTypeAvis.NumTypeAvis:=0;
     RTypeAvis.DesignationTypeAvis:='';
     RTypeAvis.CompteImputation:='';
     RTypeAvis.DebitCredit:='';
     RTypeAvis.SigneDebitCredit:=1;
     RTypeAvis.TypeProces:='';
     RTypeAvis.FichierConserne:='';
     RTypeAvis.JourneauxAuxiliaireUtilise:='';

     TypeProcesTypeAvis:='Business';
     FichierConserneTypeAvis:='FTypeAvis';
     if not(FunctionAdresseProces(TypeProcesTypeAvis,FichierConserneTypeAvis,'',AdresseTypeAvis,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConserneTypeAvis<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConserneTypeAvis+'} recherché !');
     end;

     ChTypeAvis:=AdresseTypeAvis;
     assignfile(FTypeAvis,ChTypeAvis);
     if FileExists(ChTypeAvis)then
     begin
          try
          Reset(FTypeAvis);
          Seek(FTypeAvis,0);
          OKTypeAvis:='?';
          while not eof(FTypeAvis)and(OKTypeAvis='?')do
          begin
               read(FTypeAvis,RTypeAvis);

               OKNumTypeAvis:='?';

               if(OKNumTypeAvis<>'0')then
               begin
                    if(NumTypeAvis<>'')then
                    begin
                         if(RTypeAvis.NumTypeAvis=strtointeger(NumTypeAvis))
                         then OKNumTypeAvis:='1'
                         else OKNumTypeAvis:='0';
                    end
                    else OKNumTypeAvis:='?';
               end;

               if(OKNumTypeAvis<>'0')then
               begin
                    if(DesignationTypeAvis<>'')then
                    begin
                         if(RTypeAvis.DesignationTypeAvis=DesignationTypeAvis)
                         then OKDesignationTypeAvis:='1'
                         else OKDesignationTypeAvis:='0';
                    end
                    else OKDesignationTypeAvis:='?';
               end;

               if(OKDesignationTypeAvis<>'0')then
               begin
                    if(CompteImputation<>'')then
                    begin
                         if(RTypeAvis.CompteImputation=CompteImputation)
                         then OKCompteImputation:='1'
                         else OKCompteImputation:='0';
                    end
                    else OKCompteImputation:='?';
               end;

               if(OKCompteImputation<>'0')then
               begin
                    if(DebitCredit<>'')then
                    begin
                         if(RTypeAvis.DebitCredit=DebitCredit)
                         then OKDebitCredit:='1'
                         else OKDebitCredit:='0';
                    end
                    else OKDebitCredit:='?';
               end;

               if(OKDebitCredit<>'0')then
               begin
                    if(TypeProces<>'')then
                    begin
                         if(RTypeAvis.TypeProces=TypeProces)
                         then OKTypeProces:='1'
                         else OKTypeProces:='0';
                    end
                    else OKTypeProces:='?';
               end;

               if(OKTypeProces<>'0')then
               begin
                    if(AvisConcerneTiers<>'')then
                    begin
                         if(RTypeAvis.FichierConserne=AvisConcerneTiers)
                         then OKAvisConcerneTiers:='1'
                         else OKAvisConcerneTiers:='0';
                    end
                    else OKAvisConcerneTiers:='?';
               end;

               if (OKNumTypeAvis<>'0')
               and(OKDesignationTypeAvis<>'0')
