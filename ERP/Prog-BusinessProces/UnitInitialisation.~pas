Function IndiquePeriode(DateDebut,DateFin:string):string;
var  JourDebut,JourFin,MoisDebut,MoisFin:integer; AnneeDebut,AnneeFin:string[4];
     OKPeriode:boolean;
begin
OKPeriode:=false;
if (DateDebut<>'')and(DateDebut<>'  /    ')and(DateFin<>'')and(DateFin<>'  /    ')
then
begin
     if(strtodate(DateDebut)>strtodate(DateFin))then
     begin
          OKPeriode:=true;
     end;
end
else
begin
     OKPeriode:=true;
end;

if(OKPeriode=true)then
begin
     IndiquePeriode:='non valide!';
     Showmessage('Période non valide!');
     exit;
end;

     JourDebut:=strtointeger(Firstlaters(DateDebut,2));
     MoisDebut:=strtointeger(Firstlaters(Lastlaters(DateDebut,7),2));
     AnneeDebut:=Lastlaters(DateDebut,4);

     JourFin:=strtointeger(Firstlaters(DateFin,2));
     MoisFin:=strtointeger(Firstlaters(Lastlaters(DateFin,7),2));
     AnneeFin:=Lastlaters(DateFin,4);

if(DateDebut=DateFin)then
begin
     OKPeriode:=true;
     IndiquePeriode:='Journée du '+DateDebut;
end
else
if(JourDebut=1)and(JourFin=LastDay(DateFin))then
begin
     if(OKPeriode=false)
     and(MoisDebut=MoisFin)
     and(AnneeDebut=AnneeFin)
     then
     begin
          OKPeriode:=true;
          case MoisDebut of
          1:  IndiquePeriode:='Janvier '+AnneeDebut;
          2:  IndiquePeriode:='Février '+AnneeDebut;
          3:  IndiquePeriode:='Mars '+AnneeDebut;
          4:  IndiquePeriode:='Avril '+AnneeDebut;
          5:  IndiquePeriode:='Mai '+AnneeDebut;
          6:  IndiquePeriode:='Juin '+AnneeDebut;
          7:  IndiquePeriode:='Juillet '+AnneeDebut;
          8:  IndiquePeriode:='Aoűt '+AnneeDebut;
          9:  IndiquePeriode:='Septembre '+AnneeDebut;
          10: IndiquePeriode:='Octobre '+AnneeDebut;
          11: IndiquePeriode:='Novembre '+AnneeDebut;
          12: IndiquePeriode:='Décembre '+AnneeDebut;
          end;
     end;

     if(OKPeriode=false)
     and(AnneeDebut=AnneeFin)then
     begin
          case MoisDebut of
          1:case MoisFin of
            3:  begin IndiquePeriode:='1er Trimestre '+AnneeDebut; OKPeriode:=true; end;
            6:  begin IndiquePeriode:='1er Semestre '+AnneeDebut; OKPeriode:=true; end;
            12: begin IndiquePeriode:='Année '+AnneeDebut; OKPeriode:=true; end;
            end;

          4:case MoisFin of
            6:  begin IndiquePeriode:='2čme Trimestre '+AnneeDebut; OKPeriode:=true; end;
            12: begin IndiquePeriode:='2čme Semestre '+AnneeDebut; OKPeriode:=true; end;
            end;

          7:case MoisFin of
            9: begin IndiquePeriode:='3čme Trimestre '+AnneeDebut; OKPeriode:=true; end;
            end;

          10:case MoisFin of
            12: begin IndiquePeriode:='4čme Trimestre '+AnneeDebut; OKPeriode:=true; end;
            end;
          end;           
     end;
end;

     if(OKPeriode=false)then
     begin
          IndiquePeriode:=DateDebut+' - '+DateFin;
     end;

end;

Function  LongueurWidth(Text:string; FondSeiz:integer):integer;
var iLongueur:integer;  Width:Real;
begin
Text:=Text+'$';
iLongueur:=1;
Width:=0;
while(Text[iLongueur]<>'$')do
begin
     if(Text[iLongueur]in['A','D','G','H','N','Q','U'])then Width:=Width+FondSeiz
     else
     if(Text[iLongueur]in['B','C','K','P','R','V','X'])then Width:=Width+FondSeiz-1
     else
     if(Text[iLongueur]in['E','F','L','S','T','Y','Z'])then Width:=Width+FondSeiz-2
     else
     if(Text[iLongueur]in[' ','.',',','I'])then Width:=Width+FondSeiz-5
     else
     if(Text[iLongueur]in['J'])then Width:=Width+FondSeiz-4
     else
     if(Text[iLongueur]in['M'])then Width:=Width+FondSeiz+3
     else
     if(Text[iLongueur]in['O'])then Width:=Width+FondSeiz+1
     else
     if(Text[iLongueur]in['W'])then Width:=Width+FondSeiz+4
     else
     if(Text[iLongueur]in['a','c','g','k','v','x','y' ])then Width:=Width+FondSeiz-2
     else
     if(Text[iLongueur]in['b','d','e','h','n','o','p','q','u'])then Width:=Width+FondSeiz-1
     else
     if(Text[iLongueur]in['f','j','t'])then Width:=Width+FondSeiz-4
     else
     if(Text[iLongueur]in[' ','i','l'])then Width:=Width+FondSeiz-5
     else
     if(Text[iLongueur]in['m'])then Width:=Width+FondSeiz+2
     else
     if(Text[iLongueur]in['r','s','z'])then Width:=Width+FondSeiz-3
     else
     if(Text[iLongueur]in['w'])then Width:=Width+FondSeiz+1
     else
     if(Text[iLongueur]in['0'..'9'])then Width:=Width+FondSeiz-2
     else
     Width:=Width+FondSeiz+2;

     iLongueur:=iLongueur+1;
end;

LongueurWidth:=FondSeiz+ValeAbsolue(Width);
end;

Function ValeAbsolue(Chiffre:real):integer;
var   ChiffreTexte,Texte:string;
begin
     ValeAbsolue:=0;
     ChiffreTexte:=Floattostr(Chiffre);
     Texte:='';
     i:=1;
     while((i<=Longueur(ChiffreTexte))and(ChiffreTexte[i]<>','))do
     begin
          if(ChiffreTexte[i]<>'-')then
          Texte:=Texte+ChiffreTexte[i];
          i:=i+1;
     end;
     ValeAbsolue:=Strtointeger(Texte);
end;

Function RealInInteger(Chiffre:real):integer;
var  ValeEntiere,ValeDecimale:integer;
begin
     ValeEntiere:=ValeAbsolue(Chiffre);
     ValeDecimale:=ValeAbsolue((Chiffre-ValeEntiere)*100);
     if(ValeDecimale>1)
     then RealInInteger:= ValeEntiere+1
     else RealInInteger:= ValeEntiere;
end;

Function Vale(Texte:string):real;
begin
     Vale:=ValePrecis(strtoreal(Texte),strtointeger(FSMenuPrincipal.EditValeDecimalePrecise.Text));
end;

