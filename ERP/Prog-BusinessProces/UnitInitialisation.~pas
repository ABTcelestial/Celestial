Function FirstLaters(Texte:string;Nbr:integer):string;
var iFL:integer; ResultLaters:string;
begin
     if(Nbr<=Longueur(Texte))then
     begin
          ResultLaters:='';
          for iFL:=1 to Nbr do
          begin
               ResultLaters:=ResultLaters+Texte[iFL];
          end;
          FirstLaters:=ResultLaters;
     end
     else FirstLaters:=Texte;
end;

Function LastLaters(Texte:string;Nbr:integer):string;
var iLL:integer; ResultLaters:string;
begin
     if(Nbr<=Longueur(Texte))then
     begin
          ResultLaters:='';
          for iLL:=(Longueur(Texte)-Nbr+1)to Longueur(Texte) do
          begin
               ResultLaters:=ResultLaters+Texte[iLL];
          end;
          LastLaters:=ResultLaters;
     end
     else LastLaters:=Texte;
end;

Function MidelLaters(Texte:string; NbrBegin,NbrEnd:integer):string;
var iML:integer; ResultLaters:string;
begin
     if(NbrBegin<=NbrEnd)then
     begin
          if(NbrEnd<=Longueur(Texte))then
          begin
               ResultLaters:='';
               for iML:=NbrBegin to NbrEnd do
               begin
                    ResultLaters:=ResultLaters+Texte[iML];
               end;
               MidelLaters:=ResultLaters;
          end
          else
          begin
               if(NbrBegin<=Longueur(Texte))then
               begin
                    ResultLaters:='';
                    for iML:=NbrBegin to Longueur(Texte) do
                    begin
                         ResultLaters:=ResultLaters+Texte[iML];
                    end;
                    MidelLaters:=ResultLaters;
               end
               else
               begin
                    MidelLaters:='';
               end;
          end;
     end
     else MidelLaters:='';
end;

