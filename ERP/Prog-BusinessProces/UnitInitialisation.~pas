                         TTravauxRestant[TI-1].MontantRestantOM:=TTravauxRestant[TI-1].QuantiteRestantOM*TTravauxRestant[TI-1].PrixUnitaire;
                         TTravauxRestant[TI-1].MontantRestantOA:=TTravauxRestant[TI-1].QuantiteRestantOA*TTravauxRestant[TI-1].PrixUnitaire;
                    end
                    else
                    begin
                         TTravauxRestant[TI-1].MontantMarche:=0;
                         TTravauxRestant[TI-1].MontantAvenant:=0;

                         TTravauxRestant[TI-1].MontantRealiser:=0;
                         TTravauxRestant[TI-1].MontantRealiserOM:=0;
                         TTravauxRestant[TI-1].MontantRealiserOA:=0;

                         TTravauxRestant[TI-1].MontantRestant:=0;
                         TTravauxRestant[TI-1].MontantRestantOM:=0;
                         TTravauxRestant[TI-1].MontantRestantOA:=0
                    end;

                    TTravauxRestant[TI-1].CodeTrie:=RDetailMarche.CodeTrie;
                    TTravauxRestant[TI-1].CodeProduit:=RDetailMarche.CodeStock;

                    if((TTravauxRestant[TI-1].QuantiteOM+TTravauxRestant[TI-1].QuantiteOA)<>0)
                    then TTravauxRestant[TI-1].PourcentagePhysique:=TTravauxRestant[TI-1].QuantiteRealiser/(TTravauxRestant[TI-1].QuantiteOM+TTravauxRestant[TI-1].QuantiteOA)
                    else TTravauxRestant[TI-1].PourcentagePhysique:=0;

                    if(TTravauxRestant[TI-1].MontantMarche<>0)or(TTravauxRestant[TI-1].MontantAvenant<>0)and(RMarcheCopie.MontantMarche<>0)
                    then TTravauxRestant[TI-1].CoefficientParticipation:=(TTravauxRestant[TI-1].MontantMarche+TTravauxRestant[TI-1].MontantAvenant)/RMarcheCopie.MontantMarche
                    else TTravauxRestant[TI-1].CoefficientParticipation:=0;

                    if(TTravauxRestant[TI-1].PourcentagePhysique<>0)and(TTravauxRestant[TI-1].CoefficientParticipation<>0)
                    then TTravauxRestant[TI-1].PourcentageGlobal:=TTravauxRestant[TI-1].PourcentagePhysique*TTravauxRestant[TI-1].CoefficientParticipation
                    else TTravauxRestant[TI-1].PourcentageGlobal:=0;
               end;
          end;
          finally
          closefile(FDetailMarche);
          end;
          TTravauxRestant:=OrganiseTravauxRestant(TTravauxRestant,TI,TI);
          ImporterTravauxRestant:=TI;
end;

Function ChargementTravauxRestant(var TTravauxRestant:TTravauxRestants):integer;
var  TC,RChoix:integer; OKChoix,OKDispo:boolean;
     QteMarche,QteAvenant,QteRealiserMarche,QteRealiserAvenant,QteRestanteMarche,QteRestanteAvenant,MontantMarcheAvenantGlobal:real;
begin
     MontantMarcheAvenantGlobal:=FunctMontantMarcheHT(FSDetailMarche.EditNSMarche.Text);

     for R:=1 to FSDetailMarche.TableauAvenantMarche.RowCount-1 do
     begin
          if(FSDetailMarche.TableauAvenantMarche.Cells[2,R]<>'')
          then MontantMarcheAvenantGlobal:=MontantMarcheAvenantGlobal+FunctMontantMarcheHT(FSDetailMarche.TableauAvenantMarche.Cells[2,R]);
     end;

     FSDetailMarche.MontantMarcheHT.Caption:='MHT Marche: '+Vergule(floattostr(MontantMarcheAvenantGlobal),'2','C','');

     SetLength(TTravauxRestant,0);
     TC:=0;
     for R:= 1 to FSDetailMarche.TableauDetailMarche.RowCount-1 do
     begin

     {***** Chois par Lots *****}
               if(FSDetailMarche.RBListelots.Checked=true)then
               begin
                    OKChoix:=false;
                    RChoix:=1;
                    while(RChoix<=FSDetailMarche.TableauChoixLots.RowCount-1)and(OKChoix=false)do
                    begin
                         if((FSDetailMarche.TableauChoixLots.Cells[3,RChoix]='OK')
                         and(firstlaters(Lastlaters(FSDetailMarche.TableauDetailMarche.Cells[7,R],11),2)=firstlaters(FSDetailMarche.TableauChoixLots.Cells[1,RChoix],2)))
                         then
                         begin
                              OKChoix:=true;
                         end;
                         RChoix:=RChoix+1;
                    end;
               end
               else OKChoix:=true;
               {***** Chois par Lots *****}

          if(OKChoix=true)
          and(FSDetailMarche.TableauDetailMarche.Cells[7,R]<>'')
          and(Lastlaters(FSDetailMarche.TableauDetailMarche.Cells[7,R],11)<>'00.00.00.00')
          then
          begin
               SoldeAttachement(FSDetailMarche.TableauDetailMarche.Cells[7,R],QteMarche,QteAvenant,QteRealiserMarche,QteRealiserAvenant,QteRestanteMarche,QteRestanteAvenant);

               if(FSDetailMarche.RBArticlesDisponible.Checked=true)then
               begin
                    if(QteMarche=0)then
                    begin
                         if(Lastlaters(FSDetailMarche.TableauDetailMarche.Cells[7,R],5)='00.00')
                         or(Lastlaters(FSDetailMarche.TableauDetailMarche.Cells[7,R],8)='00.00.00')
                         or(Lastlaters(FSDetailMarche.TableauDetailMarche.Cells[7,R],11)='00.00.00.00')
                         then OKDispo:=true
                         else OKDispo:=false;
                    end
                    else
                    if((QteRestanteMarche+QteRestanteAvenant)<>0)
                    then OKDispo:=true
                    else OKDispo:=false;
               end
               else
               begin
                    OKDispo:=true;
               end;

               if(OKDispo=true)then
               begin
                    TC:=TC+1;
                    SetLength(TTravauxRestant,TC);
                    TTravauxRestant[TC-1].NDetailMarche:=strtointeger(FSDetailMarche.TableauDetailMarche.Cells[1,R]);
                    TTravauxRestant[TC-1].NArticle:=FSDetailMarche.TableauDetailMarche.Cells[2,R];
                    TTravauxRestant[TC-1].DesignationArticle:=FSDetailMarche.TableauDetailMarche.Cells[3,R];
                    TTravauxRestant[TC-1].UniteM:=FSDetailMarche.TableauDetailMarche.Cells[4,R];

                    TTravauxRestant[TC-1].QuantiteMarcheAvenant:=QteMarche+QteAvenant;
                    TTravauxRestant[TC-1].QuantiteOM:=QteMarche;
                    TTravauxRestant[TC-1].QuantiteOA:=QteAvenant;
                    TTravauxRestant[TC-1].QuantiteRealiser:=QteRealiserMarche+QteRealiserAvenant;
                    TTravauxRestant[TC-1].QuantiteRealiserOM:=QteRealiserMarche;
                    TTravauxRestant[TC-1].QuantiteRealiserOA:=QteRealiserAvenant;
                    TTravauxRestant[TC-1].QuantiteRestant:=QteRestanteMarche+QteRestanteAvenant;
                    TTravauxRestant[TC-1].QuantiteRestantOM:=QteRestanteMarche;
                    TTravauxRestant[TC-1].QuantiteRestantOA:=QteRestanteAvenant;

                    TTravauxRestant[TC-1].PrixUnitaire:=strtoreal(FSDetailMarche.TableauDetailMarche.Cells[6,R]);

                    TTravauxRestant[TC-1].MontantMarche:=(TTravauxRestant[TC-1].QuantiteOM+TTravauxRestant[TC-1].QuantiteOA)*TTravauxRestant[TC-1].PrixUnitaire;
                    TTravauxRestant[TC-1].MontantRealiser:=TTravauxRestant[TC-1].QuantiteRealiser*TTravauxRestant[TC-1].PrixUnitaire;
                    TTravauxRestant[TC-1].MontantRestant:=TTravauxRestant[TC-1].QuantiteRestant*TTravauxRestant[TC-1].PrixUnitaire;

                    TTravauxRestant[TC-1].CodeTrie:=FSDetailMarche.TableauDetailMarche.Cells[7,R];
                    TTravauxRestant[TC-1].CodeProduit:=FSDetailMarche.TableauDetailMarche.Cells[8,R];

                    if(TTravauxRestant[TC-1].QuantiteMarcheAvenant<>0)
                    then TTravauxRestant[TC-1].PourcentagePhysique:=TTravauxRestant[TC-1].QuantiteRealiser/TTravauxRestant[TC-1].QuantiteMarcheAvenant
                    else TTravauxRestant[TC-1].PourcentagePhysique:=0;

                    if(MontantMarcheAvenantGlobal<>0)
                    then TTravauxRestant[TC-1].CoefficientParticipation:=TTravauxRestant[TC-1].MontantMarche/MontantMarcheAvenantGlobal
                    else TTravauxRestant[TC-1].CoefficientParticipation:=0;

                    TTravauxRestant[TC-1].PourcentageGlobal:=TTravauxRestant[TC-1].PourcentagePhysique*TTravauxRestant[TC-1].CoefficientParticipation;
               end;
          end;
     end;
     TTravauxRestant:=OrganiseTravauxRestant(TTravauxRestant,TC,TC);
     ChargementTravauxRestant:=TC;
end;

Function OrganiseDevisQE(TDevisQE:TDevisQEs; TORGIn:integer; CumuleArticle:boolean; var TORGOut:integer):TDevisQEs;
var    RowGlobal,RowMax,NSMarche,NStructureMarche,NStatistiqueMarche:integer;   OKCode,OKCode1,OKCode2:boolean; UniM:string;
begin
TrierDevisQE(TDevisQE,TORGIn);

NSMarche:=strtointeger(FSDetailMarche.EditNSMarche.Text);
NStructureMarche:=strtointeger(FSDetailMarche.IndiceAfficheStructure.Text)*strtointeger(FSDetailMarche.EditNStructureMarche.Text);
NStatistiqueMarche:=strtointeger(FSDetailMarche.EditNStatistiqueMarche.Text)*strtointeger(FSDetailMarche.IndiceAfficheStatistique.Text);
RStructureMarche:=ChercherStructureMarche(NSMarche,NStructureMarche);
RStatistiqueMarche:=ChercherStatistiqueMarche(NSMarche,NStatistiqueMarche);


if(FSDetailMarche.RBAfficherTotalStructure.Checked=true)
then
begin
RowGlobal:=TORGIn+1;
Setlength(TDevisQE,RowGlobal);
TDevisQE[RowGlobal-1].NDetailMarche:=0;
TDevisQE[RowGlobal-1].NArticle:='';

if(RStructureMarche.StructureMarche='')
then TDevisQE[RowGlobal-1].DesignationArticle:='Montant Devis'
else TDevisQE[RowGlobal-1].DesignationArticle:='Montant Devis '+RStructureMarche.StructureMarche+': '+RStatistiqueMarche.StatistiqueMarche;
TDevisQE[RowGlobal-1].UniteM:='';
TDevisQE[RowGlobal-1].QuantiteGlobale:=0;
TDevisQE[RowGlobal-1].PrixUnitaire:=0;
TDevisQE[RowGlobal-1].Montant:=0;
TDevisQE[RowGlobal-1].CodeTrie:='ZZZ';
TDevisQE[RowGlobal-1].CodeProduit:='';
end
else
begin
     RowGlobal:=TORGIn;
     Setlength(TDevisQE,RowGlobal);
end;

RowMax:=RowGlobal+2;
j:=0;
R:=1;
while(R<=RowGlobal-1)do
begin
     if(TDevisQE[R-1].CodeTrie<>'')
     and(Lastlaters(TDevisQE[R-1].CodeTrie,11)<>'00.00.00.00')
     then
     begin
          if(FSDetailMarche.RBAfficherTotalStructure.Checked=true)
          then TDevisQE[RowGlobal-1].Montant:=TDevisQE[RowGlobal-1].Montant+
                                             (TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire);
          OKCode:=false;
          OKCode1:=false;
          OKCode2:=false;
          i:=RowGlobal+1;
          while((i<=RowMax)and((OKCode=false)or(OKCode1=false)or(OKCode2=false)))do
          begin
               if TDevisQE[i-1].CodeTrie=FirstLaters(TDevisQE[R-1].CodeTrie,15)+'00.00.00.00'
               then
               begin
                    OKCode:=true;
                    TDevisQE[i].Montant:=TDevisQE[i].Montant+
                                         (TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire)
               end;
               if(TDevisQE[i-1].CodeTrie=FirstLaters(TDevisQE[R-1].CodeTrie,17)+'.ZZ')
               then
               begin
                    OKCode1:=true;
                    TDevisQE[i-1].Montant:=TDevisQE[i-1].Montant+
                                           (TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire);
               end;
               if(TDevisQE[i-1].CodeTrie=FirstLaters(TDevisQE[R-1].CodeTrie,20)+'.ZZ')
               then
               begin
                    OKCode2:=true;
                    TDevisQE[i-1].Montant:=TDevisQE[i-1].Montant+
                                           (TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire);
                    end;
          i:=i+1;
          end;

          if(OKCode=false)then
          begin

               RStructureMarche:=ChercherStructureMarche(strtointeger(DTrie('M',TDevisQE[R-1].CodeTrie)),strtointeger(DTrie('S',TDevisQE[R-1].CodeTrie)));
               RStatistiqueMarche:=ChercherStatistiqueMarche(strtointeger(DTrie('M',TDevisQE[R-1].CodeTrie)),strtointeger(DTrie('T',TDevisQE[R-1].CodeTrie)));

               if(DTrie('T',TDevisQE[R-1].CodeTrie)<>'')then
               begin
                    RowMax:=RowMax+(2*j);
                    Setlength(TDevisQE,RowMax);

                    TDevisQE[RowMax-2].NDetailMarche:=0;
                    TDevisQE[RowMax-2].NArticle:='';
                    TDevisQE[RowMax-2].DesignationArticle:=RStructureMarche.StructureMarche+': '+RStatistiqueMarche.StatistiqueMarche;
                    TDevisQE[RowMax-2].CodeTrie:=FirstLaters(TDevisQE[R-1].CodeTrie,15)+'00.00.00.00';
                    TDevisQE[RowMax-2].UniteM:='';
                    TDevisQE[RowMax-2].QuantiteGlobale:=0;
                    TDevisQE[RowMax-2].PrixUnitaire:=0;
                    TDevisQE[RowMax-2].Montant:=0;
                    TDevisQE[RowMax-2].CodeProduit:='';

                    TDevisQE[RowMax-1].NDetailMarche:=0;
                    TDevisQE[RowMax-1].NArticle:='';
                    TDevisQE[RowMax-1].DesignationArticle:='Montant '+RStructureMarche.StructureMarche+': '+RStatistiqueMarche.StatistiqueMarche;
                    TDevisQE[RowMax-1].UniteM:='';
                    TDevisQE[RowMax-1].QuantiteGlobale:=TDevisQE[R-1].QuantiteGlobale;
                    TDevisQE[RowMax-1].PrixUnitaire:=TDevisQE[R-1].PrixUnitaire;
                    TDevisQE[RowMax-1].Montant:=TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire;
                    TDevisQE[RowMax-1].CodeTrie:=FirstLaters(TDevisQE[R-1].CodeTrie,15)+'Z';
                    TDevisQE[RowMax-1].CodeProduit:='';
               j:=1;
               end
               else
               if(DTrie('S',TDevisQE[R-1].CodeTrie)<>'')then
               begin
                    RowMax:=RowMax+(2*j);
                    Setlength(TDevisQE,RowMax);

                    TDevisQE[RowMax-2].NDetailMarche:=0;
                    TDevisQE[RowMax-2].NArticle:='';
                    TDevisQE[RowMax-2].DesignationArticle:=RStructureMarche.StructureMarche;
                    TDevisQE[RowMax-2].CodeTrie:=FirstLaters(TDevisQE[R-1].CodeTrie,15)+'00.00.00.00';
                    TDevisQE[RowMax-2].UniteM:='';
                    TDevisQE[RowMax-2].QuantiteGlobale:=0;
                    TDevisQE[RowMax-2].PrixUnitaire:=0;
                    TDevisQE[RowMax-2].Montant:=0;
                    TDevisQE[RowMax-2].CodeProduit:='';

                    TDevisQE[RowMax-1].NDetailMarche:=0;
                    TDevisQE[RowMax-1].NArticle:='';
                    TDevisQE[RowMax-1].DesignationArticle:='Montant '+RStructureMarche.StructureMarche;
                    TDevisQE[RowMax-1].UniteM:='';
                    TDevisQE[RowMax-1].QuantiteGlobale:=TDevisQE[R-1].QuantiteGlobale;
                    TDevisQE[RowMax-1].PrixUnitaire:=TDevisQE[R-1].PrixUnitaire;
                    TDevisQE[RowMax-1].Montant:=TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire;
                    TDevisQE[RowMax-1].CodeTrie:=FirstLaters(TDevisQE[R-1].CodeTrie,15)+'Z';
                    TDevisQE[RowMax-1].CodeProduit:='';
               j:=1;
               end
               else
               begin
                    RowMax:=RowMax+(2*j);
                    Setlength(TDevisQE,RowMax);

                    TDevisQE[RowMax-2].NDetailMarche:=0;
                    TDevisQE[RowMax-2].NArticle:='';
                    TDevisQE[RowMax-2].DesignationArticle:='Marché Global:';
                    TDevisQE[RowMax-2].CodeTrie:=FirstLaters(TDevisQE[R-1].CodeTrie,15)+'00.00.00.00';
                    TDevisQE[RowMax-2].UniteM:='';
                    TDevisQE[RowMax-2].QuantiteGlobale:=0;
                    TDevisQE[RowMax-2].PrixUnitaire:=0;
                    TDevisQE[RowMax-2].Montant:=0;
                    TDevisQE[RowMax-2].CodeProduit:='';

                    TDevisQE[RowMax-1].NDetailMarche:=0;
                    TDevisQE[RowMax-1].NArticle:='';
                    TDevisQE[RowMax-1].DesignationArticle:='Montant Marché';
                    TDevisQE[RowMax-1].UniteM:='';
                    TDevisQE[RowMax-1].QuantiteGlobale:=TDevisQE[R-1].QuantiteGlobale;
                    TDevisQE[RowMax-1].PrixUnitaire:=TDevisQE[R-1].PrixUnitaire;
                    TDevisQE[RowMax-1].Montant:=TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire;
                    TDevisQE[RowMax-1].CodeTrie:=FirstLaters(TDevisQE[R-1].CodeTrie,15)+'Z';
                    TDevisQE[RowMax-1].CodeProduit:='';
               j:=1;
               end;
          end;

          if(FSDetailMarche.RBAfficherTotaux.Checked=true)
          and(OKCode1=false)
          and(longueur(TDevisQE[R-1].CodeTrie)=31)
          and(Lastlaters(TDevisQE[R-1].CodeTrie,11)<>'00.00.00.00')
          then
          begin
               RowMax:=RowMax+j;
               Setlength(TDevisQE,RowMax);

               TDevisQE[RowMax-1].NDetailMarche:=0;
               TDevisQE[RowMax-1].NArticle:='';
               TDevisQE[RowMax-1].DesignationArticle:='Total: '+LastLaters(FirstLaters(TDevisQE[R-1].CodeTrie,17),2)+' - '+DesigCompte('Marche','72'+WithoutPoint(LastLaters(FirstLaters(TDevisQE[R-1].CodeTrie,17),2))+'0',UniM);
               TDevisQE[RowMax-1].UniteM:='';
               TDevisQE[RowMax-1].QuantiteGlobale:=TDevisQE[R-1].QuantiteGlobale;
               TDevisQE[RowMax-1].PrixUnitaire:=TDevisQE[R-1].PrixUnitaire;
               TDevisQE[RowMax-1].Montant:=TDevisQE[R-1].QuantiteGlobale*TDevisQE[R-1].PrixUnitaire;
               TDevisQE[RowMax-1].CodeTrie:=FirstLaters(TDevisQE[R-1].CodeTrie,17)+'.ZZ';
               TDevisQE[RowMax-1].CodeProduit:='';

               j:=1;
          end;

          if(FSDetailMarche.RBAfficherSousTotaux.Checked=true)
          and(OKCode2=false)
          and((TDevisQE[R-1].QuantiteGlobale=0)or(TDevisQE[R-1].PrixUnitaire=0))
          and(longueur(TDevisQE[R-1].CodeTrie)=31)
          and(Lastlaters(TDevisQE[R-1].CodeTrie,8)<>'00.00.00')
          then
          begin
               RowMax:=RowMax+1;
               Setlength(TDevisQE,RowMax);

               TDevisQE[RowMax-1].NDetailMarche:=0;
               TDevisQE[RowMax-1].NArticle:='';
