     AjusterColWidth(TableauImputationComptable,'',NotCol);
end;

Procedure ReportSoldeJournalAuxiliaire(CodeJournal,DateImputation,NumEntite:string; var DateMax:string; var TotalDebit:real; var TotalCredit:real);
var  i:integer; OKEntite:boolean; TypeProces,FichierConcerne,Adresse:string;
begin
     DateMax:=datetostr(strtodate('01/'+lastlaters(DateImputation,7))-1);
     TotalDebit:=0;
     TotalCredit:=0;

     TypeProces:='Comptabilité';
     FichierConcerne:='FJournalGeneralTransitoire'+Firstlaters(NumEntite,5);
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcerne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché !'+' {'+FichierConcerne+'}');
     end;

     assignfile(FJournalGeneral,Adresse);
     try
     if FileExists(Adresse)
     then Reset(FJournalGeneral)else Rewrite(FJournalGeneral);
     Seek(FJournalGeneral,0);
     while not eof(FJournalGeneral)do
     begin
          Read(FJournalGeneral,RJournalGeneral);

          if(NumEntite<>'')and(NumEntite<>'Tous')then
          begin
               if(Firstlaters(RJournalGeneral.NumEntite,longueur(NumEntite))=NumEntite)
               then OKEntite:=true
               else OKEntite:=false;
          end
          else OKEntite:=true;

          if(OKEntite=true)then
          begin
               if(RJournalGeneral.CodeJournal=CodeJournal)
               and(strtodate(RJournalGeneral.DateImputation)<=strtodate(DateMax))then
               begin
                    if(RJournalGeneral.DebitCredit='Débit')then
                    TotalDebit:=TotalDebit+RJournalGeneral.MontantImputer;
                    if(RJournalGeneral.DebitCredit='Crédit')then
                    TotalCredit:=TotalCredit+RJournalGeneral.MontantImputer;
               end;
          end;
     end;
     finally
     CloseFile(FJournalGeneral);
     end;
     TotalDebit:=ValePrecis(TotalDebit,3);
     TotalCredit:=ValePrecis(TotalCredit,3);
end;

