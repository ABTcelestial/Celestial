Procedure AfficherIndiqueAdresseTypeMouvement(TableauIndiqueAdresseListeTypeMouvement:TStringGrid; ListePositionTypeMouvement:string);
var RAATM,lAATM:integer;   TypeProcesAATM,FichierConserneAATM,AdresseAATM,AdresseNew:string;   OKTypeMouvement,OKAdresseExiste:boolean;
begin
     TableauIndiqueAdresseListeTypeMouvement.ColCount:=3;
     TableauIndiqueAdresseListeTypeMouvement.Cols[0].Text:='N°';
     TableauIndiqueAdresseListeTypeMouvement.Cols[1].Text:='PTMvt';
     TableauIndiqueAdresseListeTypeMouvement.Cols[2].Text:='Adresse';

     TableauIndiqueAdresseListeTypeMouvement.RowCount:=2;
     TableauIndiqueAdresseListeTypeMouvement.Rows[1].Text:='';

     TypeProcesAATM:='Business';   FichierConserneAATM:='FTypeMouvement';
     if not(FunctionAdresseProces(TypeProcesAATM,FichierConserneAATM,'',AdresseAATM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConserneAATM<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneAATM+' recherché !');
     end;

     ChTypeMouvementCopie:=AdresseAATM;
     assignfile(FTypeMouvementCopie,ChTypeMouvementCopie);
     try
     if FileExists(ChTypeMouvementCopie)
     then Reset(FTypeMouvementCopie)
     else Rewrite(FTypeMouvementCopie);
     seek(FTypeMouvementCopie,0);
     RAATM:=0;
     while not eof(FTypeMouvementCopie)do
     begin
          Read(FTypeMouvementCopie,RTypeMouvementCopie);

          if(ListePositionTypeMouvement<>'')then
          begin
               if ExisteNuminTexte(inttostr(RTypeMouvementCopie.PositionTypeMouvement),ListePositionTypeMouvement)
               then OKTypeMouvement:=true
               else OKTypeMouvement:=false;
          end
          else OKTypeMouvement:=true;

          if(OKTypeMouvement=true)then
          begin
               AdresseNew:=IndiqueAdresseListeMouvement(inttostr(RTypeMouvementCopie.PositionTypeMouvement),TypeProcesReseauxListeMouvement);

               lAATM:=1;
               OKAdresseExiste:=false;
               while(lAATM<=RAATM)and(OKAdresseExiste=false)do
               begin
                    if(TableauIndiqueAdresseListeTypeMouvement.Cells[2,lAATM]=AdresseNew)then
                    begin
                         OKAdresseExiste:=true;
                    end;
               lAATM:=lAATM+1
               end;

               if(OKAdresseExiste=false)then
               begin
                    RAATM:=RAATM+1;
                    TableauIndiqueAdresseListeTypeMouvement.Cells[0,RAATM]:=inttostr(RAATM);
                    TableauIndiqueAdresseListeTypeMouvement.Cells[1,RAATM]:=inttostr(RTypeMouvementCopie.PositionTypeMouvement);
                    TableauIndiqueAdresseListeTypeMouvement.Cells[2,RAATM]:=AdresseNew;
               end;
          end;
     end;
     finally
     CloseFile(FTypeMouvementCopie);
     end;

     if(RAATM>0)then TableauIndiqueAdresseListeTypeMouvement.RowCount:=RAATM+1
                else TableauIndiqueAdresseListeTypeMouvement.RowCount:=2;

     AjusterColWidth(TableauIndiqueAdresseListeTypeMouvement,'','');
end;

