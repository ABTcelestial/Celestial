          Seek(FFicheTechniqueCopie,0);
          OKFicheTechniqueCopie:=false;
          while not eof(FFicheTechniqueCopie)and(OKFicheTechniqueCopie=false)do
          begin
               read(FFicheTechniqueCopie,RFicheTechniqueCopie);
               if(RFicheTechniqueCopie.NumFicheTechnique=strtointeger(NumFicheTechnique))then
               begin
                    OKFicheTechniqueCopie:=true;
                    ChercherTypeAvis(inttostr(RFicheTechniqueCopie.NumTypeAvis),'','','','','',RTypeAvis);
               end;
          end;
          finally
          CloseFile(FFicheTechniqueCopie);
          end;
     end;

     RubriqueArborescence:=OKFicheTechniqueCopie;
