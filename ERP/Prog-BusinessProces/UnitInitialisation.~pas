               if(Firstlaters(NumEntite,longueur(REntite.NumEntite))=REntite.NumEntite)
               then OKEntite:=true
               else OKEntite:=false;
          end;
     end
     else OKEntite:=true;

     if(OKEntite=true)then
     begin
          if(NomEntite<>'')then
          begin
               if(firstlaters(REntite.NomEntite,Longueur(NomEntite))=NomEntite)
               then OKEntite:=true
               else OKEntite:=false;
          end
          else OKEntite:=true;
     end;

     if(OKEntite=true)then
     begin
          ARowCount:=ARowCount+1;
          ACol:=ValeAbsolue(longueur(REntite.NumEntite)/5)+1;
          if(ACol>ColMax)then ColMax:=ACol;
          TableauEntite.Rows[ARowCount].Text:=inttostr(ARowCount);
          TableauEntite.Cells[1,ARowCount]:=REntite.NumEntite;
          TableauEntite.Cells[ACol,ARowCount]:=REntite.NomEntite;
     end;
end;

/////////////////////Compléter l'arborescence /////////////////////////////
Seek(FEntite,0);
ARow:=ARowCount;
while not eof(FEntite)do
begin
     read(FEntite,REntite);
     R:=1;
     while(R<=ARow)do
     begin
          if(REntite.NumEntite=firstlaters(TableauEntite.Cells[1,R],longueur(REntite.NumEntite)))then
          begin
               l:=1;
               OKEntite:=false;
               while(l<=ARowCount)and(OKEntite=false)do
               begin
                    if(REntite.NumEntite=TableauEntite.Cells[1,l])then
                    begin
                         OKEntite:=true;
                    end;
               l:=l+1;
               end;

               if(OKEntite=false)then
               begin
                    ARowCount:=ARowCount+1;
                    ACol:=ValeAbsolue(longueur(REntite.NumEntite)/5)+1;
                    if(ACol>ColMax)then ColMax:=ACol;
                    TableauEntite.Rows[ARowCount].Text:=inttostr(ARowCount);
                    TableauEntite.Cells[1,ARowCount]:=REntite.NumEntite;
                    TableauEntite.Cells[ACol,ARowCount]:=REntite.NomEntite;
               end;
          end;
     R:=R+1;
     end;
end;
//////////////////////////////////////////////////////////////////////////
finally
CloseFile(FEntite);
end;

if(ARowCount>0)then TableauEntite.RowCount:=ARowCount+1
               else TableauEntite.RowCount:=2;

TableauEntite.ColCount:=ColMax+1;

TableauEntite.Cells[0,0]:=' N° ';
TableauEntite.Cells[1,0]:='     Code     ';
TableauEntite.Cells[2,0]:='          Entité          ';
R:=1;
while(R<=ColMax)do
begin
     TableauEntite.Cells[R+2,0]:='     Entité '+inttostr(R)+' rong     ';
     R:=R+1;
end;

TableauEntite.ColWidths[1]:=0;
AjusterColWidth(TableauEntite,'','1');
TrierTableauARowSpecial(TableauEntite,1,TableauEntite.RowCount-1,1,'1','','+');
end;

