Procedure WidthsMaxRubriqueEtatDouble(TableauDetaiMouvement:TStringGrid; WidthsPlace:integer; TableIndexColIn:TableIndexCols; var TableIndexColOut:TableIndexCols);
var  R,C,TotalTaille,TailleMax,TailleTeste,Resultat,Reste,WidthsOcuper:integer;
begin
     C:=-6;
     TotalTaille:=0;
     WidthsOcuper:=0;
     while(C<=2)do
     begin
          if(TableIndexColIn[C].NumCols<>0)and(C<>-5)then
          begin
               if(C=-5)then
               begin
                    {R:=5;
                    TailleMax:=0;
                    while(R<=TableauDetaiMouvement.RowCount-1)do
                    begin
                         FSFicheSaisie.TestePrintFacureDinamique.Lines.Text:=TableauDetaiMouvement.Cells[TableIndexColIn[C].NumCols,R]+' '+TableauDetaiMouvement.Cells[TableIndexColIn[C].NumCols+1,R];
                         TailleTeste:=longueur(FSFicheSaisie.TestePrintFacureDinamique.Lines.Strings[0]);
                         if(TailleMax<TailleTeste)then TailleMax:=TailleTeste;
                    R:=R+1;
                    end;
                    TableIndexColIn[C].Widths:=TailleMax;
                    TotalTaille:=TotalTaille+TailleMax;}
               end
               else
               begin
                    R:=5;
                    TailleMax:=0;
                    while(R<=TableauDetaiMouvement.RowCount-1)do
                    begin
                         TailleTeste:=LongueurWidthEtat(TableauDetaiMouvement.Cells[TableIndexColIn[C].NumCols,R],TableauDetaiMouvement.Font.Size);//longueur(TableauDetaiMouvement.Cells[TableIndexColIn[C].NumCols,R]);
                         if(TailleMax<TailleTeste)then TailleMax:=TailleTeste;
                    R:=R+1;
                    end;
                    TailleMax:=ValeAbsolue(TailleMax/2);
                    TableIndexColIn[C].Widths:=TailleMax;
                    TotalTaille:=TotalTaille+TailleMax;
               end;
          end;
     C:=C+1;
     end;

     C:=9;
     while(C>=-6)do
     begin
          if(TableIndexColIn[C].NumCols<>0)and(C<>-5)then
          begin
               if(C<>-5)then
               begin
                    //Resultat:=ValeAbsolue(ValePrecis(WidthsPlace/TotalTaille,0));
                    //TableIndexColIn[C].Widths:=MaxInt(TableIndexColIn[C].Widths*Resultat,50);
                    WidthsOcuper:=WidthsOcuper+TableIndexColIn[C].Widths;
               end;
          end;
     C:=C-1;
     end;

     TableIndexColIn[-5].Widths:=(WidthsPlace-WidthsOcuper);

     TableIndexColOut:=TableIndexColIn;

     AfficherTableIndexColIn(FSFicheSaisie.TableAvisErronnes,TableIndexColOut);

end;

Procedure AfficherTableIndexColIn(TableauTableIndexCol:TStringGrid; TableIndexCol:TableIndexCols);
var C:integer;
begin
     TableauTableIndexCol.ColCount:=17;
     for C:=1 to 16 do TableauTableIndexCol.Cols[C].Text:=inttostr(C-7);

     TableauTableIndexCol.RowCount:=3;
     TableauTableIndexCol.Rows[1].Text:='NumCols';
     TableauTableIndexCol.Rows[2].Text:='Widths';

     for C:=-6 to 9 do
     begin
          TableauTableIndexCol.Cells[C+7,1]:=inttostr(TableIndexCol[C].NumCols);
          TableauTableIndexCol.Cells[C+7,2]:=inttostr(TableIndexCol[C].Widths);
     end;

     AjusterColWidth(TableauTableIndexCol,'','');
end;

Procedure IndiquerPositionListeMouvementPeriodique(PositionTypeMouvement,PositionMouvement,TypeProcesReseaux:string; DateBeginLM,DateEndLM:string; var PBeginLM,PEndLM:integer);
var  iAnneeBegin,iAnneeEnd,iMoisBegin,iMoisEnd,MoisTeste,AnneeTeste:integer;  DateTeste,DateLaste:string[10];
begin
     PBeginLM:=999999999;
     PEndLM:=0;

     ChMouvement:=IndiqueAdresseMouvement(PositionTypeMouvement,TypeProcesReseaux);
     FSGenerateurBase.MemoRapportPlus.Lines.Add(ChMouvement);
     assignfile(FMouvement,ChMouvement);
     if FileExists(ChMouvement)then
     begin
          try
          Reset(FMouvement);
          Seek(FMouvement,strtointeger(PositionMouvement));
          if(not eof(FMouvement))then
          begin
               Read(FMouvement,RMouvement);

               iAnneeBegin:=strtointeger(MidelLaters(DateBeginLM,7,10));
               iMoisBegin:=strtointeger(MidelLaters(DateBeginLM,4,5));

               MoisTeste:=iMoisBegin;
               AnneeTeste:=iAnneeBegin;
               DateTeste:=completezerogauche(inttostr(LastDay('01/'+completezerogauche(inttostr(iMoisBegin),'2')+'/'+inttostr(iAnneeBegin))),'2')+'/'+completezerogauche(inttostr(iMoisBegin),'2')+'/'+inttostr(iAnneeBegin);

               iAnneeEnd:=strtointeger(MidelLaters(DateEndLM,7,10));
               iMoisEnd:=strtointeger(MidelLaters(DateEndLM,4,5));
               DateLaste:=completezerogauche(inttostr(LastDay('01/'+completezerogauche(inttostr(iMoisEnd),'2')+'/'+inttostr(iAnneeEnd))),'2')+'/'+completezerogauche(inttostr(iMoisEnd),'2')+'/'+inttostr(iAnneeEnd);

               while(strtodate(DateTeste)<=strtodate(DateLaste))do
               begin
                    if(PBeginLM>RMouvement.RegistrePositionListeMouvementParPeriode[AnneeTeste,MoisTeste].PositionListeMouvementBegin)
                    then PBeginLM:=RMouvement.RegistrePositionListeMouvementParPeriode[AnneeTeste,MoisTeste].PositionListeMouvementBegin;

                    if(RMouvement.RegistrePositionListeMouvementParPeriode[AnneeTeste,MoisTeste].PositionListeMouvementEnd<>999999999)
                    and(PEndLM<RMouvement.RegistrePositionListeMouvementParPeriode[AnneeTeste,MoisTeste].PositionListeMouvementEnd)
                    then PEndLM:=RMouvement.RegistrePositionListeMouvementParPeriode[AnneeTeste,MoisTeste].PositionListeMouvementEnd;

                    MoisTeste:=MoisTeste+1;
                    if(MoisTeste>12)then
                    begin
                         MoisTeste:=1;
                         AnneeTeste:=AnneeTeste+1;
                    end;
                    DateTeste:=completezerogauche(inttostr(LastDay('01/'+completezerogauche(inttostr(MoisTeste),'2')+'/'+inttostr(AnneeTeste))),'2')+'/'+completezerogauche(inttostr(MoisTeste),'2')+'/'+inttostr(AnneeTeste);
               end;

               FSGenerateurBase.MemoRapportPlus.Lines.Add(RMouvement.DesignationMouvement+', PBeginLM: '+inttostr(PBeginLM)+', PEndLM: '+inttostr(PEndLM));
          end;
          finally
          closefile(FMouvement);
          end;
     end;

     if(PBeginLM=999999999)then PBeginLM:=0;
     if(PEndLM=0)then PEndLM:=0;
end;

Procedure TableauToExcel(TableauDonnees:TStringGrid; DebutControleRow,DebutChargementRow:integer; ColNum,ColDate,ColTexte,ColGauche,ColCentre,ColDroite,TitreEtat,SousTitreEtat,NomFichierExcel:string; NewClasseur,InsertLogo,AfficherLaSaisie:boolean);
var i,R,RExcel,C,CExcel,CExcelMax,Ecart,NbrColonne:integer; AZ:char; Index,CCentre,CGauche,CDroite,Adresse,NomDossierExel:string;
    TableauAlphabet:array[1..52]of string;  OKDate,OKNum:boolean;
begin
     C:=0;
     NbrColonne:=0;
     while(C<=TableauDonnees.ColCount-1)do
     begin
          if(TableauDonnees.ColWidths[C]>10)then
          begin
               NbrColonne:=NbrColonne+1;
          end;
     C:=C+1;
     end;

     FSRapportAffichageSysteme.Show;

     FSRapportAffichageSysteme.ProgressCDL.Max:=(NbrColonne*(TableauDonnees.RowCount-DebutChargementRow+1));
     FSRapportAffichageSysteme.ProgressCDL.Position:=0;
     FSRapportAffichageSysteme.TimerPourcentage.Enabled:=true;

     FSRapportAffichageSysteme.Caption:='Rapport: '+TitreEtat+': '+inttostr(TableauDonnees.RowCount-1+12)+' Lignes et '+inttostr(NbrColonne)+' Colonnes.';
     FSRapportAffichageSysteme.RapportTraitement.Lines.Text:='';
     FSRapportAffichageSysteme.RapportTraitement.Lines.Add('Début de traitement');
     FSRapportAffichageSysteme.RapportTraitement.Lines.Add('');
     FSRapportAffichageSysteme.RapportTraitement.Lines.Add('Initialisation...');
     i:=1;
     for AZ:='A' to 'Z' do
     begin
          TableauAlphabet[i]:=AZ;
          i:=i+1;
     end;

     for AZ:='A' to 'Z' do
     begin
          TableauAlphabet[i]:='A'+AZ;
          i:=i+1;
     end;

     CExcelMax:=0;
     for C:=0 to TableauDonnees.ColCount-1 do
     begin
          if(TableauDonnees.ColWidths[C]>10)then
          begin
               CExcelMax:=CExcelMax+1;
          end;
     end;

     FSRapportAffichageSysteme.RapportTraitement.Lines.Add('Vérification de données...');
     CCentre:='0';
