     Texte:=AnsiUpperCase(Texte);
     if(Texte<>'OUI')and(Texte<>'TRUE')and(Texte<>'NON')and(Texte<>'FALSE')and(Texte<>'')then
     begin
          AfficherMessage('le type de donnée n''est pas Boolean !' );
          StrtoBoolean:=false;
     end
     else
     begin
          if(Texte='OUI')or(Texte='TRUE')then StrtoBoolean:=true;
          if(Texte='')or(Texte='NON')or(Texte='FALSE')or(Texte='')then StrtoBoolean:=false;
     end;
