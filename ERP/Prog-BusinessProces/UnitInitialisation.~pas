Function WidthsString(Texte:string):integer;
begin
     FSFicheSaisie.TesteMemoLigneaire.Width:=50;
     FSFicheSaisie.TesteMemoLigneaire.Lines.Text:=Texte;
     While(FSFicheSaisie.TesteMemoLigneaire.Lines.Strings[0]<>Texte)do
     begin
          FSFicheSaisie.TesteMemoLigneaire.Width:=FSFicheSaisie.TesteMemoLigneaire.Width+1;
     end;

     WidthsString:=FSFicheSaisie.TesteMemoLigneaire.Width;
end;

Function  LongueurWidthEtat(Text:string; FondSeiz:integer):integer;
var iLongueur:integer;  Width:Real;
begin
Text:=Text+'$';
iLongueur:=1;
Width:=0;
while(Text[iLongueur]<>'$')do
begin
     if(Text[iLongueur]in['A','D','G','H','N','Q','U'])then Width:=Width+FondSeiz
     else
     if(Text[iLongueur]in['B','C','K','P','R','V','X'])then Width:=Width+FondSeiz-1
     else
     if(Text[iLongueur]in['E','F','L','S','T','Y','Z'])then Width:=Width+FondSeiz-2
     else
     if(Text[iLongueur]in[' ','.',',','I'])then Width:=Width+FondSeiz-5
     else
     if(Text[iLongueur]in['J'])then Width:=Width+FondSeiz-4
     else
     if(Text[iLongueur]in['M'])then Width:=Width+FondSeiz+3
     else
     if(Text[iLongueur]in['O'])then Width:=Width+FondSeiz+1
     else
     if(Text[iLongueur]in['W'])then Width:=Width+FondSeiz+4
     else
     if(Text[iLongueur]in['a','c','g','k','v','x','y' ])then Width:=Width+FondSeiz-2
     else
     if(Text[iLongueur]in['b','d','e','h','n','o','p','q','u'])then Width:=Width+FondSeiz-1
     else
     if(Text[iLongueur]in['f','j','t'])then Width:=Width+FondSeiz-4
     else
     if(Text[iLongueur]in[' ','i','l'])then Width:=Width+FondSeiz-5
     else
     if(Text[iLongueur]in['m'])then Width:=Width+FondSeiz+2
     else
     if(Text[iLongueur]in['r','s','z'])then Width:=Width+FondSeiz-3
     else
     if(Text[iLongueur]in['w'])then Width:=Width+FondSeiz+1
     else
     if(Text[iLongueur]in['0'..'9'])then Width:=Width+FondSeiz-2
     else
     Width:=Width+FondSeiz+2;

     iLongueur:=iLongueur+1;
end;
                     
LongueurWidthEtat:=FondSeiz+ValeAbsolue(Width)+ValeAbsolue(Width*50/100);
end;

