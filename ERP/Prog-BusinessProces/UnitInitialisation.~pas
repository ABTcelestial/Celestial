Procedure TableauCouleursLignes(Sender:TObject; ACol,ARow: Integer; Rect:TRect; State:TGridDrawState);
var Couleur1,Couleur2:TColor;
begin
    if(not ActiverMultiCouleursLignesTableaux(Couleur1,Couleur2))then exit;

     with Sender As TStringGrid Do With Canvas Do
     Begin
          { sélection de la couleur de fond }
          If gdFixed in State
          then Brush.Color := clBtnFace
          else If gdSelected In State
          then Brush.Color := clNavy
          else If Odd(ARow)
          then Brush.Color :=Couleur1 // $FFE0FF
          else Brush.Color :=Couleur2;// $FFFFE0;
          { Dessin du fond }
          FillRect(Rect);
          { Sélection de la couleur d'écriture }
          if gdSelected In State
          then Font.Color:=clWhite
          else Font.Color:=clBlack;
          { Dessin du texte }
          TextOut(Rect.Left,Rect.Top,Cells[ACol,ARow]);
     end;
end;

