                    else TTravauxRestant[TI-1].PrixUnitaire:=0;

                    if(FSDetailMarche.RBRemplireMontantG.Checked=true)
                    then
                    begin
                         TTravauxRestant[TI-1].MontantMarche:=TTravauxRestant[TI-1].QuantiteOM*TTravauxRestant[TI-1].PrixUnitaire;
                         TTravauxRestant[TI-1].MontantAvenant:=TTravauxRestant[TI-1].QuantiteOA*TTravauxRestant[TI-1].PrixUnitaire;

                         TTravauxRestant[TI-1].MontantRealiser:=TTravauxRestant[TI-1].QuantiteRealiser*TTravauxRestant[TI-1].PrixUnitaire;
                         TTravauxRestant[TI-1].MontantRealiserOM:=TTravauxRestant[TI-1].QuantiteRealiserOM*TTravauxRestant[TI-1].PrixUnitaire;
                         TTravauxRestant[TI-1].MontantRealiserOA:=TTravauxRestant[TI-1].QuantiteRealiserOA*TTravauxRestant[TI-1].PrixUnitaire;

