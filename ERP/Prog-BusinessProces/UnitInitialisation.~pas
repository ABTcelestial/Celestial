Function ChercherMoyenTransport(PositionMoyenTransport,TypeFiche,NumMovementPrelevement,MatriculeEffectif,NumFiche:string):RMoyenTransports;
var  OKMT:boolean;  Archive,PositionPrelevement,TypeProcesInt,FichierConcerneInt,Adresse:string;
begin
     ChercherMoyenTransport.PositionMoyenTransport:=0;
     ChercherMoyenTransport.TypeFiche:='';
     ChercherMoyenTransport.NumMovementPrelevement:=0;
     ChercherMoyenTransport.MatriculeEffectif:='';
     ChercherMoyenTransport.NumFiche:=0;
     ChercherMoyenTransport.CodeTiers:='';
     ChercherMoyenTransport.MoyenTransport:='';
     ChercherMoyenTransport.MatriculeTransport:='';
     ChercherMoyenTransport.NomChauffeur:='';
     ChercherMoyenTransport.PrenomChauffeur:='';
     ChercherMoyenTransport.PieceIdentite:='';

     Archive:='';
     if(TypeFiche='Prélčvement')then
     begin
          RPrelevement:=ChercherPrelevement(strtointeger(NumMovementPrelevement),ExerciceAnnee,'',PositionPrelevement);
          if(RPrelevement.Archiver=true)then Archive:='Archive';
     end;

     TypeProcesInt:='Business';
     FichierConcerneInt:='F'+Archive+'MoyenTransport'+TypeFiche;
     Adresse:='';
     if not(FunctionAdresseProces(TypeProcesInt,FichierConcerneInt,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcerneInt<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConcerneInt+'} recherché !');
     end;

     ChMoyenTransportCopie:=Adresse;
     assignfile(FMoyenTransportCopie,ChMoyenTransportCopie);
     try
     if FileExists(ChMoyenTransportCopie)then
     Reset(FMoyenTransportCopie)
     else Rewrite(FMoyenTransportCopie);
     Seek(FMoyenTransportCopie,0);
     OKMT:=false;
     while not eof(FMoyenTransportCopie)and(OKMT=false)do
     begin
          read(FMoyenTransportCopie,RMoyenTransportCopie);

          OKMT:=false;

          if(NumMovementPrelevement<>'')then
          begin
               if(inttostr(RMoyenTransportCopie.NumMovementPrelevement)=NumMovementPrelevement)
               then OKMT:=true
               else OKMT:=false;
          end;

          if(OKMT=true)then
          begin
               if(MatriculeEffectif<>'')then
               begin
                    if(RMoyenTransportCopie.MatriculeEffectif=MatriculeEffectif)
                    then OKMT:=true
                    else OKMT:=false;
               end;
          end;

          if(OKMT=true)then
          begin
               if(PositionMoyenTransport<>'')then
               begin
                    if(inttostr(RMoyenTransportCopie.PositionMoyenTransport)=PositionMoyenTransport)
                    then OKMT:=true
                    else OKMT:=false;
               end;
          end;

          if(OKMT=true)then
          begin
               if(TypeFiche<>'')then
               begin
                    if(RMoyenTransportCopie.TypeFiche=TypeFiche)
                    then OKMT:=true
                    else OKMT:=false;
               end;
          end;

          if(OKMT=true)then
          begin
               if(NumFiche<>'')then
               begin
                    if(inttostr(RMoyenTransportCopie.NumFiche)=NumFiche)
                    then OKMT:=true
                    else OKMT:=false;
               end;
          end;

          if(OKMT=true)then
          begin
               ChercherMoyenTransport:=RMoyenTransportCopie;
          end;
     end;
     finally
     CloseFile(FMoyenTransportCopie);
     end;
end;

