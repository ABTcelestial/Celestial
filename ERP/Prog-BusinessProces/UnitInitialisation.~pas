Procedure AjusterColWidth(TableauAjuster:TStringGrid; NotRow,NotCol:string);
var Rv,Cv,RowTaille,ColTaille,DefaultRowHeight:integer;
begin
     DefaultRowHeight:=TableauAjuster.DefaultRowHeight;

     for Rv:=0 to TableauAjuster.RowCount-1 do
     begin
          if not(ExisteNuminTexte(inttostr(Rv),NotRow))
          then TableauAjuster.RowHeights[Rv]:=DefaultRowHeight
          else TableauAjuster.RowHeights[Rv]:=-1;
     end;

     for Cv:=0 to TableauAjuster.ColCount-1 do
     begin
          if not(ExisteNuminTexte(inttostr(Cv),NotCol))then
          begin
               ColTaille:=-1;
               for Rv:=0 to TableauAjuster.RowCount-1 do
               begin
                    if not(ExisteNuminTexte(inttostr(Rv),NotRow))then
                    begin
                         if ColTaille<(LongueurWidth(TableauAjuster.Cells[Cv,Rv],TableauAjuster.Font.Size))
                         then ColTaille:=LongueurWidth(TableauAjuster.Cells[Cv,Rv],TableauAjuster.Font.Size);
                    end;
               end;
          TableauAjuster.ColWidths[Cv]:=ColTaille;
          end;
     end;
end;
                                                                                                                                                                                                                                                                                                                                    
Procedure OptionsImpression(Tableau:TStringGrid; AlignementTitre:string; DebutRowIn,FixedRow:integer; TitreEtat:string; AjustePrint:boolean; OrintationPapier:string; FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol:string; ImprimeEtat:boolean; EcartTableau:integer; ImageCodebarre:TImage; ApercuAvantImpression:boolean; var DebutRowOut:integer);
var CTeste:integer;  IndiceWidth,ColCountTeste:real;
begin
     if(OrintationPapier='Automatique')then
     begin
          IndiceWidth:=10/Tableau.Font.Size;
          ColCountTeste:=0;
          for CTeste:=0 to Tableau.ColCount-1 do
          begin
               if(Tableau.ColWidths[CTeste]>10)then
               ColCountTeste:=ColCountTeste+(Tableau.ColWidths[CTeste]*IndiceWidth);
          end;

          if(PrintEtatTraitementDonneesPortrait.PageTitreEtat.Width>=ColCountTeste)
          then ImprimerTableauPortrait(Tableau,AlignementTitre,DebutRowIn,FixedRow,TitreEtat,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,ImageCodebarre,ApercuAvantImpression,DebutRowOut)
