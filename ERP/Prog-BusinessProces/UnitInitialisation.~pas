Procedure ExcelToTableau(TableauDonnees:TStringGrid; RBegin,REnd,CBegin,CEnd:integer; AdresseFichier:string; ReouvrirFichier:boolean);
var  Row,Col,R,C,i:integer;  TableauAlphabet:array[1..52]of string;     Alphabet:char;  Cellule,ValeurCellule:string;
begin
     i:=1;
     for Alphabet:='A' to 'Z' do
     begin
          TableauAlphabet[i]:=Alphabet;
     i:=i+1;
     end;

     for Alphabet:='A' to 'Z' do
     begin
          TableauAlphabet[i]:='A'+Alphabet;
     i:=i+1;
     end;

     if(ReouvrirFichier=true)then
     begin
           OleApplication:= CreateOleObject('Excel.Application');// création du lien OLE
           OleApplication.visible:=True; // pour rendre word visible
           OleWorkBook:=OleApplication.Workbooks.open(AdresseFichier); // pour créer un  nouveau document
     end;

     Row:=0;
     for R:=RBegin to REnd do
     begin
          Col:=0;
          for C:= CBegin to CEnd do
          begin
               Cellule:=TableauAlphabet[C]+inttostr(R);
               ValeurCellule:=OleApplication.Range[Cellule].value;
               TableauDonnees.Cells[Col,Row]:=ValeurCellule;
          Col:=Col+1;
          end;
     Row:=Row+1;
     end;
     TableauDonnees.ColCount:=Col+2;
     TableauDonnees.RowCount:=Row;

     AjusterColWidth(TableauDonnees,'','');
     TableauDonnees.FixedCols:=0;
     TableauDonnees.FixedRows:=0;

     OleApplication.visible:=false;
end;

