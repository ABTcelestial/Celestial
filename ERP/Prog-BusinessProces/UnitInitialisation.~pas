          if(FichierConcerne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier {'+FichierConcerne+'} recherché !');
     end;

     ChStockArticleRecherche:=Adresse;
     assignfile(FStockArticleRecherche,ChStockArticleRecherche);
     if FileExists(ChStockArticleRecherche)then
     begin
          try
          Reset(FStockArticleRecherche);
          Seek(FStockArticleRecherche,0);
          SousFamilleStock:='';
          while not eof(FStockArticleRecherche)do
          begin
               //Read(FStockArticleRecherche,RStockArticleRecherche);

               BlockRead(FStockArticleRecherche,TableauRStockArticle[0],NbrAExecute,NbrRStockArticleExecute);

               Application.ProcessMessages;  if(FSTraitementDonnees.RBSuspendreTraitement.Checked)then begin RapportTraitement.Lines.Add('Traitement Suspendu.'); Exit; end;

               Nbr:=0;
               While Nbr<=NbrRStockArticleExecute-1 do
               begin
                    RStockArticleRecherche:=TableauRStockArticle[Nbr];

               if(Firstlaters(RStockArticleRecherche.Code,6)<>SousFamilleStock)then
               begin
                    SousFamilleStock:=Firstlaters(RStockArticleRecherche.Code,6);
                    iSFS:=0;
                    OKIndexSousFamilleStock:=false;
                    while(iSFS<=High(ArrayIndexSousFamilleStock))and(OKIndexSousFamilleStock=false)do
                    begin
                         if(ArrayIndexSousFamilleStock[iSFS]=SousFamilleStock)then OKIndexSousFamilleStock:=true;
                    iSFS:=iSFS+1;
                    end;

                    if(OKIndexSousFamilleStock=false)then
                    begin
                         IndexSousFamilleStock:=IndexSousFamilleStock+1;
                         setlength(ArrayIndexSousFamilleStock,IndexSousFamilleStock);
                         ArrayIndexSousFamilleStock[IndexSousFamilleStock-1]:=SousFamilleStock;
                    end;
               end;

               Nbr:=Nbr+1;
               end;
          end;

          Seek(FStockArticleRecherche,0);
          while not eof(FStockArticleRecherche)do
          begin
               //Read(FStockArticleRecherche,RStockArticleRecherche);   Application.ProcessMessages;  if(FSTraitementDonnees.RBSuspendreTraitement.Checked)then begin RapportTraitement.Lines.Add('Traitement Suspendu.'); Exit; end;

               BlockRead(FStockArticleRecherche,TableauRStockArticle[0],NbrAExecute,NbrRStockArticleExecute);

               Nbr:=0;
               While Nbr<=NbrRStockArticleExecute-1 do
               begin
                    RStockArticleRecherche:=TableauRStockArticle[Nbr];

               SousFamilleStock:=Firstlaters(RStockArticleRecherche.Code,6);

               iSFS:=0;
               OKIndexSousFamilleStock:=false;
               while(iSFS<=High(ArrayIndexSousFamilleStock))and(OKIndexSousFamilleStock=false)do
               begin
                    if(ArrayIndexSousFamilleStock[iSFS]=SousFamilleStock)then
                    begin
                         OKIndexSousFamilleStock:=true;
                         CodeSimple:=strtoint(inttostr(iSFS)+lastlaters(RStockArticleRecherche.Code,4));
                    end
                    else iSFS:=iSFS+1;
               end;

               if(IndiceTableauMax<CodeSimple)then
               begin
                    IndiceTableauMax:=CodeSimple;
                    setlength(TStockArticlePointeur,IndiceTableauMax+1);
               end;

               TStockArticlePointeur[CodeSimple].QteEntree:=RStockArticleRecherche.QteEntree;
               TStockArticlePointeur[CodeSimple].QteSortie:=RStockArticleRecherche.QteSortie;
               TStockArticlePointeur[CodeSimple].QteStock:=RStockArticleRecherche.QteStock;
               TStockArticlePointeur[CodeSimple].QteInitial:=RStockArticleRecherche.QteInitial;
               TStockArticlePointeur[CodeSimple].QteLimite:=RStockArticleRecherche.QteLimite;
               TStockArticlePointeur[CodeSimple].CoutUnitaire:=RStockArticleRecherche.CoutUnitaire;
               TStockArticlePointeur[CodeSimple].PrixVenteDetaille:=RStockArticleRecherche.PrixVenteDetaille;
               TStockArticlePointeur[CodeSimple].PrixVenteDemiGros:=RStockArticleRecherche.PrixVenteDemiGros;
               TStockArticlePointeur[CodeSimple].PrixVenteGros:=RStockArticleRecherche.PrixVenteGros;
               TStockArticlePointeur[CodeSimple].Design:=RStockArticleRecherche.Design;
               TStockArticlePointeur[CodeSimple].Ref:=RStockArticleRecherche.Ref;
               TStockArticlePointeur[CodeSimple].Observ:=RStockArticleRecherche.Observ;
               TStockArticlePointeur[CodeSimple].Emplace:=RStockArticleRecherche.Emplace;
               TStockArticlePointeur[CodeSimple].CodeBarre:=RStockArticleRecherche.CodeBarre;
               TStockArticlePointeur[CodeSimple].Code:=RStockArticleRecherche.Code;
               TStockArticlePointeur[CodeSimple].UM:=RStockArticleRecherche.UM;
               TStockArticlePointeur[CodeSimple].Formule:=RStockArticleRecherche.Formule;
               TStockArticlePointeur[CodeSimple].enregistrement:=RStockArticleRecherche.enregistrement;

               RapportTraitement.Lines.Add('CodeSimple: '+inttostr(CodeSimple)+', Stock: '+RStockArticleRecherche.Code+' '+RStockArticleRecherche.Design+' '+RStockArticleRecherche.Ref);

               Nbr:=Nbr+1;
               end;
          end;
          finally
          CloseFile(FStockArticleRecherche);
          end;
     end;

     RemplireTStockArticle:=TStockArticlePointeur;

     LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);

     FSTraitementDonnees.RBRemplireTStockArticle.Checked:=true;
end;

