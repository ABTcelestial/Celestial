                         iENT:=iENT+1;
                    end;

                    IndexTrouverF:=Firstlaters(NumTesteF,2);
                    NumTrouverF:=Lastlaters(NumTesteF,longueur(NumTesteF)-2);

                    if((IndexTrouver=Index)and(strtointeger(Num)>=strtointeger(NumTrouver)))
                    and((IndexTrouverF=Index)and(strtointeger(Num)<=strtointeger(NumTrouverF)))
