          CodeStockConcerneSource:=RListeMouvementCopie.NumProjetFinance;
          CodeStockConcerneCible:=RListeMouvementCopie.CodeTiers;

          NbrNewArticle:=0;
          NbrChargeArticle:=0;

          if(SigneMouvementAOperer<>'*')then
          begin
               ProcMiseAJourStockArticle(CodeStockConcerneSource,CodeStockConcerneSource,CodeArticleAOperer,TypeStock,SigneMouvementAOperer,QteAOperer,PrixAOperer,NbrNewArticle,NbrChargeArticle,PrixAOperer,NbrNewArticle,NbrChargeArticle,OKMiseAJour);

               if(FSFicheSaisie.RBAppliquerFormuleComposition.Checked=true)then
               begin
                    if(SigneMouvementAOperer='+')then SigneMouvementFormuleComposition:='-';
                    if(SigneMouvementAOperer='-')then SigneMouvementFormuleComposition:='+';
                    MiseAJourStockFormuleComposition(CodeStockConcerneSource,FSFicheSaisie.EditTypeStock.Text,CodeArticleAOperer,SigneMouvementFormuleComposition,QteAOperer,RowEditing,RowEditing);
               end;
          end
          else
          begin
               ProcTransfertStockArticle(CodeStockConcerneSource,CodeStockConcerneCible,CodeArticleAOperer,TypeStock,QteAOperer,PrixAOperer);

               if(FSFicheSaisie.RBAppliquerFormuleComposition.Checked=true)then
               begin
                    SigneMouvementFormuleComposition:=SigneMouvementAOperer;
               end;
          end;

          RDetailMouvement.ValidationDetailMouvement:=false;
          Seek(FDetailMouvement,RDetailMouvement.PositionDetailMouvement);
          Write(FDetailMouvement,RDetailMouvement);
          Confirme:=true;
     end;

end;//F1
finally
CloseFile(FDetailMouvement);
end;

FSFormuleComposition.EditRowEditing.Text:=inttostr(RowEditing);

end;//F0

