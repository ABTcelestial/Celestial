Procedure RubriqueEtatTrier(PositionEtat:integer; CodeTypeFormule:string; Var TRubriqueEtat:TRubriqueEtats; Var Taille:integer);
var  i,k:integer; OKTrie:boolean;
begin
     OpenFParc(RParc);
     ChRubriqueEtat:=RParc.Parcours+'\'+Exercice+'FRubriqueEtat'+CodeTypeFormule;
     assignfile(FRubriqueEtat,ChRubriqueEtat);
     try
     if FileExists(ChRubriqueEtat)then
     Reset(FRubriqueEtat)
     else Rewrite(FRubriqueEtat);
     seek(FRubriqueEtat,0);
     setlength(TRubriqueEtat,0);
     k:=0;
     while not eof(FRubriqueEtat)do
     begin
          Read(FRubriqueEtat,RRubriqueEtat);
          if(RRubriqueEtat.PositionEtat=PositionEtat)then
          begin
               k:=k+1;
               setlength(TRubriqueEtat,k);
               TRubriqueEtat[k-1].Ordre:=RRubriqueEtat.Ordre;
               TRubriqueEtat[k-1].PositionRubriqueEtat:=RRubriqueEtat.PositionRubriqueEtat;
               TRubriqueEtat[k-1].PositionEtat:=RRubriqueEtat.PositionEtat;
               TRubriqueEtat[k-1].PositionFormule:=RRubriqueEtat.PositionFormule;
          end;
     end;
     finally
     CloseFile(FRubriqueEtat);
     end;

     ///////////////////// TRIER LISTE FORMULES
     OKTrie:=true;
     setlength(TRubriqueEtatCopie,1);
     while(OKTrie=true)do
     begin
          OKTrie:=false;
          i:=0;
          while(i<=K-2)do
          begin
               if(TRubriqueEtat[i].Ordre>TRubriqueEtat[i+1].Ordre )then
               begin
                    OKTrie:=true;
                    TRubriqueEtatCopie[0]:=TRubriqueEtat[i];
                    TRubriqueEtat[i]:=TRubriqueEtat[i+1];
                    TRubriqueEtat[i+1]:=TRubriqueEtatCopie[0];
               end;
          i:=i+1;
          end;
     end;
     /////////////////// FIN TRIER LISTE FORMULES
Taille:=k;
end;

