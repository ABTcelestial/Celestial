Procedure PreferenceContrePartie(NumCptPrincipal:string; var NumCptPrincipalPreference:string; var TCompteCPPreference:TCompteCPPreferences; var TailleTPreference:integer);
var iPreference,jPreference:integer; OKPreference:boolean;
begin
TailleTPreference:=0;

     NumCptPrincipalPreference:=NumCptPrincipal;
     if(ControleSpecificite(NumCptPrincipal,ResultCompte))then
     begin
          NumCptPrincipalPreference:=ResultCompte.CodeCompte;
     end;

     if(NumCptPrincipalPreference<>'')then
     begin
          OpenFParc(RParc);
          ChListeCompteCP:=RParc.Parcours+'\'+Exercice+'FListeCompteCP';
          assignfile(FListeCompteCP,ChListeCompteCP);
          try
          if FileExists(ChListeCompteCP)
          then Reset(FListeCompteCP)else Rewrite(FListeCompteCP);
          Seek(FListeCompteCP,0);
          iPreference:=0;
          while not eof(FListeCompteCP)do
          begin
               Read(FListeCompteCP,RListeCompteCP);
               if(RListeCompteCP.NumCptPrincipal=NumCptPrincipalPreference)
               and(RListeCompteCP.NumCptCP<>NumCptPrincipal)
               then
               begin
                    iPreference:=iPreference+1;
                    Setlength(TCompteCPPreference,iPreference);
                    TCompteCPPreference[iPreference-1].NumCptPrincipal:=RListeCompteCP.NumCptPrincipal;
                    TCompteCPPreference[iPreference-1].NumCptCP:=RListeCompteCP.NumCptCP;
                    TCompteCPPreference[iPreference-1].Specificite:=RListeCompteCP.Specificite;

                    jPreference:=1;
                    OKPreference:=false;
                    while(jPreference<=longueur(NumCptPrincipal))and(OKPreference=false)do
                    begin
                         if(NumCptPrincipal[jPreference]<>'0')
                         and(NumCptPrincipal[jPreference]=RListeCompteCP.NumCptCP[1])then
                         begin
                              OKPreference:=true;
                         end;
                    jPreference:=jPreference+1;
                    end;

                    TCompteCPPreference[iPreference-1].Preference:=OKPreference;
               end;
          end;
          finally
          CloseFile(FListeCompteCP);
          end;
          TailleTPreference:=iPreference;
     end;
end;

