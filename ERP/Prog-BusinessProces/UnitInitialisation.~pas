Function RechercherPlanComptable(CompteRechercher:string):RRegistreComptes;
var  l,Ordre:integer;    ExisteCompte:boolean;  TypeProces,FichierConcerne,Adresse:string;
begin
     RechercherPlanComptable.CodeCompte:='';
     RechercherPlanComptable.Designation:='';
     RechercherPlanComptable.ContrePartie.UsesCompte:=false;
     RechercherPlanComptable.ContrePartie.TypeUses:='';
     RechercherPlanComptable.Specificite:='';
     RechercherPlanComptable.Tiers:=false;
     RechercherPlanComptable.Active:=false;

     if(longueur(CompteRechercher)<=0)then Exit;
l:=0;
Repeat
     Ordre:=longueur(CompteRechercher)-l;
     TypeProces:='Comptabilité';
     case Ordre of
     1: FichierConcerne:='FClassePlanComptable';
     2: FichierConcerne:='FSousClassePlanComptable';
     3: FichierConcerne:='FCategoriePlanComptable';
     4: FichierConcerne:='FSousCategoriePlanComptable';
     5: FichierConcerne:='FFamillePlanComptable';
     6: FichierConcerne:='FSousFamillePlanComptable';
     end;

     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcerne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier recherché !'+' {'+FichierConcerne+'}');
     end;

     assignfile(FRegistreCompte,Adresse);
     try
     if FileExists(Adresse)
     then Reset(FRegistreCompte)else Rewrite(FRegistreCompte);
     Seek(FRegistreCompte,0);
     ExisteCompte:=false;
     while not eof(FRegistreCompte)and(ExisteCompte=false)do
     begin
          Read(FRegistreCompte,RRegistreCompte);
          if(RRegistreCompte.CodeCompte=firstlaters(CompteRechercher,Ordre))then
          begin
               ExisteCompte:=true;
               RechercherPlanComptable:=RRegistreCompte;
          end;
     end;
     l:=l+1;
     finally
     CloseFile(FRegistreCompte);
     end;

Until (ExisteCompte=true)or(Ordre=1);

end;

