Function DTrie(OutCode:string; CodeTrie:string):string;
begin
     DTrie:='';
     if(OutCode='M')then DTrie:=WithoutZeroGauche(Firstlaters(CodeTrie,5));
     if(OutCode='S')then DTrie:=WithoutZeroGauche(MidelLaters(CodeTrie,6,10));
     if(OutCode='T')then DTrie:=WithoutZeroGauche(MidelLaters(CodeTrie,11,15));
     if(OutCode='P')then DTrie:=WithoutPoint(Lastlaters(CodeTrie,11));
     if(OutCode='K')then DTrie:=Lastlaters(CodeTrie,11);
end;

Function WithoutZeroGauche(Code:string):string;
var  OKZero:boolean;  Texte:string;
begin
     OKZero:=false;
     Texte:='';
     l:=1;
     while(l<=Longueur(Code))do
     begin
          if(OKZero=false)then
          begin
               if(Code[l]<>'0')then
               begin
                    OKZero:=true;
                    Texte:=Texte+Code[l];
               end;
          end
          else Texte:=Texte+Code[l];
     l:=l+1;
     end;

     if(OKZero=true)then WithoutZeroGauche:=Texte else WithoutZeroGauche:='';
end;

Function WithoutCharGauche(Code,Char:string):string;
var  OKChar:boolean;  Texte:string;
begin
     OKChar:=false;
     Texte:='';
     l:=1;
     while(l<=Longueur(Code))do
     begin
          if(OKChar=false)then
          begin
               if(Code[l]<>Char)then
               begin
                    OKChar:=true;
                    Texte:=Texte+Code[l];
               end;
          end
          else Texte:=Texte+Code[l];
     l:=l+1;
     end;

     if(OKChar=true)then WithoutCharGauche:=Texte else WithoutCharGauche:='';
end;

Function WithoutPoint(Code:string):string;
var  Texte:string;
begin
     Texte:='';
     for l:=1 to Longueur(Code)do if(Code[l]<>'.')then Texte:=Texte+Code[l];
     WithoutPoint:=Texte;
end;

Function WithoutChar(Code,Char:string):string;
var  Texte:string;
begin
     Texte:='';
     for l:=1 to Longueur(Code)do
     if(Code[l]<>Char)then Texte:=Texte+Code[l];
     WithoutChar:=Texte;
end;

