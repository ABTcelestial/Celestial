                          if(RPrelevementRecherche.RegistrePositionMoyenTransportPrelevement.PositionArchiveEnd>RPrelevementCopie.RegistrePositionMoyenTransportPrelevement.PositionArchiveEnd)then RPrelevementCopie.RegistrePositionMoyenTransportPrelevement.PositionArchiveEnd:=RPrelevementRecherche.RegistrePositionMoyenTransportPrelevement.PositionArchiveEnd;

                          if(RPrelevementRecherche.RegistrePositionEtatStockPrelevement.PositionArchiveBegin<RPrelevementCopie.RegistrePositionEtatStockPrelevement.PositionArchiveBegin)then RPrelevementCopie.RegistrePositionEtatStockPrelevement.PositionArchiveBegin:=RPrelevementRecherche.RegistrePositionEtatStockPrelevement.PositionArchiveBegin;
