Function ImporteData(Data,TypeFormule,CodeFormule,CodeTypeFormule:string; TableauDatat:TStringGrid; ModePayement:string; RowDatat:integer):string;
var  R:integer; DataResult:string;  OKData:boolean;
begin
     if(Data='Valeur Initiale')then
     begin
          ImporteData:=floattostr(Strtoreal(TableauDatat.Cells[6,RowDatat])*Strtoreal(TableauDatat.Cells[7,RowDatat]));
     end
     else
     if(Data='Mode de payement')then
     begin
          if(AnsiUpperCase(ModePayement)=AnsiUpperCase('Espčce'))
          then ImporteData:='0,01'
          else ImporteData:='0';
     end
     else
     if(Data='Liste Valeurs')then
     begin

          if(ValeurFormuleParArticle(TypeFormule,CodeFormule,TableauDatat.Cells[1,RowDatat],DataResult)=true)
          then ImporteData:=DataResult
          else ImporteData:=FindFormule(TypeFormule,CodeFormule).Taux;
     end
     else
     if(ExisteCharInString(Data,FunctListeFormuleString(CodeTypeFormule)))then
     begin
          R:=1;
          OKData:=false;
          while(R<=TableauDatat.RowCount-1)and(OKData=false)do
          begin
               if(TableauDatat.Cells[2,R]=Data)then
               begin
                    OKData:=true;
                    ImporteData:=floattostr(Strtoreal(TableauDatat.Cells[5,R]));
               end;
          R:=R+1;
          end;
     end;
end;

