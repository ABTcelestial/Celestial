Function DateCorrecte(DateTexte:string):boolean;
var  Ix:integer; OKDateCorrecte:boolean;
begin
     OKDateCorrecte:=false;

     if(longueur(DateTexte)=10)then
     begin
          OKDateCorrecte:=true;
          Ix:=1;
          while(Ix<=longueur(DateTexte))do
          begin
               if(Ix in[1,2,4,5,7,8,9,10])then if not(DateTexte[Ix]in['0'..'9'])then OKDateCorrecte:=false;
               if(Ix in[3,6])then if not(DateTexte[Ix]in['/'])then OKDateCorrecte:=false;
          Ix:=Ix+1;
          end;

          if(OKDateCorrecte=true)then
          begin
               if(strtointeger(DateTexte[1]+DateTexte[2])>31)
               or(strtointeger(DateTexte[4]+DateTexte[5])>12)then OKDateCorrecte:=false;
          end;
     end
     else OKDateCorrecte:=false;

     DateCorrecte:=OKDateCorrecte;
end;

Function StringToDate(DateTexte,Source:string):TDateTime;
begin
     if(DateCorrecte(DateTexte)=true)then
     begin
          StringToDate:=strtodate(DateTexte);
     end
     else
     begin
          if(Source<>'')then AfficherMessage('{'+DateTexte+'} n''est pas une date correcte, source: '+Source);
          StringToDate:=date;
     end;
end;

Function RealCorrecte(RealTexte:string):boolean;
var  Ix:integer; OKRealCorrecte,OKVergule:boolean;  Signe:string;
begin
     RealTexte:=WithoutChar(RealTexte,'.');

     if(RealTexte<>'')then
     begin
          if(RealTexte[1]in['+','-'])then
          begin
               Signe:=RealTexte[1];
               RealTexte:=Lastlaters(RealTexte,longueur(RealTexte)-1);
          end
          else Signe:='';
     end;

     if(longueur(RealTexte)>0)then
     begin
          OKRealCorrecte:=true;
          OKVergule:=false;
          Ix:=1;
          while(Ix<=longueur(RealTexte))do
          begin
               if not(RealTexte[Ix]in['0'..'9',','])then OKRealCorrecte:=false;
               if(RealTexte[Ix]=',')then OKVergule:=true;
          Ix:=Ix+1;
          end;
     end
     else
     begin
          OKRealCorrecte:=false;
          OKVergule:=false;
     end;

     if(OKRealCorrecte=true)and(OKVergule=true)then
     begin
          RealCorrecte:=true;
     end
     else
     begin
          RealCorrecte:=false;
     end;
end;

Function IntegerCorrecte(IntegerTexte:string):boolean;
var  Ix:integer; OKIntegerCorrecte:boolean; Signe:string;
begin
     IntegerTexte:=WithoutChar(IntegerTexte,'.');

     if(IntegerTexte<>'')then
     begin
          if(IntegerTexte[1]in['+','-'])then
          begin
               Signe:=IntegerTexte[1];
               IntegerTexte:=Lastlaters(IntegerTexte,longueur(IntegerTexte)-1);
          end
          else Signe:='';
     end;

     if(longueur(IntegerTexte)>0)and(longueur(IntegerTexte)<10)and(IntegerTexte[1]<>'0')then
     begin
          OKIntegerCorrecte:=true;
          Ix:=1;
          while(Ix<=longueur(IntegerTexte))do
          begin
               if not(IntegerTexte[Ix]in['0'..'9'])then OKIntegerCorrecte:=false;
          Ix:=Ix+1;
          end;
     end
     else
     begin
          OKIntegerCorrecte:=false;
     end;

     if(OKIntegerCorrecte=true)then
     begin
          IntegerCorrecte:=true;
     end
     else
     begin
          IntegerCorrecte:=false;
     end;
end;

Function PourcentageCorrecte(RealTexte:string):boolean;
var  Ix:integer; OKRealCorrecte,OKVergule:boolean;  Signe,SinePg:string;
begin
     PourcentageCorrecte:=false;

     RealTexte:=WithoutChar(RealTexte,'.');

     if(RealTexte<>'')then
     begin
          if(RealTexte[1]in['+','-'])then
          begin
               Signe:=RealTexte[1];
               RealTexte:=Lastlaters(RealTexte,longueur(RealTexte)-1);
          end
          else Signe:='';

          if(Lastlaters(RealTexte,1)='%')then
          begin
               SinePg:=Lastlaters(RealTexte,1);
               RealTexte:=Firstlaters(RealTexte,longueur(RealTexte)-1);
          end
          else SinePg:='';
     end;

     if(IntegerCorrecte(RealTexte))or(RealCorrecte(RealTexte))then PourcentageCorrecte:=true;
end;

