               TDetailMarche[TC-1].QuantiteGlobale:=strtoreal(FSDetailMarche.TableauDetailMarche.Cells[5,R]);
               TDetailMarche[TC-1].PrixUnitaire:=strtoreal(FSDetailMarche.TableauDetailMarche.Cells[6,R]);
