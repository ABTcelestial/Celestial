     end
     else
     if(OrintationPapier='Portrait')
     then ImprimerTableauPortrait(Tableau,AlignementTitre,DebutRowIn,FixedRow,TitreEtat,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,ImageCodebarre,ApercuAvantImpression,DebutRowOut)
     else ImprimerTableau(Tableau,AlignementTitre,DebutRowIn,FixedRow,TitreEtat,AjustePrint,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,ImageCodebarre,ApercuAvantImpression,DebutRowOut);
