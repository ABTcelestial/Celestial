Function ExisteMachineSousReseauxX(NomMachine:string; ActiveControleTableReseaux,AfficherMessageAuthentificationreseaux:boolean):boolean;
// attention si par exemple \\ordi5 existe
//il faudra passer comme valeur Ordi : '\\ordi5' et non 'ordi5'
// ou '\\ordi5\'
var
  PRessource: PNetResource;
  HandleEnum:THandle;
  RReseaux,RowSelect,NbrNotification:integer;
  Etat:string;
begin

     if(AfficherMessageAuthentificationreseaux=true)then AfficherAuthentificationreseaux('Authentification réseaux');

     result:=true;
     PRessource := AllocMem(16384);// 16Ko
     PRessource.lpRemoteName:=LPTSTR(NomMachine);
     if WNetOpenEnum(RESOURCE_GLOBALNET, RESOURCETYPE_ANY, 0, PRessource, HandleEnum) <> NO_ERROR then
     result:=false;
     WNetCloseEnum(HandleEnum);
     FreeMem(pRessource);

     ExisteMachineSousReseauxX:=result;

          NbrNotification:=0;
          if(result=true)
          then Etat:='Connecté'
          else Etat:='Déconnecté';

          for RReseaux:=1 to FSMenuPrincipal.TableauAdresseDossierPartageReseaux.RowCount-1 do
          begin
               if(FSMenuPrincipal.TableauAdresseDossierPartageReseaux.Cells[4,RReseaux]='Réseaux')
               and(ExtractFileDir(FSMenuPrincipal.TableauAdresseDossierPartageReseaux.Cells[3,RReseaux])=NomMachine)
               and(FSMenuPrincipal.TableauAdresseDossierPartageReseaux.Cells[5,RReseaux]<>Etat)then
               begin
                    RowSelect:=RReseaux;
                    NbrNotification:=NbrNotification+1;
                    FSMenuPrincipal.TableauAdresseDossierPartageReseaux.Cells[5,RReseaux]:=Etat;
               end;
          end;

          if(ActiveControleTableReseaux=true)and(NbrNotification>0)then
          begin
               FSMenuPrincipal.AfficheAdresseDossierPartageReseaux.Visible:=true;
               if(NbrNotification<=1)
               then FSMenuPrincipal.EditNotification.Caption:=inttostr(NbrNotification)+' Notification'
               else FSMenuPrincipal.EditNotification.Caption:=inttostr(NbrNotification)+' Notifications';

               if(NbrNotification=1)then  FSMenuPrincipal.EditNotification.Caption:=FSMenuPrincipal.EditNotification.Caption+' {'+NomMachine+'} '+Etat;
          end;

          MiseAjourCaptionMenuPrincipal(FSMenuPrincipal.TableauAdresseDossierPartageReseaux);

FSAuthentificationreseaux.TimerShowmessage.Enabled:=false;
FSAuthentificationreseaux.Close;
end;

Function ExisteFichierPartageReseauInTableauFPR(FichierConcerne:string; TableauListeFPR:ArrayListeFichierPartageReseaux; TailTFPR:integer):boolean;
var iFPR:integer;   OKFichierFPR:boolean;
begin
     iFPR:=0;
     OKFichierFPR:=false;
     while(iFPR<=TailTFPR-1)and(OKFichierFPR=false)do
     begin
          if((Firstlaters(TableauListeFPR[iFPR],13)='FDetailMarche')or(TableauListeFPR[iFPR]='FMarche'))and((Firstlaters(FichierConcerne,13)='FDetailMarche'))then OKFichierFPR:=true;
          if((Firstlaters(TableauListeFPR[iFPR],14)='FDetailAvenant')or(TableauListeFPR[iFPR]='FMarche'))and((Firstlaters(FichierConcerne,14)='FDetailAvenant'))then OKFichierFPR:=true;
          if((Firstlaters(TableauListeFPR[iFPR],18)='FDetailAttachement')or(TableauListeFPR[iFPR]='FMarche'))and((Firstlaters(FichierConcerne,18)='FDetailAttachement'))then OKFichierFPR:=true;
          if((Firstlaters(TableauListeFPR[iFPR],16)='FStructureMarche')or(TableauListeFPR[iFPR]='FMarche'))and((Firstlaters(FichierConcerne,16)='FStructureMarche'))then OKFichierFPR:=true;
          if((Firstlaters(TableauListeFPR[iFPR],18)='FStatistiqueMarche')or(TableauListeFPR[iFPR]='FMarche'))and((Firstlaters(FichierConcerne,18)='FStatistiqueMarche'))then OKFichierFPR:=true;
          if((Firstlaters(TableauListeFPR[iFPR],16)='FSituationMarche')or(TableauListeFPR[iFPR]='FMarche'))and((Firstlaters(FichierConcerne,16)='FSituationMarche'))then OKFichierFPR:=true;
          if((Firstlaters(TableauListeFPR[iFPR],22)='FDetailSituationMarche')or(TableauListeFPR[iFPR]='FMarche'))and((Firstlaters(FichierConcerne,22)='FDetailSituationMarche'))then OKFichierFPR:=true;
          if(Firstlaters(TableauListeFPR[iFPR],6)='FTiers')and((Firstlaters(FichierConcerne,6)='FTiers'))then OKFichierFPR:=true;
          if(ExisteFichierConcerneinTypeFichierTiers(FichierConcerne,'',''))and((TableauListeFPR[iFPR]=FichierConcerne)or(Firstlaters(FichierConcerne,6)='FTiers'))then OKFichierFPR:=true;
          if(Firstlaters(TableauListeFPR[iFPR],6)='FStock')and(Firstlaters(FichierConcerne,6)='FStock')then OKFichierFPR:=true;
          if(Firstlaters(TableauListeFPR[iFPR],7)='Formule')and(Firstlaters(FichierConcerne,7)='Formule')then OKFichierFPR:=true;
          if(FichierConcerne='FAutorisationPartageRegistre')then OKFichierFPR:=true;
          if(Firstlaters(TableauListeFPR[iFPR],10)='FTransfert')and(Firstlaters(FichierConcerne,10)='FTransfert')then OKFichierFPR:=true;
          if(Firstlaters(TableauListeFPR[iFPR],15)='FListeMouvement')then OKFichierFPR:=true;
          if(ExisteCharInString('Mouvement',TableauListeFPR[iFPR])and ExisteCharInString('Mouvement',FichierConcerne))then OKFichierFPR:=true;  //FMouvement, FTypeMouvement, DétailMouvement
          if(TableauListeFPR[iFPR]=FichierConcerne)then OKFichierFPR:=true;
     iFPR:=iFPR+1;
     end;

     ExisteFichierPartageReseauInTableauFPR:=OKFichierFPR;
end;

Function ExisteFichierConcerneinTypeFichierTiers(FichierConcerneRecherche,NumAdresseProces,NomPosteReseaux:string):boolean;
var  OKFichierTiersEFCTFT:boolean;    TypeProces,ChRegistreReseaux,AdresseReseaux,NomDossierPartageOut,EmlacementLocalOuReseauxOut,ExerciceReseaux,TypeProcesTFT,FichierConcerneTFT,AdresseTFT:string;
begin
     TypeProces:='';

     if(NumAdresseProces<>'')then
     begin
          RAdresseProcesRecherche:=ChercherAdresseProces(strtointeger(NumAdresseProces));
          TypeProces:=RAdresseProcesRecherche.TypeProces;
          NomPosteReseaux:=RAdresseProcesRecherche.Repertoire;
     end
     else
     if(NomPosteReseaux<>'')then
     begin
          RAdresseDossierPartageReseauxCopie:=ChercherDossierPartageReseaux('',NomPosteReseaux,'');
          TypeProces:=RAdresseDossierPartageReseauxCopie.EmlacementLocalOuReseaux;
     end;

     if(TypeProces<>'Réseaux')then
     begin
           OpenFParc(RParc);
           ChTypeFichierTiersCopie:=RParc.Parcours+'\'+Exercice+'FTypeFichierTiers';
           assignfile(FTypeFichierTiersCopie,ChTypeFichierTiersCopie);
           try
           if FileExists(ChTypeFichierTiersCopie)then
           Reset(FTypeFichierTiersCopie)
           else Rewrite(FTypeFichierTiersCopie);
           Seek(FTypeFichierTiersCopie,0);
           OKFichierTiersEFCTFT:=false;
           while not eof(FTypeFichierTiersCopie)and(OKFichierTiersEFCTFT=false)do
           begin
                read(FTypeFichierTiersCopie,RTypeFichierTiersCopie);

                if(RTypeFichierTiersCopie.FichierConcerne=FichierConcerneRecherche)then
                begin
                     OKFichierTiersEFCTFT:=true;
                end;
           end;
           finally
           CloseFile(FTypeFichierTiersCopie);
           end;
     end
     else
     begin
           AdresseReseaux:=ProcAdresseDossierPartageReseaux('','Local',NomDossierPartageOut,EmlacementLocalOuReseauxOut);

           ChRegistreReseaux:=AdresseReseaux+'\WinBus'+DataIdentificateurReseaux+' '+NomDossierPartageOut+'.File';
           assignfile(FRegistre,ChRegistreReseaux);
           if FileExists(ChRegistreReseaux)then
           begin
                try
                Reset(FRegistre);
                Seek(FRegistre,0);
                read(FRegistre,RRegistre);
                ExerciceReseaux:=RRegistre.Exercice;
                finally
                closefile(FRegistre);
                end;
           end
           else ExerciceReseaux:=ExerciceAnnee;
     
           ChTypeFichierTiersCopie:=AdresseReseaux+'\Enregistrement Réseaux'+DataIdentificateurReseaux+'-'+ExerciceReseaux+'FTypeFichierTiers'+' '+NomDossierPartageOut;
           assignfile(FTypeFichierTiersCopie,ChTypeFichierTiersCopie);
           if FileExists(ChTypeFichierTiersCopie)then
           begin
                try
                Reset(FTypeFichierTiersCopie);
                Seek(FTypeFichierTiersCopie,0);
                OKFichierTiersEFCTFT:=false;
                while not eof(FTypeFichierTiersCopie)and(OKFichierTiersEFCTFT=false)do
                begin
                     read(FTypeFichierTiersCopie,RTypeFichierTiersCopie);

                     if(RTypeFichierTiersCopie.FichierConcerne=FichierConcerneRecherche)then
                     begin
                          OKFichierTiersEFCTFT:=true;
                     end;
                end;
                finally
                CloseFile(FTypeFichierTiersCopie);
                end;
           end;
     end;

     ExisteFichierConcerneinTypeFichierTiers:=OKFichierTiersEFCTFT;
end;

