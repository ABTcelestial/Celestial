Procedure AjusterImprimeEtatTD(ARow,ACol,L,C:integer; Tableau:TStringGrid; AjustePrint:boolean; FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol:string; EcartTableau:integer);
var   MaxRow:integer;  IndiceWidth:real; CadreRubrique,CadreRubriqueNext,CadreRubriqueNextRow:TQRShape; Rubrique,RubriqueNext:TQRLabel;
      CTeste:integer;  ColCountTeste:real;
begin
     IndiceWidth:=10/Tableau.Font.Size;

     ColCountTeste:=0;
     for CTeste:=0 to Tableau.ColCount-1 do
     begin
          if(Tableau.ColWidths[CTeste]>10)then
          ColCountTeste:=ColCountTeste+(Tableau.ColWidths[CTeste]*IndiceWidth);
     end;

     if(AjustePrint)then
     begin
          IndiceWidth:=IndiceWidth*(PrintEtatTraitementDonnees.PageDonnees.Width/ColCountTeste);
     end;

     MaxRow:=Tableau.RowCount-1;
     IdentificationRubrique(L,C,CadreRubrique,CadreRubriqueNext,CadreRubriqueNextRow,Rubrique,RubriqueNext);

     CadreRubrique.Height:=Tableau.RowHeights[ARow]+5;
     if(L=0)then CadreRubrique.Top:=0
     else CadreRubrique.Top:=CadreRubriqueNextRow.Top+CadreRubriqueNextRow.Height-1;
     Rubrique.Top:=CadreRubrique.Top+5;

     CadreRubrique.Width:=ValeAbsolue(Tableau.ColWidths[ACol]*IndiceWidth);
     if(C=0)then CadreRubrique.Left:=0
     else CadreRubrique.Left:=CadreRubriqueNext.Left+CadreRubriqueNext.Width-1;

     if(ExisteNuminTexte(inttostr(ARow),FontGrasARow))
     or(ExisteNuminTexte(inttostr(ACol),FontGrasACol))
     then
     begin
          Rubrique.Font.Style:=[fsBold];
     end
     else
     begin
          Rubrique.Font.Style:=[];
     end;

     if(ExisteNuminTexte(inttostr(ARow),AlignementCenterARow))
     or(ExisteNuminTexte(inttostr(ACol),AlignementCenterACol))
     then
     begin
          Rubrique.Alignment:=taCenter;
          Rubrique.Left:=CadreRubrique.Left+ValeAbsolue((CadreRubrique.Width-Rubrique.Width)/2);
     end
     else
     if(ExisteNuminTexte(inttostr(ARow),AlignementRightARow))
     or(ExisteNuminTexte(inttostr(ACol),AlignementRightACol))
     then
     begin
          Rubrique.Alignment:=taRightJustify;
          Rubrique.Left:=CadreRubrique.Width+CadreRubrique.Left-Rubrique.Width-3;
     end
     else
     begin
          Rubrique.Alignment:=taLeftJustify;
          Rubrique.Left:=CadreRubrique.Left+5;
     end;

     if(EcartTableau=0)then CadreRubrique.Enabled:=false;
     Rubrique.Font.Size:=MinInt(ValeAbsolue(Tableau.Font.Size*IndiceWidth),10);
     Rubrique.Caption:=Tableau.Cells[ACol,ARow]
end;

