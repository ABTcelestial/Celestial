procedure TFSBaremeComptabilisationCodeParCompte.BitOperationBaremeComptabilisationCodeParCompteClick(
  Sender: TObject);
var  l,LTrouver:integer;  OKBaremeCCPC:boolean;
begin

     if(FSBaremeComptabilisationCodeParCompte.BitOperationBaremeComptabilisationCodeParCompte.Caption='Valider')then
     begin
          OpenFParc(RParc);
          ChBaremeComptabilisationCodeParCompte:=RParc.Parcours+'\'+Exercice+'FBaremeComptabilisationCodeParCompte';
          assignfile(FBaremeComptabilisationCodeParCompte,ChBaremeComptabilisationCodeParCompte);
          if FileExists(ChBaremeComptabilisationCodeParCompte)then
          Reset(FBaremeComptabilisationCodeParCompte)
          else Rewrite(FBaremeComptabilisationCodeParCompte);
          Seek(FBaremeComptabilisationCodeParCompte,0);
          OKBaremeCCPC:=false;
          l:=0;
          while not eof(FBaremeComptabilisationCodeParCompte)and(OKBaremeCCPC=false)do
          begin
               read(FBaremeComptabilisationCodeParCompte,RBaremeComptabilisationCodeParCompte);

               if(inttostr(RBaremeComptabilisationCodeParCompte.PositionBaremeCCPC)=FSBaremeComptabilisationCodeParCompte.EditPositionBaremeCCPC.Text)then
               begin
                    LTrouver:=l;
                    OKBaremeCCPC:=true;
               end;
          l:=l+1;
          end;

          if(OKBaremeCCPC=true)then l:=LTrouver;
          Seek(FBaremeComptabilisationCodeParCompte,l);
          RBaremeComptabilisationCodeParCompte.PositionBaremeCCPC:=l;
          RBaremeComptabilisationCodeParCompte.TypeProces:=FSBaremeComptabilisationCodeParCompte.EditTypeProces.Text;
          RBaremeComptabilisationCodeParCompte.FichierConcerne:=FSBaremeComptabilisationCodeParCompte.EditFichierConcerne.Text;
          RBaremeComptabilisationCodeParCompte.CodeAImputer:=FSBaremeComptabilisationCodeParCompte.EditCodeAImputer.Text;
          RBaremeComptabilisationCodeParCompte.CompteImputation:=FSBaremeComptabilisationCodeParCompte.EditCompteImputation.Text;
          Write(FBaremeComptabilisationCodeParCompte,RBaremeComptabilisationCodeParCompte);
          CloseFile(FBaremeComptabilisationCodeParCompte);
     end;

     if(FSBaremeComptabilisationCodeParCompte.BitOperationBaremeComptabilisationCodeParCompte.Caption='Supprimer')then
     begin
          DeleteFBaremeComptabilisationCodeParCompte(FSBaremeComptabilisationCodeParCompte.EditPositionBaremeCCPC.Text,OKBaremeCCPC);
     end;

     AfficheListeBaremeCCPC(FSBaremeComptabilisationCodeParCompte.TableauBaremeComptabilisationCodeParCompte,'');
     FSBaremeComptabilisationCodeParCompte.AfficheOperationBaremeComptabilisationCodeParCompte.Visible:=false;

     FSBaremeComptabilisationCodeParCompte.TableauBaremeComptabilisationCodeParCompte.SetFocus;
end;

Procedure AfficheListeBaremeCCPC(TableauListeBaremeCCPC:TStringGrid;  CompteImputation:string);
var  R:integer;  OKBaremeCCPC:boolean;
begin
     TableauListeBaremeCCPC.ColCount:=8;
     TableauListeBaremeCCPC.Cols[0].Text:='N°°';
     TableauListeBaremeCCPC.Cols[1].Text:='Position';
     TableauListeBaremeCCPC.Cols[2].Text:='TypeProces';
     TableauListeBaremeCCPC.Cols[3].Text:='Fichier Concerne';
     TableauListeBaremeCCPC.Cols[4].Text:='Code ŕ Imputer';
     TableauListeBaremeCCPC.Cols[5].Text:='Désignation';
     TableauListeBaremeCCPC.Cols[6].Text:='Compte d''imputation';
     TableauListeBaremeCCPC.Cols[7].Text:='Désignation Compte';

     TableauListeBaremeCCPC.RowCount:=2;
     TableauListeBaremeCCPC.Rows[1].Text:='';

     OpenFParc(RParc);
     ChBaremeComptabilisationCodeParCompte:=RParc.Parcours+'\'+Exercice+'FBaremeComptabilisationCodeParCompte';
     assignfile(FBaremeComptabilisationCodeParCompte,ChBaremeComptabilisationCodeParCompte);
     if FileExists(ChBaremeComptabilisationCodeParCompte)then
     Reset(FBaremeComptabilisationCodeParCompte)
     else Rewrite(FBaremeComptabilisationCodeParCompte);
     Seek(FBaremeComptabilisationCodeParCompte,0);
     
     R:=0;
     while not eof(FBaremeComptabilisationCodeParCompte)do
     begin
          read(FBaremeComptabilisationCodeParCompte,RBaremeComptabilisationCodeParCompte);

          if(CompteImputation<>'')then
          begin
               if(RBaremeComptabilisationCodeParCompte.CompteImputation=CompteImputation)
               then OKBaremeCCPC:=true
               else OKBaremeCCPC:=false;
          end
          else OKBaremeCCPC:=true;

          if(OKBaremeCCPC=true)then
          begin
               R:=R+1;
               TableauListeBaremeCCPC.Rows[R].Text:=inttostr(R);
               TableauListeBaremeCCPC.Cells[1,R]:=inttostr(RBaremeComptabilisationCodeParCompte.PositionBaremeCCPC);
               TableauListeBaremeCCPC.Cells[2,R]:=RBaremeComptabilisationCodeParCompte.TypeProces;
               TableauListeBaremeCCPC.Cells[3,R]:=RBaremeComptabilisationCodeParCompte.FichierConcerne;
               TableauListeBaremeCCPC.Cells[4,R]:=RBaremeComptabilisationCodeParCompte.CodeAImputer;
               TableauListeBaremeCCPC.Cells[5,R]:='???';
               TableauListeBaremeCCPC.Cells[6,R]:=RBaremeComptabilisationCodeParCompte.CompteImputation;
               if(ChercherCompteComptable(RBaremeComptabilisationCodeParCompte.CompteImputation,inttostr(longueur(RBaremeComptabilisationCodeParCompte.CompteImputation)),'PlanComptable',RRegistreCompteCopie))
               then TableauListeBaremeCCPC.Cells[7,R]:=RRegistreCompteCopie.Designation
               else TableauListeBaremeCCPC.Cells[7,R]:='???';
          end;
     end;
     CloseFile(FBaremeComptabilisationCodeParCompte);

     if(R>0)then TableauListeBaremeCCPC.RowCount:=R+1
            else TableauListeBaremeCCPC.RowCount:=2;

     AjusterColWidth(TableauListeBaremeCCPC,'','');
end;

