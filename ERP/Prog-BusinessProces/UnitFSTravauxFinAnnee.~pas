                TableauDeBohrTiers.Cells[C,l]:=Vergule(floattostr(Solde*Indice),'2','C','');

                TableauDeBohrTiers.Cells[3,T+2]:=Vergule(floattostr(strtoreal(TableauDeBohrTiers.Cells[3,T+2])+strtoreal(TableauDeBohrTiers.Cells[3,l])),'2','C','');
