begin
     if not(ActiverReouvertureMarche(NewExercice,true,FSTravauxFinAnnee.RBAucuneReouvertureReseaux.Checked,FSTravauxFinAnnee.RBNouvelleReouvertureReseaux.Checked,TypeProcesControleReseaux))then
     begin
