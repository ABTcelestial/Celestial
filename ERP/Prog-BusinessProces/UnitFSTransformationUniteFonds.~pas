          RPrelevementUniteFonds.NumPiece:='';
          RPrelevementUniteFonds.Domiciliation:='';
          RPrelevementUniteFonds.ValeurPrelevement:=(-1)*strtoreal(FSTransformationUniteFonds.TableauUniteFondsSortante.Cells[18,R]);
          Seek(FPrelevementUniteFonds,i);
          write(FPrelevementUniteFonds,RPrelevementUniteFonds);
          i:=i+1;
          end;
     end;

     for R:=1 to FSTransformationUniteFonds.TableauUniteFondsEntrante.RowCount-1 do
     begin
          if(strtoreal(FSTransformationUniteFonds.TableauUniteFondsEntrante.Cells[17,R])>0)then
