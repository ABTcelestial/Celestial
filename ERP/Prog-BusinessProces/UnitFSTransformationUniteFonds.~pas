procedure TFSTransformationUniteFonds.TableauListePrelevementDblClick(
  Sender: TObject);
var  R,NbrSelect:integer;
begin

if(strtoboolean(FSTransformationUniteFonds.TableauListePrelevement.Cells[6,FSTransformationUniteFonds.TableauListePrelevement.Row])=false)then
begin
     showmessage('Le prélčvement n''est pas archivé !');
     Exit;
end;

FSTransformationUniteFonds.EditNumPrelevement.Text:='';

if(FSTransformationUniteFonds.TableauListePrelevement.Cells[1,FSTransformationUniteFonds.TableauListePrelevement.Row]<>'')then
begin
     if(FSTransformationUniteFonds.TableauListePrelevement.Cells[9,FSTransformationUniteFonds.TableauListePrelevement.Row]='')then
     begin
          FSTransformationUniteFonds.TableauListePrelevement.Cells[9,FSTransformationUniteFonds.TableauListePrelevement.Row]:='OK';
     end
     else
     begin
          FSTransformationUniteFonds.TableauListePrelevement.Cells[9,FSTransformationUniteFonds.TableauListePrelevement.Row]:='';
     end;

     NbrSelect:=0;
     for R:=1 to FSTransformationUniteFonds.TableauListePrelevement.RowCount-1 do
     begin
          if(FSTransformationUniteFonds.TableauListePrelevement.Cells[9,R]='OK')then
          begin
               NbrSelect:=NbrSelect+1;
          end;
     end;

     if(NbrSelect<=2)then
     begin
          FSTransformationUniteFonds.EditPeriode.Text:='Prélčvement ';

          NbrSelect:=0;
          for R:=1 to FSTransformationUniteFonds.TableauListePrelevement.RowCount-1 do
          begin
               if(FSTransformationUniteFonds.TableauListePrelevement.Cells[9,R]='OK')then
               begin
                    NbrSelect:=NbrSelect+1;

                    if(NbrSelect=1)then
                    begin
                         FSTransformationUniteFonds.EditPeriode.Text:=FSTransformationUniteFonds.EditPeriode.Text+'N°:'+FSTransformationUniteFonds.TableauListePrelevement.Cells[1,R]+' du '+FSTransformationUniteFonds.TableauListePrelevement.Cells[4,R]+'/'+FSTransformationUniteFonds.TableauListePrelevement.Cells[5,R];
                         FSTransformationUniteFonds.EditNumPrelevement.Text:=FSTransformationUniteFonds.TableauListePrelevement.Cells[1,R];
                         FSTransformationUniteFonds.EditTypeAffichge.Text:='Par Prélčvement: ';
                    end;
                    if(NbrSelect=2)then
                    begin
                         FSTransformationUniteFonds.EditPeriode.Text:=FSTransformationUniteFonds.EditPeriode.Text+' au '+'N°:'+FSTransformationUniteFonds.TableauListePrelevement.Cells[1,R]+' du '+FSTransformationUniteFonds.TableauListePrelevement.Cells[4,R]+'/'+FSTransformationUniteFonds.TableauListePrelevement.Cells[5,R];
                         FSTransformationUniteFonds.EditNumPrelevement.Text:='';
                         FSTransformationUniteFonds.EditTypeAffichge.Text:='Périodique: ';
                    end;
               end;
          end;
     end
     else
     begin
          FSTransformationUniteFonds.TableauListePrelevement.Cells[9,FSTransformationUniteFonds.TableauListePrelevement.Row]:='';
          FSTransformationUniteFonds.EditNumPrelevement.Text:='';
          Showmessage('La Période est sélectionné !, Veuillez confirmer votre requette SVP');
     end;
end;
end;

procedure TFSTransformationUniteFonds.TableauListePrelevementKeyDown(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var  R,C,NbrSelect:integer; TypeProces,FichierConcerne,NotCol,NumPrelevement,NumPrelevementFin,DateIn,HeureIn,DatePrelevement,HeurePrelevement:string;
begin

if key in[VK_RETURN]then
begin
     if(FSTransformationUniteFonds.EditTypeAffichge.Text='Par Prélčvement: ')then
     begin
          R:=1;
          NbrSelect:=0;
          while(R<=FSTransformationUniteFonds.TableauListePrelevement.RowCount-1)and(NbrSelect<>1)do
          begin
               if(FSTransformationUniteFonds.TableauListePrelevement.Cells[9,R]='OK')then
               begin
                    NbrSelect:=1;
                    NumPrelevement:=FSTransformationUniteFonds.TableauListePrelevement.Cells[1,R];
                    NumPrelevementFin:='';
                    DateIn:=FSTransformationUniteFonds.TableauListePrelevement.Cells[4,R];
                    HeureIn:=FSTransformationUniteFonds.TableauListePrelevement.Cells[5,R];
                    DatePrelevement:=FSTransformationUniteFonds.TableauListePrelevement.Cells[4,R];
                    HeurePrelevement:=FSTransformationUniteFonds.TableauListePrelevement.Cells[5,R];

                    FSTransformationUniteFonds.EditDateAffichage.Text:=DatePrelevement;
                    FSTransformationUniteFonds.EditHeureAffichage.Text:=HeurePrelevement;

                    ////////////////
                    ProcPrelevementUniteFonds(FSTransformationUniteFonds.TableauUniteFondsSortante,FSTransformationUniteFonds.TableauTitreUniteFondsSortante,
                                          FSTransformationUniteFonds.EditMontantUniteFonds,
                                          FSTransformationUniteFonds.EditNumPrelevement,
                                          NumPrelevement,NumPrelevementFin,'',FSTransformationUniteFonds.TableauUniteFondsSortante.Cells[6,FSTransformationUniteFonds.TableauUniteFondsSortante.Row]);
                    FSTransformationUniteFonds.TableauUniteFondsSortante.Cols[18].Text:='   Nombre Sortant!';

                    NotCol:='1;2;3;4;5;6;7;8;10;11;12;13;14;15;16';
                    for C:=0 to FSTransformationUniteFonds.TableauUniteFondsSortante.ColCount-1 do
                    begin
                         if Existenumintexte(inttostr(C),NotCol)then FSTransformationUniteFonds.TableauUniteFondsSortante.ColWidths[C]:=0;
                    end;
                    AjusterColWidth(FSTransformationUniteFonds.TableauUniteFondsSortante,'',NotCol);
                    //////////////
                    ProcPrelevementUniteFonds(FSTransformationUniteFonds.TableauUniteFondsEntrante,FSTransformationUniteFonds.TableauTitreUniteFondsEntrante,
                                          FSTransformationUniteFonds.EditMontantUniteFondsEntrant,
                                          FSTransformationUniteFonds.EditNumPrelevementEntrant,
                                          NumPrelevement,NumPrelevementFin,'',FSTransformationUniteFonds.TableauUniteFondsEntrante.Cells[6,FSTransformationUniteFonds.TableauUniteFondsEntrante.Row]);
                    FSTransformationUniteFonds.TableauUniteFondsEntrante.ColCount:=18;
                    FSTransformationUniteFonds.TableauUniteFondsEntrante.Cols[17].Text:='   Nombre Entrant!';
                    FSTransformationUniteFonds.EditMontantUniteFondsEntrant.Text:='';

                    NotCol:='1;2;3;4;5;6;7;8;10;11;12;13;14;15;16';
                    for C:=0 to FSTransformationUniteFonds.TableauUniteFondsEntrante.ColCount-1 do
                    begin
                         if Existenumintexte(inttostr(C),NotCol)then FSTransformationUniteFonds.TableauUniteFondsEntrante.ColWidths[C]:=0;
                    end;
                    AjusterColWidth(FSTransformationUniteFonds.TableauUniteFondsEntrante,'',NotCol);

                    FSTransformationUniteFonds.TableauListePrelevement.Visible:=false;

                    if(FSTransformationUniteFonds.EditCodeTiers.Text='')then
                    begin
                         FSTransformationUniteFonds.AfficheTiers.Visible:=true;
                         TypeProces:=FSTransformationUniteFonds.EditTypeProcesUF.Text;
                         FichierConcerne:=FSTransformationUniteFonds.EditFichierConserneUF.Text;
                         ListeTiers(FSTransformationUniteFonds.TableauTiers,TypeProces,FichierConcerne,'','','',true);
                         FSTransformationUniteFonds.TableauTiers.SetFocus;
                    end;

               end;
