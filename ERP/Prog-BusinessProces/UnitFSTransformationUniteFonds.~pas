          RPrelevementUniteFonds.TypeProces:=FSTransformationUniteFonds.EditTypeProcesUFChargement.Text;
          RPrelevementUniteFonds.FichierConcerne:=FSTransformationUniteFonds.EditFichierConserneUFChargement.Text;
          RPrelevementUniteFonds.CodeTiers:=FSTransformationUniteFonds.EditCodeTiers.Text;
