          write(FPrelevementUniteFonds,RPrelevementUniteFonds);
          i:=i+1;
          end;
     end;

     CloseFile(FPrelevementUniteFonds);

     NumPrelevement:=FSTransformationUniteFonds.EditNumPrelevement.Text;
     NumPrelevementFin:='';
     DateIn:='';
     HeureIn:='';
     DatePrelevement:=FSTransformationUniteFonds.EditDateAffichage.Text;
