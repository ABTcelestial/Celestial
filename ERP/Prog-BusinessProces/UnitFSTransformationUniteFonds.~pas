     PrintEtatProcesverbalTransformationUFonds.TextD2.Caption:=RParc.Text2;
     PrintEtatProcesverbalTransformationUFonds.TextD3.Caption:=RParc.Text3;
     PrintEtatProcesverbalTransformationUFonds.TextD4.Caption:=RParc.Text4;
     {***************Fin Entreprise***************}

     PrintEtatProcesverbalTransformationUFonds.TitreEtat.Caption:='Procčs-verbal de transformation d''Unités de Fonds';
     PrintEtatProcesverbalTransformationUFonds.TitreDate.Caption:=FSTransformationUniteFonds.EditDateAffichage.Text+' ŕ '+FSTransformationUniteFonds.EditHeureAffichage.Text;
     PrintEtatProcesverbalTransformationUFonds.DataBeneficiaire.Caption:=FSTransformationUniteFonds.TableauTiersTransformer.Cells[2,1];

     PrintEtatProcesverbalTransformationUFonds.DataRapport.Lines.Text:='';
     PrintEtatProcesverbalTransformationUFonds.DataRapport.Lines.Add('En cette date du '+FSTransformationUniteFonds.EditDateAffichage.Text+' ŕ '+FSTransformationUniteFonds.EditHeureAffichage.Text+'.');
     PrintEtatProcesverbalTransformationUFonds.DataRapport.Lines.Add('Il a été transformé un montant de:'+ FSTransformationUniteFonds.EditMontantUniteFondsTransformer.Text+', dont le détail ci-dessous :');

     PrintEtatProcesverbalTransformationUFonds.DataDetailS.Lines.Text:='';
     PrintEtatProcesverbalTransformationUFonds.DataDetailE.Lines.Text:='';
     NbrUFMax:=0;
     NbrUFS:=0;
     NbrUFE:=0;
     MontantS:=0;
     for R:=1 to FSTransformationUniteFonds.TableauUniteFondsTransformer.RowCount-1 do
     begin
          if(strtoreal(FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[17,R])<>0)then
          begin
               NbrUFS:=NbrUFS+1;
               NbrUFMax:=NbrUFMax+1;
               PrintEtatProcesverbalTransformationUFonds.DataDetailS.Lines.Add(inttostr(NbrUFS)+')- '+CompleteZerogauche(FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[17,R],'2')+' '+FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[9,R]);
               MontantS:=MontantS+strtoreal(FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[19,R]);
          end;

          if(strtoreal(FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[18,R])<>0)then
          begin
               NbrUFE:=NbrUFE+1;
               NbrUFMax:=NbrUFMax+1;
               PrintEtatProcesverbalTransformationUFonds.DataDetailE.Lines.Add(inttostr(NbrUFE)+')- '+CompleteZerogauche(FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[18,R],'2')+' '+FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[9,R]);
               MontantS:=MontantS+strtoreal(FSTransformationUniteFonds.TableauUniteFondsTransformer.Cells[19,R]);
          end;
     end;

     PrintEtatProcesverbalTransformationUFonds.DataRapport.Height:=50;

     PrintEtatProcesverbalTransformationUFonds.TitreDetailS.Top:=PrintEtatProcesverbalTransformationUFonds.DataRapport.Top+
                                                                 PrintEtatProcesverbalTransformationUFonds.DataRapport.Height+24;
     PrintEtatProcesverbalTransformationUFonds.TitreDetailE.Top:=PrintEtatProcesverbalTransformationUFonds.TitreDetailS.Top;

     PrintEtatProcesverbalTransformationUFonds.HorizontaleHaut.Top:=PrintEtatProcesverbalTransformationUFonds.TitreDetailS.Top+24;
     PrintEtatProcesverbalTransformationUFonds.DataDetailS.Top:=PrintEtatProcesverbalTransformationUFonds.HorizontaleHaut.Top+24;
     PrintEtatProcesverbalTransformationUFonds.DataDetailE.Top:=PrintEtatProcesverbalTransformationUFonds.DataDetailS.Top;
     PrintEtatProcesverbalTransformationUFonds.Verticale.Top:=PrintEtatProcesverbalTransformationUFonds.HorizontaleHaut.Top+4;

     PrintEtatProcesverbalTransformationUFonds.DataDetailS.Height:=NbrUFMax*25;
     PrintEtatProcesverbalTransformationUFonds.DataDetailE.Height:=NbrUFMax*25;
     PrintEtatProcesverbalTransformationUFonds.Verticale.Height:=NbrUFMax*25;
     PrintEtatProcesverbalTransformationUFonds.HorizontaleBas.Top:=PrintEtatProcesverbalTransformationUFonds.Verticale.Top+
                                                                PrintEtatProcesverbalTransformationUFonds.Verticale.Height;

     PrintEtatProcesverbalTransformationUFonds.TitreVisaBeneficiaire.Top:=PrintEtatProcesverbalTransformationUFonds.DataDetailS.Top+
                                                                          PrintEtatProcesverbalTransformationUFonds.DataDetailS.Height+40;

     PrintEtatProcesverbalTransformationUFonds.TitreVisaEntreprise.Top:=PrintEtatProcesverbalTransformationUFonds.TitreVisaBeneficiaire.Top;

     PrintEtatProcesverbalTransformationUFonds.Preview;
end;

