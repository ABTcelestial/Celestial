          RPrelevementUniteFonds.CodeUtilisateur:=FSMenuPrincipal.EditCodeUtilisateur.Text;
          RPrelevementUniteFonds.DatePrelevement:=FSTransformationUniteFonds.EditDateAffichage.Text;
          RPrelevementUniteFonds.HeurePrelevement:=FSTransformationUniteFonds.EditHeureAffichage.Text;
          RPrelevementUniteFonds.NumEquipe:=0;
          RPrelevementUniteFonds.NumUniteFonds:=strtointeger(FSTransformationUniteFonds.TableauUniteFondsEntrante.Cells[6,R]);
          RPrelevementUniteFonds.ValeurPrecise:=strtoboolean(FSTransformationUniteFonds.TableauUniteFondsEntrante.Cells[10,R]);
          RPrelevementUniteFonds.TypeProces:=FSTransformationUniteFonds.EditTypeProcesUFChargement.Text;
          RPrelevementUniteFonds.FichierConcerne:=FSTransformationUniteFonds.EditFichierConserneUFChargement.Text;
          RPrelevementUniteFonds.CodeTiers:=FSTransformationUniteFonds.EditCodeTiers.Text;
          RPrelevementUniteFonds.ModePaiement:=FSTransformationUniteFonds.TableauUniteFondsEntrante.Cells[14,R];
