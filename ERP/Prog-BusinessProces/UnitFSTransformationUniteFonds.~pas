Procedure PrelevementTransfertUniteFonds(TableauUniteFonds,TableauTiers:TStringGrid; NumPrelevement:string; MemoCummulUniteFonds:TMemo; CodeTiers:string);
var C,R,NbrUF,NbrTiers,ACol,Signe:integer; OKTiers:boolean;  DateIn,HeureIn,DatePrelevement,HeurePrelevement,NotCol,FichierConcerne,SigleDevise:string; OKData:boolean;
begin

     TableauTiers.ColCount:=3;
     TableauTiers.Cols[1].Text:='N°';
     TableauTiers.Cols[1].Text:='    Code   ';
     TableauTiers.Cols[1].Text:='     Tiers     ';
     TableauTiers.RowCount:=2;
     TableauTiers.Rows[1].Text:='';

     TableauUniteFonds.ColCount:=20;
     TableauUniteFonds.Cols[1].Text:='Num';
     TableauUniteFonds.Cols[2].Text:='Code Utilisateur';
     TableauUniteFonds.Cols[3].Text:='Num Equipe';
     TableauUniteFonds.Cols[4].Text:='Date';
     TableauUniteFonds.Cols[5].Text:='Heure';
     TableauUniteFonds.Cols[6].Text:='Num Unite Fonds';
     TableauUniteFonds.Cols[7].Text:='Num Type U.F';
     TableauUniteFonds.Cols[8].Text:='Type U.F';
     TableauUniteFonds.Cols[9].Text:='Unite Fonds';
     TableauUniteFonds.Cols[10].Text:='Data';
     TableauUniteFonds.Cols[11].Text:='T.Proces';
     TableauUniteFonds.Cols[12].Text:='F.Concerne';
     TableauUniteFonds.Cols[13].Text:='Valeur UF';
     TableauUniteFonds.Cols[14].Text:='Mode.Paie.';
     TableauUniteFonds.Cols[15].Text:='Num.Pičce';
     TableauUniteFonds.Cols[16].Text:='Domciliation';
     TableauUniteFonds.Cols[17].Text:='Nbr.Sortant';
     TableauUniteFonds.Cols[18].Text:='Nbr.Entrant';
     TableauUniteFonds.Cols[19].Text:='Montant';
     TableauUniteFonds.RowCount:=2;
     TableauUniteFonds.Rows[1].Text:='';

     MemoCummulUniteFonds.Text:='';

     FichierConcerne:='FPrelevementUniteFonds';

     if(NumPrelevement<>'')then
     begin
          DateIn:='';
          HeureIn:='';
          DatePrelevement:='';
          HeurePrelevement:='';
          OpenFParc(RParc);
          ChPrelevement:=RParc.Parcours+'\'+Exercice+'FPrelevement';
          assignfile(FPrelevement,ChPrelevement);
          if FileExists(ChPrelevement)then
          Reset(FPrelevement)
          else Rewrite(FPrelevement);
          Seek(FPrelevement,strtointeger(NumPrelevement));
          if not eof(FPrelevement)then
          begin
               read(FPrelevement,RPrelevement);
               if(RPrelevement.Archiver=false)
               then FichierConcerne:='FPrelevementUniteFonds'
               else FichierConcerne:='FArchivePrelevementUniteFonds';

               DatePrelevement:=RPrelevement.DatePrelevement;
               HeurePrelevement:=RPrelevement.HeurePrelevement;
          end;
          CloseFile(FPrelevement);

          ///////////////////////////////////////////////////////////////////////////

          OpenFParc(RParc);
          ChPrelevementUniteFonds:=RParc.Parcours+'\'+Exercice+FichierConcerne;
          assignfile(FPrelevementUniteFonds,ChPrelevementUniteFonds);
          if FileExists(ChPrelevementUniteFonds)then
          Reset(FPrelevementUniteFonds)
          else Rewrite(FPrelevementUniteFonds);
          Seek(FPrelevementUniteFonds,0);
          NbrUF:=0;
          NbrTiers:=0;
          SigleDevise:='';
          while not eof(FPrelevementUniteFonds)do
          begin
               read(FPrelevementUniteFonds,RPrelevementUniteFonds);
               if(RPrelevementUniteFonds.NumPrelevement=strtointeger(NumPrelevement))
               then
               begin
                    if(RPrelevementUniteFonds.ValeurPrecise=true)
                    and(RPrelevementUniteFonds.CodeTiers<>'')
                    then
                    begin
                         if(CodeTiers='')then
                         begin
                              OKTiers:=false;
                              R:=1;
                              while(R<=NbrTiers)and(OKTiers=false)do
                              begin
                                   if(TableauTiers.Cells[1,R]=RPrelevementUniteFonds.CodeTiers)then OKTiers:=true;
                              R:=R+1;
                              end;

                              if(OKTiers=false)then
                              begin
                                   NbrTiers:=NbrTiers+1;
                                   TableauTiers.Rows[NbrTiers].Text:=inttostr(NbrTiers);
                                   TableauTiers.Cells[1,NbrTiers]:=RPrelevementUniteFonds.CodeTiers;
                                   TableauTiers.Cells[2,NbrTiers]:=ImporteDataProcesTiers(RPrelevementUniteFonds.TypeProces,RPrelevementUniteFonds.FichierConcerne,RPrelevementUniteFonds.CodeTiers);
                              end;
                         OKTiers:=true;
                         end
                         else
                         begin
                              if(CodeTiers=RPrelevementUniteFonds.CodeTiers)then
                              begin
                                   OKTiers:=true;
                                   if(TableauTiers.Cells[1,1]='')then
                                   begin
                                        TableauTiers.Rows[1].Text:=inttostr(1);
                                        TableauTiers.Cells[1,1]:=RPrelevementUniteFonds.CodeTiers;
                                        TableauTiers.Cells[2,1]:=ImporteDataProcesTiers(RPrelevementUniteFonds.TypeProces,RPrelevementUniteFonds.FichierConcerne,RPrelevementUniteFonds.CodeTiers);
                                   end;
                              end
                              else OKTiers:=false;
                         end;

                         if(OKTiers=true)then
                         begin
                              NbrUF:=NbrUF+1;
                              TableauUniteFonds.Rows[NbrUF].Text:=inttostr(NbrUF);
                              TableauUniteFonds.Cells[1,NbrUF]:=inttostr(RPrelevementUniteFonds.NumPrelevement);
                              TableauUniteFonds.Cells[2,NbrUF]:=RPrelevementUniteFonds.CodeUtilisateur;
                              TableauUniteFonds.Cells[3,NbrUF]:=inttostr(RPrelevementUniteFonds.NumEquipe);
                              TableauUniteFonds.Cells[4,NbrUF]:=RPrelevementUniteFonds.DatePrelevement;
                              TableauUniteFonds.Cells[5,NbrUF]:=RPrelevementUniteFonds.HeurePrelevement;
                              TableauUniteFonds.Cells[6,NbrUF]:=inttostr(RPrelevementUniteFonds.NumUniteFonds);
                              RUniteFonds:=ChercherUniteFonds(inttostr(RPrelevementUniteFonds.NumUniteFonds));
                              TableauUniteFonds.Cells[7,NbrUF]:=inttostr(RUniteFonds.NumTypeUniteFonds);
                              RTypeUniteFonds:=ChercherTypeUniteFonds(inttostr(RUniteFonds.NumTypeUniteFonds));
                              TableauUniteFonds.Cells[8,NbrUF]:=RTypeUniteFonds.DesignationTypeUniteFonds;
                              TableauUniteFonds.Cells[9,NbrUF]:=RUniteFonds.DesignationUniteFonds;
                              TableauUniteFonds.Cells[10,NbrUF]:=booleantostr(RUniteFonds.ValeurPrecise);
                              TableauUniteFonds.Cells[11,NbrUF]:=RUniteFonds.TypeProces;
                              TableauUniteFonds.Cells[12,NbrUF]:=RUniteFonds.FichierConcerne;
                              TableauUniteFonds.Cells[13,NbrUF]:=floattostr(RUniteFonds.ValeurMonetaireUnitaire);
                              TableauUniteFonds.Cells[14,NbrUF]:=RPrelevementUniteFonds.ModePaiement;
                              TableauUniteFonds.Cells[15,NbrUF]:=RPrelevementUniteFonds.NumPiece;
                              TableauUniteFonds.Cells[16,NbrUF]:=RPrelevementUniteFonds.Domiciliation;

                              if(RPrelevementUniteFonds.ValeurPrelevement<0)
                              then begin ACol:=17; Signe:=-1;end
                              else begin ACol:=18; Signe:=1;end;

                              if(RPrelevementUniteFonds.ValeurPrecise=true)
                              then TableauUniteFonds.Cells[ACol,NbrUF]:=Vergule(Floattostr(RPrelevementUniteFonds.ValeurPrelevement*Signe),'2','C','')
                              else
                              begin
                                   if(RPrelevementUniteFonds.ValeurPrelevement<>0)
                                   then TableauUniteFonds.Cells[ACol,NbrUF]:=Vergule(Floattostr(RUniteFonds.ValeurMonetaireUnitaire*Signe),'2','C','')
                                   else TableauUniteFonds.Cells[ACol,NbrUF]:='';
                              end;

                              TableauUniteFonds.Cells[19,NbrUF]:=Vergule(Floattostr(RPrelevementUniteFonds.ValeurPrelevement*RUniteFonds.ValeurMonetaireUnitaire),'2','C','');

                              if(SigleDevise<>'?')then
                              begin
                                   if(SigleDevise='')then
                                   begin
                                        SigleDevise:=RUniteFonds.SigleDevise;
                                   end
                                   else
                                   begin
                                        if(SigleDevise<>RUniteFonds.SigleDevise)then SigleDevise:='?';
                                   end;
                              end;
                         end;
                    end;
               end;
          end;
          CloseFile(FPrelevementUniteFonds);
          ///////////////////////////////////////////////////////////////////////////
     end;

     if(NbrUF>0)then TableauUniteFonds.RowCount:=NbrUF+1
                else TableauUniteFonds.RowCount:=2;

     if(NbrTiers>0)then TableauTiers.RowCount:=NbrTiers+1
                   else TableauTiers.RowCount:=2;
     AjusterColWidth(TableauTiers,'','');

     for R:=1 to TableauUniteFonds.ColCount-1 do
     begin
          if strtoreal(TableauUniteFonds.Cells[19,R])>0 then
          MemoCummulUniteFonds.Text:=floattostr(strtoreal(MemoCummulUniteFonds.Text)+strtoreal(TableauUniteFonds.Cells[19,R]));
     end;

     if(SigleDevise='?')then SigleDevise:='';

     MemoCummulUniteFonds.Text:=Vergule(MemoCummulUniteFonds.Text,'2','C','')+' '+SigleDevise;

NotCol:='1;2;3;4;5;6;7;8;10;11;12;13;14;15;16';
for C:=0 to TableauUniteFonds.ColCount-1 do
begin
     if existenumintexte(inttostr(C),NotCol)then TableauUniteFonds.ColWidths[C]:=0;
end;
AjusterColWidth(TableauUniteFonds,'',NotCol);
TrierTableauARowSpecial(TableauUniteFonds,1,TableauUniteFonds.RowCount-1,1,'13','Num','-');
end;

