          else FSGenerateurBase.TableauStockArticle.Cells[0,FSGenerateurBase.TableauStockArticle.Row]:='';

          R:=1;                  
          l:=0;
          FSGenerateurBase.EditListeCodeArticle.Text:='';
          FSGenerateurBase.ListeArticleSupp.Text:='';
          while(R<=FSGenerateurBase.TableauStockArticle.RowCount-1)do
          begin
               if(FSGenerateurBase.TableauStockArticle.Cells[0,R]='Supp')then
               begin
                    if(FSGenerateurBase.EditListeCodeArticle.Text='')
                    then FSGenerateurBase.EditListeCodeArticle.Text:=FSGenerateurBase.TableauStockArticle.Cells[1,R]
                    else FSGenerateurBase.EditListeCodeArticle.Text:=FSGenerateurBase.EditListeCodeArticle.Text+';'+FSGenerateurBase.TableauStockArticle.Cells[1,R];

                    l:=l+1;
                    FSGenerateurBase.ListeArticleSupp.Lines.Add(FSGenerateurBase.TableauStockArticle.Cells[1,R]+': '+FSGenerateurBase.TableauStockArticle.Cells[2,R]+' '+FSGenerateurBase.TableauStockArticle.Cells[3,R]+' {'+FSGenerateurBase.TableauStockArticle.Cells[15,R]+'}');
               end;
          R:=R+1;
          end;

          if(l<=1)
          then FSGenerateurBase.NbrArticlesSupp.Caption:=inttostr(l)+' article.'
          else FSGenerateurBase.NbrArticlesSupp.Caption:=inttostr(l)+' articles.';
     end
     else
     begin
