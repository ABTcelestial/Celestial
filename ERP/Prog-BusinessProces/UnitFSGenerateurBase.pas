procedure TFSGenerateurBase.EditTypeStockChange(Sender: TObject);
var TypeProces,FichierConcerne,Adresse:string;
begin
     FSGenerateurBase.EditNumProjet.Text:='';
     FSGenerateurBase.EditNomProjet.Text:='';

     if(FSGenerateurBase.EditTypeStock.Text='Marche')
     then FSGenerateurBase.EditTypeComptabilite.Text:=FSGenerateurBase.EditTypeStock.Text
     else FSGenerateurBase.EditTypeComptabilite.Text:='PlanComptable';

     TypeProces:='Commercial';   FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     ChStockArticle:=Adresse;
     ProcAfficheListeStock(FSGenerateurBase.TableauStockArticle,ChStockArticle,'','','',FSGenerateurBase.RBAvecCodeBarre.Checked);
     FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=ChStockArticle;

     if(FSGenerateurBase.EditTypeStock.Text='Marche')then
     begin
          FSGenerateurBase.EditChoisPrix.Items.Text:='';
          FSGenerateurBase.EditChoisPrix.Items.Add('Prix Marchť');
          FSGenerateurBase.EditChoisPrix.Items.Add('Prix Soutraitance');
          FSGenerateurBase.EditChoisPrix.Items.Add('Prix Attache');
          FSGenerateurBase.EditChoisPrix.Items.Add('CoŻt Unitaire');

          FSGenerateurBase.TitreEditPrixVente.Caption:='Prix Marchť';
          FSGenerateurBase.TitreEditPrixVenteGros.Caption:='Prix Soutraitance';
          FSGenerateurBase.TitreEditPrixVenteDemiGros.Caption:='Prix Attache';
     end
     else
     begin
          FSGenerateurBase.EditChoisPrix.Items.Text:='';
          FSGenerateurBase.EditChoisPrix.Items.Add('Prix de vente dťtail');
          FSGenerateurBase.EditChoisPrix.Items.Add('Prix de vente gros');
          FSGenerateurBase.EditChoisPrix.Items.Add('Prix de vente Demi-gros');
          FSGenerateurBase.EditChoisPrix.Items.Add('Prix d''achat');

          FSGenerateurBase.TitreEditPrixVente.Caption:='Prix de vente:';
          FSGenerateurBase.TitreEditPrixVenteGros.Caption:='Prix de vente G.';
          FSGenerateurBase.TitreEditPrixVenteDemiGros.Caption:='Prix de vente D.G.';
     end;

     FSGenerateurBase.EditChoisPrix.ItemIndex:=0;
end;

