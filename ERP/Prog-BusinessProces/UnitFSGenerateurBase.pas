     if(FSGenerateurBase.PageGenerateurDomiciliation.Visible=true)then ListeDomiciliation(FSGenerateurBase.TableauDomiciliation);
     if(FSGenerateurBase.PageTypeProjet.Visible=true)then ListeTypeProjet(FSGenerateurBase.TableauTypeProjet);

     if(FSGenerateurBase.PageGenerateurCompteur.Visible=true)then ProcAfficheListeCompteur(FSGenerateurBase.TableauCompteur,'',FSGenerateurBase.TableauAffectationCompteur.Cells[1,FSGenerateurBase.TableauAffectationCompteur.Row]);

     if(FSGenerateurBase.PageGenerateurEquipe.Visible=true)then
     begin
          ListeEquipe(FSGenerateurBase.TableauEquipe,'');
          ListeEffectifEquipe(FSGenerateurBase.TableauEffectifEquipe,FSGenerateurBase.TableauEquipe.Cells[1,FSGenerateurBase.TableauEquipe.Row],FSGenerateurBase.RBAfficherUniquementEquipe.Checked);
     end;

     if(FSGenerateurBase.PageGenerateurUniteFonds.Visible=true)then
     begin
          ListeTypeUniteFonds(FSGenerateurBase.TableauTypeUniteFonds);
          ListeUniteFonds(FSGenerateurBase.TableauUniteFonds,'');
     end;

     ListeBaseAvis(FSGenerateurBase.TableauBaseAvis);
     RBaseAvisCopie:=ChercherBaseAvis(FSGenerateurBase.TableauBaseAvis.Cells[1,FSGenerateurBase.TableauBaseAvis.Row],'',Confirmer);

     A:=strtointeger(FSGenerateurBase.EditAnnees.Text);
     for M:=1 to 12 do
     begin
          FSGenerateurBase.TableauPositionAvisParPeriode.Rows[M].Text:=inttostr(M);
          FSGenerateurBase.TableauPositionAvisParPeriode.Cells[1,M]:=inttostr(RBaseAvisCopie.RegistrePositionAvisParPeriode[A,M].PositionAvisBegin);
          FSGenerateurBase.TableauPositionAvisParPeriode.Cells[2,M]:=inttostr(RBaseAvisCopie.RegistrePositionAvisParPeriode[A,M].PositionAvisEnd);
     end;

     if(Confirmer=true)
     then FSGenerateurBase.TableauPositionAvisParPeriode.FixedColor:=clLime
     else FSGenerateurBase.TableauPositionAvisParPeriode.FixedColor:=clBtnFace;

     FSGenerateurBase.EditIBeginMin.Text:=inttostr(IndiquerIBeginMin(RBaseAvisCopie,'01/01/'+FSGenerateurBase.EditAnnees.Text,''));
     FSGenerateurBase.EditIEndMax.Text:=inttostr(IndiquerIEndMax(RBaseAvisCopie,'','31/12/'+FSGenerateurBase.EditAnnees.Text));

