Procedure ProcAfficheListeStock(TableauStock:TStringGrid; AdresseStock,CodeSFamille,CodeArticleRowSelect,ListeCompteConcerne:string; AvecCodeBarre:boolean);
var  k,ARowSelect:integer;
     OKStock:boolean;
     NotCol,TypeData,TypeStock:string;
     TableauRStock:array of RStocks;
     NbrALire,NbrRStockLus,Nbr:integer;

begin
NbrALire:=NombreOptimaleBufferSize('RStock');
SetLength(TableauRStock,NbrALire);

AccelerationAffichageTableau(TableauStock,true);

TypeStock:='Article';
if(ExisteCharinString('Marche',FichierConcerne)=true)then TypeStock:='Marche';

TableauStock.ColCount:=19;
TableauStock.Cols[0].Text:='Nį';
TableauStock.Cols[1].Text:='Code';
TableauStock.Cols[2].Text:='Dťsignation';
TableauStock.Cols[3].Text:='Rťference';
TableauStock.Cols[4].Text:='UM';
TableauStock.Cols[5].Text:='Qte.Entrťe';
TableauStock.Cols[6].Text:='Qte.Sortie';
TableauStock.Cols[7].Text:='Qte en Stock';
TableauStock.Cols[8].Text:='Qte.Initial';
TableauStock.Cols[9].Text:='Qte.Limite';

if(TypeStock='Marche')
then TableauStock.Cols[10].Text:='CoŻt Unitaire'
else TableauStock.Cols[10].Text:='Prix d''Achat';

if(TypeStock='Marche')
then TableauStock.Cols[11].Text:='Prix Marchť'
else TableauStock.Cols[11].Text:='P.V.D';

if(TypeStock='Marche')
then TableauStock.Cols[12].Text:='Prix Soutraitance'
else TableauStock.Cols[12].Text:='P.V.G';

if(TypeStock='Marche')
then TableauStock.Cols[13].Text:='Prix Attache'
else TableauStock.Cols[13].Text:='P.V.D.G';

TableauStock.Cols[14].Text:='Emplacement';
TableauStock.Cols[15].Text:='Code barre';
TableauStock.Cols[16].Text:='Formule';
TableauStock.Cols[17].Text:='Observation';
TableauStock.Cols[18].Text:='Enreg';

TableauStock.RowCount:=2;
TableauStock.Rows[1].Text:='';

ChStock:=AdresseStock;
assignfile(FStock,ChStock);
try
if FileExists(ChStock)then
Reset(FStock)
else Rewrite(FStock);
Seek(FStock,0);
k:=0;
ARowSelect:=1;
while not eof(FStock)do
begin
     //read(FStock,RStock);

     BlockRead(FStock,TableauRStock[0],NbrALire,NbrRStockLus);

     Nbr:=0;
     while Nbr<=NbrRStockLus-1 do
     begin
          RStock:=TableauRStock[Nbr];
     if(CodeSFamille<>'')then
     begin
          if(Firstlaters(RStock.Code,longueur(CodeSFamille))=CodeSFamille)
          then OKStock:=true
          else OKStock:=false;
     end
     else OKStock:=true;

     if(OKStock=true)then
     begin
          if(ListeCompteConcerne<>'')then
          begin
               if ExisteFirstLatersNuminTexte(RStock.Code,ListeCompteConcerne)
               then OKStock:=true
               else OKStock:=false;
          end;
     end;

     if(OKStock=true)then
     begin
          if(AvecCodeBarre=true)then
          begin
               OKStock:=CodeBareCorrecte(RStock.Code,RStock.CodeBarre);
          end;
     end;

     if(OKStock=true)then
     begin
          k:=k+1;
          TableauStock.Rows[k].Text:=inttostr(k);
          TableauStock.Cells[1,k]:=RStock.Code;
          TableauStock.Cells[2,k]:=RStock.Design;
          TableauStock.Cells[3,k]:=RStock.Ref;
          TableauStock.Cells[4,k]:=RStock.UM;
          TableauStock.Cells[5,k]:=Vergule(floattostr(RStock.QteEntree),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[6,k]:=Vergule(floattostr(RStock.QteSortie),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[7,k]:=Vergule(floattostr(RStock.QteStock),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[8,k]:=Vergule(floattostr(RStock.QteInitial),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[9,k]:=Vergule(floattostr(RStock.QteLimite),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[10,k]:=Vergule(floattostr(RStock.CoutUnitaire),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[11,k]:=Vergule(floattostr(RStock.PrixVenteDetaille),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[12,k]:=Vergule(floattostr(RStock.PrixVenteGros),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[13,k]:=Vergule(floattostr(RStock.PrixVenteDemiGros),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[14,k]:=RStock.Emplace;
          TableauStock.Cells[15,k]:=RStock.CodeBarre;
          TableauStock.Cells[16,k]:=RStock.Formule;
          TableauStock.Cells[17,k]:=RStock.Observ;
          TableauStock.Cells[18,k]:=RStock.enregistrement;
     end;
     Nbr:=Nbr+1;
     end;
end;
finally
closefile(FStock);
end;

if(k>0)then TableauStock.RowCount:=k+1
       else TableauStock.RowCount:=2;

if(TypeStock='Marche')
then NotCol:='5-9;14;16;17;18'
else NotCol:='14;16;17;18';

for k:=1 to TableauStock.ColCount-1 do if existenumintexte(inttostr(k),NotCol)then TableauStock.ColWidths[k]:=0;
AjusterColWidth(TableauStock,'',NotCol);
if(TableauStock.ColWidths[2]>500)then TableauStock.ColWidths[2]:=500;

if(FSGenerateurBase.EditRubriqueTrie.Text<>'1')then
begin
     TypeData:='';
     if strtointeger(FSGenerateurBase.EditRubriqueTrie.Text)in[1,5,6,7,8,9,10,11,12,13,15]then TypeData:='Num';
     TrierTableauARowSpecial(TableauStock,1,TableauStock.RowCount-1,1,FSGenerateurBase.EditRubriqueTrie.Text,TypeData,FSGenerateurBase.EditTypeTrie.Text);
end;

if(CodeArticleRowSelect<>'')then
begin
     K:=1;
     while(K<=TableauStock.RowCount-1)and(CodeArticleRowSelect<>'')do
     begin
          if(TableauStock.Cells[1,k]=CodeArticleRowSelect)then
          begin
               ARowSelect:=k;
               CodeArticleRowSelect:='';
          end;
     K:=K+1;
     end;
end;

TableauStock.Row:=ARowSelect;

AccelerationAffichageTableau(TableauStock,false);
if(FSGenerateurBase.AfficheRegularisationCoutValeurAjouter.Visible=false)then TableauStock.SetFocus;
end;

Procedure ProcAfficheListeCompteur(TableauCompteur:TStringGrid; CodeArticle,NumAffectationCompteur:string);
var  k,C:integer; OKCompteur:boolean;  NotCol,UniM,CodeStockArticle:string;
begin
TableauCompteur.ColCount:=11;
TableauCompteur.Cols[0].Text:='';
TableauCompteur.Cols[1].Text:='Num';
