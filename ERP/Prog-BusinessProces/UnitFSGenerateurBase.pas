                          if(OKProjetFinance=true)then
                          begin
                                if(FunctStockSpecifierParStructure(false)=true)then
                                begin
                                     NumStructure:=IndiqueNumStructurePrelevement(RArchivePrelevementCompteur.NumPrelevement);

                                     if(NumStructure=NumProjetStockArticle)
                                     then OKProjetFinance:=true
                                     else OKProjetFinance:=false;
                                end
                                else
                                begin
                                     OKProjetFinance:=true;
                                     NumStructure:=NumProjetStockArticle;
                                end;
                          end;

                          if(OKProjetFinance=true)then
                          begin
                               if(stringtodate(RArchivePrelevementCompteur.DatePrelevement,RArchivePrelevementCompteur.DatePrelevement)>=stringtodate(DateDebutPeriodeAnalysePrelevement,DateDebutPeriodeAnalysePrelevement))
                               and(stringtodate(RArchivePrelevementCompteur.DatePrelevement,RArchivePrelevementCompteur.DatePrelevement)<=stringtodate(DateFinPeriodeAnalysePrelevement,DateFinPeriodeAnalysePrelevement))
                               then OKProjetFinance:=true
                               else OKProjetFinance:=false;
                          end;

                          if(OKProjetFinance=true)then
                          begin
                               //RStock:=ChercherStockArticle('Article',NumStructure,RArchivePrelevementCompteur.CodeArticle,'',OKStockRecherche,RubriqueRecherche);

                               if(RArchivePrelevementCompteur.ValeurMouvement>0)then
                               begin
                                    SigneMouvement:='+';

                                    EtatEntreeSortie:='';
                                    if(SigneMouvement='+')then EtatEntreeSortie:='E';
                                    if(SigneMouvement='-')then EtatEntreeSortie:='S';

