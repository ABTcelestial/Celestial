Function ExisteQteForfaitaire(TableauQuantiteForfait:TStringGrid; CodeArticle,TypeStock,NumProjetFinance:string; var NbrQuantite:integer; var QuantiteForfait,PrixUnitaire:real; var DesignationQteForfait,UnitM:string):boolean;
var  R:integer; OKArticle:boolean;
begin
     DesignationQteForfait:='';
     QuantiteForfait:=0;
     PrixUnitaire:=0;
     UnitM:='';
     NbrQuantite:=0;

     TableauQuantiteForfait.ColCount:=5;
     TableauQuantiteForfait.Cols[0].Text:='Nį';
     TableauQuantiteForfait.Cols[1].Text:='Dťsignation Quantitť';
     TableauQuantiteForfait.Cols[2].Text:='Valeur';
     TableauQuantiteForfait.Cols[3].Text:='U.M';
     TableauQuantiteForfait.Cols[4].Text:='Prix';

     TableauQuantiteForfait.RowCount:=2;
     TableauQuantiteForfait.Rows[1].Text:='';

     TypeProces:='Commercial';
     FichierConcerne:='FQteforfaitStock';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
                 //AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     ChQteforfaitStock:=Adresse;
     assignfile(FQteforfaitStock,ChQteforfaitStock);
     try
     if FileExists(ChQteforfaitStock)then
     Reset(FQteforfaitStock)
     else Rewrite(FQteforfaitStock);
     Seek(FQteforfaitStock,0);
     OKArticle:=false;
     R:=0;
     while not eof(FQteforfaitStock)do
     begin
          read(FQteforfaitStock,RQteforfaitStock);

          if(RQteforfaitStock.CodeArticle=CodeArticle)
          and(RQteforfaitStock.TypeStockQteForfait=TypeStock)
          and(RQteforfaitStock.NumProjetFinanceQteForfait=NumProjetFinance)
          then
          begin
               OKArticle:=true;
               NbrQuantite:=NbrQuantite+1;
               R:=R+1;
               TableauQuantiteForfait.Rows[R].Text:=inttostr(R);
               TableauQuantiteForfait.Cells[1,R]:=RQteforfaitStock.DesignationQteForfait;
               TableauQuantiteForfait.Cells[2,R]:=floattostr(RQteforfaitStock.Qteforfait);
               TableauQuantiteForfait.Cells[3,R]:=RQteforfaitStock.UMQteforfait;
               TableauQuantiteForfait.Cells[4,R]:=floattostr(RQteforfaitStock.PrixQteforfait);
          end;
     end;
     finally
     CloseFile(FQteforfaitStock);
     end;

     ExisteQteForfaitaire:=OKArticle;

     if(R>0)then TableauQuantiteForfait.RowCount:=R+1
            else TableauQuantiteForfait.RowCount:=2;

     AjusterColWidth(TableauQuantiteForfait,'','');

     DesignationQteForfait:=TableauQuantiteForfait.Cells[1,1];
     QuantiteForfait:=strtoreal(TableauQuantiteForfait.Cells[2,1]);
     UnitM:=TableauQuantiteForfait.Cells[3,1];
     PrixUnitaire:=strtoreal(TableauQuantiteForfait.Cells[4,1]);
end;

