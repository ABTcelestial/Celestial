begin

     if(FSGenerateurBase.AfficheOptionArticle.Visible=true)
     and(FSGenerateurBase.RBMultiSupprime.Checked=true)
     then
     begin
          if(FSGenerateurBase.TableauStockArticle.Cells[0,FSGenerateurBase.TableauStockArticle.Row]='')
