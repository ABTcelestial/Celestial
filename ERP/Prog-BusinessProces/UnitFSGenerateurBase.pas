     if(FSGenerateurBase.TableauAdresseProces.Cells[5,FSGenerateurBase.TableauAdresseProces.Row]='Auto')then
     begin
          FSGenerateurBase.RBExerciceAutomatique.Checked:=true;
     end
     else
     begin
          FSGenerateurBase.RBExerciceAutomatique.Checked:=false;
     end;

     FSGenerateurBase.EditExercice.Text:=FSGenerateurBase.TableauAdresseProces.Cells[5,FSGenerateurBase.TableauAdresseProces.Row];
     FSGenerateurBase.EditExercice.ReadOnly:=FSGenerateurBase.RBExerciceAutomatique.Checked;
     FSGenerateurBase.EditFichierConcerneAdresseProcecs.Text:=FSGenerateurBase.TableauAdresseProces.Cells[6,FSGenerateurBase.TableauAdresseProces.Row];

     if key in['m','M']then
     begin
          FSGenerateurBase.BitValiderAdresseProces.Kind:=bkAll;
          FSGenerateurBase.BitValiderAdresseProces.Caption:='Valider';
          FSGenerateurBase.EditTypeProces.SetFocus;
     end;

     if key in['s','S']then
