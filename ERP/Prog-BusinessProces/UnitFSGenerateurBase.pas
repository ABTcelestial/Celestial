procedure TFSGenerateurBase.TableauStockArticleKeyPress(Sender: TObject;
  var Key: Char);
var l:integer;  TypeProces,FichierConcerne,Adresse,Action:string; 
begin

if key in['r','R','?']then
begin
     FSGenerateurBase.AfficheOptionCompteConcerne.Visible:=true;
     FSGenerateurBase.EditRecherche.SetFocus;
     FSGenerateurBase.EditRecherche.Text:='';
     Exit;
end;

if key in['s','S','m','M','n','N']then
begin
     if key in['s','S']then Action:='suppression';
     if key in['m','M']then Action:='modification';
     if key in['n','N']then Action:='Ajout';
     if(FSGenerateurBase.EditNumProjet.Text<>'')
     and(FunctCreationStockLibre=false)then begin AfficherMessage('Attention ! '+Action+' de stock par structure non autorisť !'); Exit; end;
end;

if key in['n','N']then
begin
     TypeProces:='Commercial';
     FichierConcerne:='';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          showmessage('Gťnťration locale !');
          FSGenerateurBase.AfficheProduits.Visible:=true;
          FSGenerateurBase.BitValiderProduit.Kind:=bkAll;
          FSGenerateurBase.BitValiderProduit.Caption:='Valider';

          FSGenerateurBase.NomSFl.Caption:='Ajouter un produit: ';
          InitialisationFicheSaisieProduit;
          FSGenerateurBase.EditCodeProduit.SetFocus;
          exit;
     end;
     showmessage('Gťnťration externe !');
     FichierConcerne:=Adresse+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     FSGenerateurBase.AfficheStock.Visible:=true;
     ProcAfficheListeStock(FSGenerateurBase.TableauStock,FichierConcerne,'','','',FSGenerateurBase.RBAvecCodeBarre.Checked);
     FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=FichierConcerne;
     FSGenerateurBase.TableauStock.SetFocus;
     Exit;
end;

if key in['m','M']then
begin

FSGenerateurBase.AfficheProduits.Visible:=true;
FSGenerateurBase.BitValiderProduit.Kind:=bkRetry;
FSGenerateurBase.BitValiderProduit.Caption:='Modifier';
FSGenerateurBase.EditCodeProduit.SetFocus;

