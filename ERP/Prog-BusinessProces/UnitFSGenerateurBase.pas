                          end
                          else OKMAJ:=true;

                          if (OKMAJ=true)
                          and((RArchivePrelevementCompteur.ValeurMouvement<>0)or(RArchivePrelevementCompteur.ValeurPrelevement<>RArchivePrelevementCompteur.ValeurInitiale))
                          then OKProjetFinance:=true
