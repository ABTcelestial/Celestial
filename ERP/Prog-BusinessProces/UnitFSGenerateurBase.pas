var  R:integer;  CoutRegularisation,PrixRegularisation:real;
begin
     if(FSGenerateurBase.RBRegularisationTableau.Checked=true)then
     begin
          if(FSGenerateurBase.BitConfirmerRegularisation.Caption='Confirmer la Rťgularisation du coŻt des articles sťlectionnťs')then
          begin
               RegulariserCoutStockTableau(FSGenerateurBase.TableauStockArticleRegularisation);
