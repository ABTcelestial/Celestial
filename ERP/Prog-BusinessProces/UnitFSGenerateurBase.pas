Procedure MiseAJourStockPublicationReseauxEntrante(CodeSFamille,DateDebutMAJ,TypeStock,NumProjet:string);
var  TableauListeFPR:ArrayListeFichierPartageReseaux; TailTFPR:integer;
     FichierConcerne,FichierConcerneDetailMouvement,DesignationTypeMouvement:string;
     OKTypeMouvement:boolean;
begin
     FSMenuPrincipal.EditRapport.Lines.Add('');
     FSMenuPrincipal.EditRapport.Lines.Add('...');
     FSMenuPrincipal.EditRapport.Lines.Add('');
     FSMenuPrincipal.EditDetailRapport.Lines.Text:='';
     FSMenuPrincipal.AfficheRapport.Visible:=FunctAfficherRapportPublicationReseaux;

     TypeProces:='Commercial';   FichierConcerne:='FStock'+TypeStock+NumProjet;
     if (FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(TypeProcesReseaux='Rťseaux')then
          begin
               FSMenuPrincipal.EditRapport.Lines.Add('Source Stock rťseaux, aucune Mises ŗ jour du Stock publication rťseaux ŗ opťrť');
               FSMenuPrincipal.EditRapport.Lines.Add('');
               Exit;
          end;
     end;

     FSMenuPrincipal.EditRapport.Lines.Add('Chercher des Mises ŗ jour du Stock publication rťseaux');
     FSMenuPrincipal.EditRapport.Lines.Add('');

     OpenFParc(RParc);
     ChAdresseProces:=RParc.Parcours+'\'+Exercice+'FAdresseProces';
     assignfile(FAdresseProces,ChAdresseProces);
     if FileExists(ChAdresseProces)then
     begin
          try
          Reset(FAdresseProces);
          Seek(FAdresseProces,0);
          while not eof(FAdresseProces)do
          begin
                read(FAdresseProces,RAdresseProces);

                if(RAdresseProces.TypeProces='Rťseaux')then
                begin
                     if ExisteFichierDetailMouvementInListeFichierConcernePartageReseaux(inttostr(RAdresseProces.NumAdresseProces),RListeFichierConcernePartageReseauxCopie,TableauListeFPR,TailTFPR)then
                     begin
                          FichierConcerneDetailMouvement:=RListeFichierConcernePartageReseauxCopie.FichierConcerne;
                          DesignationTypeMouvement:=Lastlaters(FichierConcerneDetailMouvement,longueur(RListeFichierConcernePartageReseauxCopie.FichierConcerne)-16);

                          TypeProces:='Business';   FichierConcerne:='FTypeMouvement';
                          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                          begin
                               if(FichierConcerne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
                          end;

                          ChTypeMouvement:=Adresse;
                          assignfile(FTypeMouvement,ChTypeMouvement);
                          if FileExists(ChTypeMouvement)then
                          begin
                               try
                               Reset(FTypeMouvement);
                               Seek(FTypeMouvement,0);
                               OKTypeMouvement:=false;
                               while(not eof(FTypeMouvement)and(OKTypeMouvement=false))do
                               begin
                                    Read(FTypeMouvement,RTypeMouvement);

                                    if(RTypeMouvement.DesignationTypeMouvement=DesignationTypeMouvement)then
                                    begin
                                         OKTypeMouvement:=true;
                                         FSMenuPrincipal.EditRapport.Lines.Add('Mise ŗ jour Stock publication rťseaux '+FichierConcerneDetailMouvement);
                                         MiseAJourStockPublicationDetailMouvement(FichierConcerneDetailMouvement,RTypeMouvement.SigneTypeMouvement,CodeSFamille,DateDebutMAJ);
                                    end;
                               end;
                               finally
                               CloseFile(FTypeMouvement);
                               end;
                          end;
                     end;
                end;
          end;
          finally
          CloseFile(FAdresseProces)
          end;
     end;

     if(OKTypeMouvement=true)
     then FSMenuPrincipal.EditRapport.Lines.Add('Fin de la Mise ŗ jour Stock publication rťseaux.')
     else FSMenuPrincipal.EditRapport.Lines.Add('Aucune Mise ŗ jour du Stock publication rťseaux opťrť !')
end;

