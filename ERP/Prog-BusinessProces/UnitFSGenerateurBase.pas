Procedure ProcListeQteForfaitStock(TableauQteFoarfaitStock:TStringGrid; CodeStock:string);
var  R,C:integer;  OKArticle,OKStockArticleRecherche:boolean; RubriqueRecherche,NotRow,NotCol:string;
begin
     TableauQteFoarfaitStock.ColCount:=10;
     TableauQteFoarfaitStock.Cols[0].Text:='Nį';
     TableauQteFoarfaitStock.Cols[1].Text:='PįQte';
     TableauQteFoarfaitStock.Cols[2].Text:='Code';
     TableauQteFoarfaitStock.Cols[3].Text:='Article';
     TableauQteFoarfaitStock.Cols[4].Text:='Dťsignation Qte';
     TableauQteFoarfaitStock.Cols[5].Text:='Valeur';
     TableauQteFoarfaitStock.Cols[6].Text:='U.M';
     TableauQteFoarfaitStock.Cols[7].Text:='Prix';
     TableauQteFoarfaitStock.Cols[8].Text:='TypeStock';
     TableauQteFoarfaitStock.Cols[9].Text:='NumProjetFinance';

     TableauQteFoarfaitStock.RowCount:=2;
     TableauQteFoarfaitStock.Rows[1].Text:='';

     TypeProces:='Commercial';
     FichierConcerne:='FQteforfaitStock';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
                 //AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     ChQteforfaitStock:=Adresse;
     assignfile(FQteforfaitStock,ChQteforfaitStock);
     try
     if FileExists(ChQteforfaitStock)then
     Reset(FQteforfaitStock)
     else Rewrite(FQteforfaitStock);
     Seek(FQteforfaitStock,0);
     R:=0;
     while not eof(FQteforfaitStock)do
     begin
          read(FQteforfaitStock,RQteforfaitStock);

          if(CodeStock<>'')then
          begin
               if(RQteforfaitStock.CodeArticle=CodeStock)
               then OKArticle:=true
               else OKArticle:=false;
          end
          else OKArticle:=true;

          if(OKArticle=true)then
          begin
               RStockArticleCopie:=ChercherStockArticle(RQteforfaitStock.TypeStockQteForfait,RQteforfaitStock.NumProjetFinanceQteForfait,RQteforfaitStock.CodeArticle,'',OKStockArticleRecherche,RubriqueRecherche);
               R:=R+1;
               TableauQteFoarfaitStock.Rows[R].Text:=inttostr(R);
               TableauQteFoarfaitStock.Cells[1,R]:=inttostr(RQteforfaitStock.PositionQteforfait);
               TableauQteFoarfaitStock.Cells[2,R]:=RQteforfaitStock.CodeArticle;
               TableauQteFoarfaitStock.Cells[3,R]:=RStockArticleCopie.Design+' '+RStockArticleCopie.Ref;
               TableauQteFoarfaitStock.Cells[4,R]:=RQteforfaitStock.DesignationQteForfait;
               TableauQteFoarfaitStock.Cells[5,R]:=Floattostr(RQteforfaitStock.Qteforfait);
               TableauQteFoarfaitStock.Cells[6,R]:=RQteforfaitStock.UMQteforfait;
               TableauQteFoarfaitStock.Cells[7,R]:=Floattostr(RQteforfaitStock.PrixQteforfait);
               TableauQteFoarfaitStock.Cells[8,R]:=RQteforfaitStock.TypeStockQteForfait;
               TableauQteFoarfaitStock.Cells[9,R]:=RQteforfaitStock.NumProjetFinanceQteForfait;
          end;
     end;
     finally
     CloseFile(FQteforfaitStock);
     end;

     if(R>0)then TableauQteFoarfaitStock.RowCount:=R+1
            else TableauQteFoarfaitStock.RowCount:=2;

     NotRow:='';
     if(CodeStock<>'')then NotCol:='1;2;3;8;9'
                      else NotCol:='1;8;9';

     for C:=0 to TableauQteFoarfaitStock.ColCount-1 do if ExisteNuminTexte(inttostr(C),NotCol)then TableauQteFoarfaitStock.ColWidths[C]:=0;
     AjusterColWidth(TableauQteFoarfaitStock,NotRow,NotCol);
end;

procedure TFSGenerateurBase.BitValiderAfficheOptionAfficheQteForfaitClick(
  Sender: TObject);
var  i,iSelect,RExistant,RSupprimer,RSauvgarder:integer; OKArticle:boolean;
begin
     if(FSGenerateurBase.BitValiderAfficheOptionAfficheQteForfait.Caption='Valider')then
     begin
           TypeProces:='Commercial';
           FichierConcerne:='FQteforfaitStock';
           Adresse:='';
           if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
           begin
                 //AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
           end;

           ChQteforfaitStock:=Adresse;
           assignfile(FQteforfaitStock,ChQteforfaitStock);
           try
           if FileExists(ChQteforfaitStock)then
           Reset(FQteforfaitStock)
           else Rewrite(FQteforfaitStock);
           Seek(FQteforfaitStock,0);
           OKArticle:=false;
           i:=0;
           iSelect:=0;
           while not eof(FQteforfaitStock)and(OKArticle=false)do
           begin
                read(FQteforfaitStock,RQteforfaitStock);

                if(FSGenerateurBase.EditPositionQteforfait.Text<>'')
                and(RQteforfaitStock.PositionQteforfait=strtointeger(FSGenerateurBase.EditPositionQteforfait.Text))
                then
                begin
                     OKArticle:=true;
                     iSelect:=i;
                end;
                i:=i+1;
           end;

           if(OKArticle=true)then i:=iSelect;
           RQteforfaitStock.PositionQteforfait:=i;
           RQteforfaitStock.CodeArticle:=FSGenerateurBase.EditCodeQteForfait.Text;
           RQteforfaitStock.DesignationQteForfait:=FSGenerateurBase.EditDesignationQteForfait.Text;
           RQteforfaitStock.Qteforfait:=strtoreal(FSGenerateurBase.EditValeurQteForfait.Text);
           RQteforfaitStock.UMQteforfait:=WithoutChar(Firstlaters(FSGenerateurBase.EditUMQteForfait.Text,3),' ');
           RQteforfaitStock.PrixQteforfait:=strtoreal(FSGenerateurBase.EditPrixUQteForfait.Text);
           RQteforfaitStock.TypeStockQteForfait:=FSGenerateurBase.EditTypeStockQteForfait.Text;
           RQteforfaitStock.NumProjetFinanceQteForfait:=FSGenerateurBase.EditNumProjetFinanceQteForfait.Text;
           Seek(FQteforfaitStock,i);
           write(FQteforfaitStock,RQteforfaitStock);

           finally
           CloseFile(FQteforfaitStock);
           end;
     end;

     if(FSGenerateurBase.BitValiderAfficheOptionAfficheQteForfait.Caption='Supprimer')then
     begin
          SupprimerFQteforfaitStock(FSGenerateurBase.EditPositionQteforfait.Text,RExistant,RSupprimer,RSauvgarder);
     end;

     FSGenerateurBase.AfficheOptionAfficheQteForfait.Visible:=false;
     ProcListeQteForfaitStock(FSGenerateurBase.TableauQteForfaitStock,FSGenerateurBase.EditCodeQteForfait.Text);
     FSGenerateurBase.TableauQteForfaitStock.SetFocus;
end;

