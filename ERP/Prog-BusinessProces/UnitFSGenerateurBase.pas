     FSGenerateurBase.AfficheOptionArticle.Visible:=true;
     FSGenerateurBase.AfficheOptionArticle.Caption:='Supprimer l''Article Sťlectionnť !';
     FSGenerateurBase.BitOptionArticle.Kind:=bkCancel;
     FSGenerateurBase.BitOptionArticle.Caption:='Supprimer';
     FSGenerateurBase.BitOptionArticle.SetFocus;
     Exit;
end;

if key in['l','L']then
begin
     FSGenerateurBase.AfficheSFamille.Visible:=true;
     FSGenerateurBase.EditRequette.Text:='Liste';
     FSGenerateurBase.EditRechercheCodeSFamille.SetFocus;
     Exit;
end;

if key in['f','F']then
begin
     if not AccesPrivilegies('FS Stock',FSMenuPrincipal.EditCodeUtilisateur.Text,'MA',true) then begin key:=#0; exit; end;

     if(FSGenerateurBase.TableauStockArticle.Cells[1,FSGenerateurBase.TableauStockArticle.Row]<>'')then
     begin
          OpenFParc(RParc);
          ChFormuleComposition:=RParc.Parcours+'\'+Exercice+'FFormuleComposition';
          assignfile(FFormuleComposition,ChFormuleComposition);
          try
          if FileExists(ChFormuleComposition)then
          Reset(FFormuleComposition)
          else Rewrite(FFormuleComposition);
          Seek(FFormuleComposition,0);
          l:=0;
          while not eof(FFormuleComposition)do
          begin
               read(FFormuleComposition,RFormuleComposition);
               if(RFormuleComposition.CodeProd=FSFormuleComposition.EditExtentionCodeProduit.Text+FSGenerateurBase.TableauStockArticle.Cells[1,FSGenerateurBase.TableauStockArticle.Row])
               then
               begin
                    l:=l+1;
               end;
          end;
          finally
          closefile(FFormuleComposition);
          end;

          FSGenerateurBase.AfficheConfirmeFormule.Visible:=true;
          FSGenerateurBase.BitOKFormulation.SetFocus;

          if(l=0)then FSGenerateurBase.AfficheConfirmeFormule.Caption:='Pas de Formule';
          if(l=1)then FSGenerateurBase.AfficheConfirmeFormule.Caption:='Une composition';
          if(l>1)then FSGenerateurBase.AfficheConfirmeFormule.Caption:=inttostr(l)+' Compositions';
     end;
     Exit;
end;

if key in['i','I']then
begin
     FSGenerateurBase.RBInitialisationQuatiteEntree.Enabled:=false;
     FSGenerateurBase.RBInitialisationQuatiteSortie.Enabled:=false;
     FSGenerateurBase.RBInitialisationQuatiteStock.Enabled:=false;
     FSGenerateurBase.RBInitialisationQuatiteLimite.Enabled:=false;

     FSGenerateurBase.RBInitialisationQuatiteEntree.Checked:=false;
     FSGenerateurBase.RBInitialisationQuatiteSortie.Checked:=false;
     FSGenerateurBase.RBInitialisationQuatiteStock.Checked:=false;
     FSGenerateurBase.RBInitialisationQuatiteLimite.Checked:=false;

     FSGenerateurBase.AfficheInitialisationDataStock.Visible:=true;
     FSGenerateurBase.RBInitialisationQuatiteInitiale.Checked:=false;
end;

end;

