Procedure ProcAfficheTableauParTypeCol(Tableau:TStringGrid; ColComparer,RowDebutComparer,RowFinComparer:integer; DataComparer:string);
var  R:integer;  RowSelect:string;
begin
     R:=RowDebutComparer;
     RowSelect:='';
     While(R<=Tableau.RowCount-1)and(R<=RowFinComparer)do
     begin
          if(Tableau.Cells[ColComparer,R]=DataComparer)then
          begin
               Tableau.RowHeights[R]:=24;
               if(RowSelect='')then RowSelect:=inttostr(R);
          end
          else
          begin
               Tableau.RowHeights[R]:=0;
          end;
     R:=R+1;
     end;
     if(RowSelect='')then RowSelect:='1';
     Tableau.Row:=strtointeger(RowSelect);
end;

Procedure TotalRubriqueParTypeCol(Tableau:TStringGrid);
var R:integer;
begin
     Tableau.Cells[7,Tableau.RowCount-1]:='';
     R:=1;
     while(R<=Tableau.RowCount-3)do
     begin
          if(Tableau.RowHeights[R]>0)then
          begin
               Tableau.Cells[7,Tableau.RowCount-1]:=floattostr(strtoreal(Tableau.Cells[7,Tableau.RowCount-1])
                                                    +strtoreal(Tableau.Cells[7,R]));
          end;
     R:=R+1;
     end;

     Tableau.Cells[7,Tableau.RowCount-1]:=Vergule(Tableau.Cells[7,Tableau.RowCount-1],'2','C','');
end;

