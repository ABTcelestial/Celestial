procedure TFSGenerateurBase.TableauProjetFinanceContextPopup(
  Sender: TObject; MousePos: TPoint; var Handled: Boolean);
var LongMaxCodeProjet,Rong,PositionIndex,R:integer;  Classement:string;
begin
     if(FSGenerateurBase.TableauProjetFinance.Cells[2,FSGenerateurBase.TableauProjetFinance.Row]<>'')then
     begin
          FSGenerateurBase.AffichePropositionFicheTechnique.Visible:=true;
          FSGenerateurBase.EditCodeProjetPropose.Text:=FSGenerateurBase.TableauProjetFinance.Cells[1,FSGenerateurBase.TableauProjetFinance.Row];
          FSGenerateurBase.EditDesignationProjetPropose.Text:=FSGenerateurBase.TableauProjetFinance.Cells[2,FSGenerateurBase.TableauProjetFinance.Row];
          FSGenerateurBase.TableauFicheTechniquePropose.ColCount:=6;
          FSGenerateurBase.TableauFicheTechniquePropose.RowCount:=2;
          FSGenerateurBase.TableauFicheTechniquePropose.Rows[1].Text:='';

          OpenFParc(RParc);
          ChProjetFinance:=RParc.Parcours+'\'+Exercice+'FProjetFinance';
          assignfile(FProjetFinance,ChProjetFinance);
          try
          if FileExists(ChProjetFinance)then
          Reset(FProjetFinance)
          else Rewrite(FProjetFinance);
          Seek(FProjetFinance,0);
          LongMaxCodeProjet:=0;
          while not eof(FProjetFinance)do
          begin
               read(FProjetFinance,RProjetFinance);
               if(Firstlaters(RProjetFinance.NumProjetFinance,Longueur(FSGenerateurBase.EditCodeProjetPropose.Text))=FSGenerateurBase.EditCodeProjetPropose.Text)then
               begin
                    if(LongMaxCodeProjet<=longueur(RProjetFinance.NumProjetFinance))then LongMaxCodeProjet:=longueur(RProjetFinance.NumProjetFinance);
               end;
          end;
          finally
          CloseFile(FProjetFinance);
          end;

          Rong:=ValeAbsolue(LongMaxCodeProjet/5);

          if(Rong>3)then PositionIndex:=MaxInt(0,Rong-3)else PositionIndex:=MaxInt(0,Rong-2);
          FSGenerateurBase.EditRonStructure.Items.Text:='';
          for R:=1to(Rong-1)do
          begin
               Classement:=inttostr(R);
               if(R=1)
               then Classement:=Classement+'er'
               else Classement:=Classement+'Ťme';
               FSGenerateurBase.EditRonStructure.Items.Add('Structure '+Classement+' Rong');
          end;

          FSGenerateurBase.EditRonStructure.ItemIndex:=PositionIndex;

          ListeProjetFinance(FSGenerateurBase.TableauProjetFinancePropose,'',FSGenerateurBase.EditCodeProjetPropose.Text,inttostr(10+(FSGenerateurBase.EditRonStructure.ItemIndex*5)),FSGenerateurBase.StructurePrecis.Checked,'1','',FSGenerateurBase.RBIndiquerReservationStructure.Checked,false,FSRecapitulatifProjets.EditTiersTypeProces.Text,FSRecapitulatifProjets.EditTiersFichierConserne.Text);
     end
     else
     begin
          ProcAfficheMessage('Veuillez sťlectionner un projet principal SVP !');
     end;
end;

