procedure TFSGenerateurBase.TableauAdresseDossierPartageReseauxKeyPress(
  Sender: TObject; var Key: Char);
var  NumAdresseDossierPartage:integer;
begin

if key in['n','N']then
begin
     FSGenerateurBase.AfficheOptionAdresseDossierPartageReseaux.Visible:=true;
     OpenFParc(RParc);
     ChAdresseDossierPartageReseaux:=RParc.Parcours+'\'+Exercice+'FAdresseDossierPartageReseaux';
     assignfile(FAdresseDossierPartageReseaux,ChAdresseDossierPartageReseaux);
     try
     if FileExists(ChAdresseDossierPartageReseaux)then
     Reset(FAdresseDossierPartageReseaux)
     else Rewrite(FAdresseDossierPartageReseaux);
     Seek(FAdresseDossierPartageReseaux,0);
     NumAdresseDossierPartage:=1;
     while not eof(FAdresseDossierPartageReseaux)do
     begin
          read(FAdresseDossierPartageReseaux,RAdresseDossierPartageReseaux);
          if(NumAdresseDossierPartage<=RAdresseDossierPartageReseaux.NumAdresseDossierPartageReseaux)then NumAdresseDossierPartage:=RAdresseDossierPartageReseaux.NumAdresseDossierPartageReseaux+1;
     end;

     FSGenerateurBase.EditNumAdresseDossierPartageReseaux.Text:=inttostr(NumAdresseDossierPartage);
     FSGenerateurBase.EditNomPosteReseaux.Text:='';
     FSGenerateurBase.EditAdresseDossierPartageReseaux.Text:='';
     FSGenerateurBase.EditEmlacementLocalOuReseaux.Text:='';
     FSGenerateurBase.EditPort.Text:='';
     FSGenerateurBase.EditAdresseIP.Text:='';
     FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.Kind:=bkAll;
     FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.Caption:='Valider';

     finally
     closefile(FAdresseDossierPartageReseaux);
     end;

     FSGenerateurBase.EditNomPosteReseaux.SetFocus;
end;

if key in['m','M','s','S']then
begin
     FSGenerateurBase.AfficheOptionAdresseDossierPartageReseaux.Visible:=true;
     FSGenerateurBase.EditNumAdresseDossierPartageReseaux.Text:=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[1,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row];
     FSGenerateurBase.EditNomPosteReseaux.Text:=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[2,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row];
     FSGenerateurBase.EditAdresseDossierPartageReseaux.Text:=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[3,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row];
     FSGenerateurBase.EditEmlacementLocalOuReseaux.Text:=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[4,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row];

     FSGenerateurBase.EditPort.Text:=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[6,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row];
     FSGenerateurBase.EditAdresseIP.Text:=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[7,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row];

     if key in['m','M']then
     begin
          FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.Kind:=bkAll;
          FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.Caption:='Valider';
          FSGenerateurBase.EditNomPosteReseaux.SetFocus;
     end;

     if key in['s','S']then
     begin
          FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.Kind:=bkCancel;
          FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.Caption:='Supprimer';
          FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.SetFocus;
     end;
end;

end;

