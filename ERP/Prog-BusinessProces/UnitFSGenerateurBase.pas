procedure TFSGenerateurBase.EditNomFichierConcerneRechercheKeyUp(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var  Rs:integer;   OKFichierConcerne:boolean;
begin
     if(FSGenerateurBase.EditNomFichierConcerneRecherche.Text<>'')then
     begin
          OKFichierConcerne:=false;
          Rs:=1;
          while(Rs<=FSGenerateurBase.TableauListeFichierConcerne.RowCount-1)and(OKFichierConcerne=false)do
          begin
               if RechercheSequenceParMotsCle(AnsiUpperCase(FSGenerateurBase.EditNomFichierConcerneRecherche.Text),AnsiUpperCase(FSGenerateurBase.TableauListeFichierConcerne.Cells[3,Rs]))then
               begin
                    OKFichierConcerne:=true;
                    FSGenerateurBase.EditRowSelect.Text:=inttostr(Rs);
               end;
          Rs:=Rs+1;
          end;

          if(OKFichierConcerne=false)then FSGenerateurBase.EditRowSelect.Text:='1';
          FSGenerateurBase.TableauListeFichierConcerne.Row:=strtointeger(FSGenerateurBase.EditRowSelect.Text);
          FSGenerateurBase.TableauListeFichierConcerne.Col:=3;
     end;
end;

procedure TFSGenerateurBase.BitBtn66Click(Sender: TObject);
var  Rs:integer;   OKFichierConcerne:boolean;
begin
     if(FSGenerateurBase.EditNomFichierConcerneRecherche.Text<>'')then
     begin
          OKFichierConcerne:=false;
          Rs:=strtointeger(FSGenerateurBase.EditRowSelect.Text)+1;
          while(Rs<=FSGenerateurBase.TableauListeFichierConcerne.RowCount-1)and(OKFichierConcerne=false)do
          begin
               if(RechercheSequenceParMotsCle(AnsiUpperCase(FSGenerateurBase.EditNomFichierConcerneRecherche.Text),AnsiUpperCase(FSGenerateurBase.TableauListeFichierConcerne.Cells[3,Rs]))=true)then
               begin
                    OKFichierConcerne:=true;
                    FSGenerateurBase.EditRowSelect.Text:=inttostr(Rs);
               end;
          Rs:=Rs+1;
          end;

          if(OKFichierConcerne=false)then
          begin
               FSGenerateurBase.EditRowSelect.Text:='1';
               FSGenerateurBase.EditNomFichierConcerneRecherche.SetFocus;
          end
          else
