procedure TFSGenerateurBase.TableauStockArticleContextPopup(
  Sender: TObject; MousePos: TPoint; var Handled: Boolean);
begin
FSGenerateurBase.AfficheOptions.Visible:=true;

if MousePos.X<(FSGenerateurBase.TableauStockArticle.Width-FSGenerateurBase.AfficheOptions.Width)
then FSGenerateurBase.AfficheOptions.Left:=(MousePos.X+FSGenerateurBase.TableauStockArticle.Left)
else FSGenerateurBase.AfficheOptions.Left:=(FSGenerateurBase.TableauStockArticle.Width-
     FSGenerateurBase.AfficheOptions.Width+FSGenerateurBase.TableauStockArticle.Left);

