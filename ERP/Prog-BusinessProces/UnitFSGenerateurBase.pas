procedure TFSGenerateurBase.EditRechercheKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  l:integer;  OKArticle:boolean;   Codebarre:string;
begin

if key in[VK_RETURN,VK_ESCAPE]then
begin
     if(FSGenerateurBase.RBParCodebarre.Checked=true)then
     begin
          l:=1;
          OKArticle:=false;
          while(l<=FSGenerateurBase.TableauStockArticle.RowCount-1)and(OKArticle=false)do
          begin
               Codebarre:=FSGenerateurBase.TableauStockArticle.Cells[15,l];
               if(FSGenerateurBase.EditRecherche.Text=Codebarre)then
               begin
                    OKArticle:=true;
                    FSGenerateurBase.TableauStockArticle.Row:=l;
               end;
          l:=l+1;
          end;
     end
     else OKArticle:=true;

     if(OKArticle=true)then//and(FSGenerateurBase.RBParCodebarre.Checked=false)then
     begin
          FSGenerateurBase.TableauStockArticle.SetFocus;
          
          if(FSGenerateurBase.RBParCodebarre.Checked=false)
          then
          begin
               FSGenerateurBase.AfficheOptionCompteConcerne.Visible:=false;
          end
          else
          begin
               FSGenerateurBase.EditRecherche.SetFocus;
               FSGenerateurBase.EditRecherche.SelectAll;
          end;
     end
     else
     begin
          FSGenerateurBase.EditRecherche.SelectAll;
     end;
end;

if key in[VK_DOWN]then
begin
     if(FSGenerateurBase.RBParCodeSFamille.Checked=true)then FSGenerateurBase.RBParCodeArticle.Checked:=true
     else
     if(FSGenerateurBase.RBParCodeArticle.Checked=true)then FSGenerateurBase.RBParDesignationArticle.Checked:=true
     else
     if(FSGenerateurBase.RBParDesignationArticle.Checked=true)then FSGenerateurBase.RBParCodeSFamille.Checked:=true
end;

if key in[VK_UP]then 
begin
     if(FSGenerateurBase.RBParDesignationArticle.Checked=true)then FSGenerateurBase.RBParCodeArticle.Checked:=true
     else
     if(FSGenerateurBase.RBParCodeArticle.Checked=true)then FSGenerateurBase.RBParCodeSFamille.Checked:=true
     else
     if(FSGenerateurBase.RBParCodeSFamille.Checked=true)then FSGenerateurBase.RBParDesignationArticle.Checked:=true
end;

end;

