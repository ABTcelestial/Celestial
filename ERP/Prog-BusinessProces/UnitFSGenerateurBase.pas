           begin
                if(FSGenerateurBase.TableauStockArticleRegularisation.Cells[14,R]='OK')then
                begin
                     if(FSGenerateurBase.BitConfirmerRegularisation.Caption='Confirmer la Rťgularisation du coŻt des articles sťlectionnťs')then
                     begin
                          CoutRegularisation:=strtoreal(FSGenerateurBase.TableauStockArticleRegularisation.Cells[10,R]);
