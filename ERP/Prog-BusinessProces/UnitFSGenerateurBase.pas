                 if(RAdresseDossierPartageReseauxListe.EmlacementLocalOuReseaux='Rťseaux')then
                 begin
                      if DirectoryExists(RAdresseDossierPartageReseauxListe.AdresseDossierPartageReseaux)then
                      begin
                           TableauAdresseDossierPartageReseaux.Cells[5,i]:='Connectť '+Utilisation;
                           NbrConnect:=NbrConnect+1;
                      end
                      else
                      begin
                           TableauAdresseDossierPartageReseaux.Cells[5,i]:='Dťconnectť '+Utilisation;
