procedure TFSGenerateurBase.BitAjouterClick(Sender: TObject);
var  i,R,l,NumFiche,NumRubrique:integer;   OKProjet:boolean;
begin
          OpenFParc(RParc);
          ChFicheTechnique:=RParc.Parcours+'\'+Exercice+'FFicheTechnique';
          assignfile(FFicheTechnique,ChFicheTechnique);
          try
          if FileExists(ChFicheTechnique)then
          Reset(FFicheTechnique)
          else Rewrite(FFicheTechnique);
          Seek(FFicheTechnique,0);
          NumFiche:=1;
          i:=0;
          while not eof(FFicheTechnique)do
          begin
               read(FFicheTechnique,RFicheTechnique);
               if(NumFiche<=RFicheTechnique.NumFicheTechnique)then NumFiche:=RFicheTechnique.NumFicheTechnique+1;
               i:=i+1;
          end;


          for R:=1 to FSGenerateurBase.TableauFicheTechniquePropose.RowCount-1 do
          begin
               Seek(FFicheTechnique,i);
               RFicheTechnique.NumFicheTechnique:=NumFiche;
               RFicheTechnique.CodeProjet:=FSGenerateurBase.TableauFicheTechniquePropose.Cells[1,R];
               RFicheTechnique.DesignationFicheTechnique:=FSGenerateurBase.TableauFicheTechniquePropose.Cells[3,R];
               RFicheTechnique.NumTypeAvis:=strtointeger(FSGenerateurBase.TableauFicheTechniquePropose.Cells[4,R]);
               write(FFicheTechnique,RFicheTechnique);

               for l:=1 to FSGenerateurBase.TableauRubriqueFicheTechniquePropose.RowCount-3 do
               begin
                    if(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[2,l]=FSGenerateurBase.TableauFicheTechniquePropose.Cells[2,R])
                    then FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[9,l]:=inttostr(NumFiche);
               end;

          i:=i+1;
          NumFiche:=NumFiche+1;
          end;

          finally
          CloseFile(FFicheTechnique);
          end;

          OpenFParc(RParc);
          ChRubriqueFicheTechnique:=RParc.Parcours+'\'+Exercice+'FRubriqueFicheTechnique';
          assignfile(FRubriqueFicheTechnique,ChRubriqueFicheTechnique);
          try
          if FileExists(ChRubriqueFicheTechnique)then
          Reset(FRubriqueFicheTechnique)
          else Rewrite(FRubriqueFicheTechnique);
          Seek(FRubriqueFicheTechnique,0);
          NumRubrique:=1;
          i:=0;
          while not eof(FRubriqueFicheTechnique)do
          begin
               read(FRubriqueFicheTechnique,RRubriqueFicheTechnique);
               if(NumRubrique<=RRubriqueFicheTechnique.NumRubrique)then NumRubrique:=RRubriqueFicheTechnique.NumRubrique+1;
               i:=i+1;
          end;

          for R:=1 to FSGenerateurBase.TableauRubriqueFicheTechniquePropose.RowCount-3do
          begin
               Seek(FRubriqueFicheTechnique,i);
               RRubriqueFicheTechnique.NumRubrique:=NumRubrique;
               RRubriqueFicheTechnique.NumFicheTechnique:=strtointeger(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[9,R]);
               RRubriqueFicheTechnique.DesignationRubrique:=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[3,R];
               RRubriqueFicheTechnique.Quantite:=strtoreal(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[4,R]);
               RRubriqueFicheTechnique.TypeUnite:=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[5,R];
               RRubriqueFicheTechnique.PrixUnitaire:=strtoreal(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[6,R]);
               RRubriqueFicheTechnique.Montant:=strtoreal(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[7,R]);
               write(FRubriqueFicheTechnique,RRubriqueFicheTechnique);
          i:=i+1;
          NumRubrique:=NumRubrique+1;
          end;

          finally
          CloseFile(FRubriqueFicheTechnique);
          end;

FSGenerateurBase.AfficheOptionValiderProposition.Visible:=false;
FSGenerateurBase.TimerAfficheMessage.Enabled:=false;
end;

