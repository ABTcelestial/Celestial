Procedure ListeTypeFichierTiers(TableauTypeFichierTiers:TStringGrid; TypeProcesRecherche:string;  IndiceRubriqueTrie:integer);
var ip:integer;   OKTypeFichierTiers:boolean;  TypeProces,FichierConserne,Adresse:string;
begin

TableauTypeFichierTiers.ColCount:=5;
TableauTypeFichierTiers.RowCount:=2;
TableauTypeFichierTiers.Rows[1].Text:='';
TableauTypeFichierTiers.Cols[0].Text:='Nį';
TableauTypeFichierTiers.Cols[1].Text:='Ordre';
TableauTypeFichierTiers.Cols[2].Text:='Type Proces';
TableauTypeFichierTiers.Cols[3].Text:='Fichier Concerne';
TableauTypeFichierTiers.Cols[4].Text:='Base Avis';

TypeProces:='Business';   FichierConserne:='FTypeFichierTiers';
if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
begin
     AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConserne+' recherchť !');
end;

ChTypeFichierTiers:=Adresse;
assignfile(FTypeFichierTiers,ChTypeFichierTiers);
ip:=0;
if FileExists(ChTypeFichierTiers)then
begin
     try
     Reset(FTypeFichierTiers);
     Seek(FTypeFichierTiers,0);
     while not eof(FTypeFichierTiers)do
     begin
          read(FTypeFichierTiers,RTypeFichierTiers);

          if(TypeProcesRecherche<>'Tous')then
          begin
               if(RTypeFichierTiers.TypeProces=TypeProcesRecherche)
               then OKTypeFichierTiers:=true
               else OKTypeFichierTiers:=false;

          end
          else OKTypeFichierTiers:=true;

          if(OKTypeFichierTiers=true)then
          begin
               ip:=ip+1;
               TableauTypeFichierTiers.Rows[ip].Text:=inttostr(ip);
               TableauTypeFichierTiers.Cells[1,ip]:=inttostr(RTypeFichierTiers.OrdreTypeFichierTiers);
               TableauTypeFichierTiers.Cells[2,ip]:=RTypeFichierTiers.TypeProces;
               TableauTypeFichierTiers.Cells[3,ip]:=Lastlaters(RTypeFichierTiers.FichierConcerne,longueur(RTypeFichierTiers.FichierConcerne)-1);
               TableauTypeFichierTiers.Cells[4,ip]:=RTypeFichierTiers.BaseAvis;
          end;
     end;

     finally
     CloseFile(FTypeFichierTiers);
     end;
end;

if(ip>0)then TableauTypeFichierTiers.RowCount:=ip+1
        else TableauTypeFichierTiers.RowCount:=2;

TrierTableauARowSpecial(TableauTypeFichierTiers,1,TableauTypeFichierTiers.RowCount-1,1,inttostr(IndiceRubriqueTrie),'','+');

AjusterColWidth(TableauTypeFichierTiers,'','');

end;

Procedure ListeBaseAvis(TableauBaseAvis:TStringGrid);
var ip:integer;   OKBaseAvis:boolean;  TypeProces,FichierConserne,Adresse,TypeData:string;
begin

TableauBaseAvis.ColCount:=3;
TableauBaseAvis.RowCount:=2;
TableauBaseAvis.Rows[1].Text:='';
TableauBaseAvis.Cols[0].Text:='Nį';
TableauBaseAvis.Cols[1].Text:='Pį';
TableauBaseAvis.Cols[2].Text:='Dťsignation BaseAvis';

TypeProces:='Business';   FichierConserne:='FBaseAvis';
if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
begin
     AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConserne+' recherchť !');
end;

ChBaseAvis:=Adresse;    FSGenerateurBase.AfficherAdresseFBaseAvis.Caption:=Adresse;
assignfile(FBaseAvis,ChBaseAvis);
ip:=0;
if FileExists(ChBaseAvis)then
begin
     try
     Reset(FBaseAvis);
     Seek(FBaseAvis,0);
     while not eof(FBaseAvis)do
     begin
          read(FBaseAvis,RBaseAvis);

          OKBaseAvis:=true;

          if(OKBaseAvis=true)then
          begin
               ip:=ip+1;
               TableauBaseAvis.Rows[ip].Text:=inttostr(ip);
