procedure TFSGenerateurBase.BitOperationBaseAvisClick(Sender: TObject);
var  i,A,M,RExistant,RSupprimer,RSauvgarder:integer;   OKBaseAvis:boolean;
     TypeProces,FichierConserne,Adresse:string;
begin

     if(FSGenerateurBase.BitOperationBaseAvis.Caption='Valider')then
     begin
          TypeProces:='Business';   FichierConserne:='FBaseAvis';
          if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConserne+' recherchť !');
          end;

          ChBaseAvis:=Adresse;
          assignfile(FBaseAvis,ChBaseAvis);
          try
          if FileExists(ChBaseAvis)then
          Reset(FBaseAvis)
          else Rewrite(FBaseAvis);
          Seek(FBaseAvis,0);
          i:=0;
          OKBaseAvis:=false;
          while not eof(FBaseAvis)and(OKBaseAvis=false)do
          begin
               read(FBaseAvis,RBaseAvis);
               if(inttostr(RBaseAvis.PositionBaseAvis)=FSGenerateurBase.EditPositionBaseAvis.Text)
               then OKBaseAvis:=true
               else i:=i+1;
          end;

          RBaseAvis.PositionBaseAvis:=i;
          RBaseAvis.DesignationBaseAvis:=FSGenerateurBase.EditDesignationBaseAvis.Text;
          for A:=2010 to 2050 do
          for M:=1 to 12 do
          begin
               RBaseAvis.RegistrePositionAvisParPeriode[A,M].PositionAvisBegin:=0;
               RBaseAvis.RegistrePositionAvisParPeriode[A,M].PositionAvisEnd:=999999999;
          end;
          Seek(FBaseAvis,i);
          write(FBaseAvis,RBaseAvis);

          finally
          CloseFile(FBaseAvis);
          end;
     end;

     if(FSGenerateurBase.BitOperationBaseAvis.Caption='Supprimer')then
     begin
          SupprimerBaseAvis(FSGenerateurBase.EditPositionBaseAvis.Text,RExistant,RSupprimer,RSauvgarder);
          if(RSupprimer>0)
          then AfficherMessage('Suppression rťussie ! FTotal: '+inttostr(RExistant)+' FSupprimer: '+inttostr(RSupprimer)+' FSauvgarder: '+inttostr(RSauvgarder))
          else AfficherMessage('Aucun Registre Supprimer ! FTotal: '+inttostr(RExistant)+' FSupprimer: '+inttostr(RSupprimer)+' FSauvgarder: '+inttostr(RSauvgarder));
     end;

ProceTrieBaseAvisLocalReseaux;
ListeBaseAvis(FSGenerateurBase.TableauBaseAvis);
FSGenerateurBase.AfficheOperationBaseAvis.Visible:=false;

FSGenerateurBase.TableauBaseAvis.SetFocus;
end;

