     if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          ChStockArticle:=Adresse;
          assignfile(FStockArticle,ChStockArticle);
          if FileExists(ChStockArticle)then
          begin
               try
               Reset(FStockArticle);
               Seek(FStockArticle,0);
               while not eof(FStockArticle)and(OKStockArticle=false)do
               begin
                    Read(FStockArticle,RStockArticle);  Application.ProcessMessages;

                    if(RStockArticle.UM<>'Pst')
                    and(RStockArticle.UM<>'H')
                    and(Firstlaters(RStockArticle.Code,longueur(CodePlanComptable))=CodePlanComptable)
                    then
                    begin
                         OKStockArticle:=true;
                    end;
               end;
               finally
               CloseFile(FStockArticle);
               end;
          end;
     end;

     ExisteStockArticlePlanComptable:=OKStockArticle;
end;

