procedure TFSGenerateurBase.BitBtn10Click(Sender: TObject);
var  NumProjetFinance,RongPrincipal,RongSecondaire:integer; OKProjetFinance,OKNbrChiffre:boolean;
     UniteMesure,TypeStructure,CodePrincipale,Structure:string;  PrixUnite:real; Codification,LongueurCode:integer;
begin

if(FSGenerateurBase.TableauProjetFinance.Cells[1,FSGenerateurBase.TableauProjetFinance.Row]<>'')then
begin
     UniteMesure:='';
     PrixUnite:=0;

     OpenFParc(RParc);
     ChProjetFinance:=RParc.Parcours+'\'+Exercice+'FProjetFinance';
     assignfile(FProjetFinance,ChProjetFinance);
     try
     if FileExists(ChProjetFinance)then
     Reset(FProjetFinance)
     else Rewrite(FProjetFinance);
     Seek(FProjetFinance,0);
     OKProjetFinance:=false;
     while not eof(FProjetFinance)and(OKProjetFinance=false)do
     begin
          read(FProjetFinance,RProjetFinance);
          if(RProjetFinance.NumProjetFinance=FSGenerateurBase.TableauProjetFinance.Cells[1,FSGenerateurBase.TableauProjetFinance.Row])then
          begin
               OKProjetFinance:=true;
               UniteMesure:=RProjetFinance.UniteMesureProjetFinance;
               PrixUnite:=RProjetFinance.PrixUniteHTMesureProjetFinance;
               CodePrincipale:=RProjetFinance.Codification;
               TypeStructure:=RProjetFinance.NatureProjetFinance;
          end;
     end;
     finally
     CloseFile(FProjetFinance);
     end;

     if(OKProjetFinance=true)
     and(RProjetFinance.DecompositionProjetFinance=false)then
     begin
          showmessage('La structure sťlectionť n''est pas dťcomposable !');
          Exit;
     end;
end;

if(FSGenerateurBase.TableauProjetFinance.Cells[FSGenerateurBase.TableauProjetFinance.Col,FSGenerateurBase.TableauProjetFinance.Row]<>'')then
begin
     RongPrincipal:=Longueur(FSGenerateurBase.TableauProjetFinance.Cells[1,FSGenerateurBase.TableauProjetFinance.Row]);
     RongSecondaire:=(ValeAbsolue(RongPrincipal/5)+1)*5;

     FSGenerateurBase.AfficheOptionProjetFinance.Visible:=true;
     OpenFParc(RParc);
     ChProjetFinance:=RParc.Parcours+'\'+Exercice+'FProjetFinance';
     assignfile(FProjetFinance,ChProjetFinance);
     try
     if FileExists(ChProjetFinance)then
     Reset(FProjetFinance)
     else Rewrite(FProjetFinance);
     Seek(FProjetFinance,0);
     NumProjetFinance:=1;
     Codification:=1;
     Structure:='';
     while not eof(FProjetFinance)do
     begin
          read(FProjetFinance,RProjetFinance);
          if(Longueur(RProjetFinance.NumProjetFinance)=RongSecondaire)
          and(Firstlaters(RProjetFinance.NumProjetFinance,RongPrincipal)=FSGenerateurBase.TableauProjetFinance.Cells[1,FSGenerateurBase.TableauProjetFinance.Row])then
          begin
               if(NumProjetFinance<=strtointeger(lastlaters(RProjetFinance.NumProjetFinance,RongSecondaire-RongPrincipal)))then NumProjetFinance:=strtointeger(lastlaters(RProjetFinance.NumProjetFinance,RongSecondaire-RongPrincipal))+1;
               LongueurCode:=longueur(RProjetFinance.Codification);
               if(Codification<=strtointeger(lastlaters(RProjetFinance.Codification,LongueurCode-longueur(CodePrincipale))))then Codification:=strtointeger(lastlaters(RProjetFinance.Codification,LongueurCode-longueur(CodePrincipale)))+1;
               Structure:=RProjetFinance.DesignationProjetFinance;
          end;
     end;
     finally
     closefile(FProjetFinance);
     end;

     FSGenerateurBase.EditNumProjetFinance.Text:=FSGenerateurBase.TableauProjetFinance.Cells[1,FSGenerateurBase.TableauProjetFinance.Row]+Completezerogauche(inttostr(NumProjetFinance),'5');
     FSGenerateurBase.EditDesignationProjetFinance.Text:=Structure;
