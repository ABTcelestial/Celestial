     RAdresseProces.AdresseProces:=FSGenerateurBase.EditAdresseProces.Text;
     RAdresseProces.Exercice:=FSGenerateurBase.EditExercice.Text;
     RAdresseProces.FichierConcerne:=FSGenerateurBase.EditFichierConcerneAdresseProcecs.Text;
     write(FAdresseProces,RAdresseProces);
end;

finally
Closefile(FAdresseProces);
end;
end;

if(FSGenerateurBase.BitValiderAdresseProces.Caption='Supprimer')then
begin
     if(FSGenerateurBase.RBSupprimerYComprisListeFichiersPartages.Checked=true)
     then DeleteFListeFichierConcernePartageReseaux(FSGenerateurBase.EditNumAdresseProces.Text,'',Confirme);
     DeleteFAdresseProces(strtointeger(FSGenerateurBase.EditNumAdresseProces.Text),Confirme);
