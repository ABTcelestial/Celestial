procedure TFSGenerateurBase.TableauListeFichierConcerneDblClick(
  Sender: TObject);
var  i,R:integer;
begin
     if(FSGenerateurBase.AfficheOptionAdresseProces.Visible=true)then
     begin
          if(FSGenerateurBase.TableauListeFichierConcerne.Cells[4,FSGenerateurBase.TableauListeFichierConcerne.Row]='OK')
          then FSGenerateurBase.TableauListeFichierConcerne.Cells[4,FSGenerateurBase.TableauListeFichierConcerne.Row]:=''
          else FSGenerateurBase.TableauListeFichierConcerne.Cells[4,FSGenerateurBase.TableauListeFichierConcerne.Row]:='OK';

          //  Crťation Liste Fichier concerne partage rťseaux
          OpenFParc(RParc);
          ChListeFichierConcernePartageReseaux:=RParc.Parcours+'\'+Exercice+'FListeFichierConcernePartageReseaux'+' '+FSGenerateurBase.EditNumAdresseProces.Text;
          assignfile(FListeFichierConcernePartageReseaux,ChListeFichierConcernePartageReseaux);
          try
          if FileExists(ChListeFichierConcernePartageReseaux)then
          Reset(FListeFichierConcernePartageReseaux)
          else Rewrite(FListeFichierConcernePartageReseaux); // Crťation nouveau fichier
          Seek(FListeFichierConcernePartageReseaux,0);
          Truncate(FListeFichierConcernePartageReseaux);
          i:=0;
          R:=1;
          while(R<=FSGenerateurBase.TableauListeFichierConcerne.RowCount-1)do
          begin
               if(FSGenerateurBase.TableauListeFichierConcerne.Cells[4,R]='OK')then
               begin
                    Seek(FListeFichierConcernePartageReseaux,i);
                    RListeFichierConcernePartageReseaux.NumAdresseProces:=strtointeger(FSGenerateurBase.EditNumAdresseProces.Text);
                    RListeFichierConcernePartageReseaux.NomPosteReseaux:=FSGenerateurBase.EditRepertoire.Text;
                    RListeFichierConcernePartageReseaux.FichierConcerne:=FSGenerateurBase.TableauListeFichierConcerne.Cells[3,R];
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.NumeroAcces:=i;
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.CodeUtilisateur:=FSMenuPrincipal.EditCodeUtilisateur.Text;
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.CodePosteMenu:=FSGenerateurBase.TableauListeFichierConcerne.Cells[3,R];
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeConsultation:=true;
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutConsultation:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinConsultation:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeAjouter:=false;
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutAjouter:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinAjouter:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeModifier:=false;
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutModifier:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinModifier:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeSupprimer:=false;
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutSupprimer:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinSupprimer:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeImprimer:=false;
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutImprimer:='';
                    RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinImprimer:='';

                    write(FListeFichierConcernePartageReseaux,RListeFichierConcernePartageReseaux);
                    i:=i+1;
               end;
          R:=R+1;
          end;
          finally
          CloseFile(FListeFichierConcernePartageReseaux);
          end;
          ListeFichierConecernePartageReseaux(FSGenerateurBase.TableauxFichierConcernePartageReseaux,FSGenerateurBase.EditNumAdresseProces.Text,'');
          ///////////////////////////////////////////////////

          IndiquerListeFichierPartagerAuxClientsReseaux(FSGenerateurBase.TableauAdresseProces.Cells[1,FSGenerateurBase.TableauAdresseProces.Row],FSGenerateurBase.TableauAdresseProces.Cells[3,FSGenerateurBase.TableauAdresseProces.Row]);// Procedure rťseaux

          TrierTableauARowSpecial(FSGenerateurBase.TableauListeFichierConcerne,1,FSGenerateurBase.TableauListeFichierConcerne.RowCount+-1,1,'4','','-');
     end
     else
     if(FSGenerateurBase.AfficheAccesPrivilegies.Visible=true)then
     begin
          FSGenerateurBase.EditCodePosteMenuNewAcces.Text:=FSGenerateurBase.TableauListeFichierConcerne.Cells[3,FSGenerateurBase.TableauListeFichierConcerne.Row];
          FSGenerateurBase.AfficheListeFichierConcerne.Visible:=false;
          FSGenerateurBase.EditCodePosteMenuNewAcces.SetFocus;
     end;
end;

Procedure ListeFichierConecernePartageReseaux(TableauListeFichier:TStringGrid; NumAdresseProces,AdresseListeFichierConcernePartageReseaux:string);
var  R:integer; OKListeFichier:boolean;
begin
     TableauListeFichier.ColCount:=19;
     TableauListeFichier.Cols[0].Text:='Nį';
     TableauListeFichier.Cols[1].Text:='Nį Partage';
     TableauListeFichier.Cols[2].Text:='Nom Dossier Partagť';
     TableauListeFichier.Cols[3].Text:='Nom Fichier';

     TableauListeFichier.Cols[4].Text:='MC';
     TableauListeFichier.Cols[5].Text:='Date D. MC';
     TableauListeFichier.Cols[6].Text:='Date F. MC';

     TableauListeFichier.Cols[7].Text:='MA';
     TableauListeFichier.Cols[8].Text:='Date D. MA';
     TableauListeFichier.Cols[9].Text:='Date F. MA';

     TableauListeFichier.Cols[10].Text:='MM';
     TableauListeFichier.Cols[11].Text:='Date D. MM';
     TableauListeFichier.Cols[12].Text:='Date F. MM';

     TableauListeFichier.Cols[13].Text:='MS';
     TableauListeFichier.Cols[14].Text:='Date D. MS';
     TableauListeFichier.Cols[15].Text:='Date F. MS';

     TableauListeFichier.Cols[16].Text:='MI';
     TableauListeFichier.Cols[17].Text:='Date D. MI';
     TableauListeFichier.Cols[18].Text:='Date F. MI';

     TableauListeFichier.RowCount:=2;
     TableauListeFichier.Rows[1].Text:='';

     if(AdresseListeFichierConcernePartageReseaux<>'')then
     begin
          ChListeFichierConcernePartageReseaux:=AdresseListeFichierConcernePartageReseaux;
     end
     else
     begin
         OpenFParc(RParc);
         ChListeFichierConcernePartageReseaux:=RParc.Parcours+'\'+Exercice+'FListeFichierConcernePartageReseaux'+' '+NumAdresseProces;
     end;

     assignfile(FListeFichierConcernePartageReseaux,ChListeFichierConcernePartageReseaux);
     R:=0;
     if FileExists(ChListeFichierConcernePartageReseaux)then
     begin
          try
          Reset(FListeFichierConcernePartageReseaux);
          Seek(FListeFichierConcernePartageReseaux,0);
          OKListeFichier:=false;
          while not eof(FListeFichierConcernePartageReseaux)do
          begin
               read(FListeFichierConcernePartageReseaux,RListeFichierConcernePartageReseaux);

                if(NumAdresseProces<>'')then
                begin
                     if(inttostr(RListeFichierConcernePartageReseaux.NumAdresseProces)=NumAdresseProces)
                     then OKListeFichier:=true
                     else OKListeFichier:=false;
                end
                else OKListeFichier:=true;

                if(OKListeFichier=true)then
                begin
                     R:=R+1;
                     TableauListeFichier.Rows[R].Text:=inttostr(R);
                     TableauListeFichier.Cells[1,R]:=inttostr(RListeFichierConcernePartageReseaux.NumAdresseProces);
                     TableauListeFichier.Cells[2,R]:=RListeFichierConcernePartageReseaux.NomPosteReseaux;
                     TableauListeFichier.Cells[3,R]:=RListeFichierConcernePartageReseaux.FichierConcerne;

                     TableauListeFichier.Cells[4,R]:=booleantostr(RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeConsultation);
                     TableauListeFichier.Cells[5,R]:=RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutConsultation;
                     TableauListeFichier.Cells[6,R]:=RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinConsultation;

