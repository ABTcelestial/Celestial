     begin
     OpenFParc(RParc);
     ChListeFichierConcernePartageReseaux:=RParc.Parcours+'\'+Exercice+'FListeFichierConcernePartageReseaux'+' '+FSGenerateurBase.TableauAdresseProces.Cells[1,FSGenerateurBase.TableauAdresseProces.Row];
     assignfile(FListeFichierConcernePartageReseaux,ChListeFichierConcernePartageReseaux);
     try
     if FileExists(ChListeFichierConcernePartageReseaux)then
     Reset(FListeFichierConcernePartageReseaux)
     else Rewrite(FListeFichierConcernePartageReseaux);  // Crťation nouveau fichier
     Seek(FListeFichierConcernePartageReseaux,0);
     OKListeFichier:=false;
     i:=0;
     iSelect:=0;
     while not eof(FListeFichierConcernePartageReseaux)and(OKListeFichier=false)do
     begin
          read(FListeFichierConcernePartageReseaux,RListeFichierConcernePartageReseaux);

          if(RListeFichierConcernePartageReseaux.NumAdresseProces=strtointeger(FSGenerateurBase.TableauAdresseProces.Cells[1,FSGenerateurBase.TableauAdresseProces.Row]))
          and(RListeFichierConcernePartageReseaux.FichierConcerne=FSGenerateurBase.EditCodePosteMenuNewAccesLast.Text)
          then
          begin
               OKListeFichier:=true;
               iSelect:=i;
          end;
     i:=i+1;
     end;

     if(OKListeFichier=true)then i:=iSelect;
     RListeFichierConcernePartageReseaux.NumAdresseProces:=strtointeger(FSGenerateurBase.TableauAdresseProces.Cells[1,FSGenerateurBase.TableauAdresseProces.Row]);
     RListeFichierConcernePartageReseaux.NomPosteReseaux:=FSGenerateurBase.TableauAdresseProces.Cells[3,FSGenerateurBase.TableauAdresseProces.Row];
