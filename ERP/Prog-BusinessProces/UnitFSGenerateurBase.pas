Procedure AnalyseStockArticle(NumProjetStockArticle:string; TableauMouvement,TableauDetailMouvement:TStringGrid; RowControleTableauMouvement,RowTableauDetailMouvementEntree:integer; OKInclureMouvement,OKInclurePrelevement:boolean; DateDebutPeriodeAnalyseMouvement,DateDebutPeriodeAnalysePrelevement,DateFinPeriodeAnalyseMouvement,DateFinPeriodeAnalysePrelevement:string; var RowTableauDetailMouvementEntreeSortie:integer);
var   iAS,IBegin,NewLastNumDetailMouvementMAJ,iDM,PBeginDM,PEndDM,PBeginLM,PEndLM:integer; QteSortiePrelevement:real; OKProjetFinance,OKCodeStock,OKMAJ:boolean;  SigneMouvement,NumStructure,FichierConcerne,EtatEntreeSortie:string;
begin
     FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+NumProjetStockArticle+' rťsultat d''analyse';
     OpenFParc(RParc);
     ChStockArticleCopie:=RParc.Parcours+'\'+Exercice+FichierConcerne;
     assignfile(FStockArticleCopie,ChStockArticleCopie);
     try
     if FileExists(ChStockArticleCopie)then
     Reset(FStockArticleCopie)
     else Rewrite(FStockArticleCopie);
     Seek(FStockArticleCopie,0);
     iAS:=0;
     while not eof(FStockArticleCopie)do
     begin
          read(FStockArticleCopie,RStockArticleCopie);  Application.ProcessMessages;
          iAS:=iAS+1;
     end;

     if(RowControleTableauMouvement<=TableauMouvement.RowCount-1)then
     begin
          if(TableauMouvement.Cells[1,RowControleTableauMouvement]<>'Pr')and(TableauMouvement.Cells[1,RowControleTableauMouvement]<>'ST')and(OKInclureMouvement=true)then
          begin
                PBeginLM:=0;
                PEndLM:=0;

                PBeginDM:=0;
                PEndDM:=0;

                FSGenerateurBase.MemoRapportPlus.Lines.Text:='';
                IndiquerPositionListeMouvementPeriodique(TableauMouvement.Cells[0,RowControleTableauMouvement],TableauMouvement.Cells[1,RowControleTableauMouvement],'',DateDebutPeriodeAnalyseMouvement,DateFinPeriodeAnalyseMouvement,PBeginLM,PEndLM);
