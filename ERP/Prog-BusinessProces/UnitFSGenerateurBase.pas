procedure TFSGenerateurBase.TableauTypeUniteFondsClick(Sender: TObject);
var  NumUniteFonds,CodeUniteFonds:integer;
begin
FSGenerateurBase.AfficheOptionsTypeUniteFonds.Visible:=false;

if(FSGenerateurBase.BitValiderUniteFonds.Caption='Modifier')then
begin
     OpenFParc(RParc);
     ChUniteFonds:=RParc.Parcours+'\'+Exercice+'FUniteFonds';
     assignfile(FUniteFonds,ChUniteFonds);
     try
     if FileExists(ChUniteFonds)then
     Reset(FUniteFonds)
     else Rewrite(FUniteFonds);
     Seek(FUniteFonds,0);
     NumUniteFonds:=1;
     CodeUniteFonds:=1;
     while not eof(FUniteFonds)do
     begin
          read(FUniteFonds,RUniteFonds);

          if(RUniteFonds.NumTypeUniteFonds=strtointeger(FSGenerateurBase.TableauTypeUniteFonds.Cells[1,FSGenerateurBase.TableauTypeUniteFonds.Row]))then
          begin
               if(strtointeger(Lastlaters(RUniteFonds.CodeUniteFonds,10-longueur(FSGenerateurBase.TableauTypeUniteFonds.Cells[2,FSGenerateurBase.TableauTypeUniteFonds.Row])))<=CodeUniteFonds)then CodeUniteFonds:=strtointeger(Lastlaters(RUniteFonds.CodeUniteFonds,10-longueur(FSGenerateurBase.TableauTypeUniteFonds.Cells[2,FSGenerateurBase.TableauTypeUniteFonds.Row])))+1;
          end;
     end;
     finally
     closefile(FUniteFonds);
     end;

     FSGenerateurBase.EditCodeUniteFonds.Text:=FSGenerateurBase.TableauTypeUniteFonds.Cells[2,FSGenerateurBase.TableauTypeUniteFonds.Row]+Completezerogauche(inttostr(CodeUniteFonds),inttostr(10-longueur(FSGenerateurBase.TableauTypeUniteFonds.Cells[2,FSGenerateurBase.TableauTypeUniteFonds.Row])));
end
else
begin
     FSGenerateurBase.AfficheOptionsUniteFonds.Visible:=false;
end;
ListeUniteFonds(FSGenerateurBase.TableauUniteFonds,FSGenerateurBase.TableauTypeUniteFonds.Cells[1,FSGenerateurBase.TableauTypeUniteFonds.Row]);
end;

