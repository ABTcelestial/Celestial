procedure TFSGenerateurBase.BitValiderAdresseProcesClick(Sender: TObject);
var  i,R:integer; OKAdresseProces,Confirme:boolean;  NomDossierPartageOut,EmlacementLocalOuReseauxOut:string;
begin
FSGenerateurBase.AfficheListeFichierConcerne.Visible:=false;

if(FSGenerateurBase.BitValiderAdresseProces.Caption='Valider')then
begin
OpenFParc(RParc);
ChAdresseProces:=RParc.Parcours+'\'+Exercice+'FAdresseProces';
assignfile(FAdresseProces,ChAdresseProces);
try
if FileExists(ChAdresseProces)then
Reset(FAdresseProces)
else Rewrite(FAdresseProces); //Nouveau Fichier FAdresseProces
Seek(FAdresseProces,0); //Ajout ou modification
i:=0;
OKAdresseProces:=false;
Confirme:=false;
while not eof(FAdresseProces)and(OKAdresseProces=false)and(Confirme=false)do
begin
     read(FAdresseProces,RAdresseProces);

     if(RAdresseProces.NumAdresseProces<>strtointeger(FSGenerateurBase.EditNumAdresseProces.Text))then
     begin
          if(RAdresseProces.TypeProces=FSGenerateurBase.EditTypeProces.Text)
          and((FSGenerateurBase.EditFichierConcerneAdresseProcecs.Text<>'Liste')and(RAdresseProces.FichierConcerne=FSGenerateurBase.EditFichierConcerneAdresseProcecs.Text))
          then
          begin
               Confirme:=true;
          end;
     end;

     if(RAdresseProces.NumAdresseProces=strtointeger(FSGenerateurBase.EditNumAdresseProces.Text))then
     begin
          OKAdresseProces:=true;
     end
     else i:=i+1;
end;

if(Confirme=true)then
begin
     showmessage('Le proces est dťjas enregistrť, veuillez choisir un autre SVP !');
     FSGenerateurBase.EditTypeProces.SetFocus;
end
else
begin
     Seek(FAdresseProces,i);
     RAdresseProces.NumAdresseProces:=strtointeger(FSGenerateurBase.EditNumAdresseProces.Text);
     RAdresseProces.TypeProces:=FSGenerateurBase.EditTypeProces.Text;
