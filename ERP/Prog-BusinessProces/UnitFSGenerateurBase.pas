procedure TFSGenerateurBase.BitValiderCompteurClick(Sender: TObject);
var i:integer;  OKCompteur:boolean;
begin

     OpenFParc(RParc);
     ChCompteur:=RParc.Parcours+'\'+Exercice+'FCompteur';
     assignfile(FCompteur,ChCompteur);
     try
     if FileExists(ChCompteur)then
     Reset(FCompteur)
     else Rewrite(FCompteur);
     Seek(FCompteur,0);
     i:=0;
     OKCompteur:=false;
     while not eof(FCompteur)and(OKCompteur=false)do
     begin
          Read(FCompteur,RCompteur);
          if(FSGenerateurBase.EditNumCompteur.Text<>'')
          and(RCompteur.NumCompteur=strtointeger(FSGenerateurBase.EditNumCompteur.Text))then
          begin
               OKCompteur:=true;
          end
          else i:=i+1;
     end;

     Seek(FCompteur,i);
     RCompteur.NumCompteur:=i;
     RCompteur.NumAffectationCompteur:=FSGenerateurBase.TableauAffectationCompteur.Cells[1,FSGenerateurBase.TableauAffectationCompteur.Row];
     RCompteur.CodeCompteur:=FSGenerateurBase.EditCodeCompteur.Text;
     RCompteur.DesignationCompteur:=FSGenerateurBase.EditDesignationCompteur.Text;
     RCompteur.IdentificateurCompteur:=FSGenerateurBase.EditIdentificateurCompteur.Text;
     RCompteur.CodeArticleGenerateur:=FSGenerateurBase.EditCodeArticleGenerateur.Text;

     if(FSGenerateurBase.RBStockRestant.Checked=true)then
     RCompteur.TypeIndicePrelevement:=FSGenerateurBase.RBStockRestant.Caption;

     if(FSGenerateurBase.RBCumuleSortie.Checked=true)then
     RCompteur.TypeIndicePrelevement:=FSGenerateurBase.RBCumuleSortie.Caption;

     if(FSGenerateurBase.RBStockSortant.Checked=true)then
     RCompteur.TypeIndicePrelevement:=FSGenerateurBase.RBStockSortant.Caption;

     RCompteur.CodeTypeFormule:=FSGenerateurBase.EditCodeTypeFormuleCompteur.Text;

     Write(FCompteur,RCompteur);

     finally
     Closefile(FCompteur);
     end;

     ProcAfficheListeCompteur(FSGenerateurBase.TableauCompteur,'',FSGenerateurBase.TableauAffectationCompteur.Cells[1,FSGenerateurBase.TableauAffectationCompteur.Row]);
     FSGenerateurBase.AfficheOperationCompteur.Visible:=false;
     FSGenerateurBase.TableauCompteur.SetFocus;

end;

