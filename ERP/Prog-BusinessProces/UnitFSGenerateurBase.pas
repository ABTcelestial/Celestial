Function ListePlanComptableStockTypeMouvement:string;
var  TypeProcesMouvemen,FichierConserneMouvemen,AdresseMouvemen,TypeProcesReseauxMouvemen,NomDossierPartageReseauxOutMouvemen,ListeCompteStock:string;
begin
     ListeCompteStock:='';

     TypeProcesMouvemen:='Business';   FichierConserneMouvemen:='FMouvement';
     if not(FunctionAdresseProces(TypeProcesMouvemen,FichierConserneMouvemen,'',AdresseMouvemen,TypeProcesReseauxMouvemen,NomDossierPartageReseauxOutMouvemen))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConserneMouvemen+' recherchť !');
     end;

     ChMouvement:=AdresseMouvemen;
     assignfile(FMouvement,ChMouvement);
     if FileExists(ChMouvement)then
     begin
          try
          Reset(FMouvement);
          seek(FMouvement,0);
          while not eof(FMouvement)do
          begin
               Read(FMouvement,RMouvement); Application.ProcessMessages;

               if(RMouvement.CompteConserne<>'')then
               begin
                    if(ListeCompteStock='')then
                    begin
                         ListeCompteStock:=RMouvement.CompteConserne;
                    end
                    else
                    begin
                         if not(ExisteNumInTexte(RMouvement.CompteConserne,ListeCompteStock))then ListeCompteStock:=ListeCompteStock+';'+RMouvement.CompteConserne;
                    end;
               end;
          end;
          finally
          CloseFile(FMouvement);
          end;
     end;

     ListePlanComptableStockTypeMouvement:=ListeCompteStock;
end;

Procedure ListeCompteComptableInventaireGlobal(TableauCompteComptable:TStringGrid; Ordre:integer; TypeComptabilite:string);
var i:integer; ExisteCompte:boolean;  TypeProces,FichierConcerne,Adresse,CompteComptableStock:string;
begin
FSGenerateurBase.EditCodeCompteSelect.Text:='';

FSGenerateurBase.AfficheAttenteInventaireGlobale.Visible:=true;
FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Min:=0;
FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Smooth:=false;

TableauCompteComptable.ColCount:=10;
TableauCompteComptable.Cols[1].Text:='Cd';
TableauCompteComptable.Cols[2].Text:='Dťsignation';
TableauCompteComptable.Cols[3].Text:='C/P';
TableauCompteComptable.Cols[4].Text:='Nombre';
TableauCompteComptable.Cols[5].Text:='Qte';
TableauCompteComptable.Cols[6].Text:='CoŻt';
TableauCompteComptable.Cols[7].Text:='Valeur';
TableauCompteComptable.Cols[8].Text:='Marge';
TableauCompteComptable.Cols[9].Text:='%';

TableauCompteComptable.RowCount:=2;
TableauCompteComptable.Rows[1].Text:='';

TypeProces:='Comptabilitť';
case Ordre of
     1: FichierConcerne:='FClasse'+TypeComptabilite;
     2: FichierConcerne:='FSousClasse'+TypeComptabilite;
     3: FichierConcerne:='FCategorie'+TypeComptabilite;
     4: FichierConcerne:='FSousCategorie'+TypeComptabilite;
     5: FichierConcerne:='FFamille'+TypeComptabilite;
     6: FichierConcerne:='FSousFamille'+TypeComptabilite;
     end;

if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
begin
     if(FichierConcerne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier recherchť !'+' {'+FichierConcerne+'}');
end;

assignfile(FRegistreCompte,Adresse);
try
if FileExists(Adresse)
then Reset(FRegistreCompte)else Rewrite(FRegistreCompte);
Seek(FRegistreCompte,0);
i:=0;

CompteComptableStock:=ListePlanComptableStockTypeMouvement;

FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Max:=FileSize(FRegistreCompte);

while not eof(FRegistreCompte) do
begin
     Read(FRegistreCompte,RRegistreCompte);  Application.ProcessMessages;

     FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.StepIt;

     ExisteCompte:=ExisteStockArticlePlanComptable(RRegistreCompte.CodeCompte);

     if(ExisteCompte=true)then
     begin
          if(CompteComptableStock<>'')then
          begin
               if ExisteFirstLatersNuminTexte(RRegistreCompte.CodeCompte,CompteComptableStock)
               then ExisteCompte:=true
               else ExisteCompte:=false;
          end;
     end;

     if(ExisteCompte=true)then
     begin
          i:=i+1;

          TableauCompteComptable.Rows[i].Text:=inttostr(i);
          TableauCompteComptable.Cells[1,i]:=RRegistreCompte.CodeCompte;
          TableauCompteComptable.Cells[2,i]:=RRegistreCompte.Designation;
          TableauCompteComptable.Cells[3,i]:=booleantostr(RRegistreCompte.ContrePartie.UsesCompte);
          TableauCompteComptable.Cells[4,i]:='';
          TableauCompteComptable.Cells[5,i]:='';
          TableauCompteComptable.Cells[6,i]:='';
          TableauCompteComptable.Cells[7,i]:='';
          TableauCompteComptable.Cells[8,i]:='';
          TableauCompteComptable.Cells[9,i]:='';
     end;
end;
finally
closefile(FRegistreCompte);
end;

if(i>0)then
       begin
            TableauCompteComptable.RowCount:=i+3;
            TableauCompteComptable.Rows[TableauCompteComptable.RowCount-1].Text:='';
            TableauCompteComptable.Rows[TableauCompteComptable.RowCount-2].Text:='';
       end
       else TableauCompteComptable.RowCount:=2;

AjusterColWidth(TableauCompteComptable,'','');
//TrierTableauARowSpecial(TableauCompteComptable,1,TableauCompteComptable.RowCount-3,1,FSGenerateurBase.EditRubriqueTrieInventaireGlobal.Text,'','+');

TableauCompteComptable.Cells[0,0]:=inttostr(Ordre);

FSGenerateurBase.AfficheAttenteInventaireGlobale.Visible:=false;
end;

Procedure ProcAfficheListeStockInventaireGlobal(TableauStock:TStringGrid; AdresseStock,CodeSFamille,CodeArticleRowSelect,ListeCompteConcerne:string; AvecCodeBarre:boolean);
var  k,ARowSelect:integer; OKStock:boolean;  NotCol,TypeData,TypeStock:string;
begin
FSGenerateurBase.EditCodeCompteSelect.Text:=CodeSFamille;

FSGenerateurBase.AfficheAttenteInventaireGlobale.Visible:=true;
FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Min:=0;
FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Smooth:=false;

AccelerationAffichageTableau(TableauStock,true);

TypeStock:='Article';
if(ExisteCharinString('Marche',FichierConcerne)=true)then TypeStock:='Marche';

TableauStock.ColCount:=10;
TableauStock.Cols[0].Text:='Nį';
TableauStock.Cols[1].Text:='Code';
TableauStock.Cols[2].Text:='Dťsignation';
TableauStock.Cols[3].Text:='Rťference';
TableauStock.Cols[4].Text:='UM';
TableauStock.Cols[5].Text:='Qte';
TableauStock.Cols[6].Text:='CoŻt';
TableauStock.Cols[7].Text:='Valeur';
TableauStock.Cols[8].Text:='Marge';
TableauStock.Cols[9].Text:='%';

TableauStock.RowCount:=2;
TableauStock.Rows[1].Text:='';

ChStock:=AdresseStock;
assignfile(FStock,ChStock);
try
if FileExists(ChStock)then
Reset(FStock)
else Rewrite(FStock);
Seek(FStock,0);
k:=0;
ARowSelect:=1;

FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Max:=FileSize(FStock);

while not eof(FStock)do
begin
     read(FStock,RStock);

     FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.StepIt;

     if(RStock.UM<>'Pst')and(RStock.UM<>'H')
     then OKStock:=true
     else OKStock:=false;

     if(OKStock=true)then
     begin
          if(CodeSFamille<>'')then
          begin
               if(Firstlaters(RStock.Code,longueur(CodeSFamille))=CodeSFamille)
               then OKStock:=true
               else OKStock:=false;
          end;
     end;

     if(OKStock=true)then
     begin
          if(ListeCompteConcerne<>'')then
          begin
               if ExisteFirstLatersNuminTexte(RStock.Code,ListeCompteConcerne)
               then OKStock:=true
               else OKStock:=false;
          end;
     end;

     if(OKStock=true)then
     begin
          if(AvecCodeBarre=true)then
          begin
               OKStock:=CodeBareCorrecte(RStock.Code,RStock.CodeBarre);
          end;
     end;

     if(OKStock=true)then
     begin
          k:=k+1;
          TableauStock.Rows[k].Text:=inttostr(k);
          TableauStock.Cells[1,k]:=RStock.Code;
          TableauStock.Cells[2,k]:=RStock.Design;
          TableauStock.Cells[3,k]:=RStock.Ref;
          TableauStock.Cells[4,k]:=RStock.UM;
          TableauStock.Cells[5,k]:=Vergule(floattostr(RStock.QteStock),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[6,k]:=Vergule(floattostr(RStock.CoutUnitaire),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[7,k]:=Vergule(floattostr(RStock.PrixVenteDetaille),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[8,k]:='';
          TableauStock.Cells[9,k]:='';
     end;
end;
finally
closefile(FStock);
end;

if(k>0)then
       begin
            TableauStock.RowCount:=k+3;
            TableauStock.Rows[TableauStock.RowCount-1].Text:='';
            TableauStock.Rows[TableauStock.RowCount-2].Text:='';
       end
       else TableauStock.RowCount:=2;

NotCol:='';

for k:=1 to TableauStock.ColCount-3 do if existenumintexte(inttostr(k),NotCol)then TableauStock.ColWidths[k]:=0;
AjusterColWidth(TableauStock,'',NotCol);
if(TableauStock.ColWidths[2]>500)then TableauStock.ColWidths[2]:=500;

{if(FSGenerateurBase.EditRubriqueTrieInventaireGlobal.Text<>'1')then
begin
     TypeData:='';
     if strtointeger(FSGenerateurBase.EditRubriqueTrieInventaireGlobal.Text)in[1,5,6,7,8,9]then TypeData:='Num';
     TrierTableauARowSpecial(TableauStock,1,TableauStock.RowCount-3,1,FSGenerateurBase.EditRubriqueTrieInventaireGlobal.Text,TypeData,FSGenerateurBase.EditTypeTrie.Text);
end;}

if(CodeArticleRowSelect<>'')then
begin
     K:=1;
     while(K<=TableauStock.RowCount-3)and(CodeArticleRowSelect<>'')do
     begin
          if(TableauStock.Cells[1,k]=CodeArticleRowSelect)then
          begin
               ARowSelect:=k;
               CodeArticleRowSelect:='';
          end;
     K:=K+1;
     end;
end;

TableauStock.Row:=ARowSelect;

AccelerationAffichageTableau(TableauStock,false);
if(FSGenerateurBase.AfficheRegularisationCoutValeurAjouter.Visible=false)then TableauStock.SetFocus;

TableauStock.Cells[0,0]:='10';

FSGenerateurBase.AfficheAttenteInventaireGlobale.Visible:=false;
end;

