                    FSGenerateurBase.EditNomPosteReseaux.Text:=ExtractFileName(FSGenerateurBase.EditAdresseDossierPartageReseaux.Text);

                    if(Firstlaters(FSGenerateurBase.EditAdresseDossierPartageReseaux.Text,2)='\\')
                    then
