                                          begin
                                               OKProjetFinance:=true;

                                               if(TableauMouvement.Cells[10,RowControleTableauMouvement]='*')then
                                               begin
                                                    SigneMouvement:='+';
                                               end
                                               else
                                               begin
                                                    SigneMouvement:=TableauMouvement.Cells[10,RowControleTableauMouvement];
                                               end;
                                          end
                                          else OKProjetFinance:=false;
                                     end
                                     else
                                     begin
                                          OKProjetFinance:=true;

                                          if(TableauMouvement.Cells[10,RowControleTableauMouvement]='*')then
                                          begin
                                               SigneMouvement:='+';
                                          end
