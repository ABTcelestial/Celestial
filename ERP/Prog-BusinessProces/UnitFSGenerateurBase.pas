Procedure ListeArticleDetailStructure(TableauArticleDetailStructure:TStringGrid; NumProjetFinance,ListePositionDetailStructure,RongTypeAffichage,CodePlanComptable,NotRow,NotCol:string; AfficherCout,AfficherPrix,CummuleMemeArticle,OKUniquementArticleDSPlanifier,ReservePremierRow:boolean; RowIn,PourcentageMajorationQuantite:integer; var RowOut:integer; var ListeTypeStock,ListeTypeComptabilite:string);
var Row,l,ROper:integer; OKArticleDetailStructure,OKExisteArticle:boolean;  QteLast,QteNew,PrixLast,PrixNew,CoutLast,CoutNew,QteTotal,MontantTotal,CoutTotal,ValeurFinance:real;
begin
     if(RongTypeAffichage='')then RongTypeAffichage:='10';

     RowOut:=1;

     if(RowIn=0)then
     begin
          TableauArticleDetailStructure.ColCount:=12;
          TableauArticleDetailStructure.Cols[0].Text:='Nį';
          TableauArticleDetailStructure.Cols[1].Text:='Pį';
          TableauArticleDetailStructure.Cols[2].Text:='PįDS';
          TableauArticleDetailStructure.Cols[3].Text:='NumPF';
          TableauArticleDetailStructure.Cols[4].Text:='TypeStock';
          TableauArticleDetailStructure.Cols[5].Text:='TypeComptabilite';
          TableauArticleDetailStructure.Cols[6].Text:='Code Article';
          TableauArticleDetailStructure.Cols[7].Text:='Dťsignation Article';
          TableauArticleDetailStructure.Cols[8].Text:='Qte Globale';
          TableauArticleDetailStructure.Cols[9].Text:='CoŻt';
          TableauArticleDetailStructure.Cols[10].Text:='Prix';
          TableauArticleDetailStructure.Cols[11].Text:='U.M.';

          if(AfficherCout=true)or(AfficherPrix=true)then
          begin
               TableauArticleDetailStructure.Cols[12].Text:='Montant';
               TableauArticleDetailStructure.ColCount:=13;
          end;

          if(ReservePremierRow=true)then
          begin
               TableauArticleDetailStructure.RowCount:=3;
               TableauArticleDetailStructure.Rows[1].Text:='';
               TableauArticleDetailStructure.Rows[2].Text:='';
               TableauArticleDetailStructure.FixedRows:=2;
               NotRow:='1';
               Row:=1;
          end
          else
          begin
               TableauArticleDetailStructure.RowCount:=2;
               TableauArticleDetailStructure.Rows[1].Text:='';
               TableauArticleDetailStructure.FixedRows:=1;
               NotRow:='';
               Row:=0;
          end;
     end
     else
     begin
          Row:=RowIn;

          if(ReservePremierRow=true)then
          begin
               NotRow:='1';
          end
          else
          begin
               NotRow:='';
          end;
     end;

     OpenFParc(RParc);
     ChArticleDetailStructure:=RParc.Parcours+'\'+Exercice+'FArticleDetailStructure';
     assignfile(FArticleDetailStructure,ChArticleDetailStructure);
     try
     if FileExists(ChArticleDetailStructure)then
     Reset(FArticleDetailStructure)
     else Rewrite(FArticleDetailStructure);
     Seek(FArticleDetailStructure,0);
     ListeTypeStock:='';
     ListeTypeComptabilite:='';
     while not eof(FArticleDetailStructure)do
     begin
          read(FArticleDetailStructure,RArticleDetailStructure);

          if(ListeTypeStock='')
          then ListeTypeStock:=RArticleDetailStructure.TypeStockStructure
          else                                              
          begin
               if(not(FunctionFichierInclu(RArticleDetailStructure.TypeStockStructure,ListeTypeStock)))
               then ListeTypeStock:=ListeTypeStock+';'+RArticleDetailStructure.TypeStockStructure;
          end;

          if(ListeTypeComptabilite='')
          then ListeTypeComptabilite:=RArticleDetailStructure.TypeComptabiliteStructure
          else
          begin
               if(not(FunctionFichierInclu(RArticleDetailStructure.TypeComptabiliteStructure,ListeTypeComptabilite)))
               then ListeTypeComptabilite:=ListeTypeComptabilite+';'+RArticleDetailStructure.TypeComptabiliteStructure;
          end;

          if(NumProjetFinance<>'')then
          begin
               if(Firstlaters(RArticleDetailStructure.NumProjetFinance,longueur(NumProjetFinance))=NumProjetFinance)
               then OKArticleDetailStructure:=true
               else OKArticleDetailStructure:=false;
          end
          else
          begin
               if(RArticleDetailStructure.NumProjetFinance=NumProjetFinance)
               then OKArticleDetailStructure:=true
               else OKArticleDetailStructure:=false;
          end;

          if(OKArticleDetailStructure=true)then
          begin
               if(CodePlanComptable<>'')then
               begin
                    if(ExisteFirstLatersNuminTexte(RArticleDetailStructure.CodeArticleDetailStructure,CodePlanComptable))
                    then OKArticleDetailStructure:=true
                    else OKArticleDetailStructure:=false;
               end;
          end;

          if(OKArticleDetailStructure=true)then
          begin
               if(ListePositionDetailStructure<>'')then
               begin
                    if(Existenumintexte(inttostr(RArticleDetailStructure.PositionDetailStructure),ListePositionDetailStructure))
                    then OKArticleDetailStructure:=true
                    else OKArticleDetailStructure:=false;
               end;
          end;

          if(OKArticleDetailStructure=true)then
          begin
               if(OKUniquementArticleDSPlanifier=true)then OKArticleDetailStructure:=ExistePositionDetailStructurePlanifier(RArticleDetailStructure.NumProjetFinance,inttostr(RArticleDetailStructure.PositionDetailStructure));
          end;

          if(OKArticleDetailStructure=true)then
          begin
               if(CummuleMemeArticle=true)then
               begin
                    if(ReservePremierRow=true)then l:=2 else l:=1;
                    OKExisteArticle:=false;
                    while(l<=Row)and(OKExisteArticle=false)do
                    begin
                         if(Firstlaters(RArticleDetailStructure.CodeArticleDetailStructure,strtointeger(RongTypeAffichage))=TableauArticleDetailStructure.Cells[6,l])then
                         begin
                              OKExisteArticle:=true;
                              ROper:=l;
                         end;
                    l:=l+1;
                    end;
               end
               else OKExisteArticle:=false;
          end;

          if(OKArticleDetailStructure=true)then
          begin
               if(OKExisteArticle=true)then
               begin
                    {TableauArticleDetailStructure.Rows[ROper].Text:=inttostr(ROper);
                    TableauArticleDetailStructure.Cells[1,ROper]:=inttostr(RArticleDetailStructure.PositionArticleDetailStructure);
                    TableauArticleDetailStructure.Cells[2,ROper]:=inttostr(RArticleDetailStructure.PositionDetailStructure);
                    TableauArticleDetailStructure.Cells[3,ROper]:=RArticleDetailStructure.NumProjetFinance;
                    TableauArticleDetailStructure.Cells[4,ROper]:=RArticleDetailStructure.TypeStockStructure;
                    TableauArticleDetailStructure.Cells[5,ROper]:=RArticleDetailStructure.TypeComptabiliteStructure;
                    TableauArticleDetailStructure.Cells[6,ROper]:=Firstlaters(RArticleDetailStructure.CodeArticleDetailStructure,strtointeger(RongTypeAffichage));
                    if(strtointeger(RongTypeAffichage)=10)then
                    begin
                         RStockArticle:=ChercherStockArticle(RArticleDetailStructure.TypeStockStructure,'',TableauArticleDetailStructure.Cells[6,R]);
                         TableauArticleDetailStructure.Cells[7,ROper]:=RStockArticle.Design+' '+RStockArticle.Ref;
                    end
                    else
                    begin
                         ChercherCompteComptable(TableauArticleDetailStructure.Cells[6,R],RongTypeAffichage,RArticleDetailStructure.TypeComptabiliteStructure,RRegistreCompte);
                         TableauArticleDetailStructure.Cells[7,ROper]:=RRegistreCompte.Designation;
                    end;}

                    QteLast:=strtoreal(TableauArticleDetailStructure.Cells[8,ROper]);
                    PrixLast:=strtoreal(TableauArticleDetailStructure.Cells[9,ROper]);
                    CoutLast:=strtoreal(TableauArticleDetailStructure.Cells[10,ROper]);

                    QteNew:=RArticleDetailStructure.QuantiteArticleDetailStructure*((100+FSGenerateurBase.IncrimenteEditMojorationQuantite.Position)/100);
                    PrixNew:=RArticleDetailStructure.PrixArticleDetailStructure;
                    CoutNew:=RArticleDetailStructure.CoutArticleDetailStructure;

                    TableauArticleDetailStructure.Cells[8,ROper]:=Vergule(floattostr(QteLast+QteNew),'2','C','');
                    TableauArticleDetailStructure.Cells[9,ROper]:=Vergule(floattostr(((QteLast*CoutLast)+(QteNew*CoutNew))/(QteLast+QteNew)),'2','C','');
                    TableauArticleDetailStructure.Cells[10,ROper]:=Vergule(floattostr(((QteLast*PrixLast)+(QteNew*PrixNew))/(QteLast+QteNew)),'2','C','');

                    ValeurFinance:=0;
                    if(AfficherCout=true)then ValeurFinance:=CoutNew;
                    if(AfficherPrix=true)then ValeurFinance:=PrixNew;

                    if(AfficherCout=true)or(AfficherPrix=true)then
                    begin
                         TableauArticleDetailStructure.Cells[12,ROper]:=Vergule(floattostr(strtoreal(TableauArticleDetailStructure.Cells[12,ROper])+(QteNew*ValeurFinance)),'2','C','');
                         MontantTotal:=MontantTotal+(QteNew*RArticleDetailStructure.PrixArticleDetailStructure);
                         CoutTotal:=CoutTotal+(QteNew*RArticleDetailStructure.CoutArticleDetailStructure);
                         QteTotal:=QteTotal+QteNew;
                    end;

                    //TableauArticleDetailStructure.Cells[9,ROper]:=RArticleDetailStructure.UniteMArtcleDetailStructure;
               end
               else
               begin
                    Row:=Row+1;
                    TableauArticleDetailStructure.Rows[Row].Text:=inttostr(Row-1);
                    TableauArticleDetailStructure.Cells[1,Row]:=inttostr(RArticleDetailStructure.PositionArticleDetailStructure);
                    TableauArticleDetailStructure.Cells[2,Row]:=inttostr(RArticleDetailStructure.PositionDetailStructure);
                    TableauArticleDetailStructure.Cells[3,Row]:=RArticleDetailStructure.NumProjetFinance;
                    TableauArticleDetailStructure.Cells[4,Row]:=RArticleDetailStructure.TypeStockStructure;
                    TableauArticleDetailStructure.Cells[5,Row]:=RArticleDetailStructure.TypeComptabiliteStructure;
                    TableauArticleDetailStructure.Cells[6,Row]:=Firstlaters(RArticleDetailStructure.CodeArticleDetailStructure,strtointeger(RongTypeAffichage));

                    if(strtointeger(RongTypeAffichage)=10)then
                    begin
                         RStockArticle:=ChercherStockArticle(RArticleDetailStructure.TypeStockStructure,'',TableauArticleDetailStructure.Cells[6,Row],'',OKStockRecherche,RubriqueRecherche);
                         TableauArticleDetailStructure.Cells[7,Row]:=RStockArticle.Design+' '+RStockArticle.Ref;
                    end
                    else
                    begin
                         ChercherCompteComptable(TableauArticleDetailStructure.Cells[6,Row],RongTypeAffichage,RArticleDetailStructure.TypeComptabiliteStructure,RRegistreCompte);
                         TableauArticleDetailStructure.Cells[7,Row]:=RRegistreCompte.Designation;
                    end;

                    QteNew:=RArticleDetailStructure.QuantiteArticleDetailStructure*((100+FSGenerateurBase.IncrimenteEditMojorationQuantite.Position)/100);
                    TableauArticleDetailStructure.Cells[8,Row]:=Vergule(floattostr(QteNew),'2','C','');
                    TableauArticleDetailStructure.Cells[9,Row]:=Vergule(floattostr(RArticleDetailStructure.CoutArticleDetailStructure),'2','C','');
                    TableauArticleDetailStructure.Cells[10,Row]:=Vergule(floattostr(RArticleDetailStructure.PrixArticleDetailStructure),'2','C','');
                    TableauArticleDetailStructure.Cells[11,Row]:=RArticleDetailStructure.UniteMArticleDetailStructure;

                    ValeurFinance:=0;
                    if(AfficherCout=true)then ValeurFinance:=RArticleDetailStructure.CoutArticleDetailStructure;
                    if(AfficherPrix=true)then ValeurFinance:=RArticleDetailStructure.PrixArticleDetailStructure;

                    if(AfficherCout=true)or(AfficherPrix=true)then
                    begin
                         TableauArticleDetailStructure.Cells[12,Row]:=Vergule(floattostr(QteNew*ValeurFinance),'2','C','');
                         MontantTotal:=MontantTotal+(QteNew*ValeurFinance);
                         CoutTotal:=CoutTotal+(QteNew*RArticleDetailStructure.CoutArticleDetailStructure);
                         QteTotal:=QteTotal+QteNew;
                    end;
               end;
          end;
     end;
     finally
     CloseFile(FArticleDetailStructure);
     end;

     if(Row>0)then
            begin
                 if(AfficherCout=true)or(AfficherPrix=true)then
                 begin
                      TableauArticleDetailStructure.RowCount:=Row+3;
                      TableauArticleDetailStructure.Rows[TableauArticleDetailStructure.RowCount-1].Text:='';
                      TableauArticleDetailStructure.Rows[TableauArticleDetailStructure.RowCount-2].Text:='';

                      TableauArticleDetailStructure.Cells[7,TableauArticleDetailStructure.RowCount-1]:='Total:';

                      TableauArticleDetailStructure.Cells[8,TableauArticleDetailStructure.RowCount-1]:=Vergule(floattostr(QteTotal),'2','C','');
                      TableauArticleDetailStructure.Cells[9,TableauArticleDetailStructure.RowCount-1]:=Vergule(floattostr(CoutTotal),'2','C','');
                      TableauArticleDetailStructure.Cells[12,TableauArticleDetailStructure.RowCount-1]:=Vergule(floattostr(MontantTotal),'2','C','');
                      
                 end
                 else
                 begin
                      TableauArticleDetailStructure.RowCount:=Row+1;
                 end;
            end
            else TableauArticleDetailStructure.RowCount:=2;
            
     RowOut:=Row;

     for l:=1 to TableauArticleDetailStructure.ColCount-1 do if ExistenumInTexte(inttostr(l),NotCol)then TableauArticleDetailStructure.ColWidths[l]:=0;
     for l:=1 to TableauArticleDetailStructure.RowCount-1 do if ExistenumInTexte(inttostr(l),NotRow)then TableauArticleDetailStructure.RowHeights[l]:=0;

     AjusterColWidth(TableauArticleDetailStructure,NotRow,NotCol);
end;

