end;

if(ip>0)then TableauBaseAvis.RowCount:=ip+1
        else TableauBaseAvis.RowCount:=2;

TrierTableauARowSpecial(TableauBaseAvis,1,TableauBaseAvis.RowCount-1,1,FSGenerateurBase.EditIndiceRubriqueTrieBaseAvis.Text,FSGenerateurBase.EditTypeDataTrieBaseAvis.Text,'+');

AjusterColWidth(TableauBaseAvis,'','');

