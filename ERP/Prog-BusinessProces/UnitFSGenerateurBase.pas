Function ChoisirNbrBaseAvis(OKAfficheCoisBaseAvis:boolean; Requette:string; var BaseAvisFirst:string):integer;
var   R,NbrBaseAvis:integer; TypeProces,FichierConserne,Adresse:string;
begin
     TypeProces:='Business';   FichierConserne:='FBaseAvis';
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConserne+' recherchť !');
     end;

     ChBaseAvis:=Adresse;
     assignfile(FBaseAvis,ChBaseAvis);
     try
     if FileExists(ChBaseAvis)then
     Reset(FBaseAvis)
     else Rewrite(FBaseAvis);
     Seek(FBaseAvis,0);
     NbrBaseAvis:=0;
     BaseAvisFirst:='';
     while not eof(FBaseAvis)do
     begin
          read(FBaseAvis,RBaseAvis);
          if(RBaseAvis.DesignationBaseAvis<>'')then
          begin
               NbrBaseAvis:=NbrBaseAvis+1;
               if(BaseAvisFirst='')then BaseAvisFirst:=RBaseAvis.DesignationBaseAvis;
          end;
     end;
     finally
     CloseFile(FBaseAvis);
     end;

     ChoisirNbrBaseAvis:=NbrBaseAvis;

     if(OKAfficheCoisBaseAvis=true)then
     begin
          if(NbrBaseAvis=0)then
          begin
               showmessage('Aucune base avis enregistrť !');
          end
          else
          if(NbrBaseAvis=1)then
          begin

          end
          else
          if(NbrBaseAvis>1)then
          begin
               FSRessourceFinanciere.Show;
               ListeBaseAvis(FSRessourceFinanciere.TableauBaseAvis);
               FSRessourceFinanciere.TableauBaseAvis.ColCount:=FSRessourceFinanciere.TableauBaseAvis.ColCount+1;
               FSRessourceFinanciere.TableauBaseAvis.Cols[FSRessourceFinanciere.TableauBaseAvis.ColCount-1].Text:='Sťlect';

               if(Requette<>'AV')then for R:=1 to FSRessourceFinanciere.TableauBaseAvis.RowCount-1 do FSRessourceFinanciere.TableauBaseAvis.Cells[3,R]:='OK';

               AjusterColWidth(FSRessourceFinanciere.TableauBaseAvis,'','');
               FSRessourceFinanciere.TableauBaseAvis.SetFocus;

               FSRessourceFinanciere.TableauBaseAvis.Cells[0,0]:=Requette;
          end;
     end;
