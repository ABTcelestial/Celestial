procedure TFSGenerateurBase.BitBtn87Click(Sender: TObject);
var  R,C,l:integer;  TypeStock,NotCol:string;
begin
     FSEtatStocks.Show;

     FSEtatStocks.TableauStockArticle.RowCount:=FSGenerateurBase.TableauStockArticle.RowCount;
     FSEtatStocks.TableauStockArticle.ColCount:=FSGenerateurBase.TableauStockArticle.ColCount;

     for C:=0 to FSGenerateurBase.TableauStockArticle.ColCount-1 do
     begin
          FSEtatStocks.TableauStockArticle.Cols[C].Text:=FSGenerateurBase.TableauStockArticle.Cols[C].Text;
     end;

     FSEtatStocks.TableauStockArticle.Cells[5,0]:=FSGenerateurBase.TableauStockArticle.Cells[8,0];
     FSEtatStocks.TableauStockArticle.Cells[6,0]:=FSGenerateurBase.TableauStockArticle.Cells[5,0];
     FSEtatStocks.TableauStockArticle.Cells[7,0]:=FSGenerateurBase.TableauStockArticle.Cells[6,0];
     FSEtatStocks.TableauStockArticle.Cells[8,0]:=FSGenerateurBase.TableauStockArticle.Cells[7,0];

     for R:=1 to FSGenerateurBase.TableauStockArticle.RowCount-1 do
     begin
          for C:=0 to FSGenerateurBase.TableauStockArticle.ColCount-1 do
          begin
               FSEtatStocks.TableauStockArticle.Cells[C,R]:=FSGenerateurBase.TableauStockArticle.Cells[C,R];
          end;

          FSEtatStocks.TableauStockArticle.Cells[5,R]:=FSEtatStocks.TableauStockArticle.Cells[8,R];
          FSEtatStocks.TableauStockArticle.Cells[6,R]:='0';//'Qte.Entrťe'
          FSEtatStocks.TableauStockArticle.Cells[7,R]:='0';//'Qte.Sortie'
          //FSEtatStocks.TableauStockArticle.Cells[8,R]:=FSEtatStocks.TableauStockArticle.Cells[8,R];//'Qte.en Stock'

          for l:=1 to FSGenerateurBase.TableauDetailMouvement.RowCount-1 do
          begin
               if(FSEtatStocks.TableauStockArticle.Cells[1,R]=FSGenerateurBase.TableauDetailMouvement.Cells[2,l])then
               begin
                     if(FSGenerateurBase.TableauDetailMouvement.Cells[6,l]='-')then
                     begin
                          FSEtatStocks.TableauStockArticle.Cells[7,R]:=floattostr(strtoreal(FSEtatStocks.TableauStockArticle.Cells[7,R])+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,l]));
                          FSEtatStocks.TableauStockArticle.Cells[8,R]:=floattostr(strtoreal(FSEtatStocks.TableauStockArticle.Cells[8,R])-strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,l]));
                     end;

                     if(FSGenerateurBase.TableauDetailMouvement.Cells[6,l]='+')then
                     begin
                          if((strtoreal(FSEtatStocks.TableauStockArticle.Cells[8,R])+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,l]))>0)
                          then FSEtatStocks.TableauStockArticle.Cells[10,R]:=floattostr(((strtoreal(FSEtatStocks.TableauStockArticle.Cells[8,R])*strtoreal(FSEtatStocks.TableauStockArticle.Cells[10,R]))+(strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,l])*strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[5,l])))/(strtoreal(FSEtatStocks.TableauStockArticle.Cells[8,R])+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,l])));
                          FSEtatStocks.TableauStockArticle.Cells[6,R]:=floattostr(strtoreal(FSEtatStocks.TableauStockArticle.Cells[6,R])+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,l]));
                          FSEtatStocks.TableauStockArticle.Cells[8,R]:=floattostr(strtoreal(FSEtatStocks.TableauStockArticle.Cells[8,R])+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,l]));
                     end;
               end;
          end;
     end;

     for R:=1 to FSGenerateurBase.TableauStockArticle.RowCount-1 do
     begin
          FSEtatStocks.TableauStockArticle.Cells[5,R]:=Vergule(FSEtatStocks.TableauStockArticle.Cells[5,R],'2','C','');
          FSEtatStocks.TableauStockArticle.Cells[6,R]:=Vergule(FSEtatStocks.TableauStockArticle.Cells[6,R],'2','C','');
          FSEtatStocks.TableauStockArticle.Cells[7,R]:=Vergule(FSEtatStocks.TableauStockArticle.Cells[7,R],'2','C','');
          FSEtatStocks.TableauStockArticle.Cells[8,R]:=Vergule(FSEtatStocks.TableauStockArticle.Cells[8,R],'2','C','');
     end;

     TypeStock:='Article';
     if(ExisteCharinString('Marche','FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text)=true)then TypeStock:='Marche';

     if(TypeStock='Marche')
     then NotCol:='5-9;14-18'
     else NotCol:='9-18';
     for C:= 1 to FSEtatStocks.TableauStockArticle.ColCount-1 do if(Existenumintexte(inttostr(C),NotCol))then FSEtatStocks.TableauStockArticle.ColWidths[C]:=0;
     AjusterColWidth(FSEtatStocks.TableauStockArticle,'',NotCol);
end;

