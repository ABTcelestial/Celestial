                                    begin
                                         QteSortiePrelevement:=RArchivePrelevementCompteur.ValeurPrelevement-RArchivePrelevementCompteur.ValeurInitiale;
                                    end
                                    else
                                    if(RCompteurCopie.TypeIndicePrelevement='Stock Sortant.')then
                                    begin
                                         QteSortiePrelevement:=RArchivePrelevementCompteur.ValeurPrelevement;
                                    end;

                                    SigneMouvement:='-';

                                    EtatEntreeSortie:='';
                                    if(SigneMouvement='+')then EtatEntreeSortie:='E';
                                    if(SigneMouvement='-')then EtatEntreeSortie:='S';

                                    RowTableauDetailMouvementEntree:=RowTableauDetailMouvementEntree+1;
                                    TableauDetailMouvement.Rows[RowTableauDetailMouvementEntree].Text:=inttostr(RowTableauDetailMouvementEntree);
                                    TableauDetailMouvement.Cells[1,RowTableauDetailMouvementEntree]:=RArchivePrelevementCompteur.DatePrelevement;
                                    TableauDetailMouvement.Cells[2,RowTableauDetailMouvementEntree]:=RArchivePrelevementCompteur.CodeArticle;
                                    TableauDetailMouvement.Cells[3,RowTableauDetailMouvementEntree]:='';//RStock.Design+' '+RStock.Ref+' {'+RStock.UM+'}';
                                    TableauDetailMouvement.Cells[4,RowTableauDetailMouvementEntree]:=Vergule(floattostr(QteSortiePrelevement),'2','C','');
                                    TableauDetailMouvement.Cells[5,RowTableauDetailMouvementEntree]:=Vergule(floattostr(RArchivePrelevementCompteur.PrixPrelevement),'2','C','');
                                    TableauDetailMouvement.Cells[6,RowTableauDetailMouvementEntree]:=SigneMouvement;
                                    TableauDetailMouvement.Cells[7,RowTableauDetailMouvementEntree]:='PrťlŤvement Nį: '+inttostr(RArchivePrelevementCompteur.NumPrelevement);
                                    FSGenerateurBase.MemoRapport.Lines.Add('Article: '+TableauDetailMouvement.Cells[3,RowTableauDetailMouvementEntree]+' Qte '+EtatEntreeSortie+'.: '+TableauDetailMouvement.Cells[4,RowTableauDetailMouvementEntree]+' Prix: '+TableauDetailMouvement.Cells[5,RowTableauDetailMouvementEntree]);//////////////////////////////////////////////////

                                    if(NewLastNumDetailMouvementMAJ<RArchivePrelevementCompteur.NumPrelevement)then NewLastNumDetailMouvementMAJ:=RArchivePrelevementCompteur.NumPrelevement;
                               end;
                          end;
                     end;
                     finally
                     CloseFile(FArchivePrelevementCompteur);
                     end;

               if(NewLastNumDetailMouvementMAJ>=1)then EnregistrerLastNumDetailMouvementMAJ('FArchivePrelevementCompteur',FSGenerateurBase.EditRechercheCodeSFamilleMAJ.Text,NewLastNumDetailMouvementMAJ);
               end;
          end;
     end;
     finally
     CloseFile(FStockArticleCopie);
     end;

     if(RowTableauDetailMouvementEntree>0)then TableauDetailMouvement.RowCount:=RowTableauDetailMouvementEntree+1
                                          else TableauDetailMouvement.RowCount:=2;

     AjusterColWidth(TableauDetailMouvement,'','');

     RowTableauDetailMouvementEntreeSortie:=RowTableauDetailMouvementEntree;
