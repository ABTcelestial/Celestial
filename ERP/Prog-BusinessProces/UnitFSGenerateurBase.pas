procedure TFSGenerateurBase.TableauTypeAvisKeyPress(Sender: TObject;
  var Key: Char);
var  NumTypeAvis:integer;
begin

if key in['n','N']then
begin
     if not AccesPrivilegies('FS Gťnťrateur Avis',FSMenuPrincipal.EditCodeUtilisateur.Text,'MA',true)then exit;

     FSGenerateurBase.AfficheOptionsTypeAvis.Visible:=true;
     OpenFParc(RParc);
     ChTypeAvis:=RParc.Parcours+'\'+Exercice+'FTypeAvis';
     assignfile(FTypeAvis,ChTypeAvis);
     try
     if FileExists(ChTypeAvis)then
     Reset(FTypeAvis)
     else Rewrite(FTypeAvis);
     Seek(FTypeAvis,0);
     NumTypeAvis:=1;
     while not eof(FTypeAvis)do
     begin
          read(FTypeAvis,RTypeAvis);
          if(NumTypeAvis<=RTypeAvis.NumTypeAvis)then NumTypeAvis:=RTypeAvis.NumTypeAvis+1;
     end;
     finally
     closefile(FTypeAvis);
     end;

     FSGenerateurBase.EditNumTypeAvis.Text:=inttostr(NumTypeAvis);
