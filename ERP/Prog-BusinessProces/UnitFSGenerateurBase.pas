FSGenerateurBase.EditEnregistPr.Text:=FSGenerateurBase.TableauStockArticle.Cells[18,FSGenerateurBase.TableauStockArticle.Row];
Exit;
end;

if key in['s','S']then
begin
     FSGenerateurBase.RBMultiSupprime.Checked:=false;
     FSGenerateurBase.EditListeCodeArticle.Text:=FSGenerateurBase.TableauStockArticle.Cells[1,FSGenerateurBase.TableauStockArticle.Row];
     FSGenerateurBase.NbrArticlesSupp.Caption:='Un article.';
     FSGenerateurBase.ListeArticleSupp.Text:='';
