Procedure RegulariserCoutStock(CodeArticle:string; CoutRegularisation:real);
var  i:integer;
begin
     TypeProces:='Commercial';   FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text;
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     ChStockArticle:=Adresse+FSGenerateurBase.EditNumProjet.Text;
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     i:=0;
     while not eof(FStockArticle)do
     begin
          read(FStockArticle,RStockArticle);  Application.ProcessMessages;

          if(RStockArticle.Code=CodeArticle)then
          begin
               RStockArticle.CoutUnitaire:=CoutRegularisation;

               Seek(FStockArticle,i);
               write(FStockArticle,RStockArticle);
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FStockArticle);
     end;
end;

Procedure RegulariserCoutStockTableau(TableauArticle:TStringGrid);
var  i,R:integer;   OKArticle:boolean;
begin
     FSGenerateurBase.AfficheAttenteRegularisation.Visible:=true;
     FSGenerateurBase.ProgressAfficheAttenteRegularisation.Min:=0;

     TypeProces:='Commercial';   FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text;
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     ChStockArticle:=Adresse+FSGenerateurBase.EditNumProjet.Text;
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     i:=0;

     FSGenerateurBase.ProgressAfficheAttenteRegularisation.Max:=filesize(FStockArticle);

     while not eof(FStockArticle)do
     begin
          read(FStockArticle,RStockArticle);  Application.ProcessMessages;
          FSGenerateurBase.ProgressAfficheAttenteRegularisation.StepIt;

          R:=1;
          OKArticle:=false;
          while(R<=TableauArticle.RowCount-1)and(OKArticle=false)do
          begin
               if(RStockArticle.Code=TableauArticle.Cells[1,R])then
               begin
                    OKArticle:=true;
                    if(TableauArticle.Cells[14,R]='OK')then
                    begin
                         RStockArticle.CoutUnitaire:=strtoreal(FSGenerateurBase.TableauStockArticleRegularisation.Cells[10,R]);

                         Seek(FStockArticle,i);
                         write(FStockArticle,RStockArticle);
                    end;
               end;
          R:=R+1;
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FStockArticle);
     end;

     FSGenerateurBase.AfficheAttenteRegularisation.Visible:=false;
end;

