procedure TFSGenerateurBase.BitRegulariserCoutExerciceAnterieurClick(Sender: TObject);
var  R,C:integer; CoutAnterieur:real;  NotCol:string; OKRegularisation:boolean;
begin
     OKRegularisation:=false;

     if(FSGenerateurBase.BitRegulariserCoutExerciceAnterieur.Caption='Rťgulariser')then
     begin
          FSGenerateurBase.AfficheAttenteRegularisation.Visible:=true;
          FSGenerateurBase.ProgressAfficheAttenteRegularisation.Min:=0;
          FSGenerateurBase.ProgressAfficheAttenteRegularisation.Position:=0;
          FSGenerateurBase.ProgressAfficheAttenteRegularisation.Max:=FSGenerateurBase.TableauStockArticleRegularisation.RowCount-1;

           R:=1;
           while(R<=FSGenerateurBase.TableauStockArticleRegularisation.RowCount-1)do
           begin
                FSGenerateurBase.ProgressAfficheAttenteRegularisation.StepIt;

                if(FSGenerateurBase.TableauStockArticleRegularisation.Cells[14,R]='OK')then
                begin
                     if(CoutArticleExerciceAnterieur(FSGenerateurBase.EditExerciceAnterieurRegularisationCout.Text,FSGenerateurBase.TableauStockArticleRegularisation.Cells[1,R],CoutAnterieur)=true)then
                     begin
                          OKRegularisation:=true;
                          FSGenerateurBase.TableauStockArticleRegularisation.Cells[10,R]:=Vergule(floattostr(CoutAnterieur),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
                     end;
                end;
           R:=R+1;
           end;

           NotCol:='5-9;12;13';
           for C:=0 to FSGenerateurBase.TableauStockArticleRegularisation.ColCount-1 do if existenumintexte(inttostr(C),NotCol)then FSGenerateurBase.TableauStockArticleRegularisation.ColWidths[C]:=-1;
           AjusterColWidth(FSGenerateurBase.TableauStockArticleRegularisation,'',NotCol);

           FSGenerateurBase.EditCummulCoutApres.Text:='';
           FSGenerateurBase.EditCummulPrixApres.Text:='';
           R:=1;
           while(R<=FSGenerateurBase.TableauStockArticleRegularisation.RowCount-1)do
           begin
                FSGenerateurBase.EditCummulCoutApres.Text:=Floattostr(strtoreal(FSGenerateurBase.EditCummulCoutApres.Text)+strtoreal(FSGenerateurBase.TableauStockArticleRegularisation.Cells[10,R]));
                FSGenerateurBase.EditCummulPrixApres.Text:=Floattostr(strtoreal(FSGenerateurBase.EditCummulPrixApres.Text)+strtoreal(FSGenerateurBase.TableauStockArticleRegularisation.Cells[11,R]));
           R:=R+1;
           end;

           FSGenerateurBase.EditCummulCoutApres.Text:=Vergule(FSGenerateurBase.EditCummulCoutApres.Text,FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
           FSGenerateurBase.EditCummulPrixApres.Text:=Vergule(FSGenerateurBase.EditCummulPrixApres.Text,FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');

           FSGenerateurBase.AfficheAttenteRegularisation.Visible:=false;
     end;

     FSGenerateurBase.AfficherRegularisationCoutExerciceAnterieur.Visible:=false;

     if(OKRegularisation=true)then
     begin
          FSGenerateurBase.BitConfirmerRegularisation.Caption:='Confirmer la '+FSGenerateurBase.BitRegularisation.Caption;
          FSGenerateurBase.AfficheConfirmationRegularisation.Visible:=true;
     end
     else
     begin
          showmessage('Aucune rťgularisation !');
     end;
end;

