           read(FAdresseDossierPartageReseauxListe,RAdresseDossierPartageReseauxListe); Application.ProcessMessages;

           OKPosteReseaux:=ExistePosteReseauxInProces(RAdresseDossierPartageReseauxListe.NomPosteReseaux);

           if(AfficheEtatConection)then
           begin
                if(OKPosteReseaux=true)
                then Utilisation:=' Utilisť'
                else Utilisation:=' Non Utilisť';
           end
           else
           begin
                Utilisation:='';
           end;

           if(AfficheSelementPosteProces=false)then
           begin
                OKPosteReseaux:=true;
           end;

           if(AfficheSelementPosteReseaux=true)and(OKPosteReseaux=true)then
           begin
                if(RAdresseDossierPartageReseauxListe.EmlacementLocalOuReseaux<>'Rťseaux')
