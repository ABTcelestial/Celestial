     FSGenerateurBase.TableauDetailMouvement.Cols[3].Text:='Dťsignation';
     FSGenerateurBase.TableauDetailMouvement.Cols[4].Text:='Quantitť';
     FSGenerateurBase.TableauDetailMouvement.Cols[5].Text:='Valeur';
     FSGenerateurBase.TableauDetailMouvement.Cols[6].Text:='Signe';
     FSGenerateurBase.TableauDetailMouvement.Cols[7].Text:='Source';

     FSGenerateurBase.TableauDetailMouvement.RowCount:=2;
     FSGenerateurBase.TableauDetailMouvement.Rows[1].Text:='';


     FSGenerateurBase.ficheAnalyseStock.Visible:=true;
     ProcListeMouvement(FSGenerateurBase.TableauMouvement,'','','','Oui');
     FSGenerateurBase.TableauMouvement.ColCount:=FSGenerateurBase.TableauMouvement.ColCount+1;
     FSGenerateurBase.TableauMouvement.Cols[FSGenerateurBase.TableauMouvement.ColCount-1].Text:='Type Mouvement';
     for R :=1 to FSGenerateurBase.TableauMouvement.RowCount-1 do
     begin
          if(FSGenerateurBase.TableauMouvement.Cells[1,R]<>'Pr')
          and(FSGenerateurBase.TableauMouvement.Cells[1,R]<>'ST')
          then FSGenerateurBase.TableauMouvement.Cells[FSGenerateurBase.TableauMouvement.ColCount-1,R]:=ChercherTypeMouvement(strtointeger(FSGenerateurBase.TableauMouvement.Cells[0,R]),ExerciceAnnee,AdresseFichierConcerne).DesignationTypeMouvement;
     end;

     NotRow:='';
     NotCol:='';
     for C:=1 to FSGenerateurBase.TableauMouvement.ColCount-1 do
     if(FSGenerateurBase.TableauMouvement.ColWidths[C]=0)then if(NotCol='')then NotCol:=inttostr(c) else NotCol:=NotCol+';'+inttostr(c);
     AjusterColWidth(FSGenerateurBase.TableauMouvement,NotRow,NotCol);

     if(FSGenerateurBase.RBLancerAnalyseStock.Checked=true)then
     begin
          FSGenerateurBase.BitMiseAJourStock.Visible:=true;
          FSGenerateurBase.BitMimuleSelection.Visible:=false;

          FSGenerateurBase.EditTypeAnalyse.Text:='Tous';
          FSGenerateurBase.TableauDetailMouvement.RowCount:=2;
          FSGenerateurBase.TableauDetailMouvement.Rows[1].Text:='';
          FSGenerateurBase.AfficheAttente.Visible:=true;
          FSGenerateurBase.MemoRapport.Text:='';
          //////////////////////////////////////////////////////////////////////
          ProgresseMax:=0;
          for R:=1 to FSGenerateurBase.TableauMouvement.RowCount-1 do
          begin
               if(FSGenerateurBase.TableauMouvement.Cells[1,R]<>'Pr')and(FSGenerateurBase.TableauMouvement.Cells[1,R]<>'ST')and(FSGenerateurBase.RBInclureMouvements.Checked=true)then
               begin
                    TypeProces:='Business';   FichierConcerne:='DťtailMouvement '+FSGenerateurBase.TableauMouvement.Cells[FSGenerateurBase.TableauMouvement.ColCount-1,R];
                    if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                    begin
                          //if(<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
                    end;
                    ChDetailMouvement:=Adresse;//RParc.Parcours+'\'+Exercice+'DťtailMouvement '+FSGenerateurBase.TableauMouvement.Cells[FSGenerateurBase.TableauMouvement.ColCount-1,R];
                    assignfile(FDetailMouvement,ChDetailMouvement);
                    if FileExists(ChDetailMouvement)then
                    begin
                         try
                         Reset(FDetailMouvement);
                         ProgresseMax:=ProgresseMax+filesize(FDetailMouvement)-1;
                         finally
                         CloseFile(FDetailMouvement);
                         end;
                    end;
               end
               else
               if(FSGenerateurBase.TableauMouvement.Cells[1,R]='Pr')and(FSGenerateurBase.RBInclurePrelevement.Checked=true)then
               begin
                     OpenFParc(RParc);
                     ChArchivePrelevementCompteur:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementCompteur';
                     assignfile(FArchivePrelevementCompteur,ChArchivePrelevementCompteur);
                     if FileExists(ChArchivePrelevementCompteur)then
                     begin
                          try
                          Reset(FArchivePrelevementCompteur);
                          ProgresseMax:=ProgresseMax+filesize(FArchivePrelevementCompteur)-1;
                          finally
                          CloseFile(FArchivePrelevementCompteur);
                          end;
                     end;
               end;
          end;

          FunctionPatienter(ProgresseMax,false);
          //////////////////////////////////////////////////////////////////////
          FSGenerateurBase.TimerAnalyseStock.Enabled:=true;
     end
     else
     begin
          FSGenerateurBase.BitMimuleSelection.Visible:=true;
          FSGenerateurBase.BitMiseAJourStock.Visible:=false;
          FSGenerateurBase.EditTypeAnalyse.Text:='';
     end;

     FSGenerateurBase.AfficheOptionAnalyseStock.Visible:=false;

     FSGenerateurBase.BitActiverMAJ.Enabled:=Not FSGenerateurBase.BitMiseAJourStock.Enabled;
     FSGenerateurBase.BitActiverMAJ.Visible:=FSGenerateurBase.BitMiseAJourStock.Visible;
