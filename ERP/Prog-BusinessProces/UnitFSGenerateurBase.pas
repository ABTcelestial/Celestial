procedure TFSGenerateurBase.TableauListeFichierConcerneKeyPress(
  Sender: TObject; var Key: Char);
var  i,R:integer;
begin

if key in ['s','S']then
begin
     if(FSGenerateurBase.TableauListeFichierConcerne.Cells[4,FSGenerateurBase.TableauListeFichierConcerne.Row]='OK')
     then FSGenerateurBase.TableauListeFichierConcerne.Cells[4,FSGenerateurBase.TableauListeFichierConcerne.Row]:=''
     else FSGenerateurBase.TableauListeFichierConcerne.Cells[4,FSGenerateurBase.TableauListeFichierConcerne.Row]:='OK';

    //  Crťation Liste Fichier concerne partage rťseaux
    OpenFParc(RParc);
    ChListeFichierConcernePartageReseaux:=RParc.Parcours+'\'+Exercice+'FListeFichierConcernePartageReseaux'+' '+FSGenerateurBase.EditNumAdresseProces.Text;
    assignfile(FListeFichierConcernePartageReseaux,ChListeFichierConcernePartageReseaux);
    try
    if FileExists(ChListeFichierConcernePartageReseaux)then
    Reset(FListeFichierConcernePartageReseaux)
    else begin Showmessage('Attention ! '+ChListeFichierConcernePartageReseaux+' n''existe pas !'); Exit; end;
    Seek(FListeFichierConcernePartageReseaux,0);
    Truncate(FListeFichierConcernePartageReseaux);
    i:=0;
    R:=1;
    while(R<=FSGenerateurBase.TableauListeFichierConcerne.RowCount-1)do
    begin
         if(FSGenerateurBase.TableauListeFichierConcerne.Cells[4,R]='OK')then
         begin
              Seek(FListeFichierConcernePartageReseaux,i);
              RListeFichierConcernePartageReseaux.NumAdresseProces:=strtointeger(FSGenerateurBase.EditNumAdresseProces.Text);
