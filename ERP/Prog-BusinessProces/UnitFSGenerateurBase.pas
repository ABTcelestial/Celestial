Procedure PrevoirDateHeure(DatePrincipale,HeurePrincipale:string; delais:integer; UniteDelais:string; var DatePrevue,HeurePrevue:string);
var  JJ,mm,AAAA,Resultat,Reste:integer; DateTeste:string[10];
begin

DatePrevue:=DatePrincipale;
HeurePrevue:=HeurePrincipale;

jj:=strtointeger(firstlaters(DatePrincipale,2));
mm:=strtointeger(firstlaters(lastlaters(DatePrincipale,7),2));
AAAA:=strtointeger(lastlaters(DatePrincipale,4));

if(UniteDelais='Annťe')then
begin
     AAAA:=AAAA+delais;

end;

if(UniteDelais='Mois')then
begin
     Division(mm+delais,12,Resultat,Reste);
     if(Reste=0)then Reste:=12;
     mm:=Reste;
     AAAA:=AAAA+Resultat;
end;

if(UniteDelais='Jour')then
begin
     DateTeste:=datetostr(strtodate(DatePrincipale)+delais);
     jj:=strtointeger(firstlaters(DateTeste,2));
     mm:=strtointeger(firstlaters(lastlaters(DateTeste,7),2));
     AAAA:=strtointeger(lastlaters(DateTeste,4));
end;

if(UniteDelais='Heure')then
begin
     Division(delais,24,Resultat,Reste);
     if(ValePrecis(Reste,2)<>0)then
     begin
          HeurePrevue:=timetostr(strtotime(HeurePrincipale)+strtotime(completezerogauche(inttostr(Reste),'2')+':00:00'));
     end
     else HeurePrevue:=HeurePrincipale;

     DateTeste:=datetostr(strtodate(DatePrincipale)+Resultat);
     jj:=strtointeger(firstlaters(DateTeste,2));
     mm:=strtointeger(firstlaters(lastlaters(DateTeste,7),2));
     AAAA:=strtointeger(lastlaters(DateTeste,4));
end;

DatePrevue:=Completezerogauche(inttostr(jj),'2')+'/'+Completezerogauche(inttostr(mm),'2')+'/'+Completezerogauche(inttostr(AAAA),'4');

end;

Procedure ListeProjetFinance(Tableau:TStringGrid; NumTypeProjet,NumProjet,LonguerRong:string; UniqueRong:boolean; RowSelect,NumProjetSelect:string; IndiquerReservation,AfficheMentionTous:boolean; TypeProces,FichierConserne:string);
var i,p,ACol,ColMax,Diviseur,Resultat,Reste,ColBeginEdit,RubriqueTrie:integer; OKProjet:boolean; NotCol:string;
begin
Tableau.RowCount:=2;
Tableau.Rows[1].Text:='';

if(AfficheMentionTous=true)then
begin
     Tableau.Cells[0,1]:='1';
     Tableau.Cells[1,1]:='';
     Tableau.Cells[2,1]:='Tous Projets Cumulťs';
     i:=1;
end
else i:=0;

OpenFParc(RParc);
ChProjetFinance:=RParc.Parcours+'\'+Exercice+'FProjetFinance';
assignfile(FProjetFinance,ChProjetFinance);
try
if FileExists(ChProjetFinance)then
Reset(FProjetFinance)
else begin affichermessage('Attention ! {'+ChProjetFinance+'} n''existe pas !'); exit; end;//Rewrite(FProjetFinance);
Seek(FProjetFinance,0);
ColMax:=1;
p:=0;
while not eof(FProjetFinance)do
begin
     read(FProjetFinance,RProjetFinance);

     if(NumTypeProjet<>'')then
     begin
          if(Firstlaters(RProjetFinance.NumProjetFinance,5)=NumTypeProjet)
          then OKProjet:=true
          else OKProjet:=false;
     end
     else OKProjet:=true;

     if(OKProjet=true)then
     begin
          if(NumProjet<>'')then
          begin
               if(Firstlaters(RProjetFinance.NumProjetFinance,longueur(NumProjet))=NumProjet)
               then OKProjet:=true
               else OKProjet:=false;
          end;
     end;

     if(OKProjet=true)then
     begin
          if(UniqueRong=true)then
          begin
               if longueur(RProjetFinance.NumProjetFinance)=strtointeger(LonguerRong)
               then OKProjet:=true
               else OKProjet:=false;
          end
          else
          begin
               if(LonguerRong<>'')then
               begin
                    if longueur(RProjetFinance.NumProjetFinance)<=strtointeger(LonguerRong)
                    then OKProjet:=true
                    else OKProjet:=false;
               end
               else OKProjet:=true;
          end;
     end;

     if(OKProjet=true)then
     begin
          i:=i+1;
          ACol:=ValeAbsolue(longueur(RProjetFinance.NumProjetFinance)/5);
          if(ACol>ColMax)then ColMax:=ACol;
          Tableau.Rows[i].Text:=inttostr(p);
          Tableau.Cells[1,i]:=RProjetFinance.NumProjetFinance;
          if(RProjetFinance.NatureProjetFinance<>'')
          then Tableau.Cells[ACol,i]:=RProjetFinance.DesignationProjetFinance+' '+RProjetFinance.NatureProjetFinance+' '+RProjetFinance.Codification+' lot nį '+RProjetFinance.NumLotProjetFinance+' {'+Vergule(floattostr(RProjetFinance.MesureGlobaleProjetFinance),'2','C','')+' '+RProjetFinance.UniteMesureProjetFinance+'}'
          else Tableau.Cells[ACol,i]:=RProjetFinance.DesignationProjetFinance+' '+RProjetFinance.Codification+' lot nį '+RProjetFinance.NumLotProjetFinance;
     end;
p:=p+1;
end;
finally
CloseFile(FProjetFinance);
end;

if(i>0)then Tableau.RowCount:=i+1
       else Tableau.RowCount:=2;

Tableau.ColCount:=ColMax+1;

Tableau.Cells[0,0]:=' Nį ';
Tableau.Cells[1,0]:='     Code     ';
Tableau.Cells[2,0]:='          Structure Globale          ';
i:=1;
while(i<=ColMax)do
begin
     Tableau.Cells[i+2,0]:='     Structure '+inttostr(i)+' rong     ';
     i:=i+1;
end;

TrierTableauARowSpecial(Tableau,1,Tableau.RowCount-1,0,inttostr(FSGenerateurBase.EditRebriqueTrie.ItemIndex+1),'','+');

if(NumProjetSelect<>'')and(RowSelect='')then
begin
     i:=1;
     while(i<=Tableau.RowCount-1)and(RowSelect='')do
     begin
          if(Tableau.Cells[1,i]=NumProjetSelect)then RowSelect:=inttostr(i);
     i:=i+1;
    end;
end;

NotCol:='1';
Diviseur:=1;
Resultat:=1;
Reste:=0;
if(UniqueRong=true)then
begin
     Diviseur:=5;
     Division(strtointeger(LonguerRong),Diviseur,Resultat,Reste);
     if(Reste=0)then for i:=2 to Resultat-1 do NotCol:=NotCol+';'+inttostr(i);
end;
for i:=1 to Tableau.ColCount-1 do
if(existenumintexte(inttostr(i),NotCol))then Tableau.ColWidths[i]:=0;
AjusterColWidth(Tableau,'',NotCol);
if(Resultat>=1)and(Resultat<Tableau.ColCount)then Tableau.FixedCols:=Resultat;
if(strtointeger(RowSelect)<=Tableau.RowCount-1)
and(strtointeger(RowSelect)>0)
then Tableau.Row:=strtointeger(RowSelect) else Tableau.Row:=1;

if(IndiquerReservation=true)then
begin
     ColBeginEdit:=Tableau.ColCount;
     RecapitulatifPlanificationProjets(Tableau,TypeProces,FichierConserne,ColBeginEdit,false);
     RecapitulatifPreselection(Tableau,TypeProces,FichierConserne,ColBeginEdit,20,false);
end;

end;

