procedure TFSGenerateurBase.StaticInitialisationDonneesClick(
  Sender: TObject);
var i,R,l,PositionTrie:integer; CodeArticleTrie:string;   OKTrie,OKCodeTrie:boolean;   Quantite,Cout,QuantiteTrie,CoutTrie:real;
begin
FSGenerateurBase.AfficheOptions.Visible:=false;

     FSGenerateurBase.TableauTrieArticle.Cols[0].Text:='';

     ChStockArticle:=RParc.Parcours+'\'+Exercice+'FStockArticle Triť';
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     Truncate(FStockArticle);
     l:=0;
     QuantiteTrie:=0;
     CoutTrie:=0;

     ChStock:=RParc.Parcours+'\'+Exercice+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     assignfile(FStock,ChStock);
     try
     if FileExists(ChStock)then
     Reset(FStock)
     else Rewrite(FStock);
     OKTrie:=true;
     while(OKTrie=true)do
     begin
          Seek(FStock,0);
          i:=0;
          OKTrie:=false;
          CodeArticleTrie:='9999999999';
          Quantite:=0;
          Cout:=0;
          while not eof(FStock)do
          begin
               read(FStock,RStock);
               Quantite:=Quantite+RStock.QteStock;
               Cout:=Cout+RStock.CoutUnitaire;
               R:=0;
               OKCodeTrie:=false;
               while(R<=l)and(OKCodeTrie=false)do
               begin
                    if(RStock.Code=FSGenerateurBase.TableauTrieArticle.Cells[0,R])then OKCodeTrie:=true;
               R:=R+1;
               end;

               if(OKCodeTrie=false)
               and(CodeArticleTrie>RStock.Code)then
               begin
                    CodeArticleTrie:=RStock.Code;
                    PositionTrie:=i;
                    OKTrie:=true;
               end;
               i:=i+1;
          end;

          if(OKTrie=true)then
          begin
               Seek(FStock,PositionTrie);
               read(FStock,RStockArticle);
               Seek(FStockArticle,l);
               write(FStockArticle,RStockArticle);
               FSGenerateurBase.TableauTrieArticle.Cells[0,l]:=RStockArticle.Code;
               QuantiteTrie:=QuantiteTrie+RStockArticle.QteStock;
               CoutTrie:=CoutTrie+RStockArticle.CoutUnitaire;
               l:=l+1;
          end;
     end;

     FSGenerateurBase.TableauTrieArticle.RowCount:=l;
     finally
     CloseFile(FStock);
     end;
     finally
     CloseFile(FStockArticle);
     end;

     if(ValePrecis(Quantite,3)=ValePrecis(QuantiteTrie,3))
     and(ValePrecis(Cout,3)=ValePrecis(CoutTrie,3))
     then
     begin
          FSGenerateurBase.AfficherTrieArticle.Caption:='Voulez vous valider le trie des articles SVP !';
          FSGenerateurBase.AfficherTrieArticle.Visible:=true;
          FSGenerateurBase.BitValiderTrie.SetFocus;
     end
     else
     begin
          AfficherMessage('Trie impossible ! Perte de donnťes possible !');
     end;
end;

