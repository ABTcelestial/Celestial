procedure TFSGenerateurBase.BitValideDupliquerStockClick(Sender: TObject);
var i,l:integer;  OKStockArticle,OKArticle:boolean;
begin
     FSGenerateurBase.MemoRapportDuplication.Lines.Text:='';
     FSGenerateurBase.AfficheRapportDuplication.Visible:=true;

     OpenFParc(RParc);
     ChStockArticleCopie:=RParc.Parcours+'\'+Exercice+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjetDupliquer.Text;
     assignfile(FStockArticleCopie,ChStockArticleCopie);
     try
     if FileExists(ChStockArticleCopie)then
     Reset(FStockArticleCopie)
     else Rewrite(FStockArticleCopie);
     Seek(FStockArticleCopie,0);
     i:=0;
     if(FSGenerateurBase.RBCrieNouvelleBase.Checked=true)then
     begin
          truncate(FStockArticleCopie);
          FSGenerateurBase.MemoRapportDuplication.Lines.Add('Crťation d''une nouvelle base de donnťes');
     end
     else
     begin
          while not eof(FStockArticleCopie)do
          begin
               read(FStockArticleCopie,RStockArticleCopie);
               i:=i+1;
          end;

          FSGenerateurBase.MemoRapportDuplication.Lines.Add('Concervation de la base existante {'+inttostr(i)+' articles}' );
     end;

     ChStockArticle:=RParc.Parcours+'\'+Exercice+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     while not eof(FStockArticle)do
     begin
          read(FStockArticle,RStockArticleCopie);
          if(FSGenerateurBase.EditCodeConcerne.Text<>'')then
          begin
               if ExisteNumInTexte(Firstlaters(RStockArticleCopie.Code,strtointeger(Firstlaters(FSGenerateurBase.EditOrdreCompteConcerneDupliquer.Text,2))),FSGenerateurBase.EditCodeConcerne.Text)
               then OKStockArticle:=true
               else OKStockArticle:=false;
          end
          else OKStockArticle:=true;

          if(OKStockArticle=true)then
          begin
               OKArticle:=false;
               if(FSGenerateurBase.RBCrieNouvelleBase.Checked=false)then
               begin
                    ChStockArticleRecherche:=ChStockArticleCopie;
                    assignfile(FStockArticleRecherche,ChStockArticleRecherche);
                    if FileExists(ChStockArticleRecherche)then
                    Reset(FStockArticleRecherche)
                    else Rewrite(FStockArticleRecherche);
                    Seek(FStockArticleRecherche,0);                    
                    while not eof(FStockArticleRecherche)and(OKArticle=false)do
                    begin
                         read(FStockArticleRecherche,RStockArticleRecherche);
                         if(RStockArticleRecherche.Code=RStockArticleCopie.Code)then
                         begin
                              OKArticle:=true;
                              FSGenerateurBase.MemoRapportDuplication.Lines.Add('Article: '+RStockArticleCopie.Code+' '+RStockArticleCopie.Design+' '+RStockArticleCopie.Ref+' existe');
                         end;
                    end;
               end;

               if(OKArticle=false)
               then OKStockArticle:=true
               else OKStockArticle:=false;
          end;

          if(OKStockArticle=true)then
          begin
               if(FSGenerateurBase.RBQteEntreeAZero.Checked=true)then  RStockArticleCopie.QteEntree:=0;
               if(FSGenerateurBase.RBQteSortieAZero.Checked=true)then  RStockArticleCopie.QteSortie:=0;
               if(FSGenerateurBase.RBQteStockAZero.Checked=true)then  RStockArticleCopie.QteStock:=0;
               if(FSGenerateurBase.RBQteInitialAZero.Checked=true)then  RStockArticleCopie.QteInitial:=0;
               if(FSGenerateurBase.RBQteLimiteAZero.Checked=true)then  RStockArticleCopie.QteLimite:=0;

               Seek(FStockArticleCopie,i);
               write(FStockArticleCopie,RStockArticleCopie);
               i:=i+1;

               FSGenerateurBase.MemoRapportDuplication.Lines.Add('Article: '+RStockArticleCopie.Code+' '+RStockArticleCopie.Design+' '+RStockArticleCopie.Ref+' Ajouter');
          end;
     end;
     finally
     CloseFile(FStockArticle);
     end;

     finally
     CloseFile(FStockArticleCopie);
     end;

     FSGenerateurBase.EditNumProjet.Text:=FSGenerateurBase.EditNumProjetDupliquer.Text;
     FSGenerateurBase.EditNomProjet.Text:=FSGenerateurBase.EditNomProjetDupliquer.Text;
     FSGenerateurBase.AfficheDupliquerListeStock.Visible:=false;
     FSGenerateurBase.TableauCompteConserneDupliquer.Visible:=false;
     OpenFParc(RParc);
     ChStockArticle:=RParc.Parcours+'\'+Exercice+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     ProcAfficheListeStock(FSGenerateurBase.TableauStockArticle,ChStockArticle,'','','',FSGenerateurBase.RBAvecCodeBarre.Checked);
     FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=ChStockArticle;
     FSGenerateurBase.TableauStockArticle.SetFocus;

     FSGenerateurBase.MemoRapportDuplication.Lines.Add('Fin de duplication !');
end;

