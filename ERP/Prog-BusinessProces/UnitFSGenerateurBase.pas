          finally
          closefile(FProjetFinance);
          end;

          FSGenerateurBase.EditNumProjetFinance.Text:=FSGenerateurBase.TableauListeTypeProjet.Cells[1,FSGenerateurBase.TableauListeTypeProjet.Row]+Completezerogauche(inttostr(NumProjetFinance),'5');
