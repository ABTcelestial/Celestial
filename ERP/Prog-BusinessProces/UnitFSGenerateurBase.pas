     FSGenerateurBase.EditCompteTypeAvis.Text:='';
     FSGenerateurBase.EditDebitCreditTypeAvis.ItemIndex:=0;
     FSGenerateurBase.EditSigneDebitCredit.Text:='1'; FSGenerateurBase.RBSigneDebitCreditPositive.Checked:=true;
     FSGenerateurBase.EditTypeProcesAvis.ItemIndex:=0;
     FSGenerateurBase.EditJourneauxAuxiliaireUtiliseAvis.Text:='';
     ListeTypeFichierTiersBox(FSGenerateurBase.EditTypeProcesAvis.Text,'','',FSGenerateurBase.EditFichierConserne,FSGenerateurBase.TitreEditFichierConserne);
     FSGenerateurBase.EditFichierConserne.Text:='';
     FSGenerateurBase.BitValiderTypeAvis.Kind:=bkAll;
     FSGenerateurBase.BitValiderTypeAvis.Caption:='Valider';

     FSGenerateurBase.EditDesignationTypeAvis.SetFocus;
end;

if key in['m','M','s','S']then
begin
     FSGenerateurBase.EditNumTypeAvis.Text:=FSGenerateurBase.TableauTypeAvis.Cells[1,FSGenerateurBase.TableauTypeAvis.Row];
     FSGenerateurBase.EditDesignationTypeAvis.Text:=FSGenerateurBase.TableauTypeAvis.Cells[2,FSGenerateurBase.TableauTypeAvis.Row];
     FSGenerateurBase.EditCompteTypeAvis.Text:=FSGenerateurBase.TableauTypeAvis.Cells[3,FSGenerateurBase.TableauTypeAvis.Row];
     FSGenerateurBase.EditDebitCreditTypeAvis.Text:=FSGenerateurBase.TableauTypeAvis.Cells[4,FSGenerateurBase.TableauTypeAvis.Row];
     if(FSGenerateurBase.TableauTypeAvis.Cells[5,FSGenerateurBase.TableauTypeAvis.Row]='Positive')
     then begin FSGenerateurBase.RBSigneDebitCreditPositive.Checked:=true; FSGenerateurBase.EditSigneDebitCredit.Text:='1'; end
     else begin FSGenerateurBase.RBSigneDebitCreditNigative.Checked:=true; FSGenerateurBase.EditSigneDebitCredit.Text:='-1' end;
     FSGenerateurBase.EditTypeProcesAvis.Text:=FSGenerateurBase.TableauTypeAvis.Cells[6,FSGenerateurBase.TableauTypeAvis.Row];
     ListeTypeFichierTiersBox(FSGenerateurBase.EditTypeProcesAvis.Text,'','',FSGenerateurBase.EditFichierConserne,FSGenerateurBase.TitreEditFichierConserne);
     FSGenerateurBase.EditFichierConserne.Text:=FSGenerateurBase.TableauTypeAvis.Cells[7,FSGenerateurBase.TableauTypeAvis.Row];
     FSGenerateurBase.EditJourneauxAuxiliaireUtiliseAvis.Text:=FSGenerateurBase.TableauTypeAvis.Cells[8,FSGenerateurBase.TableauTypeAvis.Row];

     if key in['m','M']then
     begin
          if not AccesPrivilegies('FS Gťnťrateur Avis',FSMenuPrincipal.EditCodeUtilisateur.Text,'MM',true)then exit;

          FSGenerateurBase.AfficheOptionsTypeAvis.Visible:=true;
          FSGenerateurBase.BitValiderTypeAvis.Kind:=bkAll;
          FSGenerateurBase.BitValiderTypeAvis.Caption:='Valider';
          FSGenerateurBase.EditDesignationTypeAvis.SetFocus;
     end;

     if key in['s','S']then                   
     begin
          if not AccesPrivilegies('FS Gťnťrateur Avis',FSMenuPrincipal.EditCodeUtilisateur.Text,'MS',true)then exit;

          FSGenerateurBase.AfficheOptionsTypeAvis.Visible:=true;
          FSGenerateurBase.BitValiderTypeAvis.Kind:=bkCancel;
          FSGenerateurBase.BitValiderTypeAvis.Caption:='Supprimer';
          FSGenerateurBase.BitValiderTypeAvis.SetFocus;
     end;
end;

end;

