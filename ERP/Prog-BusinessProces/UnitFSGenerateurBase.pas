function AnomalieArticleDetailStructure(TableauDetailStructure:TStringGrid; NumProjetFinance:string):boolean;
var  R:integer;  OKArticleDetailStructure,OKNumPorjetFinance:boolean;
begin
     TableauDetailStructure.ColCount:=4;
     TableauDetailStructure.Cols[0].Text:='Nį';
     TableauDetailStructure.Cols[1].Text:='Pį';
     TableauDetailStructure.Cols[2].Text:='Num Projet';
     TableauDetailStructure.Cols[3].Text:='Designation Structure';

     TableauDetailStructure.RowCount:=2;
     TableauDetailStructure.Rows[1].Text:='';

     OpenFParc(RParc);
     ChArticleDetailStructure:=RParc.Parcours+'\'+Exercice+'FArticleDetailStructure';
     assignfile(FArticleDetailStructure,ChArticleDetailStructure);
     try
     if FileExists(ChArticleDetailStructure)then
     Reset(FArticleDetailStructure)
     else Rewrite(FArticleDetailStructure);
     Seek(FArticleDetailStructure,0);
     while not eof(FArticleDetailStructure)do
     begin
           read(FArticleDetailStructure,RArticleDetailStructure);

           if(NumProjetFinance<>'')then
           begin
                if(RArticleDetailStructure.NumProjetFinance=NumProjetFinance)
                then OKNumPorjetFinance:=true
                else OKNumPorjetFinance:=false;
           end
           else OKNumPorjetFinance:=true;

           if(OKNumPorjetFinance=true)then
           begin
                OpenFParc(RParc);
                ChDetailStructure:=RParc.Parcours+'\'+Exercice+'FDetailStructure';
                assignfile(FDetailStructure,ChDetailStructure);
                try
                if FileExists(ChDetailStructure)then
                Reset(FDetailStructure)
                else Rewrite(FDetailStructure);
                Seek(FDetailStructure,0);
                OKArticleDetailStructure:=false;
                while not eof(FDetailStructure)and(OKArticleDetailStructure=false)do
                begin
                     read(FDetailStructure,RDetailStructure);

                     if(NumProjetFinance<>'')then
                     begin
                          if(RDetailStructure.NumProjetFinance=NumProjetFinance)
                          then OKNumPorjetFinance:=true
                          else OKNumPorjetFinance:=false;
                     end
                     else OKNumPorjetFinance:=true;

                     if(OKNumPorjetFinance=true)then
                     begin
                          if(RArticleDetailStructure.PositionDetailStructure=RDetailStructure.PositionDetailStructure)
                          and(RArticleDetailStructure.NumProjetFinance=RDetailStructure.NumProjetFinance)
                          then
                          begin
                               OKArticleDetailStructure:=true;
                          end;
                     end;
                end;
                finally
                CloseFile(FDetailStructure);
                end;

                if(OKArticleDetailStructure=false)then
                begin
                     R:=R+1;
                     TableauDetailStructure.Rows[R].Text:=inttostr(R);
                     TableauDetailStructure.Cells[1,R]:=inttostr(RArticleDetailStructure.PositionDetailStructure);
                     TableauDetailStructure.Cells[2,R]:=RArticleDetailStructure.NumProjetFinance;
                     TableauDetailStructure.Cells[3,R]:='Non enregistrť !';
                end;
           end;
     end;
     finally
     CloseFile(FArticleDetailStructure);
     end;

     if(R>0)then
     begin
