procedure TFSGenerateurBase.BitOperationDetailStructureClick(
  Sender: TObject);
var  R,i,iSelect,PositionDetailStructure,Ordre:integer; OKDetailStructure,OKPositionStructure:boolean;  NotRow,NotCol,ListeTypeStock,ListeTypeComptabilite:string;
begin
     FSGenerateurBase.EditPositionDetailStructure.ReadOnly:=true;

     if(FSGenerateurBase.BitOperationDetailStructure.Caption='Valider')then
     begin
           if(FSGenerateurBase.EditPositionDetailStructureLast.Text<>'')
           then Ordre:=strtointeger(FSGenerateurBase.TableauDetailStructure.Cells[4,FSGenerateurBase.TableauDetailStructure.Row])
           else Ordre:=0;

           OpenFParc(RParc);
           ChDetailStructure:=RParc.Parcours+'\'+Exercice+'FDetailStructure';
           assignfile(FDetailStructure,ChDetailStructure);
           try
           if FileExists(ChDetailStructure)then
           Reset(FDetailStructure)
           else Rewrite(FDetailStructure);
           Seek(FDetailStructure,0);
           OKDetailStructure:=false;
           i:=0;
           iSelect:=0;
           PositionDetailStructure:=0;
           while not eof(FDetailStructure)and(OKDetailStructure=false)do
           begin
                read(FDetailStructure,RDetailStructure);
                if(PositionDetailStructure<=RDetailStructure.PositionDetailStructure)then PositionDetailStructure:=RDetailStructure.PositionDetailStructure+1;
                if(inttostr(RDetailStructure.PositionDetailStructure)=FSGenerateurBase.EditPositionDetailStructureLast.Text)then
                begin
                     OKDetailStructure:=true;
                     iSelect:=i;
                     PositionDetailStructure:=RDetailStructure.PositionDetailStructure;
                end;
           i:=i+1;
           end;

           if(OKDetailStructure=true)then i:=iSelect;
           Seek(FDetailStructure,i);
           RDetailStructure.PositionDetailStructure:=PositionDetailStructure;
           RDetailStructure.NumProjetFinance:=FSGenerateurBase.EditNumProjetStructure.Text;
           RDetailStructure.DesignationDetailStructure:=FSGenerateurBase.EditDesignationDetailStructure.Text;
           RDetailStructure.Ordre:=strtointeger(FSGenerateurBase.EditOrdre.Text);
           write(FDetailStructure,RDetailStructure);

           finally
           CloseFile(FDetailStructure);
           end;

           if((FSGenerateurBase.EditPositionDetailStructure.Text<>'')and(FSGenerateurBase.EditPositionDetailStructureLast.Text<>''))
           and(FSGenerateurBase.EditPositionDetailStructure.Text<>FSGenerateurBase.EditPositionDetailStructureLast.Text)
           then
           begin
                OpenFParc(RParc);
                ChArticleDetailStructure:=RParc.Parcours+'\'+Exercice+'FArticleDetailStructure';
                assignfile(FArticleDetailStructure,ChArticleDetailStructure);
                try
                if FileExists(ChArticleDetailStructure)then
                Reset(FArticleDetailStructure)
                else Rewrite(FArticleDetailStructure);
                Seek(FArticleDetailStructure,0);
                i:=0;
                while not eof(FArticleDetailStructure)do
                begin
                     read(FArticleDetailStructure,RArticleDetailStructure);
                     if(inttostr(RArticleDetailStructure.PositionDetailStructure)=FSGenerateurBase.EditPositionDetailStructureLast.Text)then
                     begin
                          RArticleDetailStructure.PositionDetailStructure:=strtointeger(FSGenerateurBase.EditPositionDetailStructure.Text);
                          Seek(FArticleDetailStructure,i);
                          write(FArticleDetailStructure,RArticleDetailStructure);
                     end;
                i:=i+1;
                end;
                finally
                CloseFile(FArticleDetailStructure);
                end;
           end;
     end;

     if(FSGenerateurBase.BitOperationDetailStructure.Caption='Supprimer')then
     begin
          DeleteFDetailStructure(FSGenerateurBase.TableauDetailStructure.Cells[1,FSGenerateurBase.TableauDetailStructure.Row],OKDetailStructure);
          DeleteFArticleDetailStructure(FSGenerateurBase.TableauDetailStructure.Cells[1,FSGenerateurBase.TableauDetailStructure.Row],'',OKDetailStructure);
     end;

     if(FSGenerateurBase.RBTypeAffichageDetaileStructure.Checked=true)
     then AnomalieArticleDetailStructure(FSGenerateurBase.TableauDetailStructure,FSGenerateurBase.EditNumProjetAnomalie.Text)
     else ListeDetailStructure(FSGenerateurBase.TableauDetailStructure,FSGenerateurBase.EditNumProjetStructure.Text);
     if(FSGenerateurBase.RBAfficherPositionDetailStructure.Checked=true)
     then NotCol:='3-5;9;10'
     else NotCol:='1-5;9;10';
     NotRow:='1';
     R:=0;
     ListeArticleDetailStructure(FSGenerateurBase.TableauArticleDetailStructure,FSGenerateurBase.TableauDetailStructure.Cells[2,FSGenerateurBase.TableauDetailStructure.Row],FSGenerateurBase.TableauDetailStructure.Cells[1,FSGenerateurBase.TableauDetailStructure.Row],'10',FSGenerateurBase.EditCodeTypeAffichage.Text,NotRow,NotCol,FSGenerateurBase.RBAfficheCoutFinance.Checked,FSGenerateurBase.RBAffichePrixCession.Checked,FSGenerateurBase.RBCummuleMemeArticle.Checked,FSGenerateurBase.RBUniquementArticleDSPlanifier.Checked,false,R,FSGenerateurBase.IncrimenteEditMojorationQuantite.Position,R,ListeTypeStock,ListeTypeComptabilite);
     FSGenerateurBase.AfficheOperationDetailStructure.Visible:=false;
     FSGenerateurBase.TableauDetailStructure.SetFocus;

     if(FSGenerateurBase.EditOrdre.Text<>inttostr(Ordre))then
     begin
           OpenFParc(RParc);
           ChDetailStructure:=RParc.Parcours+'\'+Exercice+'FDetailStructure';
           assignfile(FDetailStructure,ChDetailStructure);
           try
           if FileExists(ChDetailStructure)then
           Reset(FDetailStructure)
           else Rewrite(FDetailStructure);
           Seek(FDetailStructure,0);
           i:=0;
           while not eof(FDetailStructure)do
           begin
                read(FDetailStructure,RDetailStructure);
                if(Firstlaters(RDetailStructure.NumProjetFinance,longueur(FSGenerateurBase.EditNumProjetStructure.text))=FSGenerateurBase.EditNumProjetStructure.text)then
                begin
                     R:=1;
                     OKPositionStructure:=false;
                     while(R<=FSGenerateurBase.TableauDetailStructure.RowCount-1)and(OKPositionStructure=false)do
                     begin
                          if(inttostr(RDetailStructure.PositionDetailStructure)=FSGenerateurBase.TableauDetailStructure.Cells[1,R])then
                          begin
                               OKPositionStructure:=true;
                               Seek(FDetailStructure,i);
                               RDetailStructure.Ordre:=R;
                               write(FDetailStructure,RDetailStructure);
                          end;
                     R:=R+1;
                     end;
                end;
           i:=i+1;
           end;
           finally
           CloseFile(FDetailStructure);
           end;

           ListeDetailStructure(FSGenerateurBase.TableauDetailStructure,FSGenerateurBase.EditNumProjetStructure.Text);
     end;
end;

Procedure ListeDetailStructure(TableauDetailStructure:TStringGrid; NumProjetFinance:string);
var R:integer; OKDetailStructure:boolean;  NotCol,TypeDataTrie:string;
begin
     TableauDetailStructure.ColCount:=5;
     TableauDetailStructure.Cols[0].Text:='Nį';
     TableauDetailStructure.Cols[1].Text:='Pį';
     TableauDetailStructure.Cols[2].Text:='Num Projet';
     TableauDetailStructure.Cols[3].Text:='Designation Structure';
     TableauDetailStructure.Cols[4].Text:='Ordre';

     TableauDetailStructure.RowCount:=2;
     TableauDetailStructure.Rows[1].Text:='';

     OpenFParc(RParc);
     ChDetailStructure:=RParc.Parcours+'\'+Exercice+'FDetailStructure';
     assignfile(FDetailStructure,ChDetailStructure);
     try
     if FileExists(ChDetailStructure)then
     Reset(FDetailStructure)
     else Rewrite(FDetailStructure);
     Seek(FDetailStructure,0);
     R:=0;
     while not eof(FDetailStructure)do
     begin
          read(FDetailStructure,RDetailStructure);

          if(NumProjetFinance<>'')then
          begin
               if(firstlaters(RDetailStructure.NumProjetFinance,longueur(NumProjetFinance))=NumProjetFinance)
               then OKDetailStructure:=true
               else OKDetailStructure:=false;
          end
          else OKDetailStructure:=true;

          if(OKDetailStructure=true)then
          begin
               R:=R+1;
               TableauDetailStructure.Rows[R].Text:=inttostr(R);
               TableauDetailStructure.Cells[1,R]:=inttostr(RDetailStructure.PositionDetailStructure);
               TableauDetailStructure.Cells[2,R]:=RDetailStructure.NumProjetFinance;
               TableauDetailStructure.Cells[3,R]:=RDetailStructure.DesignationDetailStructure;
               TableauDetailStructure.Cells[4,R]:=inttostr(RDetailStructure.Ordre);

          end;
     end;
     finally
     CloseFile(FDetailStructure);
     end;

     if(R>0)then TableauDetailStructure.RowCount:=R+1
            else TableauDetailStructure.RowCount:=2;

     if(FSGenerateurBase.RBAfficherPositionDetailStructure.Checked=false)then
     begin
          TableauDetailStructure.ColWidths[1]:=0;
          NotCol:='1';
     end
     else
     begin
          NotCol:='';
     end;
     AjusterColWidth(TableauDetailStructure,'',NotCol);

     if(FSGenerateurBase.EditRubriqueTrieStructure.Text='1')
     or(FSGenerateurBase.EditRubriqueTrieStructure.Text='2')
     or(FSGenerateurBase.EditRubriqueTrieStructure.Text='4')
     then TypeDataTrie:='Num'
     else TypeDataTrie:='';

     TrierTableauARowSpecial(TableauDetailStructure,1,TableauDetailStructure.RowCount-1,1,FSGenerateurBase.EditRubriqueTrieStructure.Text,TypeDataTrie,FSGenerateurBase.EditTypeTrieStructure.Text);

     FSGenerateurBase.RBTypeAffichageDetaileStructure.Checked:=false;
     FSGenerateurBase.EditNumProjetAnomalie.Text:='';
end;

