                     Reset(FArchivePrelevementCompteur)
                     else Rewrite(FArchivePrelevementCompteur);
                     Seek(FArchivePrelevementCompteur,IBegin);
                     NewLastNumDetailMouvementMAJ:=0;
                     while not eof(FArchivePrelevementCompteur)do
                     begin
                          read(FArchivePrelevementCompteur,RArchivePrelevementCompteur); Application.ProcessMessages; FunctionPatienter(0,true);

                          if(FSGenerateurBase.RBMAJArticleSelect.Checked=true)then
