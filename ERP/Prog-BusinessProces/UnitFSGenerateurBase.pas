procedure TFSGenerateurBase.BitBtn45Click(Sender: TObject);
var  OK,OK1,OK2,OK3,OK4,OK5,OK6,OK7,OK8,OK9,OK10,OKArticle:boolean;
     Montant:real; CodeProd,CodeBarre:string[10]; DesigProd:string[255];
     RefProd:string[15]; UMProd:string[2]; CodeSF:string[10];NFS:string[4];
     NbrMax,HeightMax:integer; R,i,k,l,m,n,p,NFSD,NFSF,Saut,Nbr,SautDesig,SautLigne:integer; DateDerniereMAJ,DateMAJArticle:string[10];
     TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut,NomRegistreCompte:string;
begin
{////////////////////////////////////////////////////////}
if(FSGenerateurBase.RBEtatInventaire.Checked=true)then
begin
     if(FSGenerateurBase.LabelTypePrint.Caption='Inventaire Global')then
     begin
          NbrMax:=strtoint(FSGenerateurBase.EditNbrMax.Text)-1;
          HeightMax:=strtoint(FSGenerateurBase.EditHeightMax.Text);

          {*******************Entreprise***************}
          OpenFParc(RParc);
          PrintEtatInventaire.TextD1.Caption:=RParc.Text1;
          PrintEtatInventaire.TextD2.Caption:=RParc.Text2;
          PrintEtatInventaire.TextD3.Caption:=RParc.Text3;
          PrintEtatInventaire.TextD4.Caption:=RParc.Text4;
          PrintEtatInventaire.TextD5.Caption:=RParc.Text5;
          PrintEtatInventaire.TextD6.Caption:=RParc.Text6;
          {***************Fin Entreprise***************}
          PrintEtatInventaire.Logo.Picture:=FSMenuPrincipal.Logo.Picture;
          PrintEtatInventaire.LabelISO.Picture:=FSMenuPrincipal.LabelISO.Picture;

          TypeProces:='Comptabilitť';
          case strtointeger(FSGenerateurBase.EditOrdreCompteComptableInventaireGlobal.Text) of
          1:  begin FichierConcerne:='FClasse'+FSGenerateurBase.EditTypeComptabilite.Text;        NomRegistreCompte:='Classe'; end;
          2:  begin FichierConcerne:='FSousClasse'+FSGenerateurBase.EditTypeComptabilite.Text;    NomRegistreCompte:='S/Classe'; end;
          3:  begin FichierConcerne:='FCategorie'+FSGenerateurBase.EditTypeComptabilite.Text;     NomRegistreCompte:='Catťgorie'; end;
          4:  begin FichierConcerne:='FSousCategorie'+FSGenerateurBase.EditTypeComptabilite.Text; NomRegistreCompte:='S/Catťgorie'; end;
          5:  begin FichierConcerne:='FFamille'+FSGenerateurBase.EditTypeComptabilite.Text;       NomRegistreCompte:='Famille'; end;
          6:  begin FichierConcerne:='FSousFamille'+FSGenerateurBase.EditTypeComptabilite.Text;   NomRegistreCompte:='S/Famille'; end;
          end;

          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
          end;

          ChRegistreCompte:=Adresse;
          assignfile(FRegistreCompte,ChRegistreCompte);
          try
          if FileExists(ChRegistreCompte)then
          Reset(FRegistreCompte)
          else Rewrite(FRegistreCompte);
          Seek(FRegistreCompte,0);
          m:=0;
          while not eof(FRegistreCompte)do
          begin
          OK:=true;
          read(FRegistreCompte,RRegistreCompte);
          if(RRegistreCompte.CodeCompte<>'')then
          begin
               DateDerniereMAJ:='31/12/'+inttostr(strtointeger(ExerciceAnnee)-1);
               DateMAJArticle:='31/12/'+inttostr(strtointeger(ExerciceAnnee)-1);

               PrintEtatInventaire.Etat.Caption:='Etats Inventaire au: '+datetostr(date);
               PrintEtatInventaire.SFamille.Caption:=NomRegistreCompte+': '+RRegistreCompte.CodeCompte+' / '+RRegistreCompte.Designation;
               if(FSGenerateurBase.RBTous.Checked=true)then PrintEtatInventaire.OptionPrint.Caption:='';
               if(FSGenerateurBase.RBStockNul.Checked=true)then PrintEtatInventaire.OptionPrint.Caption:='Stock Nul';
               if(FSGenerateurBase.RBStockExistant.Checked=true)then PrintEtatInventaire.OptionPrint.Caption:='Stock Existant';
               PrintEtatInventaire.T8.Lines.Text:='';
               PrintEtatInventaire.T9.Lines.Text:='';
               PrintEtatInventaire.T10.Lines.Text:='';
               PrintEtatInventaire.T11.Lines.Text:='';
               PrintEtatInventaire.T12.Lines.Text:='';
               PrintEtatInventaire.T13.Lines.Text:='';
               PrintEtatInventaire.T14.Lines.Text:='';
               PrintEtatInventaire.TDateMAJ.Lines.Text:='';

               TypeProces:='Commercial';   FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
               if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
               begin
                    AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
               end;

               ChStock:=Adresse;
               assignfile(FStock,ChStock);
               try
               if FileExists(ChStock)then
               Reset(FStock)
               else Rewrite(FStock);
               Seek(FStock,0);
               Montant:=0;
               l:=0;
               Nbr:=0;
               SautDesig:=0;
               SautLigne:=0;
               while not eof(FStock)do
               begin
                    read(FStock,RStock);

                    if(FSGenerateurBase.TableauSelectArticleInventaire.Visible=true)then
                    begin
                         R:=1;
                         OK:=false;
                         while(R<=FSGenerateurBase.TableauSelectArticleInventaire.RowCount-1)and(OK=false)do
                         begin
                              if(FSGenerateurBase.TableauSelectArticleInventaire.Cells[10,R]='OK')then
                              begin
                                   if(RStock.Code=FSGenerateurBase.TableauSelectArticleInventaire.Cells[1,R])then
                                   begin
                                        OK:=true;
                                   end;
                              end;
                         R:=R+1;
                         end;
                    end
                    else OK:=true;

                    CodeBarre:=RStock.CodeBarre;
                    CodeProd:=RStock.Code;

                    if(OK=true)
                    and(firstlaters(CodeProd,longueur(RRegistreCompte.CodeCompte))=RRegistreCompte.CodeCompte)then
                    begin
                              if(FSGenerateurBase.RBTous.Checked=true)then
                              begin
                                   OK:=true;
                              end;

                              if(FSGenerateurBase.RBStockNul.Checked=true)then
                              begin
                                   if(RStock.QteStock=0)
                                   then OK:=true
                                   else OK:=false;
                              end;

                              if(FSGenerateurBase.RBStockExistant.Checked=true)then
                              begin
                                   if(RStock.QteStock>0)
                                   then OK:=true
                                   else OK:=false;
                              end;

                              if(OK=true)then
                              begin
                                   if(FSGenerateurBase.AfficherCodeBarre.Checked=true)
                                   then PrintEtatInventaire.T8.Lines.Add(CodeBarre)
                                   else PrintEtatInventaire.T8.Lines.Add(CodeProd);
                                   DesigProd:=RStock.Design;
                                   PrintEtatInventaire.T9.Lines.Add(DesigProd);
                                   RefProd:=RStock.Ref;
                                   PrintEtatInventaire.T10.Lines.Add(RefProd);
                                   UMProd:=RStock.UM;
                                   PrintEtatInventaire.T11.Lines.Add(UMProd);

                                   if(RStock.QteStock<>0)
                                   then PrintEtatInventaire.T12.Lines.Add(Vergule(floattostr(RStock.QteStock),FSGenerateurBase.EditDecimaleQte.Text,'C',''))
                                   else PrintEtatInventaire.T12.Lines.Add(' ');

                                   if(RStock.CoutUnitaire<>0)
                                   then PrintEtatInventaire.T13.Lines.Add(Vergule(floattostr(RStock.CoutUnitaire),'2','C',''))
                                   else PrintEtatInventaire.T13.Lines.Add(' ');

                                   if((RStock.QteStock<>0)and(RStock.CoutUnitaire<>0))
                                   then PrintEtatInventaire.T14.Lines.Add(Vergule(floattostr(RStock.QteStock*RStock.CoutUnitaire),'2','C',''))
                                   else PrintEtatInventaire.T14.Lines.Add(' ');

                                   DateMAJArticle:=DateLastMiseAJourStock('FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text,CodeProd);
                                   PrintEtatInventaire.TDateMAJ.Lines.Add(DateMAJArticle);

                                   PrintEtatInventaire.TesteDesignation.Lines.Text:='';
                                   PrintEtatInventaire.TesteDesignation.Lines.Add(DesigProd);

                                   if(PrintEtatInventaire.TesteDesignation.Lines.Capacity>1)then
                                   begin
                                        for Saut:=1 to PrintEtatInventaire.TesteDesignation.Lines.Capacity-1 do
                                        begin
                                             PrintEtatInventaire.T8.Lines.Add('');
                                             //PrintFeuilleInventaire.T9.Lines.Add('');
                                             PrintEtatInventaire.T10.Lines.Add('');
                                             PrintEtatInventaire.T11.Lines.Add('');
                                             PrintEtatInventaire.T12.Lines.Add('');
                                             PrintEtatInventaire.T13.Lines.Add('');
                                             PrintEtatInventaire.T14.Lines.Add('');
                                             PrintEtatInventaire.TDateMAJ.Lines.Add('');
                                        end;
                                        SautDesig:=SautDesig+Saut;
                                   end;

                                   PrintEtatInventaire.T8.Lines.Add('......................');
                                   PrintEtatInventaire.T9.Lines.Add('................................................................');
                                   PrintEtatInventaire.T10.Lines.Add('...............................');
                                   PrintEtatInventaire.T11.Lines.Add('.....');
                                   PrintEtatInventaire.T12.Lines.Add('..................');
                                   PrintEtatInventaire.T13.Lines.Add('.......................');
                                   PrintEtatInventaire.T14.Lines.Add('...........................');
                                   PrintEtatInventaire.TDateMAJ.Lines.Add('....................');

                                   if(strtodate(DateMAJArticle)>strtodate(DateDerniereMAJ))then DateDerniereMAJ:=DateMAJArticle;
                                   Montant:=Montant+(RStock.QteStock*RStock.CoutUnitaire);
                                   l:=l+1;
                                   Nbr:=Nbr+1;
                                   SautLigne:=SautLigne+1;
                              end;
                    end;

                    if(l+DiviseInteger(SautDesig,2)=NbrMax)or(eof(FStock))then
                    begin
                         if(l>0)then m:=m+1;
                         PrintEtatInventaire.NPage.Caption:=RRegistreCompte.CodeCompte+' / '+RRegistreCompte.CodeCompte+'-Page Nį: '+inttostr(m);
                         PrintEtatInventaire.T8.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.C8.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         PrintEtatInventaire.T9.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.C9.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         PrintEtatInventaire.T10.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.C10.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         PrintEtatInventaire.T11.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.C11.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         PrintEtatInventaire.T12.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.C12.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         PrintEtatInventaire.T13.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.C13.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         PrintEtatInventaire.T14.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.C14.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         PrintEtatInventaire.TDateMAJ.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax);
                         PrintEtatInventaire.CDateMAJ.Height:=((l+DiviseInteger(SautDesig,2)+SautLigne)*HeightMax)+6;
                         if(eof(FStock))then
                         begin
                              PrintEtatInventaire.TF15.Enabled:=true;
                              PrintEtatInventaire.TF16.Enabled:=true;
                              PrintEtatInventaire.CF15.Enabled:=true;
                              PrintEtatInventaire.CF16.Enabled:=true;
                              PrintEtatInventaire.CF15.Top:=PrintEtatInventaire.C14.Height+PrintEtatInventaire.C14.Top-1;
                              PrintEtatInventaire.TF15.Top:=PrintEtatInventaire.CF15.Top+4;
                              PrintEtatInventaire.CF16.Top:=PrintEtatInventaire.C14.Height+PrintEtatInventaire.C14.Top-1;
                              PrintEtatInventaire.TF16.Top:=PrintEtatInventaire.CF16.Top+4;
                              PrintEtatInventaire.TF16.Caption:=Vergule(floattostr(Montant),'2','C','');
                         end
                         else
                         begin
                              PrintEtatInventaire.TF15.Enabled:=false;
                              PrintEtatInventaire.TF16.Enabled:=false;
                              PrintEtatInventaire.CF15.Enabled:=false;
                              PrintEtatInventaire.CF16.Enabled:=false;
                         end;
                         PrintEtatInventaire.LastMiseAJour.Caption:='DerniŤre date de mise jour du Stock: '+DateDerniereMAJ;
                         if(l>0)then PrintEtatInventaire.Preview;
                         l:=0;
                         SautDesig:=0;
                         SautLigne:=0;
                         PrintEtatInventaire.T8.Lines.Text:='';
                         PrintEtatInventaire.T9.Lines.Text:='';
                         PrintEtatInventaire.T10.Lines.Text:='';
                         PrintEtatInventaire.T11.Lines.Text:='';
                         PrintEtatInventaire.T12.Lines.Text:='';
                         PrintEtatInventaire.T13.Lines.Text:='';
                         PrintEtatInventaire.T14.Lines.Text:='';
                         PrintEtatInventaire.TDateMAJ.Lines.Text:='';
                    end;
               end;
               finally
               closefile(FStock);
               end;
          end;
          end;
          finally
          CloseFile(FRegistreCompte);
          end;

     FSGenerateurBase.AffichePrintPr.Visible:=false;
     end;
     {************************************************}

