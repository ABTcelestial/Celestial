procedure TFSGenerateurBase.BitValiderProjetFinanceClick(Sender: TObject);
var  i:integer; OKProjetFinance,Confirme,OKExisteNewCodeStructure:boolean;  NewCodeStructure,LastCode,NewCode:string;
begin

if(FSGenerateurBase.BitValiderProjetFinance.Caption='Valider')then
begin

NewCodeStructure:=firstlaters(FSGenerateurBase.EditNumProjetFinance.Text,longueur(FSGenerateurBase.EditNumProjetFinance.Text)-5)+CompleteZeroGauche(FSGenerateurBase.EditNumOrdreStructure.Text,'5');

OpenFParc(RParc);
ChProjetFinance:=RParc.Parcours+'\'+Exercice+'FProjetFinance';
assignfile(FProjetFinance,ChProjetFinance);
try
if FileExists(ChProjetFinance)then
Reset(FProjetFinance)
else Rewrite(FProjetFinance);
Seek(FProjetFinance,0);
i:=0;
OKProjetFinance:=false;
OKExisteNewCodeStructure:=false;
while not eof(FProjetFinance)and(OKProjetFinance=false)do
begin
     read(FProjetFinance,RProjetFinance);

     if(RProjetFinance.NumProjetFinance=NewCodeStructure)then
     begin
          OKExisteNewCodeStructure:=true;
     end;

     if(RProjetFinance.NumProjetFinance=FSGenerateurBase.EditNumProjetFinance.Text)then
     begin
          OKProjetFinance:=true;
     end
     else i:=i+1;
end;

Seek(FProjetFinance,i);
if(FSGenerateurBase.EditNumOrdreStructure.Color=clLime)then
begin
     LastCode:=RProjetFinance.NumProjetFinance;
     NewCode:=NewCodeStructure;
     RProjetFinance.NumProjetFinance:=NewCodeStructure;
end
else
begin
     LastCode:=RProjetFinance.NumProjetFinance;
     NewCode:=FSGenerateurBase.EditNumProjetFinance.Text;
     RProjetFinance.NumProjetFinance:=FSGenerateurBase.EditNumProjetFinance.Text;
end;

RProjetFinance.DesignationProjetFinance:=FSGenerateurBase.EditDesignationProjetFinance.Text;
RProjetFinance.NatureProjetFinance:=FSGenerateurBase.EditNatureProjetFinance.Text;
RProjetFinance.Codification:=FSGenerateurBase.EditCodificationProjetFinance.Text;
RProjetFinance.NumLotProjetFinance:=FSGenerateurBase.EditNumLotProjetFinance.Text;
RProjetFinance.LocalisationPreciseProjetFinance:=FSGenerateurBase.EditLocalisationPreciseProjetFinance.Text;
