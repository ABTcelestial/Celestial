Procedure MiseAJourStockPublicationDetailMouvement(FichierConcerneDetailMouvement,SigneMouvement,CodeSFamille,DateDebutMAJ:string);
var  l,i,LastNumDetailMouvementMAJ,NewLastNumDetailMouvementMAJ,NbrNewArticle,NbrChargeArticle:integer;
     OKMiseAJour,OKDetailArticle,OKExistArticle:boolean;
     TableauArticleMAJStock:TableauArticleMAJStocks;
begin
     LastNumDetailMouvementMAJ:=IndiquerLastNumDetailMouvementMAJ(FichierConcerneDetailMouvement,CodeSFamille,FSGenerateurBase.RBInclureCSousFamilleNulPourTous.Checked);
     NewLastNumDetailMouvementMAJ:=LastNumDetailMouvementMAJ;
     OKMiseAJour:=false;

     TypeProces:='Business';
     if not(FunctionAdresseProces(TypeProces,FichierConcerneDetailMouvement,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcerneDetailMouvement<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerneDetailMouvement+' recherchť !');
     end;

     ChDetailMouvement:=Adresse;
     assignfile(FDetailMouvement,ChDetailMouvement);
     if FileExists(ChDetailMouvement)then
     begin
          try
          Reset(FDetailMouvement);
          Seek(FDetailMouvement,0);

          FSGenerateurBase.NomFichierConcerneDetailMouvement.Caption:=FichierConcerneDetailMouvement;
          FSGenerateurBase.ProgressMAJ.Max:=filesize(FDetailMouvement);
          FSGenerateurBase.ProgressMAJ.Position:=0;

          l:=0;
          while(not eof(FDetailMouvement))do
          begin
               Read(FDetailMouvement,RDetailMouvement); Application.ProcessMessages;

               OKDetailArticle:=RDetailMouvement.ValidationDetailMouvement;

               if(OKDetailArticle=true)then
               begin
                    if(CodeSFamille<>'')then
                    begin
                         if(Firstlaters(RDetailMouvement.CodeArticle,longueur(CodeSFamille))=CodeSFamille)
                         then OKDetailArticle:=true
                         else OKDetailArticle:=false;
                    end;
               end;

               if(OKDetailArticle=true)then
               begin
                    if(DateDebutMAJ<>'')and(datecorrecte(DateDebutMAJ))and(datecorrecte(RDetailMouvement.DateMouvement))then
                    begin
                         if(strtodate(RDetailMouvement.DateMouvement)>=strtodate(DateDebutMAJ))
                         then OKDetailArticle:=true
                         else OKDetailArticle:=false;
                    end;
               end;

               if(OKDetailArticle=true)then
               begin
                    if(RDetailMouvement.NumDetailMouvement>LastNumDetailMouvementMAJ)
                    then OKDetailArticle:=true
                    else OKDetailArticle:=false;
               end;

               if(OKDetailArticle=true)then
               begin
                    OKMiseAJour:=true;

                    i:=0;
                    OKExistArticle:=false;
                    while(i<l)and(OKExistArticle=false)do
                    begin
                         if(TableauArticleMAJStock[i].CodeArticle=RDetailMouvement.CodeArticle)
                         and(TableauArticleMAJStock[i].TypeStock=FSGenerateurBase.EditTypeStock.Text)
                         and(TableauArticleMAJStock[i].SigneMouvement=SigneMouvement)
                         and(TableauArticleMAJStock[i].PrixUnitaire=RDetailMouvement.PrixUnitaire)
                         then
                         begin
                              FSMenuPrincipal.EditRapport.Lines.Add('Article existant: '+FichierConcerneDetailMouvement+' Nį: '+inttostr(RDetailMouvement.NumDetailMouvement)+' Date: '+RDetailMouvement.DateMouvement+' Article: '+RDetailMouvement.DesignationArticle+' Quantitť: '+SigneMouvement+floattostr(RDetailMouvement.Quantite)+' au prix: '+floattostr(RDetailMouvement.PrixUnitaire));

                              OKExistArticle:=true;
                              //TableauArticleMAJStock[i].CodeArticle:=RDetailMouvement.CodeArticle;
                              //TableauArticleMAJStock[i].TypeStock:=FSGenerateurBase.EditTypeStock.Text;
                              //TableauArticleMAJStock[i].SigneMouvement:=SigneMouvement;
                              TableauArticleMAJStock[i].Quantite:=TableauArticleMAJStock[i].Quantite+RDetailMouvement.Quantite;
                              //TableauArticleMAJStock[i].PrixUnitaire:=RDetailMouvement.PrixUnitaire;
                         end;
                    i:=i+1;
                    end;

                    if(OKExistArticle=false)then
                    begin
                         FSMenuPrincipal.EditRapport.Lines.Add('Nouvel article: '+FichierConcerneDetailMouvement+' Nį: '+inttostr(RDetailMouvement.NumDetailMouvement)+' Date: '+RDetailMouvement.DateMouvement+' Article: '+RDetailMouvement.DesignationArticle+' Quantitť: '+SigneMouvement+floattostr(RDetailMouvement.Quantite)+' au prix: '+floattostr(RDetailMouvement.PrixUnitaire));

                         l:=l+1;
                         setlength(TableauArticleMAJStock,l);
                         TableauArticleMAJStock[l-1].CodeArticle:=RDetailMouvement.CodeArticle;
                         TableauArticleMAJStock[l-1].TypeStock:=FSGenerateurBase.EditTypeStock.Text;
                         TableauArticleMAJStock[l-1].SigneMouvement:=SigneMouvement;
                         TableauArticleMAJStock[l-1].Quantite:=RDetailMouvement.Quantite;
                         TableauArticleMAJStock[l-1].PrixUnitaire:=RDetailMouvement.PrixUnitaire;
                    end;

                    //ProcMiseAJourStockArticle('','',RDetailMouvement.CodeArticle,FSGenerateurBase.EditTypeStock.Text,SigneMouvement,RDetailMouvement.Quantite,RDetailMouvement.PrixUnitaire,NbrNewArticle,NbrChargeArticle,NbrNewArticle,NbrChargeArticle,OKMiseAJour);

                    if(NewLastNumDetailMouvementMAJ<RDetailMouvement.NumDetailMouvement)then NewLastNumDetailMouvementMAJ:=RDetailMouvement.NumDetailMouvement;
               end;

               FSGenerateurBase.ProgressMAJ.StepIt;
          end;
     finally
     CloseFile(FDetailMouvement);
     end;
     end;

     if(OKMiseAJour=true)and(l>0)then ProcMiseAJourStockArticleGlobal('','',FSGenerateurBase.EditTypeStock.Text,TableauArticleMAJStock,l,NbrNewArticle,NbrChargeArticle,NbrNewArticle,NbrChargeArticle,OKMiseAJour);

     if(NewLastNumDetailMouvementMAJ>0)then EnregistrerLastNumDetailMouvementMAJ(FichierConcerneDetailMouvement,CodeSFamille,NewLastNumDetailMouvementMAJ);

     if(OKMiseAJour=true)then
     begin
          FSMenuPrincipal.EditRapport.Lines.Add('Mise ŗ jour du Stock: '+FichierConcerneDetailMouvement+', du num '+inttostr(LastNumDetailMouvementMAJ)+' au num '+inttostr(NewLastNumDetailMouvementMAJ));
          FSMenuPrincipal.EditRapport.Lines.Add('');
     end
     else
     begin
          FSMenuPrincipal.EditRapport.Lines.Add('Aucune nouvelle Mise ŗ jour du Stock: '+FichierConcerneDetailMouvement+', Dťrnier num '+inttostr(LastNumDetailMouvementMAJ));
          FSMenuPrincipal.EditRapport.Lines.Add('');
     end;

     LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
end;

Function IndiquerLastNumDetailMouvementMAJ(FichierConcerneDetailMouvement,CodeSFamille:string; InclureCSousFamilleNulPourTous:boolean):integer;
var  OKLastNumDetailMouvementMAJ,OKInclureCSousFamille:boolean;
begin
     IndiquerLastNumDetailMouvementMAJ:=0;

     TypeProces:='Business';   FichierConcerne:='FLastNumDetailMouvementMAJ';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          //if(FichierConcerneDetailMouvement<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerneDetailMouvement+' recherchť !');
     end;

     ChLastNumDetailMouvementMAJSpecial:=Adresse;
     assignfile(FLastNumDetailMouvementMAJSpecial,ChLastNumDetailMouvementMAJSpecial);
     if FileExists(ChLastNumDetailMouvementMAJSpecial)then
     begin
          try
          Reset(FLastNumDetailMouvementMAJSpecial);
          Seek(FLastNumDetailMouvementMAJSpecial,0);
          OKLastNumDetailMouvementMAJ:=false;
          while(not eof(FLastNumDetailMouvementMAJSpecial))and(OKLastNumDetailMouvementMAJ=false)do
          begin
               Read(FLastNumDetailMouvementMAJSpecial,RLastNumDetailMouvementMAJSpecial);

               OKInclureCSousFamille:=false;

               if(InclureCSousFamilleNulPourTous=true)then
               begin
                    if(RLastNumDetailMouvementMAJSpecial.CodeSFamille='')
                    or(RLastNumDetailMouvementMAJSpecial.CodeSFamille=CodeSFamille)
                    then OKInclureCSousFamille:=true;
               end
               else
               begin
                    if(RLastNumDetailMouvementMAJSpecial.CodeSFamille=CodeSFamille)
                    then OKInclureCSousFamille:=true
               end;

               if(RLastNumDetailMouvementMAJSpecial.FichierConcerneDetailMouvement=FichierConcerneDetailMouvement)
               and(OKInclureCSousFamille=true)
               then
               begin
                    IndiquerLastNumDetailMouvementMAJ:=RLastNumDetailMouvementMAJSpecial.LastNumDetailMouvementMAJ;
                    OKLastNumDetailMouvementMAJ:=true;
               end;
          end;
     finally
     CloseFile(FLastNumDetailMouvementMAJSpecial);
     end;
     end;
end;

Procedure ListeLastNumDetailMouvementMAJ(TableauLastNumDetailMouvementMAJ:TStringGrid);
var  R,IndiceRubriqueTrie:integer;  RRegistreCompteRecherche:RRegistreComptes;
begin

     TableauLastNumDetailMouvementMAJ.ColCount:=7;
     TableauLastNumDetailMouvementMAJ.Cols[0].Text:='Nį';
     TableauLastNumDetailMouvementMAJ.Cols[1].Text:='Date opťration';
     TableauLastNumDetailMouvementMAJ.Cols[2].Text:='Fichier';
     TableauLastNumDetailMouvementMAJ.Cols[3].Text:='Code.S/Famille';
     TableauLastNumDetailMouvementMAJ.Cols[4].Text:='Libellť S/Famille';
     TableauLastNumDetailMouvementMAJ.Cols[5].Text:='Dťrnier numťro MAJ';
     TableauLastNumDetailMouvementMAJ.Cols[6].Text:='DťrniŤre Date MAJ';

     TableauLastNumDetailMouvementMAJ.RowCount:=2;
     TableauLastNumDetailMouvementMAJ.Rows[1].Text:='';
     R:=0;

     TypeProces:='Business';   FichierConcerne:='FLastNumDetailMouvementMAJ';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          //if(FichierConcerneDetailMouvement<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerneDetailMouvement+' recherchť !');
     end;

     ChLastNumDetailMouvementMAJ:=Adresse;
     assignfile(FLastNumDetailMouvementMAJ,ChLastNumDetailMouvementMAJ);
     if FileExists(ChLastNumDetailMouvementMAJ)then
     begin
          try
          Reset(FLastNumDetailMouvementMAJ);
          Seek(FLastNumDetailMouvementMAJ,0);
          while(not eof(FLastNumDetailMouvementMAJ))do
          begin
               Read(FLastNumDetailMouvementMAJ,RLastNumDetailMouvementMAJ);

               R:=R+1;
               TableauLastNumDetailMouvementMAJ.Rows[R].Text:=inttostr(R);
               TableauLastNumDetailMouvementMAJ.Cells[1,R]:=RLastNumDetailMouvementMAJ.DateOperationMAJ;
               TableauLastNumDetailMouvementMAJ.Cells[2,R]:=RLastNumDetailMouvementMAJ.FichierConcerneDetailMouvement;
               TableauLastNumDetailMouvementMAJ.Cells[3,R]:=RLastNumDetailMouvementMAJ.CodeSFamille;
               ChercherCompteComptable(RLastNumDetailMouvementMAJ.CodeSFamille,inttostr(Longueur(RLastNumDetailMouvementMAJ.CodeSFamille)),FSGenerateurBase.EditTypeComptabilite.Text,RRegistreCompteRecherche);
               TableauLastNumDetailMouvementMAJ.Cells[4,R]:=RRegistreCompteRecherche.Designation;
               //TableauLastNumDetailMouvementMAJ.Cells[5,R]:=inttostr(RLastNumDetailMouvementMAJ.LastNumDetailMouvementMAJ)
               TableauLastNumDetailMouvementMAJ.Cells[5,R]:=inttostr(IndiquerLastNumDetailMouvementMAJ(RLastNumDetailMouvementMAJ.FichierConcerneDetailMouvement,RLastNumDetailMouvementMAJ.CodeSFamille,FSGenerateurBase.RBInclureCSousFamilleNulPourTous.Checked));
               TableauLastNumDetailMouvementMAJ.Cells[6,R]:=RLastNumDetailMouvementMAJ.LastDateDetailMouvementMAJ;
          end;
     finally
     CloseFile(FLastNumDetailMouvementMAJ);
     end;
     end;

     if(R>0)then TableauLastNumDetailMouvementMAJ.RowCount:=R+1
            else TableauLastNumDetailMouvementMAJ.RowCount:=2;
     AjusterColWidth(TableauLastNumDetailMouvementMAJ,'','');

     IndiceRubriqueTrie:=2;
     TrierTableauARowSpecial(TableauLastNumDetailMouvementMAJ,1,TableauLastNumDetailMouvementMAJ.RowCount-1,1,inttostr(IndiceRubriqueTrie),'','+');
end;

Procedure EnregistrerLastNumDetailMouvementMAJ(FichierConcerneDetailMouvement,CodeSFamille:string; LastNumDetailMouvementMAJ:integer);
var  i:integer;  OKLastNumDetailMouvementMAJ:boolean;
begin
     TypeProces:='Business';   FichierConcerne:='FLastNumDetailMouvementMAJ';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          //if(FichierConcerneDetailMouvement<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerneDetailMouvement+' recherchť !');
     end;

     ChLastNumDetailMouvementMAJ:=Adresse;
     assignfile(FLastNumDetailMouvementMAJ,ChLastNumDetailMouvementMAJ);
     try
     if FileExists(ChLastNumDetailMouvementMAJ)
     then Reset(FLastNumDetailMouvementMAJ)
     else Rewrite(FLastNumDetailMouvementMAJ);
     Seek(FLastNumDetailMouvementMAJ,0);
     OKLastNumDetailMouvementMAJ:=false;
     i:=0;
     while(not eof(FLastNumDetailMouvementMAJ))and(OKLastNumDetailMouvementMAJ=false)do
     begin
          Read(FLastNumDetailMouvementMAJ,RLastNumDetailMouvementMAJ);

          if(RLastNumDetailMouvementMAJ.FichierConcerneDetailMouvement=FichierConcerneDetailMouvement)
          and(RLastNumDetailMouvementMAJ.CodeSFamille=CodeSFamille)
          then
          begin
               OKLastNumDetailMouvementMAJ:=true;

               RLastNumDetailMouvementMAJ.DateOperationMAJ:=datetostr(date);
               RLastNumDetailMouvementMAJ.FichierConcerneDetailMouvement:=FichierConcerneDetailMouvement;
               RLastNumDetailMouvementMAJ.CodeSFamille:=CodeSFamille;
               RLastNumDetailMouvementMAJ.LastNumDetailMouvementMAJ:=LastNumDetailMouvementMAJ;
               RLastNumDetailMouvementMAJ.LastDateDetailMouvementMAJ:=datetostr(date);

               Seek(FLastNumDetailMouvementMAJ,i);
               Write(FLastNumDetailMouvementMAJ,RLastNumDetailMouvementMAJ);
          end;
     i:=i+1;
     end;

     if(OKLastNumDetailMouvementMAJ=false)then
     begin
          RLastNumDetailMouvementMAJ.DateOperationMAJ:=datetostr(date);
          RLastNumDetailMouvementMAJ.FichierConcerneDetailMouvement:=FichierConcerneDetailMouvement;
          RLastNumDetailMouvementMAJ.CodeSFamille:=CodeSFamille;
          RLastNumDetailMouvementMAJ.LastNumDetailMouvementMAJ:=LastNumDetailMouvementMAJ;
          RLastNumDetailMouvementMAJ.LastDateDetailMouvementMAJ:=datetostr(date);

          Seek(FLastNumDetailMouvementMAJ,i);
          Write(FLastNumDetailMouvementMAJ,RLastNumDetailMouvementMAJ);
     end;
     finally
     CloseFile(FLastNumDetailMouvementMAJ);
     end;
end;

