FSGenerateurBase.EditRef.Text:=FSGenerateurBase.TableauStockArticle.Cells[3,FSGenerateurBase.TableauStockArticle.Row];
FSGenerateurBase.EditUM.Text:=TexteComboBox(FSGenerateurBase.EditUM,FSGenerateurBase.TableauStockArticle.Cells[4,FSGenerateurBase.TableauStockArticle.Row],Pt);
FSGenerateurBase.EditQTEEntree.Text:=FSGenerateurBase.TableauStockArticle.Cells[5,FSGenerateurBase.TableauStockArticle.Row];
FSGenerateurBase.EditQteSortie.Text:=FSGenerateurBase.TableauStockArticle.Cells[6,FSGenerateurBase.TableauStockArticle.Row];
FSGenerateurBase.EditQteStock.Text:=FSGenerateurBase.TableauStockArticle.Cells[7,FSGenerateurBase.TableauStockArticle.Row];
FSGenerateurBase.EditQteInitial.Text:=FSGenerateurBase.TableauStockArticle.Cells[8,FSGenerateurBase.TableauStockArticle.Row];
FSGenerateurBase.EditQteLimite.Text:=FSGenerateurBase.TableauStockArticle.Cells[9,FSGenerateurBase.TableauStockArticle.Row];
FSGenerateurBase.EditCoutUnitaire.Text:=FSGenerateurBase.TableauStockArticle.Cells[10,FSGenerateurBase.TableauStockArticle.Row];
