procedure TFSGenerateurBase.BitValiderTypeUniteFondsClick(Sender: TObject);
var  i:integer; OKTypeUniteFonds,Confirme:boolean;
begin

if(FSGenerateurBase.BitValiderTypeUniteFonds.Caption='Valider')then
begin
OpenFParc(RParc);
ChTypeUniteFonds:=RParc.Parcours+'\'+Exercice+'FTypeUniteFonds';
assignfile(FTypeUniteFonds,ChTypeUniteFonds);
try
if FileExists(ChTypeUniteFonds)then
Reset(FTypeUniteFonds)
else Rewrite(FTypeUniteFonds);
Seek(FTypeUniteFonds,0);
i:=0;
OKTypeUniteFonds:=false;
while not eof(FTypeUniteFonds)and(OKTypeUniteFonds=false)do
begin
     read(FTypeUniteFonds,RTypeUniteFonds);
     if(RTypeUniteFonds.NumTypeUniteFonds=strtointeger(FSGenerateurBase.EditNumTypeUniteFonds.Text))then
     begin
          OKTypeUniteFonds:=true;
     end
     else i:=i+1;
end;

Seek(FTypeUniteFonds,i);
RTypeUniteFonds.NumTypeUniteFonds:=strtointeger(FSGenerateurBase.EditNumTypeUniteFonds.Text);
RTypeUniteFonds.CodeTypeUniteFonds:=FSGenerateurBase.EditCodeTypeUniteFonds.Text;
RTypeUniteFonds.DesignationTypeUniteFonds:=FSGenerateurBase.EditDesignationTypeUniteFonds.Text;
write(FTypeUniteFonds,RTypeUniteFonds);

finally
Closefile(FTypeUniteFonds);
end;
end;

if(FSGenerateurBase.BitValiderTypeUniteFonds.Caption='Supprimer')then
begin
     DeleteFTypeUniteFonds(strtointeger(FSGenerateurBase.EditNumTypeUniteFonds.Text),FSGenerateurBase.TableauTypeUniteFonds.Cells[2,FSGenerateurBase.TableauTypeUniteFonds.Row],Confirme);
end;

ListeTypeUniteFonds(FSGenerateurBase.TableauTypeUniteFonds);
FSGenerateurBase.AfficheOptionsTypeUniteFonds.Visible:=false;
FSGenerateurBase.TableauTypeUniteFonds.SetFocus;
end;

