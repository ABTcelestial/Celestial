Procedure IndiquerListeFichierPartagerAuxClientsReseaux(NumAdresseProces,NomDossierPartagerReseaux:string);
var i,iR:integer; NomDossierLocal,NomDossierReseaux,EmlacementLocalOuReseauxOut,NumAdresseProcesTeste,NomDossierPartagerReseauxTeste,AdresseDossierLocal,AdresseDossierReseaux:string; OKDossierPartagerReseaux:boolean;
