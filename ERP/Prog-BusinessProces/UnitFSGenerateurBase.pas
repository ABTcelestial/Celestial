          begin
               FSGenerateurBase.EditDesig.Height:=43;
               FSGenerateurBase.TrackBar1.Position:=0;
               FSGenerateurBase.EditRef.SetFocus;
          end;

          FSGenerateurBase.CaptionNbrCharLigne.Caption:='0';
    end
