               begin
                    read(FPrelevement,RPrelevement);  Application.ProcessMessages;
                    if(stringtodate(RPrelevement.DatePrelevement,RPrelevement.DatePrelevement)>=stringtodate(DateDebutPeriodeAnalysePrelevement,DateDebutPeriodeAnalysePrelevement))
                    and(stringtodate(RPrelevement.DatePrelevement,RPrelevement.DatePrelevement)<=stringtodate(DateFinPeriodeAnalysePrelevement,DateFinPeriodeAnalysePrelevement))
                    then
