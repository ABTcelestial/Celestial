procedure TFSGenerateurBase.BitBtn84Click(Sender: TObject);
var   i:integer; AdresseNewFil:string;  OKAdresseDossierPartageReseaux,OKAdresseProces:boolean;
begin
     FSGenerateurBase.EnregistrerFichier.FileName:=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[2,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row];

     if(FSGenerateurBase.EnregistrerFichier.Execute)then
     begin
          AdresseNewFil:=FSGenerateurBase.EnregistrerFichier.FileName;

          if DirectoryExists(AdresseNewFil) then ShowMessage('le dossier existe')
          else
          begin
               if MessageDlg('Voulez-vous vraiment crťer un nouveau dossier: ' +AdresseNewFil+ '?',mtConfirmation, [mbYes, mbNo], 0)=MrYes
               then
               begin
                    CreateDir(AdresseNewFil);
                    ////////////////////////////////////////////////////////////

                    OpenFParc(RParc);
                    ChAdresseDossierPartageReseaux:=RParc.Parcours+'\'+Exercice+'FAdresseDossierPartageReseaux';
                    assignfile(FAdresseDossierPartageReseaux,ChAdresseDossierPartageReseaux);
                    try
                    if FileExists(ChAdresseDossierPartageReseaux)then
                    Reset(FAdresseDossierPartageReseaux)
                    else Rewrite(FAdresseDossierPartageReseaux);
                    Seek(FAdresseDossierPartageReseaux,0);
                    i:=0;
                    OKAdresseDossierPartageReseaux:=false;
                    while not eof(FAdresseDossierPartageReseaux)and(OKAdresseDossierPartageReseaux=false)do
                    begin
                         read(FAdresseDossierPartageReseaux,RAdresseDossierPartageReseaux);

                         if(RAdresseDossierPartageReseaux.NumAdresseDossierPartageReseaux=strtointeger(FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[1,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row]))then
                         begin
                              Seek(FAdresseDossierPartageReseaux,i);
                              //RAdresseDossierPartageReseaux.NumAdresseDossierPartageReseaux:=;
                              //RAdresseDossierPartageReseaux.NomPosteReseaux:=;
                              RAdresseDossierPartageReseaux.AdresseDossierPartageReseaux:=AdresseNewFil;
                              //RAdresseDossierPartageReseaux.EmlacementLocalOuReseaux:=;
                              //RAdresseDossierPartageReseaux.Port:=;
                              //RAdresseDossierPartageReseaux.AdresseIP:=;
                              write(FAdresseDossierPartageReseaux,RAdresseDossierPartageReseaux);
                         end;
                    i:=i+1;
                    end;
                    finally
                    Closefile(FAdresseDossierPartageReseaux);
                    end;
                    ////////////////////////////////////////////////////////////

                    OpenFParc(RParc);
                    ChAdresseProces:=RParc.Parcours+'\'+Exercice+'FAdresseProces';
                    assignfile(FAdresseProces,ChAdresseProces);
                    i:=0;
                    OKAdresseProces:=false;
                    if FileExists(ChAdresseProces)then
                    begin
                          try
                          Reset(FAdresseProces);
                          Seek(FAdresseProces,0);
                          while not eof(FAdresseProces)and(OKAdresseProces=false)do
                          begin
                               read(FAdresseProces,RAdresseProces);

                               if(RAdresseProces.Repertoire=FSGenerateurBase.TableauAdresseDossierPartageReseaux.Cells[2,FSGenerateurBase.TableauAdresseDossierPartageReseaux.Row])then
                               begin
                                    OKAdresseProces:=true;
                                    Seek(FAdresseProces,i);
                                    //RAdresseProces.NumAdresseProces:=
                                    //RAdresseProces.TypeProces:=;
                                    //RAdresseProces.Repertoire:=;
                                    RAdresseProces.AdresseProces:=AdresseNewFil;
                                    //RAdresseProces.Exercice:=;
                                    //RAdresseProces.FichierConcerne:=;
                                    write(FAdresseProces,RAdresseProces);
                               end;
                          i:=i+1;
                          end;
                          finally
                          Closefile(FAdresseProces);
                          end;
                    end;

               ListeAdresseDossierPartageReseaux(FSGenerateurBase.TableauAdresseDossierPartageReseaux,false,false,True);
               end;
          end;
     end;
end;

