RProjetFinance.HeureDebutProjetFinance:=timetostr(FSGenerateurBase.EditHeureDebutProjetFinance.Time);
RProjetFinance.DelaisRealisationProjetFinance:=strtointeger(FSGenerateurBase.EditDelaisRealisationProjetFinance.Text);
RProjetFinance.UniteDelaisRealisationProjetFinance:=FSGenerateurBase.EditUniteDelaisRealisationProjetFinance.Text;
RProjetFinance.DateFinProjetFinance:=datetostr(FSGenerateurBase.EditDateFinProjetFinance.Date);
RProjetFinance.HeureFinProjetFinance:=timetostr(FSGenerateurBase.EditHeureFinProjetFinance.Time);
RProjetFinance.UniteMesureProjetFinance:=FSGenerateurBase.EditUniteMesureProjetFinance.Text;
RProjetFinance.PrixUniteHTMesureProjetFinance:=strtoreal(FSGenerateurBase.EditPrixUniteMesureProjetFinance.Text);
RProjetFinance.MesureGlobaleProjetFinance:=strtoreal(FSGenerateurBase.EditMesureGlobaleProjetFinance.Text);
RProjetFinance.MesurePartielleProjetFinance:=strtoreal(FSGenerateurBase.EditMesurePartielleProjetFinance.Text);
RProjetFinance.MontantHTProjetFinance:=strtoreal(FSGenerateurBase.EditMontantProjetFinance.Text);
RProjetFinance.TaxePourcentage:=strtoreal(FSGenerateurBase.EditTaxePorcentage.Text);
RProjetFinance.DecompositionProjetFinance:=strtoboolean(FSGenerateurBase.EditDecompositionProjetFinance.Text);
RProjetFinance.PourcentagePartieCommune:=strtoreal(WithoutChar(FSGenerateurBase.EditPourcentagePartieCommune.Text,'%'));
RProjetFinance.TypeUsage:=FSGenerateurBase.EditTypeUsage.Text;
write(FProjetFinance,RProjetFinance);

finally
Closefile(FProjetFinance);
end;

if(LastCode<>NewCode)then
begin
     ///////////////////////////////////////////////////////////////////////////
     OpenFParc(RParc);
     ChPlanificateur:=RParc.Parcours+'\'+Exercice+'FPlanificateur';
     assignfile(FPlanificateur,ChPlanificateur);
     try
     if FileExists(ChPlanificateur)then
     Reset(FPlanificateur)
     else Rewrite(FPlanificateur);
     Seek(FPlanificateur,0);
     i:=0;
     while not eof(FPlanificateur)do
     begin
          read(FPlanificateur,RPlanificateur);
          if(RPlanificateur.CodeStructureProjet=LastCode)then
          begin
               RPlanificateur.CodeStructureProjet:=NewCode;
               Seek(FPlanificateur,i);
               write(FPlanificateur,RPlanificateur);
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FPlanificateur);
     end;

     ///////////////////////////////////////////////////////////////////////////
     OpenFParc(RParc);
     ChFormulairePreselection:=RParc.Parcours+'\'+Exercice+'FFormulairePreselection';
     assignfile(FFormulairePreselection,ChFormulairePreselection);
     try
     if FileExists(ChFormulairePreselection)then
     Reset(FFormulairePreselection)
     else Rewrite(FFormulairePreselection);
     Seek(FFormulairePreselection,0);
     i:=0;
     while not eof(FFormulairePreselection)do
     begin
          read(FFormulairePreselection,RFormulairePreselection);
          if(RFormulairePreselection.NumProjet=LastCode)then
          begin
               RFormulairePreselection.NumProjet:=NewCode;
               Seek(FFormulairePreselection,i);
               write(FFormulairePreselection,RFormulairePreselection);
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FFormulairePreselection);
     end;
end;

end;

if(FSGenerateurBase.BitValiderProjetFinance.Caption='Supprimer')then
begin
     DeleteFProjetFinance(FSGenerateurBase.EditNumProjetFinance.Text,Confirme);
end;

ListeProjetFinance(FSGenerateurBase.TableauProjetFinance,'','','',false,'',FSGenerateurBase.EditNumProjetFinance.Text,FSGenerateurBase.RBIndiquerReservationStructure.Checked,false,FSRecapitulatifProjets.EditTiersTypeProces.Text,FSRecapitulatifProjets.EditTiersFichierConserne.Text);
