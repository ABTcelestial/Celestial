then FSGenerateurBase.AfficheOptions.Top:=(MousePos.Y+FSGenerateurBase.TableauStockArticle.Top)
else FSGenerateurBase.AfficheOptions.Top:=(FSGenerateurBase.TableauStockArticle.Height-
     FSGenerateurBase.AfficheOptions.Height)+FSGenerateurBase.TableauStockArticle.Top;
end;

