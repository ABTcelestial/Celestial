procedure TFSGenerateurBase.TableauSFamilleKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var   m:integer; TypeProces,FichierConcerne,Adresse,CodeBarre:string;
begin

if key in[VK_RETURN] then
begin
     FSGenerateurBase.EditCodeSousFamille.Text:=FSGenerateurBase.TableauSFamille.Cells[1,FSGenerateurBase.TableauSFamille.Row];
     FSGenerateurBase.EditNomSousFamille.Text:=FSGenerateurBase.TableauSFamille.Cells[2,FSGenerateurBase.TableauSFamille.Row];
     FSGenerateurBase.NomSFl.Caption:='Liste des Articles de la S/Famille: '+FSGenerateurBase.TableauSFamille.Cells[2,FSGenerateurBase.TableauSFamille.Row];
     CodeBarre:=FSGenerateurBase.EditCodeBarre.Text;

     if(FSGenerateurBase.EditRequette.Text='Liste')then
     begin
          TypeProces:='Commercial';
          FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
          Adresse:='';
          if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               InitialisationFicheSaisieProduit;
               ChStockArticle:=Adresse;
               ProcAfficheListeStock(FSGenerateurBase.TableauStockArticle,ChStockArticle,FSGenerateurBase.TableauSFamille.Cells[1,FSGenerateurBase.TableauSFamille.Row],'','',FSGenerateurBase.RBAvecCodeBarre.Checked);
               FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=ChStockArticle;
               FSGenerateurBase.TableauStockArticle.SetFocus;
          end;
     end;

     if(FSGenerateurBase.EditRequette.Text='Nouveau')or(FSGenerateurBase.EditRequette.Text='Modifier')then
     begin
          FSGenerateurBase.AfficheProduits.Visible:=true;

          m:=1;
          TypeProces:='Commercial';
          FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
          Adresse:='';
          if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               ChStockArticle:=Adresse;

               ProcAfficheListeStock(FSGenerateurBase.TableauStockArticle,ChStockArticle,FSGenerateurBase.TableauSFamille.Cells[1,FSGenerateurBase.TableauSFamille.Row],'','',FSGenerateurBase.RBAvecCodeBarre.Checked);
               FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=ChStockArticle;

               assignfile(FStockArticle,ChStockArticle);
               try
               if FileExists(ChStockArticle)then
               Reset(FStockArticle)
               else Rewrite(FStockArticle);
               Seek(FStockArticle,0);
               while not eof(FStockArticle) do
               begin
                    Read(FStockArticle,RStockArticle);
                    if(FirstLaters(RStockArticle.Code,6)=FSGenerateurBase.TableauSFamille.Cells[1,FSGenerateurBase.TableauSFamille.Row])then
                    begin
                         if(m<=strtoint(LastLaters(RStockArticle.Code,4)))then m:=strtoint(LastLaters(RStockArticle.Code,4))+1;
                    end;
               end;
               finally
               CloseFile(FStockArticle);
               end;
          end
          else
          begin
               OpenFParc(RParc);
               ChStock:=RParc.Parcours+'\'+Exercice+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
               assignfile(FStock,ChStock);
               try
               if FileExists(ChStock)then
               Reset(FStock)
               else Rewrite(FStock);
               Seek(FStock,0);
               while not eof(FStock)do
               begin
                    read(FStock,RStock);
                    if(FirstLaters(RStock.Code,6)=FSGenerateurBase.TableauSFamille.Cells[1,FSGenerateurBase.TableauSFamille.Row])then
                    begin
                         if(m<=strtoint(LastLaters(RStock.Code,4)))then m:=strtoint(LastLaters(RStock.Code,4))+1;
                    end;
               end;
               finally
               CloseFile(FStock);
               end;
          end;

          if(FSGenerateurBase.EditRequette.Text='Nouveau')then
          begin
               InitialisationFicheSaisieProduit;
               FSGenerateurBase.EditCodeProduit.Text:=FSGenerateurBase.TableauSFamille.Cells[1,FSGenerateurBase.TableauSFamille.Row]+CompleteZeroGauche(inttostr(m),'4');
               FSGenerateurBase.EditCodeBarre.Text:=CodeBarre;
               FSGenerateurBase.EditDesig.Lines.Text:=FSGenerateurBase.TableauSFamille.Cells[2,FSGenerateurBase.TableauSFamille.Row];
               FSGenerateurBase.EditEnregistPr.Text:=FSGenerateurBase.TableauSFamille.Cells[3,FSGenerateurBase.TableauSFamille.Row];
               FSGenerateurBase.BitValiderProduit.Visible:=true;
               if(FSGenerateurBase.EditCodeBarre.Text='')
               then FSGenerateurBase.EditCodeBarre.SetFocus
               else FSGenerateurBase.EditRef.SetFocus;
          end;

          if(FSGenerateurBase.EditRequette.Text='Modifier')then
          begin
               FSGenerateurBase.EditCodeProduit.Text:=FSGenerateurBase.TableauSFamille.Cells[1,FSGenerateurBase.TableauSFamille.Row]+CompleteZeroGauche(inttostr(m),'4');
               FSGenerateurBase.EditCodeBarre.Text:=CodeBarre;
               //FSGenerateurBase.EditDesig.Lines.Text:=FSGenerateurBase.TableauSFamille.Cells[2,FSGenerateurBase.TableauSFamille.Row];
               //FSGenerateurBase.EditEnregistPr.Text:=FSGenerateurBase.TableauSFamille.Cells[3,FSGenerateurBase.TableauSFamille.Row];
               FSGenerateurBase.BitValiderProduit.Visible:=true;
               FSGenerateurBase.BitValiderProduit.SetFocus;
          end;
     end;

FSGenerateurBase.AfficheSFamille.Visible:=false;
end;

end;

