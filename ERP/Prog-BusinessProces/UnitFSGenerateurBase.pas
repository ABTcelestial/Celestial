Procedure StockLimite(TypeStock,NumProjet:string; OKAfficheListeStockLimite,InclureStockLimiteNonRepertotie:boolean; RowInSL:integer; var RowOutSL:integer);
var  RSL,C:integer;  NotCol:string;  OKStock:boolean;
begin
     RSL:=RowInSL;

     if(TypeStock<>'')then
     begin
           OpenFParc(RParc);
           ChStockArticle:=RParc.Parcours+'\'+Exercice+'FStock'+TypeStock+NumProjet;
           if(RowInSL=0)then
           begin
                FSAlerte.TableauStockLimite.ColCount:=13;
                FSAlerte.TableauStockLimite.Cols[0].Text:='Nį';
                FSAlerte.TableauStockLimite.Cols[1].Text:='Code';
                FSAlerte.TableauStockLimite.Cols[2].Text:='Dťsignation';
                FSAlerte.TableauStockLimite.Cols[3].Text:='Rťf';
                FSAlerte.TableauStockLimite.Cols[4].Text:='UM';
                FSAlerte.TableauStockLimite.Cols[5].Text:='CoŻt';
                FSAlerte.TableauStockLimite.Cols[6].Text:='Qte.Initial';
                FSAlerte.TableauStockLimite.Cols[7].Text:='Qte.Entrťe';
                FSAlerte.TableauStockLimite.Cols[8].Text:='Qte.Sortie';
                FSAlerte.TableauStockLimite.Cols[9].Text:='Qte.Stock';
                FSAlerte.TableauStockLimite.Cols[10].Text:='Qte.Limite';
                FSAlerte.TableauStockLimite.Cols[11].Text:='Num Structure';
                FSAlerte.TableauStockLimite.Cols[12].Text:='Structure';

                FSAlerte.TableauStockLimite.RowCount:=2;
                FSAlerte.TableauStockLimite.Rows[1].Text:='';
           end;

           ChStockControle:=ChStockArticle;
           assignfile(FStockControle,ChStockControle);
           try
           if FileExists(ChStockControle)then
           Reset(FStockControle)
           else Rewrite(FStockControle);
           Seek(FStockControle,0);
           while not eof(FStockControle)do
           begin
                read(FStockControle,RStockControle); Application.ProcessMessages;

                if(InclureStockLimiteNonRepertotie=false)then
                begin
                     if(RStockControle.QteLimite>0)
                     then OKStock:=true
                     else OKStock:=false;
                end
                else OKStock:=true;

                if(OKStock=true)and(RStockControle.QteStock<=RStockControle.QteLimite)then
                begin
                     RSL:=RSL+1;
                     FSAlerte.TableauStockLimite.Rows[RSL].Text:=inttostr(RSL);
                     FSAlerte.TableauStockLimite.Cells[1,RSL]:=RStockControle.Code;
                     FSAlerte.TableauStockLimite.Cells[2,RSL]:=RStockControle.Design;
                     FSAlerte.TableauStockLimite.Cells[3,RSL]:=RStockControle.Ref;
                     FSAlerte.TableauStockLimite.Cells[4,RSL]:=RStockControle.UM;
                     FSAlerte.TableauStockLimite.Cells[5,RSL]:=Vergule(floattostr(RStockControle.CoutUnitaire),'2','C','');
                     FSAlerte.TableauStockLimite.Cells[6,RSL]:=Vergule(floattostr(RStockControle.QteInitial),'2','C','');
                     FSAlerte.TableauStockLimite.Cells[7,RSL]:=Vergule(floattostr(RStockControle.QteEntree),'2','C','');
                     FSAlerte.TableauStockLimite.Cells[8,RSL]:=Vergule(floattostr(RStockControle.QteSortie),'2','C','');
                     FSAlerte.TableauStockLimite.Cells[9,RSL]:=Vergule(floattostr(RStockControle.QteStock),'2','C','');
                     FSAlerte.TableauStockLimite.Cells[10,RSL]:=Vergule(floattostr(RStockControle.QteLimite),'2','C','');

                     if(NumProjet<>'')then
                     begin
                          FSAlerte.TableauStockLimite.Cells[11,RSL]:=NumProjet;
                          FSAlerte.TableauStockLimite.Cells[12,RSL]:=ChercherProjetFinance(NumProjet,PositionProjetFinancesRecherche).DesignationProjetFinance;
                     end
                     else
                     begin
                          FSAlerte.TableauStockLimite.Cells[11,RSL]:='Tous';
                          FSAlerte.TableauStockLimite.Cells[12,RSL]:='Stock principal';
                     end;
                end;
           end;
           finally
           CloseFile(FStockControle);
           end;
     end;

     if(RSL>0)then
            begin
                 FSAlerte.TableauStockLimite.RowCount:=RSL+1;

                 if(OKAfficheListeStockLimite=true)then
                 begin
                      FSAlerte.Show;
                      FSAlerte.AfficheInformationStockLimite.Caption:=inttostr(RSL)+' cas stock limite';
                      FSAlerte.TableauStockLimite.SetFocus;
                 end;
            end
            else FSAlerte.TableauStockLimite.RowCount:=2;

     NotCol:='11';

     for C:=1 to FSAlerte.TableauStockLimite.ColCount-1 do if existenumintexte(inttostr(C),NotCol)then FSAlerte.TableauStockLimite.ColWidths[C]:=0;
     AjusterColWidth(FSAlerte.TableauStockLimite,'',NotCol);

     RowOutSL:=RSL;
end;

