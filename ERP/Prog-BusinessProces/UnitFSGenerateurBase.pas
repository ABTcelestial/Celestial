procedure TFSGenerateurBase.TableauPlanComptableChoisKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var R,m:integer; ListeCode,ListeDesignation:string;
begin
     if key in[VK_RETURN]then
     begin
          FSGenerateurBase.AffichageTableauPlanComptableChois.Visible:=false;
          R:=1;
          m:=0;
          ListeCode:='';
          ListeDesignation:='';
          while(R<=FSGenerateurBase.TableauPlanComptableChois.RowCount-1)do
          begin
               if(FSGenerateurBase.TableauPlanComptableChois.Cells[FSGenerateurBase.TableauPlanComptableChois.ColCount-1,R]='OK')then
               begin
                    m:=m+1;
                    if(ListeCode='')
                    then ListeCode:=FSGenerateurBase.TableauPlanComptableChois.Cells[1,R]
                    else ListeCode:=ListeCode+';'+FSGenerateurBase.TableauPlanComptableChois.Cells[1,R];
                    if(ListeDesignation='')then ListeDesignation:=FSGenerateurBase.TableauPlanComptableChois.Cells[2,R];
               end;
          R:=R+1;
          end;
     end;

     if(m=0)then
     begin
          showmessage('Aucun code sťlectionnť !');
     end
     else
     if(m=1)then
     begin
          FSGenerateurBase.EditCodeTypeAffichage.Text:=ListeCode;
          FSGenerateurBase.AfficheDesignationTypeAffichage.Caption:=ListeDesignation
     end
     else
     begin
          FSGenerateurBase.EditCodeTypeAffichage.Text:=ListeCode;
          FSGenerateurBase.AfficheDesignationTypeAffichage.Caption:=inttostr(m)+' Codes sťlectionnťs.'
     end;

     ActivationDataStructure;
end;

