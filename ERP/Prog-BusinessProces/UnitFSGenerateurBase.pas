procedure TFSGenerateurBase.TableauCompteTiersKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  OrdreDomiciliation:integer; TypeProces,FichierConcerne,Adresse,NumDomiciliation:string;
begin
if key in[VK_RETURN]then
begin
     if(FSGenerateurBase.TableauCompteTiers.Cells[2,FSGenerateurBase.TableauCompteTiers.Row]='Nouveau')then
     begin
          if(FSGenerateurBase.EditNumDomiciliation.Text='')
          or((FSGenerateurBase.EditNumDomiciliation.Text<>'')and(Firstlaters(FSGenerateurBase.EditNumDomiciliation.Text,longueur(FSGenerateurBase.TableauListeCompteCP.Cells[1,FSGenerateurBase.TableauListeCompteCP.Row]))<>FSGenerateurBase.TableauListeCompteCP.Cells[1,FSGenerateurBase.TableauListeCompteCP.Row])) then
          begin
               OpenFParc(RParc);
               ChDomiciliation:=RParc.Parcours+'\'+Exercice+'FDomiciliation';
               assignfile(FDomiciliation,ChDomiciliation);
               try
               if FileExists(ChDomiciliation)then
               Reset(FDomiciliation)
               else Rewrite(FDomiciliation);
               Seek(FDomiciliation,0);
               OrdreDomiciliation:=1;
               while not eof(FDomiciliation)do
               begin
                    read(FDomiciliation,RDomiciliation);
                    if(FSGenerateurBase.TableauListeCompteCP.Cells[1,FSGenerateurBase.TableauListeCompteCP.Row]<>'')then
                    begin
                         if(Firstlaters(RDomiciliation.NumDomiciliation,longueur(FSGenerateurBase.TableauListeCompteCP.Cells[1,FSGenerateurBase.TableauListeCompteCP.Row]))=FSGenerateurBase.TableauListeCompteCP.Cells[1,FSGenerateurBase.TableauListeCompteCP.Row])then
                         begin
                              if(strtointeger(lastlaters(RDomiciliation.NumDomiciliation,4))>=OrdreDomiciliation)then OrdreDomiciliation:=strtointeger(lastlaters(RDomiciliation.NumDomiciliation,4))+1;
                         end;
                    end
                    else
                    begin
                         if(strtointeger(lastlaters(RDomiciliation.NumDomiciliation,4))>=OrdreDomiciliation)then OrdreDomiciliation:=strtointeger(lastlaters(RDomiciliation.NumDomiciliation,4))+1;
                    end;
               end;
               finally
               closefile(FDomiciliation);
               end;
               
               NumDomiciliation:=FSGenerateurBase.TableauListeCompteCP.Cells[1,FSGenerateurBase.TableauListeCompteCP.Row]+Completezerogauche(inttostr(OrdreDomiciliation),'4');
               FSGenerateurBase.EditNumDomiciliation.Text:=NumDomiciliation;
          end;
     end
     else
     begin
          FSGenerateurBase.EditNumDomiciliation.Text:=FSGenerateurBase.TableauCompteTiers.Cells[2,FSGenerateurBase.TableauCompteTiers.Row];
          FSGenerateurBase.EditDesignationDomiciliation.Text:=FSGenerateurBase.TableauCompteTiers.Cells[3,FSGenerateurBase.TableauCompteTiers.Row];
     end;

FSGenerateurBase.EditDesignationDomiciliation.SetFocus;
FSGenerateurBase.AfficheCompteTiers.Visible:=false;
FSGenerateurBase.AfficheListeCompteCP.Visible:=false;
end;
end;

