procedure TFSGenerateurBase.BitBtn28Click(Sender: TObject);
var  l,R,RowMaxFiche,RowMaxRubrique:integer;  OKFicheTechVente,OKFicheTechCharge,OKRubrique:boolean;   RTypeAvisDebit,RTypeAvisCredit:RTypeAviss; RProjetSource:RProjetFinances; T:string;
begin
     OpenFParc(RParc);
     ChTypeAvis:=RParc.Parcours+'\'+Exercice+'FTypeAvis';
     assignfile(FTypeAvis,ChTypeAvis);
     try
     if FileExists(ChTypeAvis)then
     Reset(FTypeAvis)
     else Rewrite(FTypeAvis);
     Seek(FTypeAvis,0);
     RTypeAvisDebit.DesignationTypeAvis:='';
     RTypeAvisCredit.DesignationTypeAvis:='';
     while not eof(FTypeAvis)do
     begin
          read(FTypeAvis,RTypeAvis);
          if(RTypeAvisDebit.DesignationTypeAvis='')then if(RTypeAvis.DebitCredit='Dťbit')then RTypeAvisDebit:=RTypeAvis;
          if(RTypeAvisCredit.DesignationTypeAvis='')then if(RTypeAvis.DebitCredit='Crťdit')then RTypeAvisCredit:=RTypeAvis;
     end;
     finally
     CloseFile(FTypeAvis);
     end;
     
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.ColCount:=11;
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.RowCount:=2;
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Rows[1].Text:='';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[0].Text:='Nį';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[1].Text:='Code Structure';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[2].Text:='Codification Fiche';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[3].Text:='Dťsignation';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[4].Text:='Quantitť';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[5].Text:='Type Unitť';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[6].Text:='Prix U.';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[7].Text:='Montant';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[8].Text:='T';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[9].Text:='NumFicheTech';
     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cols[10].Text:='Nature';

     FSGenerateurBase.TableauFicheTechniquePropose.ColCount:=6;
     FSGenerateurBase.TableauFicheTechniquePropose.RowCount:=2;
     FSGenerateurBase.TableauFicheTechniquePropose.Rows[1].Text:='';
     FSGenerateurBase.TableauFicheTechniquePropose.Cols[0].Text:='Nį';
     FSGenerateurBase.TableauFicheTechniquePropose.Cols[1].Text:='Code Structure';
     FSGenerateurBase.TableauFicheTechniquePropose.Cols[2].Text:='Codification Fiche';
     FSGenerateurBase.TableauFicheTechniquePropose.Cols[3].Text:='Dťsignation de la fiche technique';
     FSGenerateurBase.TableauFicheTechniquePropose.Cols[4].Text:='Num Avis utilisť';
     FSGenerateurBase.TableauFicheTechniquePropose.Cols[5].Text:='Avis utilisť';

     OpenFParc(RParc);
     ChProjetFinance:=RParc.Parcours+'\'+Exercice+'FProjetFinance';
     assignfile(FProjetFinance,ChProjetFinance);
     try
     if FileExists(ChProjetFinance)then
     Reset(FProjetFinance)
     else Rewrite(FProjetFinance);
     Seek(FProjetFinance,0);
     RowMaxFiche:=0;
     RowMaxRubrique:=0;
     while not eof(FProjetFinance)do
     begin
          read(FProjetFinance,RProjetFinance);
          if(firstlaters(RProjetFinance.NumProjetFinance,longueur(FSGenerateurBase.EditCodeProjetPropose.Text))=FSGenerateurBase.EditCodeProjetPropose.Text)
          and(Longueur(RProjetFinance.NumProjetFinance)=10+((FSGenerateurBase.EditRonStructure.ItemIndex+1)*5))
          then
          begin
               RProjetSource:=ChercherProjetFinance(Firstlaters(RProjetFinance.NumProjetFinance,longueur(RProjetFinance.NumProjetFinance)-5),PositionProjetFinancesRecherche);
               /////////////////Proposition Fiches Technique !!!!!!!!!!!!!!!!!!!!
               R:=1;
               OKFicheTechVente:=false;
               OKFicheTechCharge:=false;
               while(R<=RowMaxFiche)and(OKFicheTechVente=false)and(OKFicheTechCharge=false)do
               begin
                    if (FSGenerateurBase.TableauFicheTechniquePropose.Cells[1,R]=Firstlaters(RProjetFinance.NumProjetFinance,longueur(RProjetFinance.NumProjetFinance)-5))
                    and(FSGenerateurBase.TableauFicheTechniquePropose.Cells[3,R]='Vente '+RProjetFinance.DesignationProjetFinance+' '+RProjetSource.DesignationProjetFinance+' '+RProjetSource.Codification)
                    then
                    begin
                         OKFicheTechVente:=true;
                    end;
               R:=R+1;
               end;

               if(OKFicheTechVente=false)then
               begin
                    RowMaxFiche:=RowMaxFiche+1;
                    FSGenerateurBase.TableauFicheTechniquePropose.Cells[0,RowMaxFiche]:=inttostr(RowMaxFiche);
                    FSGenerateurBase.TableauFicheTechniquePropose.Cells[1,RowMaxFiche]:=Firstlaters(RProjetFinance.NumProjetFinance,longueur(RProjetFinance.NumProjetFinance)-5);
                    FSGenerateurBase.TableauFicheTechniquePropose.Cells[2,RowMaxFiche]:=FSGenerateurBase.TableauFicheTechniquePropose.Cells[1,RowMaxFiche]+'Vente '+RProjetFinance.DesignationProjetFinance;
                    FSGenerateurBase.TableauFicheTechniquePropose.Cells[3,RowMaxFiche]:='Vente '+RProjetFinance.DesignationProjetFinance+' '+RProjetSource.DesignationProjetFinance+' '+RProjetSource.Codification;
                    FSGenerateurBase.TableauFicheTechniquePropose.Cells[4,RowMaxFiche]:=inttostr(RTypeAvisDebit.NumTypeAvis);
                    FSGenerateurBase.TableauFicheTechniquePropose.Cells[5,RowMaxFiche]:=RTypeAvisDebit.DesignationTypeAvis;
               end;

               /////////////////Proposition Rubriques!!!!!!!!!!!!!!!!!!!!
               R:=1;
               OKRubrique:=false;
               T:='1';
               while(R<=RowMaxRubrique)and(OKRubrique=false)do
               begin
                    if (FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[1,R]=Firstlaters(RProjetFinance.NumProjetFinance,longueur(RProjetFinance.NumProjetFinance)-5))
                    and(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[2,R]=Firstlaters(RProjetFinance.NumProjetFinance,longueur(RProjetFinance.NumProjetFinance)-5)+'Vente '+RProjetFinance.DesignationProjetFinance)
                    and(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[10,R]=RProjetFinance.NatureProjetFinance)
                    then
                    begin
                         if(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[5,R]=RProjetFinance.UniteMesureProjetFinance)
                         and(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[6,R]=floattostr(RProjetFinance.PrixUniteHTMesureProjetFinance))then
                         begin
                              OKRubrique:=true;
                              FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[4,R]:=floattostr(strtoreal(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[4,R])+
                                                                                                RProjetFinance.MesureGlobaleProjetFinance);
                         end
                         else
                         begin
                              l:=1;
                              while(l<=RowMaxRubrique)do
                              begin
                                   if(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[2,l]=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[2,R])
                                   and(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[10,l]=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[10,R])
                                   then
                                   begin
                                        if strtointeger(T)<=strtointeger(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[8,l])
                                        then T:=inttostr(strtointeger(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[8,l])+1);
                                   end;
                              l:=l+1;
                              end;
                         end;
                    end;
               R:=R+1;
               end;

               if(OKRubrique=false)then
               begin
                    RowMaxRubrique:=RowMaxRubrique+1;
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[0,RowMaxRubrique]:=inttostr(RowMaxRubrique);
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[1,RowMaxRubrique]:=Firstlaters(RProjetFinance.NumProjetFinance,longueur(RProjetFinance.NumProjetFinance)-5);
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[2,RowMaxRubrique]:=Firstlaters(RProjetFinance.NumProjetFinance,longueur(RProjetFinance.NumProjetFinance)-5)+'Vente '+RProjetFinance.DesignationProjetFinance;
                    if(RProjetFinance.NatureProjetFinance<>'')
                    then FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[3,RowMaxRubrique]:='Vente '+RProjetFinance.DesignationProjetFinance+' '+RProjetFinance.NatureProjetFinance+' '+RProjetSource.DesignationProjetFinance+' '+RProjetSource.Codification
                    else FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[3,RowMaxRubrique]:='Vente '+RProjetFinance.DesignationProjetFinance+' '+RProjetSource.DesignationProjetFinance+' '+RProjetSource.Codification;
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[4,RowMaxRubrique]:=floattostr(RProjetFinance.MesureGlobaleProjetFinance);
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[5,RowMaxRubrique]:=RProjetFinance.UniteMesureProjetFinance;
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[6,RowMaxRubrique]:=floattostr(RProjetFinance.PrixUniteHTMesureProjetFinance);
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[7,RowMaxRubrique]:='';
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[8,RowMaxRubrique]:=T;
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[9,RowMaxRubrique]:='';
                    FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[10,RowMaxRubrique]:=RProjetFinance.NatureProjetFinance;
               end;
          end;
     end;
     finally
     CloseFile(FProjetFinance);
     end;

     /////////////////Proposition Fiches Technique !!!!!!!!!!!!!!!!!!!!
     for R:=1 to FSGenerateurBase.TableauProjetFinancePropose.RowCount-1 do
     begin
          if(FSGenerateurBase.TableauProjetFinancePropose.Cells[1,R]<>'')then
          begin
               RowMaxFiche:=RowMaxFiche+1;
               FSGenerateurBase.TableauFicheTechniquePropose.Cells[0,RowMaxFiche]:=inttostr(RowMaxFiche);
               FSGenerateurBase.TableauFicheTechniquePropose.Cells[1,RowMaxFiche]:=FSGenerateurBase.TableauProjetFinancePropose.Cells[1,R];
               FSGenerateurBase.TableauFicheTechniquePropose.Cells[2,RowMaxFiche]:=FSGenerateurBase.TableauFicheTechniquePropose.Cells[1,RowMaxFiche]+'Charges '+FSGenerateurBase.TableauProjetFinancePropose.Cells[FSGenerateurBase.EditRonStructure.ItemIndex+2,R];
               FSGenerateurBase.TableauFicheTechniquePropose.Cells[3,RowMaxFiche]:='Charges '+FSGenerateurBase.TableauProjetFinancePropose.Cells[FSGenerateurBase.EditRonStructure.ItemIndex+2,R];
               FSGenerateurBase.TableauFicheTechniquePropose.Cells[4,RowMaxFiche]:=inttostr(RTypeAvisCredit.NumTypeAvis);
               FSGenerateurBase.TableauFicheTechniquePropose.Cells[5,RowMaxFiche]:=RTypeAvisCredit.DesignationTypeAvis;
          end;
     end;
     
     if(RowMaxFiche>0)then FSGenerateurBase.TableauFicheTechniquePropose.RowCount:=RowMaxFiche+1
                      else FSGenerateurBase.TableauFicheTechniquePropose.RowCount:=2;

     FSGenerateurBase.TableauFicheTechniquePropose.ColWidths[1]:=0;
     FSGenerateurBase.TableauFicheTechniquePropose.ColWidths[2]:=0;
     FSGenerateurBase.TableauFicheTechniquePropose.ColWidths[4]:=0;
     AjusterColWidth(FSGenerateurBase.TableauFicheTechniquePropose,'','1;2;4');

     ProcAfficheTableauParTypeCol(FSGenerateurBase.TableauFicheTechniquePropose,1,1,FSGenerateurBase.TableauFicheTechniquePropose.RowCount-1,FSGenerateurBase.TableauProjetFinancePropose.Cells[1,FSGenerateurBase.TableauProjetFinancePropose.Row]);

     /////////////////Proposition Rubriques!!!!!!!!!!!!!!!!!!!!
     if(RowMaxRubrique>0)then
                         begin
                              FSGenerateurBase.TableauRubriqueFicheTechniquePropose.RowCount:=RowMaxRubrique+3;
                              FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Rows[RowMaxRubrique+1].Text:='';
                              FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Rows[RowMaxRubrique+2].Text:='';
                              FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[6,RowMaxRubrique+2]:='Total:';
                              RowMaxRubrique:=RowMaxRubrique+2;
                         end
                         else FSGenerateurBase.TableauRubriqueFicheTechniquePropose.RowCount:=2;

     R:=1;
     while(R<=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.RowCount-3)do
     begin
          if(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[8,R]='1')then
          begin
               OKRubrique:=false;
               l:=1;
               while(l<=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.RowCount-3)and(OKRubrique=false)do
               begin
                    if(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[2,l]=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[2,R])
                    and(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[10,l]=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[10,R])
                    and(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[8,l]<>'1')then
                    begin
                         OKRubrique:=true;
                    end;
               l:=l+1;
               end;
          end
          else OKRubrique:=true;

          if(OKRubrique=true)then
          begin
               FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[3,R]:=FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[3,R]+' Type '+FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[8,R];
          end;

          FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[7,R]:=floattostr(strtoreal(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[4,R])
                                                                            *strtoreal(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[6,R]));
          FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[4,R]:=Vergule(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[4,R],'2','C','');
          FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[6,R]:=Vergule(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[6,R],'2','C','');
          FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[7,R]:=Vergule(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[7,R],'2','C','');
     R:=R+1;
     end;

     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[7,RowMaxRubrique]:=Vergule(FSGenerateurBase.TableauRubriqueFicheTechniquePropose.Cells[7,RowMaxRubrique],'2','C','');

     FSGenerateurBase.TableauRubriqueFicheTechniquePropose.ColWidths[1]:=0;
