procedure TFSGenerateurBase.TimerAnalyseStockTimer(Sender: TObject);
var  R,l:integer;  FichierConcerne:string;
begin
     FSGenerateurBase.TimerAnalyseStock.Enabled:=false;

     FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text+' rťsultat d''analyse';
     OpenFParc(RParc);
     ChStockArticleCopie:=RParc.Parcours+'\'+Exercice+FichierConcerne;
     assignfile(FStockArticleCopie,ChStockArticleCopie);
     try
     if FileExists(ChStockArticleCopie)then
     Reset(FStockArticleCopie)
     else Rewrite(FStockArticleCopie);
     Seek(FStockArticleCopie,0);
     Truncate(FStockArticleCopie);
     finally
     closefile(FStockArticleCopie);
     end;
     
     FSGenerateurBase.MemoRapport.Lines.Add('Dťbut du traitement');//////////////////////////////////////////////////


     if(FSGenerateurBase.EditTypeAnalyse.Text='Tous')then
     begin
          l:=0;
          for R:=1 to FSGenerateurBase.TableauMouvement.RowCount-1 do
          begin
               AnalyseStockArticle(FSGenerateurBase.EditNumProjet.Text,FSGenerateurBase.TableauMouvement,FSGenerateurBase.TableauDetailMouvement,R,l,FSGenerateurBase.RBInclureMouvements.Checked,FSGenerateurBase.RBInclurePrelevement.Checked,datetostr(FSGenerateurBase.EditDateDebutPeriodeAnalyseStockMouvement.Date),datetostr(FSGenerateurBase.EditDateDebutPeriodeAnalyseStockPrelevement.Date),datetostr(FSGenerateurBase.EditDateFinPeriodeAnalyseStockMouvement.Date),datetostr(FSGenerateurBase.EditDateFinPeriodeAnalyseStockPrelevement.Date),l);
          end;
     end
     else
     begin
          l:=0;
          AnalyseStockArticle(FSGenerateurBase.EditNumProjet.Text,FSGenerateurBase.TableauMouvement,FSGenerateurBase.TableauDetailMouvement,FSGenerateurBase.TableauMouvement.Row,l,FSGenerateurBase.RBInclureMouvements.Checked,FSGenerateurBase.RBInclurePrelevement.Checked,datetostr(FSGenerateurBase.EditDateDebutPeriodeAnalyseStockMouvement.Date),datetostr(FSGenerateurBase.EditDateDebutPeriodeAnalyseStockPrelevement.Date),datetostr(FSGenerateurBase.EditDateFinPeriodeAnalyseStockMouvement.Date),datetostr(FSGenerateurBase.EditDateFinPeriodeAnalyseStockPrelevement.Date),l);

          FSGenerateurBase.AfficheBitRafraichirMAJ.Enabled:=false;
     end;

     FSGenerateurBase.MemoRapport.Lines.Add('Fin du traitement');//////////////////////////////////////////////////

     FunctionPatienter(-1,false);

     //RemplireDesignationArticle;

     TrierTableauARowSpecial(FSGenerateurBase.TableauDetailMouvement,1,FSGenerateurBase.TableauDetailMouvement.RowCount-1,1,'1','Date','+');

     FSGenerateurBase.AfficheAttente.Visible:=false;
end;

