procedure TFSGenerateurBase.BitValiderAdresseDossierPartageReseauxClick(Sender: TObject);
var  i:integer; OKAdresseDossierPartageReseaux,OKAdresseProces,Confirme:boolean;
begin

if(FSGenerateurBase.BitValiderAdresseDossierPartageReseaux.Caption='Valider')then
begin
OpenFParc(RParc);
ChAdresseDossierPartageReseaux:=RParc.Parcours+'\'+Exercice+'FAdresseDossierPartageReseaux';
assignfile(FAdresseDossierPartageReseaux,ChAdresseDossierPartageReseaux);
try
if FileExists(ChAdresseDossierPartageReseaux)then
Reset(FAdresseDossierPartageReseaux)
else Rewrite(FAdresseDossierPartageReseaux);
Seek(FAdresseDossierPartageReseaux,0);
i:=0;
OKAdresseDossierPartageReseaux:=false;
Confirme:=false;
while not eof(FAdresseDossierPartageReseaux)and(OKAdresseDossierPartageReseaux=false)and(Confirme=false)do
begin
     read(FAdresseDossierPartageReseaux,RAdresseDossierPartageReseaux);

     if(RAdresseDossierPartageReseaux.NumAdresseDossierPartageReseaux<>strtointeger(FSGenerateurBase.EditNumAdresseDossierPartageReseaux.Text))then
     begin
          if((RAdresseDossierPartageReseaux.NomPosteReseaux=FSGenerateurBase.EditNomPosteReseaux.Text)and(FSGenerateurBase.EditNomPosteReseaux.Text<>''))
          or((RAdresseDossierPartageReseaux.AdresseDossierPartageReseaux=FSGenerateurBase.EditAdresseDossierPartageReseaux.Text)and(FSGenerateurBase.EditAdresseDossierPartageReseaux.Text<>''))
          then
          begin
               Confirme:=true;
          end;
     end;

     if(RAdresseDossierPartageReseaux.NumAdresseDossierPartageReseaux=strtointeger(FSGenerateurBase.EditNumAdresseDossierPartageReseaux.Text))
     then
     begin
          OKAdresseDossierPartageReseaux:=true;
     end
     else i:=i+1;
end;

if(Confirme=true)then
begin
