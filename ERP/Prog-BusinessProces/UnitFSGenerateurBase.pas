Procedure EnregistrementOptionsFicheStock(TitreOptionIn,DataOptionIn:string);
var  i:integer; FichierTexte:TextFile; AdresseFichierTexte,TexteLigne,TitreOptionTeste,DataOptionTeste:string;
     OKData:boolean;
begin
     FSGenerateurBase.FichierMemo.Clear;

     OpenFParc(RParc);
     AdresseFichierTexte:=RParc.Parcours+'\'+'FRegistreOptionsFicheStock.Txt';
     AssignFile(FichierTexte,AdresseFichierTexte);
     if FileExists(AdresseFichierTexte)then
     begin
          try
          Reset(FichierTexte);

          while not eof(FichierTexte)do
          begin
               Readln(FichierTexte,TexteLigne);
               FSGenerateurBase.FichierMemo.Lines.Add(TexteLigne);
          end;
          finally
          CloseFile(FichierTexte);
          end;
     end;

     i:=0;
     OKData:=false;
     while(i<=FSGenerateurBase.FichierMemo.Lines.Capacity)and(OKData=false)do
     begin
          TexteLigne:=FSGenerateurBase.FichierMemo.Lines.Strings[i];
          DataOptionsFicheStock(TexteLigne,TitreOptionTeste,DataOptionTeste);
          if(TitreOptionTeste=TitreOptionIn)
          then OKData:=true
          else i:=i+1;
     end;
     
     TexteLigne:='ß'+TitreOptionIn+'ß'+DataOptionIn;

     if(OKData=true)then
     begin
          FSGenerateurBase.FichierMemo.Lines.Delete(i);
          FSGenerateurBase.FichierMemo.Lines.Insert(i,TexteLigne);
     end
     else
     begin
          FSGenerateurBase.FichierMemo.Lines.Add(TexteLigne);
     end;
     FSGenerateurBase.FichierMemo.Lines.SaveToFile(AdresseFichierTexte);
     
end;

Procedure DataOptionsFicheStock(TexteLigne:string; var TitreOptionOut,DataOptionOut:string);
var  i,LTexte:integer;
begin
//  ßTitreOptionßOption
     TitreOptionOut:='';
     DataOptionOut:='';
     LTexte:=longueur(TexteLigne);

     if(LTexte>0)then
     begin
          if(TexteLigne[1]='ß')then
          begin
               i:=2;
               while(i<=LTexte)and(TexteLigne[i]<>'ß')do
               begin
                    TitreOptionOut:=TitreOptionOut+TexteLigne[i];
               i:=i+1;
               end;

               if(TexteLigne[i]='ß')then
               begin
                    i:=i+1;
                    while(i<=LTexte)and(TexteLigne[i]<>'ß')do
                    begin
                         DataOptionOut:=DataOptionOut+TexteLigne[i];
                    i:=i+1;
                    end;
               end;
          end;
     end;
end;

Function FindDataOptionsFicheStock(TitreOptionIn:string):string;
var  FichierTexte:TextFile; AdresseFichierTexte,TexteLigne,TitreOptionTeste,DataOptionTeste:string;
     OKData:boolean;
begin
     FindDataOptionsFicheStock:='';

     OpenFParc(RParc);
     AdresseFichierTexte:=RParc.Parcours+'\'+'FRegistreOptionsFicheStock.Txt';
     AssignFile(FichierTexte,AdresseFichierTexte);
     if FileExists(AdresseFichierTexte)then
     begin
          try
          Reset(FichierTexte);

          OKData:=false;
          while not eof(FichierTexte)and(OKData=false)do
          begin
               Readln(FichierTexte,TexteLigne);
               DataOptionsFicheStock(TexteLigne,TitreOptionTeste,DataOptionTeste);
               if(TitreOptionTeste=TitreOptionIn)then
               begin
                    OKData:=true;
                    FindDataOptionsFicheStock:=DataOptionTeste;
              end;
         end;
         finally
         CloseFile(FichierTexte);
         end;
     end;
end;

