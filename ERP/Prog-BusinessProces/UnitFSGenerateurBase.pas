Procedure GenerateurCodebarreStock(OKForcerSaisieCodeBarre:boolean; EditCodeProduit,EditCodeBarre:TEdit);
var  i,OrdreCodebarre:integer; CodeBarre:string;  TableauCodeBarre:array[1..99999]of integer;
     OKCodebarre:boolean;
begin
      if(EditCodeProduit.Text='')then
      begin
           showmessage('Aucun code article !');
           EditCodeProduit.SetFocus;
           Exit;
      end;

      for i:=1 to 99999 do TableauCodeBarre[i]:=i;

      TypeProces:='Commercial';
      FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
      Adresse:='';
      if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
      begin
           ChStockArticle:=Adresse;
           assignfile(FStockArticle,ChStockArticle);
           try
           if FileExists(ChStockArticle)then
           Reset(FStockArticle)
           else Rewrite(FStockArticle);
           Seek(FStockArticle,0);
           while not eof(FStockArticle)do
           begin
                Read(FStockArticle,RStockArticle);

                if(OKForcerSaisieCodeBarre=false)and(RStockArticle.Code=EditCodeProduit.Text)then
                begin
                     if(RStockArticle.CodeBarre<>'')then
                     begin
                          EditCodeBarre.Text:=RStockArticle.CodeBarre;
                          Exit;
                     end;
                end;

                if(longueur(RStockArticle.CodeBarre)=8)and(strtointeger(Midellaters(RStockArticle.CodeBarre,3,7))>0)then
                TableauCodeBarre[strtointeger(Midellaters(RStockArticle.CodeBarre,3,7))]:=0;

                //if(OrdreMin>strtointeger(Midellaters(RStockArticle.CodeBarre,3,7)))then OrdreMin:=strtointeger(Midellaters(RStockArticle.CodeBarre,3,7));
           end;
           finally
           CloseFile(FStockArticle);
           end;
      end;

      i:=99999;
      OrdreCodebarre:=i;
      OKCodebarre:=false;
      while(i>=1)and(OKCodebarre=false)do
      begin
           if(TableauCodeBarre[i]<>0)then
           begin
                OKCodebarre:=true;
                OrdreCodebarre:=TableauCodeBarre[i];
           end;
      i:=i-1;
      end;

     Codebarre:=Firstlaters(EditCodeProduit.Text,2)+Completezerogauche(inttostr(OrdreCodebarre),'5');
     FSEtiquettesCodeBarre.StringGrid1.RowCount:=2;
     FSEtiquettesCodeBarre.StringGrid1.Rows[1].Text:='';
     FSEtiquettesCodeBarre.StringGrid1.Cells[0,1]:=FSGenerateurBase.TableauStockArticle.Cells[2,FSGenerateurBase.TableauStockArticle.Row]+' '+FSGenerateurBase.TableauStockArticle.Cells[3,FSGenerateurBase.TableauStockArticle.Row];
     FSEtiquettesCodeBarre.StringGrid1.Cells[1,1]:=firstlaters(Codebarre,7);
     FSEtiquettesCodeBarre.StringGrid1.Cells[2,1]:='';
     FSEtiquettesCodeBarre.StringGrid1.Cells[3,1]:='1';
     FSEtiquettesCodeBarre.StringGrid1.Cells[4,1]:='Prix: '+FSGenerateurBase.TableauStockArticle.Cells[11,FSGenerateurBase.TableauStockArticle.Row]+' DA';
     FSEtiquettesCodeBarre.StringGrid1.Row:=1;
     FSEtiquettesCodeBarre.StringGrid1Click(FSEtiquettesCodeBarre.StringGrid1);

     FSGenerateurBase.ImageCodebarre.Picture:=FSEtiquettesCodeBarre.ImageCodebarre.Picture;
     EditCodeBarre.Text:=FSEtiquettesCodeBarre.EditCodebarre.Text;
end;

