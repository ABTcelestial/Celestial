procedure TFSGenerateurBase.BitMiseAJourStockClick(Sender: TObject);
var i,R,NbrNewArticle,NbrChargeArticle:integer;    MessageAnalyse,SigneMultiple,TypeProces,FichierConcerne,Adresse:string;  OKMAJ:boolean;
begin
     TypeProces:='Commercial';   FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     ChStockArticle:=Adresse;
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     i:=0;
     while not eof(FStockArticle)do
     begin
          read(FStockArticle,RStockArticle);

          if(FSGenerateurBase.RBMAJArticleSelect.Checked=true)then
          begin
               if(RStockArticle.Code=FSGenerateurBase.TableauStockArticle.Cells[1,FSGenerateurBase.TableauStockArticle.Row])
               then OKMAJ:=true
               else OKMAJ:=false;
          end
          else OKMAJ:=true;

          if(OKMAJ)then
          begin
               if(FSGenerateurBase.EditCodeSFamilleMAJ.Text<>'')then
               begin
                    if(Firstlaters(RStockArticle.Code,longueur(FSGenerateurBase.EditCodeSFamilleMAJ.Text))=FSGenerateurBase.EditCodeSFamilleMAJ.Text)
                    then OKMAJ:=true
                    else OKMAJ:=false;
               end;
          end;

          if(OKMAJ=true)then
          begin
               RStockArticle.QteEntree:=0;
               RStockArticle.QteSortie:=0;
               RStockArticle.QteStock:=RStockArticle.QteInitial;
               Seek(FStockArticle,i);
               write(FStockArticle,RStockArticle); 
          end;

          i:=i+1;
     end;
     finally
     CloseFile(FStockArticle);
     end;

     NbrNewArticle:=0;
     NbrChargeArticle:=0;

     {for R:=1 to FSGenerateurBase.TableauDetailMouvement.RowCount-1 do
     begin
          if(FSGenerateurBase.RBMAJArticleSelect.Checked=true)then
          begin
               if(FSGenerateurBase.TableauDetailMouvement.Cells[2,R]=FSGenerateurBase.TableauStockArticle.Cells[1,FSGenerateurBase.TableauStockArticle.Row])
               then OKMAJ:=true
               else OKMAJ:=false;
          end
          else OKMAJ:=true;

          if(OKMAJ=true)then ProcMiseAJourStockArticle('',FSGenerateurBase.EditNumProjet.Text,FSGenerateurBase.TableauDetailMouvement.Cells[2,R],FSGenerateurBase.TableauDetailMouvement.Cells[6,R],strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R]),strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[5,R]),NbrNewArticle,NbrChargeArticle,NbrNewArticle,NbrChargeArticle);
     end;}

     MiseAJourDuStock;

     ProcAfficheListeStock(FSGenerateurBase.TableauStockArticle,ChStockArticle,'','','',FSGenerateurBase.RBAvecCodeBarre.Checked);
     FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=ChStockArticle;


     MessageAnalyse:='';

     if(NbrNewArticle>0)then
     begin
          if(NbrNewArticle=1)then SigneMultiple:='' else SigneMultiple:='s';
          MessageAnalyse:=inttostr(NbrNewArticle)+' article'+SigneMultiple+' ajoutť ŗ partir du mouvement ! , ';
     end;

     if(NbrChargeArticle>0)then
     begin
          if(NbrChargeArticle=1)then SigneMultiple:='' else SigneMultiple:='s';
          MessageAnalyse:=MessageAnalyse+inttostr(NbrChargeArticle)+' article'+SigneMultiple+' Chargťs ŗ partir du Stock principal !';
     end;

     if(MessageAnalyse<>'')then showmessage('Authentification : '+MessageAnalyse);

     FSGenerateurBase.ficheAnalyseStock.Visible:=false;
end;

