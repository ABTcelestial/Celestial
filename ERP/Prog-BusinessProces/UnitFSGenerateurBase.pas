procedure TFSGenerateurBase.BitOperationMAJStockReseauxClick(
  Sender: TObject);
var  Row,RExistant,RSupprimer,RSauvgarder:integer;  DateOperationMAJ,FichierConcerneDetailMouvement,CodeSFamille:string;
begin
     if(FSGenerateurBase.BitOperationMAJStockReseaux.Caption='Supprimer')then
     begin
          if(FSGenerateurBase.RBSupprimerToutesMiseAJours.Checked=false)then
          begin
               Row:=FSGenerateurBase.TableauFichierConcerneDetailMouvementPublicationReseaux.Row;
               DateOperationMAJ:=FSGenerateurBase.TableauFichierConcerneDetailMouvementPublicationReseaux.Cells[1,Row];
               FichierConcerneDetailMouvement:=FSGenerateurBase.TableauFichierConcerneDetailMouvementPublicationReseaux.Cells[2,Row];
               CodeSFamille:=FSGenerateurBase.TableauFichierConcerneDetailMouvementPublicationReseaux.Cells[3,Row];
               SupprimerFLastNumDetailMouvementMAJ(DateOperationMAJ,FichierConcerneDetailMouvement,CodeSFamille,RExistant,RSupprimer,RSauvgarder);
          end
          else
          begin
               if NonOui('Voulez vous supprimť toutes les mises ŗ jour ?')then
               begin
                     TypeProces:='Business';
                     FichierConcerne:='FLastNumDetailMouvementMAJ';
                     Adresse:='';
                     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                     begin
                          //AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
                     end;

                     ChLastNumDetailMouvementMAJ:=Adresse;
                     assignfile(FLastNumDetailMouvementMAJ,ChLastNumDetailMouvementMAJ);
                     try
                     if FileExists(ChLastNumDetailMouvementMAJ)
                     then Reset(FLastNumDetailMouvementMAJ)
                     else Rewrite(FLastNumDetailMouvementMAJ);
                     Seek(FLastNumDetailMouvementMAJ,0);
                     Truncate(FLastNumDetailMouvementMAJ);
                     finally
                     closefile(FLastNumDetailMouvementMAJ);
                     end;
               end;

               FSGenerateurBase.RBSupprimerToutesMiseAJours.Checked:=false;
          end;
     end;

     FSGenerateurBase.AfficheOperationMiseAJourStockPublicationReseaux.Visible:=false;
     ListeLastNumDetailMouvementMAJ(FSGenerateurBase.TableauFichierConcerneDetailMouvementPublicationReseaux);

     FSGenerateurBase.TableauFichierConcerneDetailMouvementPublicationReseaux.SetFocus;
end;

