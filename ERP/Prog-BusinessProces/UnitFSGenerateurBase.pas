Procedure CompleterListeDetailStructureACol(TableauDetailStructure:TStringGrid; NumProjetFinance,NotRow,NotCol:string; var NbrStructure:integer);
var C:integer; OKDetailStructure:boolean;
begin
     C:=TableauDetailStructure.ColCount-1;
     NbrStructure:=0;

     OpenFParc(RParc);
     ChDetailStructure:=RParc.Parcours+'\'+Exercice+'FDetailStructure';
     assignfile(FDetailStructure,ChDetailStructure);
     try
     if FileExists(ChDetailStructure)then
     Reset(FDetailStructure)
     else Rewrite(FDetailStructure);
     Seek(FDetailStructure,0);
     while not eof(FDetailStructure)do
     begin
          read(FDetailStructure,RDetailStructure);

          if(NumProjetFinance<>'')then
          begin
               if(RDetailStructure.NumProjetFinance=NumProjetFinance)
               then OKDetailStructure:=true
               else OKDetailStructure:=false;
          end
          else OKDetailStructure:=true;

          if(OKDetailStructure=true)then
          begin
               C:=C+1;
               TableauDetailStructure.Cols[C].Text:='';
               TableauDetailStructure.Cells[C,0]:=RDetailStructure.DesignationDetailStructure;
               TableauDetailStructure.Cells[C,1]:=inttostr(RDetailStructure.PositionDetailStructure);
               NbrStructure:=NbrStructure+1;
          end;
     end;
     finally
     CloseFile(FDetailStructure);
     end;

     if(C>0)then TableauDetailStructure.ColCount:=C+1;

     AjusterColWidth(TableauDetailStructure,NotRow,NotCol);
end;

Procedure CompleterListeArticleDetailStructureACol(TableauArticleDetailStructure:TStringGrid; NotRow,NotCol:string; var NbrArticle:integer);
var R,C,ROper,COper:integer; OKArticleDetailStructure,OKExisteArticle:boolean;
begin
     NbrArticle:=0;

     OpenFParc(RParc);
     ChArticleDetailStructure:=RParc.Parcours+'\'+Exercice+'FArticleDetailStructure';
     assignfile(FArticleDetailStructure,ChArticleDetailStructure);
     try
     if FileExists(ChArticleDetailStructure)then
     Reset(FArticleDetailStructure)
     else Rewrite(FArticleDetailStructure);
     Seek(FArticleDetailStructure,0);
     while not eof(FArticleDetailStructure)do
     begin
          read(FArticleDetailStructure,RArticleDetailStructure);

          R:=2;
          OKExisteArticle:=false;
          while(R<=TableauArticleDetailStructure.RowCount-1)and(OKExisteArticle=false)do
          begin
               if(Firstlaters(RArticleDetailStructure.CodeArticleDetailStructure,longueur(TableauArticleDetailStructure.Cells[6,R]))=TableauArticleDetailStructure.Cells[6,R])then
               begin
                    OKExisteArticle:=true;
                    ROper:=R;
               end;
          R:=R+1;
          end;

          if(OKExisteArticle=true)then
          begin
               C:=1;
               OKExisteArticle:=false;
               while(C<=TableauArticleDetailStructure.ColCount-1)and(OKExisteArticle=false)do
               begin
                    if(inttostr(RArticleDetailStructure.PositionDetailStructure)=TableauArticleDetailStructure.Cells[C,1])then
                    begin
                         OKExisteArticle:=true;
                         COper:=C;
                    end;
               C:=C+1;
               end;
          end;

          if(OKExisteArticle=true)then
          begin
               TableauArticleDetailStructure.Cells[COper,ROper]:=Vergule(floattostr(strtoreal(TableauArticleDetailStructure.Cells[COper,ROper])+RArticleDetailStructure.QuantiteArticleDetailStructure*((100+FSGenerateurBase.IncrimenteEditMojorationQuantite.Position)/100)),'2','C','');
               NbrArticle:=NbrArticle+1;
          end;
     end;
     finally
     CloseFile(FArticleDetailStructure);
     end;

     AjusterColWidth(TableauArticleDetailStructure,NotRow,NotCol);
end;

