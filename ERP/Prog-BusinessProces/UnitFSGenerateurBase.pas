Procedure MiseAJourDuStock;
var  i,R:integer;  OKMAJ:boolean;
begin
     TypeProces:='Commercial';   FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text;
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     FSGenerateurBase.AfficheAttenteMiseAJourStock.Visible:=true;
     FSGenerateurBase.ProgressAfficheAttenteMiseAJourStock.Min:=0;
     FSGenerateurBase.ProgressAfficheAttenteMiseAJourStock.Position:=0;

     ChStockArticle:=Adresse+FSGenerateurBase.EditNumProjet.Text;
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);

     FSGenerateurBase.ProgressAfficheAttenteMiseAJourStock.Max:=FileSize(FStockArticle);

     i:=0;
     while not eof(FStockArticle)do
     begin
          read(FStockArticle,RStockArticle);

          FSGenerateurBase.ProgressAfficheAttenteMiseAJourStock.StepIt;

          if(FSGenerateurBase.RBMAJArticleSelect.Checked=true)then
          begin
               if(RStockArticle.Code=FSGenerateurBase.TableauStockArticle.Cells[1,FSGenerateurBase.TableauStockArticle.Row])
               then OKMAJ:=true
               else OKMAJ:=false;
          end
          else OKMAJ:=true;

          if(OKMAJ)then
          begin
               if(FSGenerateurBase.EditCodeSFamilleMAJ.Text<>'')then
               begin
                    if(Firstlaters(RStockArticle.Code,longueur(FSGenerateurBase.EditCodeSFamilleMAJ.Text))=FSGenerateurBase.EditCodeSFamilleMAJ.Text)
                    then OKMAJ:=true
                    else OKMAJ:=false;
               end;
          end;

          if(OKMAJ=true)then
          begin
               R:=1;
               while(R<=FSGenerateurBase.TableauDetailMouvement.RowCount-1)do
               begin
                    if(RStockArticle.Code=FSGenerateurBase.TableauDetailMouvement.Cells[2,R])then
                    begin
                         if(FSGenerateurBase.TableauDetailMouvement.Cells[6,R]='-')then
                         begin
                              RStockArticle.QteSortie:=RStockArticle.QteSortie+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R]);
                              RStockArticle.QteStock:=RStockArticle.QteStock-strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R]);
                         end;

                         if(FSGenerateurBase.TableauDetailMouvement.Cells[6,R]='+')then
                         begin
                              //if((RStockArticle.QteStock+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R]))>0)
                              //then RStockArticle.CoutUnitaire:=((RStockArticle.QteStock*RStockArticle.CoutUnitaire)+(strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R])*strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[5,R])))/(RStockArticle.QteStock+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R]));
                              RStockArticle.QteEntree:=RStockArticle.QteEntree+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R]);
                              RStockArticle.QteStock:=RStockArticle.QteStock+strtoreal(FSGenerateurBase.TableauDetailMouvement.Cells[4,R]);
                         end;
                    end;
               R:=R+1;
               end;

               Seek(FStockArticle,i);
               write(FStockArticle,RStockArticle);
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FStockArticle);
     end;

     FSGenerateurBase.AfficheAttenteMiseAJourStock.Visible:=false;
end;

Procedure RemplireDesignationArticle;
var  R:integer;
begin
     R:=1;
     while(R<=FSGenerateurBase.TableauDetailMouvement.RowCount-1)do
     begin
          if(FSGenerateurBase.TableauDetailMouvement.Cells[3,R]='')then
          begin
               RStock:=ChercherStockArticle('Article',FSGenerateurBase.EditNumProjet.Text,FSGenerateurBase.TableauDetailMouvement.Cells[2,R],'',OKStockRecherche,RubriqueRecherche);
               FSGenerateurBase.TableauDetailMouvement.Cells[3,R]:=RStock.Design+' '+RStock.Ref+' {'+RStock.UM+'}';
               FSGenerateurBase.TableauDetailMouvement.Cells[5,R]:=Vergule(floattostr(RStock.CoutUnitaire),'2','C','');
          end;
     R:=R+1;
     end;
end;

