                                       else Rewrite(FListeFichierConcernePartageReseauxCopie2);//begin Showmessage('Attention ! '+ChListeFichierConcernePartageReseauxCopie2+' n''existe pas !'); Exit; end;
                                       Seek(FListeFichierConcernePartageReseauxCopie2,0);
                                       Truncate(FListeFichierConcernePartageReseauxCopie2);

                                       OpenFParc(RParc);
                                       ChListeFichierConcernePartageReseaux:=RParc.Parcours+'\'+Exercice+'FListeFichierConcernePartageReseaux'+' '+NumAdresseProcesTeste;
                                       assignfile(FListeFichierConcernePartageReseaux,ChListeFichierConcernePartageReseaux);
                                       //iR:=0;
                                       if FileExists(ChListeFichierConcernePartageReseaux)then
                                       begin
                                            try
                                            Reset(FListeFichierConcernePartageReseaux);
                                            Seek(FListeFichierConcernePartageReseaux,0);

                                            while not eof(FListeFichierConcernePartageReseaux)do
                                            begin
                                                 read(FListeFichierConcernePartageReseaux,RListeFichierConcernePartageReseaux);
                                                 Seek(FListeFichierConcernePartageReseauxCopie2,iR);
                                                 write(FListeFichierConcernePartageReseauxCopie2,RListeFichierConcernePartageReseaux);
                                                 iR:=iR+1;
                                            end;
                                            finally
                                            CloseFile(FListeFichierConcernePartageReseaux);
                                            end;

                                            FSMenuPrincipal.EditRapport.Lines.Add('Enregistrement rťseaux '+'FListeFichierConcernePartageReseaux'+' '+RAdresseProces.Repertoire+' effťctuť avec succťs ! {'+inttostr(1)+' Enregistrements} "Source: '+ExtractFileDir(ExtractFileDir(ChListeFichierConcernePartageReseaux))+'"');
                                       end;
                                       finally
                                       CloseFile(FListeFichierConcernePartageReseauxCopie2);
                                       end;
                                 end;
                           end;
                      end;
                finally
                CloseFile(FAdresseProces);
                end;
                end;
                //////////////////////////////////////////////////
                FSMenuPrincipal.EditRapport.Lines.Add('');

                FSMenuPrincipal.EditRapport.Lines.Add('Fin.');
                FSMenuPrincipal.EditRapport.Lines.Add('');
          finally
          closefile(FListeFichierConcernePartageReseauxCopie);
          end;
          end
          else FSMenuPrincipal.EditDetailRapport.Lines.Add('le fichier '+ChListeFichierConcernePartageReseauxCopie+' n''existe pas');
     end
     else
     begin
          FSMenuPrincipal.EditRapport.Lines.Add('');

          FSMenuPrincipal.EditRapport.Lines.Add('Pas de dossier local.');
          FSMenuPrincipal.EditRapport.Lines.Add('');
     end;
