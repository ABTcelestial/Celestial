procedure TFSGenerateurBase.TableauEquipeKeyPress(Sender: TObject;
  var Key: Char);
var  NumEquipe:integer;
begin

if key in['n','N']then
begin
     FSGenerateurBase.AfficheOptionsEquipe.Visible:=true;
     OpenFParc(RParc);
     ChEquipe:=RParc.Parcours+'\'+Exercice+'FEquipe';
     assignfile(FEquipe,ChEquipe);
     try
     if FileExists(ChEquipe)then
     Reset(FEquipe)
     else Rewrite(FEquipe);
     Seek(FEquipe,0);
     NumEquipe:=1;
     while not eof(FEquipe)do
     begin
          read(FEquipe,REquipe);
          if(REquipe.NumEquipe<=NumEquipe)then NumEquipe:=REquipe.NumEquipe+1;
     end;
     finally
     closefile(FEquipe);
     end;

     FSGenerateurBase.EditNumEquipe.Text:=inttostr(NumEquipe);
     FSGenerateurBase.EditCodeEquipe.Text:='';
     FSGenerateurBase.EditDesignationEquipe.Text:='';      
     FSGenerateurBase.EditHeureDebut.Text:=Timetostr(Time);
     FSGenerateurBase.EditHeureFin.Text:=Timetostr(Time);
     FSGenerateurBase.EditTacheOccuper.Text:='';
     FSGenerateurBase.BitValiderEquipe.Kind:=bkAll;
     FSGenerateurBase.BitValiderEquipe.Caption:='Valider';

     FSGenerateurBase.EditCodeEquipe.SetFocus;
end;

if key in['m','M','s','S']then
begin
     FSGenerateurBase.AfficheOptionsEquipe.Visible:=true;
     FSGenerateurBase.EditNumEquipe.Text:=FSGenerateurBase.TableauEquipe.Cells[1,FSGenerateurBase.TableauEquipe.Row];
     FSGenerateurBase.EditCodeEquipe.Text:=FSGenerateurBase.TableauEquipe.Cells[2,FSGenerateurBase.TableauEquipe.Row];
     FSGenerateurBase.EditDesignationEquipe.Text:=FSGenerateurBase.TableauEquipe.Cells[3,FSGenerateurBase.TableauEquipe.Row];
     FSGenerateurBase.EditHeureDebut.Text:=FSGenerateurBase.TableauEquipe.Cells[4,FSGenerateurBase.TableauEquipe.Row];
     FSGenerateurBase.EditHeureFin.Text:=FSGenerateurBase.TableauEquipe.Cells[5,FSGenerateurBase.TableauEquipe.Row];
     FSGenerateurBase.EditTacheOccuper.Text:=FSGenerateurBase.TableauEquipe.Cells[6,FSGenerateurBase.TableauEquipe.Row];

     if key in['m','M']then
     begin
          FSGenerateurBase.BitValiderEquipe.Kind:=bkAll;
          FSGenerateurBase.BitValiderEquipe.Caption:='Valider';
          FSGenerateurBase.EditDesignationEquipe.SetFocus;
     end;

     if key in['s','S']then
     begin
          FSGenerateurBase.BitValiderEquipe.Kind:=bkCancel;
          FSGenerateurBase.BitValiderEquipe.Caption:='Supprimer';
          FSGenerateurBase.BitValiderEquipe.SetFocus;
     end;
end;

end;

procedure TFSGenerateurBase.BitValiderEquipeClick(Sender: TObject);
var  i:integer; OKEquipe,Confirme:boolean;
begin

if(FSGenerateurBase.BitValiderEquipe.Caption='Valider')then
begin
OpenFParc(RParc);
ChEquipe:=RParc.Parcours+'\'+Exercice+'FEquipe';
assignfile(FEquipe,ChEquipe);
try
if FileExists(ChEquipe)then
Reset(FEquipe)
else Rewrite(FEquipe);
Seek(FEquipe,0);
i:=0;
OKEquipe:=false;
while not eof(FEquipe)and(OKEquipe=false)do
begin
     read(FEquipe,REquipe);
     if(REquipe.NumEquipe=strtointeger(FSGenerateurBase.EditNumEquipe.Text))then
     begin
          OKEquipe:=true;
     end
     else i:=i+1;
end;

Seek(FEquipe,i);
REquipe.NumEquipe:=strtointeger(FSGenerateurBase.EditNumEquipe.Text);
REquipe.CodeEquipe:=FSGenerateurBase.EditCodeEquipe.Text;
REquipe.DesignationEquipe:=FSGenerateurBase.EditDesignationEquipe.Text;
REquipe.HeureDebut:=FSGenerateurBase.EditHeureDebut.Text;
REquipe.HeureFin:=FSGenerateurBase.EditHeureFin.Text;
REquipe.TacheOccuper:=FSGenerateurBase.EditTacheOccuper.Text;
write(FEquipe,REquipe);

finally
Closefile(FEquipe);
end;
end;

if(FSGenerateurBase.BitValiderEquipe.Caption='Supprimer')then
begin
     DeleteFEquipe(strtointeger(FSGenerateurBase.EditNumEquipe.Text),Confirme);
end;

ListeEquipe(FSGenerateurBase.TableauEquipe,'');
FSGenerateurBase.AfficheOptionsEquipe.Visible:=false;
FSGenerateurBase.TableauEquipe.SetFocus;
end;

