procedure TFSGenerateurBase.BitBtn50Click(Sender: TObject);
var  i,R:integer;     NomFichier,FichierConcerne:string;
begin
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.ColCount:=6;
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cols[0].Text:='Nį';
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cols[1].Text:='Code';
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cols[2].Text:='Dťsignation';
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cols[3].Text:='Valeur Principale';
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cols[4].Text:='Valleur Finale';
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cols[5].Text:='Formule';
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.RowCount:=2;
     FSModuleCalculeFormules.TableauTransfertValeurTaxe.Rows[1].Text:='';

     if(FSGenerateurBase.EditAutorisationTransfertFormuleCalcule.Text='000')then
     begin
          if(FSGenerateurBase.EditSource.Text='PrixVente')then
          begin
               FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
               OpenFParc(RParc);
               ChStockArticle:=RParc.Parcours+'\'+Exercice+FichierConcerne;
               assignfile(FStockArticle,ChStockArticle);
               try
               if FileExists(ChStockArticle)then
               Reset(FStockArticle)
               else Rewrite(FStockArticle);
               Seek(FStockArticle,0);
               i:=0;
               R:=0;
               while not eof(FStockArticle)do
               begin
                    read(FStockArticle,RStockArticle);
                    if(RStockArticle.PrixVenteDetaille>0)then
                    begin
                         FSGenerateurBase.EditValeurePrincipale.Text:=floattostr(RStockArticle.PrixVenteDetaille);
                         TransfertFormuleCalcule(FSGenerateurBase.EditCodeTypeFormule.Text,FSGenerateurBase.EditValeurePrincipale,FSGenerateurBase.EditValeurFinale);
                         RStockArticle.PrixVenteDetaille:=strtoreal(FSGenerateurBase.EditValeurFinale.Text);
                         Seek(FStockArticle,i);
                         write(FStockArticle,RStockArticle);
                         R:=R+1;
                         FSModuleCalculeFormules.TableauTransfertValeurTaxe.Rows[R].Text:=inttostr(R);
                         FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cells[1,R]:=RStockArticle.Code;
                         FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cells[2,R]:=RStock.Design+' '+RStock.Ref;
                         FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cells[3,R]:=Vergule(FSGenerateurBase.EditValeurePrincipale.Text,'2','C','');
                         FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cells[4,R]:=Vergule(FSGenerateurBase.EditValeurFinale.Text,'2','C','');
                         FSModuleCalculeFormules.TableauTransfertValeurTaxe.Cells[5,R]:='{'+FSGenerateurBase.EditCodeTypeFormule.Text+'} '+ChercherTypeFormule(FSGenerateurBase.EditCodeTypeFormule.Text,'').DesignationTypeFormule;
                    end;
               i:=i+1;
               end;
               finally
               closefile(FStockArticle);
               end;

               if(R>0)then FSModuleCalculeFormules.TableauTransfertValeurTaxe.RowCount:=R+1
                      else FSModuleCalculeFormules.TableauTransfertValeurTaxe.RowCount:=2;
               NomFichier:='Rapport de transfert Stock'+FSGenerateurBase.EditTypeStock.Text+' {'+FSGenerateurBase.EditCodeTypeFormule.Text+'}'+'{'+WithoutChar(WithoutChar(FSModuleCalculeFormules.EditTime.Text,'/'),':')+'}'+'.txt';
               TableauInFileTexte(FSModuleCalculeFormules.TableauTransfertValeurTaxe,NomFichier,FSCreateFichierTexte.RBCodificationRubriqes,FSCreateFichierTexte.RBLibelleRubriques,FSCreateFichierTexte.RBSignatureEntrepeise);
          end;

          FSGenerateurBase.EditAutorisationTransfertFormuleCalcule.Text:='';
     end
     else
     begin
          showmessage('Veuillez saisire le code SVP !');
          FSGenerateurBase.EditAutorisationTransfertFormuleCalcule.Text:='';
          FSGenerateurBase.EditAutorisationTransfertFormuleCalcule.SetFocus;
     end;
end;

