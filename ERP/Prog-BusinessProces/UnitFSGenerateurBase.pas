procedure TFSGenerateurBase.EditRechercheCodeSFamilleMAJKeyUp(Sender: TObject; var Key: Word;
  Shift: TShiftState);
var   Ordre,RowOut:integer;  CodeSFamille,CodeArticle,DesignationArticle:string;
begin
     Ordre:=strtointeger(firstlaters(FSGenerateurBase.EditOrdreCompteComptableArticleMAJ.Text,2));

     if(Ordre in[1..6])then
     begin
          ListePlanComptable(FSGenerateurBase.TableauSFamilleMAJ,Ordre,FSGenerateurBase.EditRechercheCodeSFamilleMAJ.Text,FSGenerateurBase.EditRechercheDesigSFamilleMAJ.Text,FSGenerateurBase.EditTypeComptabilite.Text);
