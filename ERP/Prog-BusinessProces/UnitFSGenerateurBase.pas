procedure TFSGenerateurBase.BitBtn99Click(Sender: TObject);
var  i:integer; OKInitialisation:boolean;
begin
     FSGenerateurBase.AfficheInitialisationDataStock.Visible:=false;

     TypeProces:='Commercial';
     FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     Adresse:='';
     if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          ChStockArticle:=Adresse;
          assignfile(FStockArticle,ChStockArticle);
          if FileExists(ChStockArticle)then
          begin
               try
               Reset(FStockArticle);
               Seek(FStockArticle,0);
               i:=0;
               while not eof(FStockArticle)do
               begin
                    Read(FStockArticle,RStockArticle);

                    OKInitialisation:=false;

                    if(FSGenerateurBase.RBInitialisationQuatiteInitiale.Checked=true)then
                    begin
                         RStockArticle.QteInitial:=0;
                         OKInitialisation:=true;
                    end;

                    if(FSGenerateurBase.RBInitialisationQuatiteEntree.Checked=true)then
                    begin
                         RStockArticle.QteEntree:=0;
                         OKInitialisation:=true;
                    end;

                    if(FSGenerateurBase.RBInitialisationQuatiteSortie.Checked=true)then
                    begin
                         RStockArticle.QteSortie:=0;
                         OKInitialisation:=true;
                    end;

                    if(FSGenerateurBase.RBInitialisationQuatiteStock.Checked=true)then
                    begin
                         RStockArticle.QteStock:=RStockArticle.QteEntree+RStockArticle.QteInitial-RStockArticle.QteSortie;
                         OKInitialisation:=true;
                    end;

                    if(FSGenerateurBase.RBInitialisationQuatiteLimite.Checked=true)then
                    begin
                         RStockArticle.QteLimite:=0;
                         OKInitialisation:=true;
                    end;

                    if(OKInitialisation=true)then
                    begin
                         Seek(FStockArticle,i);
                         write(FStockArticle,RStockArticle);
                    end;
               i:=i+1;
               end;
               finally
               CloseFile(FStockArticle);
               end;
          end;

     FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=ChStockArticle;
     ProcAfficheListeStock(FSGenerateurBase.TableauStockArticle,ChStockArticle,'','','',FSGenerateurBase.RBAvecCodeBarre.Checked);
     end;
end;

