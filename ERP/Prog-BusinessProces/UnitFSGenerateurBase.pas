procedure TFSGenerateurBase.TableauSFamilleAFFKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  R,k:integer;   FichierConcerne,NomRegistreCompte:string;
begin
      if key in[VK_RETURN]then
      begin
            FSGenerateurBase.AffichePrintPr.Visible:=true;
            FSGenerateurBase.AfficheOrdrePlanComptableInventaireGlobal.Visible:=false;
            FSGenerateurBase.RBFicheIdentification.Enabled:=true;
            FSGenerateurBase.EditNFSD.Enabled:=true;
            FSGenerateurBase.EditNFSF.Enabled:=true;
            FSGenerateurBase.RBTous.Checked:=true;
            FSGenerateurBase.RBFeuilleInventaire.Checked:=true;
            FSGenerateurBase.EditNbrMax.Text:='23';
            FSGenerateurBase.IncrimenteEditHeightMax.Position:=17;

            case strtointeger(FSGenerateurBase.EditOrdreCompteComptableInventaire.Text) of
            1:  begin FichierConcerne:='FClasse'+FSGenerateurBase.EditTypeComptabilite.Text;        NomRegistreCompte:='Classe'; end;
            2:  begin FichierConcerne:='FSousClasse'+FSGenerateurBase.EditTypeComptabilite.Text;    NomRegistreCompte:='S/Classe'; end;
            3:  begin FichierConcerne:='FCategorie'+FSGenerateurBase.EditTypeComptabilite.Text;     NomRegistreCompte:='Catťgorie'; end;
            4:  begin FichierConcerne:='FSousCategorie'+FSGenerateurBase.EditTypeComptabilite.Text; NomRegistreCompte:='S/Catťgorie'; end;
            5:  begin FichierConcerne:='FFamille'+FSGenerateurBase.EditTypeComptabilite.Text;       NomRegistreCompte:='Famille'; end;
            6:  begin FichierConcerne:='FSousFamille'+FSGenerateurBase.EditTypeComptabilite.Text;   NomRegistreCompte:='S/Famille'; end;
            end;

            R:=FSGenerateurBase.TableauSFamilleAFF.Row;

            OpenFParc(RParc);
            ChStock:=RParc.Parcours+'\'+Exercice+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
            assignfile(FStock,ChStock);
            try
            if FileExists(ChStock)then
            Reset(FStock)
            else Rewrite(FStock);
            Seek(FStock,0);
            k:=0;
            while not eof(FStock)do
            begin
                 read(FStock,RStock);
                 if Firstlaters(RStock.Code,longueur(FSGenerateurBase.TableauSFamilleAFF.Cells[1,R]))=FSGenerateurBase.TableauSFamilleAFF.Cells[1,R]then
                 begin
                      k:=k+1;
                 end;
            end;
            finally
            CloseFile(FStock);
            end;

            if(K>0)then
            begin
                 FSGenerateurBase.EditNFSD.Text:='1';
                 FSGenerateurBase.EditNFSF.Text:=inttostr(k);
            end
            else
            begin
                 FSGenerateurBase.EditNFSD.Text:='';
