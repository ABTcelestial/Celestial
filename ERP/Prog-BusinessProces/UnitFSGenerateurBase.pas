                    end
                    else
                    begin
                         FSGenerateurBase.EditEmlacementLocalOuReseaux.Text:='Local';
                         FSGenerateurBase.EditAdresseIP.Text:=IndiqueAdresseIPMayMachine;
                    end;
               end
               else
               begin
                    showmessage('Chemin introuvable !');
