Procedure ProcInventaireGlobal;
var  R:integer;  OKCompte:boolean;   NbrGlobal,QteGlobale,CoutGlobal,ValeurGlobal,MargeGlobal:real;  UniM:string;
begin
     FSGenerateurBase.AfficheAttenteInventaireGlobale.Visible:=true;
     FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Min:=0;
     FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Smooth:=true;

     FSGenerateurBase.TableauInventaireGlobal.ColCount:=10;
     FSGenerateurBase.TableauInventaireGlobal.Cols[5].Text:='Qte';
     FSGenerateurBase.TableauInventaireGlobal.Cols[6].Text:='CoŻt';
     FSGenerateurBase.TableauInventaireGlobal.Cols[7].Text:='Valeur';
     FSGenerateurBase.TableauInventaireGlobal.Cols[8].Text:='Marge';
     FSGenerateurBase.TableauInventaireGlobal.Cols[9].Text:='%';

     NbrGlobal:=0;
     QteGlobale:=0;
     CoutGlobal:=0;
     ValeurGlobal:=0;
     MargeGlobal:=0;

     TypeProces:='Commercial';
     FichierConcerne:='FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     Adresse:='';
     if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          ChStockArticle:=Adresse;
          assignfile(FStockArticle,ChStockArticle);
          if FileExists(ChStockArticle)then
          begin
               try
               Reset(FStockArticle);
               Seek(FStockArticle,0);

               FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.Max:=FileSize(FStockArticle);

               while not eof(FStockArticle) do
               begin
                    Read(FStockArticle,RStockArticle);  Application.ProcessMessages;

                    FSGenerateurBase.ProgressAfficheAttenteInventaireGlobale.StepIt;

                    if(RStockArticle.UM<>'Pst')and(RStockArticle.UM<>'H')then
                    begin
                          R:=1;
                          OKCompte:=false;
                          while(R<=FSGenerateurBase.TableauInventaireGlobal.RowCount-1)and(OKCompte=false)do
                          begin
                               if(Firstlaters(RStockArticle.Code,longueur(FSGenerateurBase.TableauInventaireGlobal.Cells[1,R]))=FSGenerateurBase.TableauInventaireGlobal.Cells[1,R])then
                               begin
                                    OKCompte:=true;

                                    if(FSGenerateurBase.RBInventaireParUnite.Checked=true)and(longueur(FSGenerateurBase.TableauInventaireGlobal.Cells[1,R])=10)then
                                    begin
                                         FSGenerateurBase.TableauInventaireGlobal.Cells[5,R]:='1';
                                         FSGenerateurBase.TableauInventaireGlobal.Cells[6,R]:=Floattostr(RStockArticle.CoutUnitaire);
                                         FSGenerateurBase.TableauInventaireGlobal.Cells[7,R]:=Floattostr(RStockArticle.PrixVenteDetaille);
                                    end
                                    else
                                    begin
                                         if(longueur(FSGenerateurBase.TableauInventaireGlobal.Cells[1,R])<>10)
                                         then FSGenerateurBase.TableauInventaireGlobal.Cells[4,R]:=Inttostr(strtointeger(FSGenerateurBase.TableauInventaireGlobal.Cells[4,R])+1);
                                         FSGenerateurBase.TableauInventaireGlobal.Cells[5,R]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[5,R])+RStockArticle.QteStock);
                                         FSGenerateurBase.TableauInventaireGlobal.Cells[6,R]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,R])+RStockArticle.QteStock*RStockArticle.CoutUnitaire);
                                         FSGenerateurBase.TableauInventaireGlobal.Cells[7,R]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[7,R])+RStockArticle.QteStock*RStockArticle.PrixVenteDetaille);
                                    end;
                               end;
                          R:=R+1;
                          end;

                          if(OKCompte=false)and(FSGenerateurBase.TableauInventaireGlobal.Cells[0,0]<>'10')then
                          begin
                               FSGenerateurBase.TableauInventaireGlobal.RowCount:=FSGenerateurBase.TableauInventaireGlobal.RowCount+1;

                               FSGenerateurBase.TableauInventaireGlobal.Cells[1,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Firstlaters(RStockArticle.Code,strtointeger(FSGenerateurBase.TableauInventaireGlobal.Cells[0,0]));
                               FSGenerateurBase.TableauInventaireGlobal.Cells[2,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=DesigCompte(FSGenerateurBase.EditTypeComptabilite.Text,FSGenerateurBase.TableauInventaireGlobal.Cells[1,FSGenerateurBase.TableauInventaireGlobal.RowCount-1],UniM);
                               FSGenerateurBase.TableauInventaireGlobal.Cells[3,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:='';
                               FSGenerateurBase.TableauInventaireGlobal.Cells[4,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:='1';

                               if(FSGenerateurBase.RBInventaireParUnite.Checked=true)and(longueur(FSGenerateurBase.TableauInventaireGlobal.Cells[1,R])=10)then
                               begin
                                    FSGenerateurBase.TableauInventaireGlobal.Cells[5,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:='1';
                                    FSGenerateurBase.TableauInventaireGlobal.Cells[6,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Floattostr(RStockArticle.CoutUnitaire);
                                    FSGenerateurBase.TableauInventaireGlobal.Cells[7,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Floattostr(RStockArticle.PrixVenteDetaille);
                               end
                               else
                               begin
                                    FSGenerateurBase.TableauInventaireGlobal.Cells[5,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[5,FSGenerateurBase.TableauInventaireGlobal.RowCount-1])+RStockArticle.QteStock);
                                    FSGenerateurBase.TableauInventaireGlobal.Cells[6,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,FSGenerateurBase.TableauInventaireGlobal.RowCount-1])+RStockArticle.QteStock*RStockArticle.CoutUnitaire);
                                    FSGenerateurBase.TableauInventaireGlobal.Cells[7,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[7,FSGenerateurBase.TableauInventaireGlobal.RowCount-1])+RStockArticle.QteStock*RStockArticle.PrixVenteDetaille);
                               end;
                          end;

                    end;
               end;
          finally
          CloseFile(FStockArticle);
          end;
          end;

          R:=1;
          while(R<=FSGenerateurBase.TableauInventaireGlobal.RowCount-3)do
          begin
               if(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[7,R])>0)
               then FSGenerateurBase.TableauInventaireGlobal.Cells[8,R]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[7,R])-strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,R]))
               else FSGenerateurBase.TableauInventaireGlobal.Cells[8,R]:='';

               if(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,R])<>0)
               then FSGenerateurBase.TableauInventaireGlobal.Cells[9,R]:=Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[8,R])/strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,R]))
               else FSGenerateurBase.TableauInventaireGlobal.Cells[9,R]:='0';

               FSGenerateurBase.TableauInventaireGlobal.Cells[5,R]:=Vergule(FSGenerateurBase.TableauInventaireGlobal.Cells[5,R],'2','C','');
               FSGenerateurBase.TableauInventaireGlobal.Cells[6,R]:=Vergule(FSGenerateurBase.TableauInventaireGlobal.Cells[6,R],'2','C','');
               FSGenerateurBase.TableauInventaireGlobal.Cells[7,R]:=Vergule(FSGenerateurBase.TableauInventaireGlobal.Cells[7,R],'2','C','');
               FSGenerateurBase.TableauInventaireGlobal.Cells[8,R]:=Vergule(FSGenerateurBase.TableauInventaireGlobal.Cells[8,R],'2','C','');
               FSGenerateurBase.TableauInventaireGlobal.Cells[9,R]:=Vergule(FSGenerateurBase.TableauInventaireGlobal.Cells[9,R],'2','C','%');

               if(FSGenerateurBase.TableauInventaireGlobal.Cells[0,0]<>'10')
               then NbrGlobal:=NbrGlobal+strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[4,R]);
               QteGlobale:=QteGlobale+strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[5,R]);
               CoutGlobal:=CoutGlobal+strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,R]);
               ValeurGlobal:=ValeurGlobal+strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[7,R]);
               MargeGlobal:=MargeGlobal+strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[8,R]);
          R:=R+1;
          end;

          if(FSGenerateurBase.TableauInventaireGlobal.Cells[9,0]<>'%')then FSGenerateurBase.TableauInventaireGlobal.RowCount:=FSGenerateurBase.TableauInventaireGlobal.RowCount+2;
          FSGenerateurBase.TableauInventaireGlobal.Rows[FSGenerateurBase.TableauInventaireGlobal.RowCount-2].Text:='';
          FSGenerateurBase.TableauInventaireGlobal.Rows[FSGenerateurBase.TableauInventaireGlobal.RowCount-1].Text:='';

          FSGenerateurBase.TableauInventaireGlobal.Cells[3,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:='Total';

          if(FSGenerateurBase.TableauInventaireGlobal.Cells[0,0]<>'10')
          then FSGenerateurBase.TableauInventaireGlobal.Cells[4,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Vergule(floattostr(NbrGlobal),'2','C','');
          
          FSGenerateurBase.TableauInventaireGlobal.Cells[5,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Vergule(floattostr(QteGlobale),'2','C','');
          FSGenerateurBase.TableauInventaireGlobal.Cells[6,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Vergule(floattostr(CoutGlobal),'2','C','');
          FSGenerateurBase.TableauInventaireGlobal.Cells[7,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Vergule(floattostr(ValeurGlobal),'2','C','');
          FSGenerateurBase.TableauInventaireGlobal.Cells[8,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Vergule(floattostr(MargeGlobal),'2','C','');

          if(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,FSGenerateurBase.TableauInventaireGlobal.RowCount-1])<>0)
          then FSGenerateurBase.TableauInventaireGlobal.Cells[9,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:=Vergule(Floattostr(strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[8,FSGenerateurBase.TableauInventaireGlobal.RowCount-1])/strtoreal(FSGenerateurBase.TableauInventaireGlobal.Cells[6,FSGenerateurBase.TableauInventaireGlobal.RowCount-1])),'2','C','%')
          else FSGenerateurBase.TableauInventaireGlobal.Cells[9,FSGenerateurBase.TableauInventaireGlobal.RowCount-1]:='0,00 %';

          AjusterColWidth(FSGenerateurBase.TableauInventaireGlobal,'','');
     end;

     TrierTableauARowSpecial(FSGenerateurBase.TableauInventaireGlobal,1,FSGenerateurBase.TableauInventaireGlobal.RowCount-3,1,FSGenerateurBase.EditRubriqueTrieInventaireGlobal.Text,'','+');

     FSGenerateurBase.AfficheAttenteInventaireGlobale.Visible:=false;
end;

