procedure TFSGenerateurBase.BitAffectationCompteurClick(Sender: TObject);
var i:integer;  OKAffectationCompteur:boolean;
begin
     if(FSGenerateurBase.BitAffectationCompteur.Caption='Valider')then
     begin
           OpenFParc(RParc);
           ChAffectationCompteur:=RParc.Parcours+'\'+Exercice+'FAffectationCompteur';
           assignfile(FAffectationCompteur,ChAffectationCompteur);
           try
           if FileExists(ChAffectationCompteur)then
           Reset(FAffectationCompteur)
           else Rewrite(FAffectationCompteur);
           Seek(FAffectationCompteur,0);
           i:=0;
           OKAffectationCompteur:=false;
           while not eof(FAffectationCompteur)and(OKAffectationCompteur=false)do
           begin
                Read(FAffectationCompteur,RAffectationCompteur);
                if(FSGenerateurBase.EditNumAffectationCompteur.Text<>'')
                and(RAffectationCompteur.NumAffectationCompteur=strtointeger(FSGenerateurBase.EditNumAffectationCompteur.Text))then
                begin
                     OKAffectationCompteur:=true;
                end
                else i:=i+1;
           end;

           Seek(FAffectationCompteur,i);
           RAffectationCompteur.NumAffectationCompteur:=i;
           RAffectationCompteur.DesignationAffectationCompteur:=FSGenerateurBase.EditDesignationAffectationCompteur.Text;
           RAffectationCompteur.ComptesConcerne:=FSGenerateurBase.EditComptesConcerne.Text;
           RAffectationCompteur.NumProjetFinance:=FSGenerateurBase.EditNumProjetCompteur.Text;
           Write(FAffectationCompteur,RAffectationCompteur);

           finally
           Closefile(FAffectationCompteur);
           end;
     end;

     if(FSGenerateurBase.BitAffectationCompteur.Caption='Supprimer')then
     begin
          DeleteFAffectationCompteur(strtointeger(FSGenerateurBase.EditNumAffectationCompteur.Text),OKAffectationCompteur);
     end;

     ProcAfficheListeAffectationCompteur(FSGenerateurBase.TableauAffectationCompteur,'');
     FSGenerateurBase.TableauAffectationCompteur.SetFocus;
     FSGenerateurBase.AfficheAffectationCompteur.Visible:=false;
end;

