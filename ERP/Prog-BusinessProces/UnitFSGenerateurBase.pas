Function ExistePositionDetailStructurePlanifier(NumProjetFinance,PositionDetailStructure:string):boolean;
var  OKPositionDetailStructure:boolean;
begin
     OpenFParc(RParc);
     ChDetailStructureCopie:=RParc.Parcours+'\'+Exercice+'FDetailStructure';
     assignfile(FDetailStructureCopie,ChDetailStructureCopie);
     try
     if FileExists(ChDetailStructureCopie)then
     Reset(FDetailStructureCopie)
     else Rewrite(FDetailStructureCopie);
     Seek(FDetailStructureCopie,0);
     OKPositionDetailStructure:=false;
     while not eof(FDetailStructureCopie)and(OKPositionDetailStructure=false)do
     begin
          read(FDetailStructureCopie,RDetailStructureCopie);

          if(RDetailStructureCopie.NumProjetFinance=NumProjetFinance)
          and(inttostr(RDetailStructureCopie.PositionDetailStructure)=PositionDetailStructure)
          then OKPositionDetailStructure:=true
          else OKPositionDetailStructure:=false;
     end;
     finally
     CloseFile(FDetailStructureCopie);
     end;

     ExistePositionDetailStructurePlanifier:=OKPositionDetailStructure;
end;

