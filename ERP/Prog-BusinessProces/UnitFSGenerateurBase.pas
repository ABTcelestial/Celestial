               end
               else
               if(IBegin=999999999)then
               begin
                    FSGenerateurBase.MemoRapport.Lines.Add('Traitement prťlŤvement,Pťriode: '+DateDebutPeriodeAnalysePrelevement+', Aucun prťlŤvement.');//////////////////////////////////////////////////
               end
