procedure TFSGenerateurBase.TableauDetailStructureRechercheKeyDown(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var R,m:integer; ListeCode,ListeDesignation:string;
begin
     if key in[VK_RETURN]then
     begin
          FSGenerateurBase.AfficheDetailStructureRecherche.Visible:=false;
          R:=1;
          m:=0;
          ListeCode:='';
          ListeDesignation:='';
          while(R<=FSGenerateurBase.TableauDetailStructureRecherche.RowCount-1)do
          begin
               if(FSGenerateurBase.TableauDetailStructureRecherche.Cells[FSGenerateurBase.TableauDetailStructureRecherche.ColCount-1,R]='OK')then
               begin
                    m:=m+1;
                    if(ListeCode='')
                    then ListeCode:=FSGenerateurBase.TableauDetailStructureRecherche.Cells[1,R]
                    else ListeCode:=ListeCode+';'+FSGenerateurBase.TableauDetailStructureRecherche.Cells[1,R];
                    if(ListeDesignation='')then ListeDesignation:=FSGenerateurBase.TableauDetailStructureRecherche.Cells[3,R];
               end;
          R:=R+1;
          end;
     end;

     if(m=0)then
     begin
          showmessage('Aucun code sťlectionnť !');
     end
     else
     if(m=1)then
     begin
          FSGenerateurBase.EditListePositionDetailStructure.Text:=ListeCode;
          FSGenerateurBase.AfficheDesignationDetailStructure.Caption:=ListeDesignation
     end
     else
     begin
          FSGenerateurBase.EditListePositionDetailStructure.Text:=ListeCode;
          FSGenerateurBase.AfficheDesignationDetailStructure.Caption:=inttostr(m)+' Codes sťlectionnťs.'
     end;

     ActivationDataStructure;
end;

