Function FichierCencerneTiersSelect(ListeFichierConcerneTiers,BaseAvis:string):string;
var  OKTypeFichierTiers:boolean;
begin
     FichierCencerneTiersSelect:='';

     TypeProces:='Business';   FichierConcerne:='FTypeFichierTiers';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui gťnťre le fichier '+FichierConcerne+' recherchť !');
     end;

     ChTypeFichierTiers:=Adresse;
     assignfile(FTypeFichierTiers,ChTypeFichierTiers);
     try
     if FileExists(ChTypeFichierTiers)then
     Reset(FTypeFichierTiers)
     else Rewrite(FTypeFichierTiers);
     Seek(FTypeFichierTiers,0);
     OKTypeFichierTiers:=false;
     while not eof(FTypeFichierTiers)and(OKTypeFichierTiers=false)do
     begin
          read(FTypeFichierTiers,RTypeFichierTiers);

          if(FunctionFichierInclu(RTypeFichierTiers.FichierConcerne,ListeFichierConcerneTiers))
          and(RTypeFichierTiers.BaseAvis=BaseAvis)
          then
          begin
               OKTypeFichierTiers:=true;
               FichierCencerneTiersSelect:=RTypeFichierTiers.FichierConcerne;
          end;
     end;
     finally
     CloseFile(FTypeFichierTiers);
     end;
end;

