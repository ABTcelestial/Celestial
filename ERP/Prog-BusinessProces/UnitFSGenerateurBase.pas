procedure TFSGenerateurBase.BitValiderTrieClick(Sender: TObject);
var  i:integer;
begin
     ChStock:=RParc.Parcours+'\'+Exercice+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
     assignfile(FStock,ChStock);
     try
     if FileExists(ChStock)then
     Reset(FStock)
     else Rewrite(FStock);
     Seek(FStock,0);
     Truncate(FStock);

     ChStockArticle:=RParc.Parcours+'\'+Exercice+'FStockArticle Triť';
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     i:=0;
     while not eof(FStockArticle)do
     begin
          read(FStockArticle,RStockArticle);
          Seek(FStock,i);
          write(FStock,RStockArticle);
     i:=i+1;
     end;
     finally
     CloseFile(FStock);
     end;

     finally
     CloseFile(FStockArticle);
     end;

ProcAfficheListeStock(FSGenerateurBase.TableauStockArticle,ChStock,'','','',FSGenerateurBase.RBAvecCodeBarre.Checked);
FSGenerateurBase.AfficheAdresseFichierConcerne.Caption:=ChStock;
FSGenerateurBase.AfficherTrieArticle.Visible:=false;
end;

