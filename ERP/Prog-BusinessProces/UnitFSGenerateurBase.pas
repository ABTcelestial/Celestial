          if(FSGenerateurBase.BitConfirmerRegularisation.Caption='Confirmer la Rťgularisation du prix VD des articles sťlectionnťs')then
          begin
               RegulariserPrixStockTableau(FSGenerateurBase.TableauStockArticleRegularisation);
