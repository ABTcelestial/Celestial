procedure TFSGenerateurBase.EditNumUniteFondsDblClick(Sender: TObject);
var  R,NumUniteFonds:integer; OKUniteFonds:boolean;
begin
     if(FSGenerateurBase.BRNouvelleUniteFonds.Checked=true)then
     begin
          if(FSGenerateurBase.EditNumUniteFonds.Text<>'0')then
          begin
               FSGenerateurBase.EditNumUniteFonds.Text:='0';
          end
          else
          begin
               FSGenerateurBase.TableauIndiceNumUniteFonds.Cols[0].Text:='Indices';
               FSGenerateurBase.TableauIndiceNumUniteFonds.RowCount:=2;
               FSGenerateurBase.TableauIndiceNumUniteFonds.Rows[1].Text:='';

                OpenFParc(RParc);
                ChUniteFonds:=RParc.Parcours+'\'+Exercice+'FUniteFonds';
                assignfile(FUniteFonds,ChUniteFonds);
                try
                if FileExists(ChUniteFonds)then
                Reset(FUniteFonds)
                else Rewrite(FUniteFonds);
                Seek(FUniteFonds,0);
                NumUniteFonds:=1;
                while not eof(FUniteFonds)do
                begin
                     read(FUniteFonds,RUniteFonds);
                     FSGenerateurBase.TableauIndiceNumUniteFonds.Cells[0,RUniteFonds.NumUniteFonds]:=inttostr(RUniteFonds.NumUniteFonds);
                     if(NumUniteFonds<=RUniteFonds.NumUniteFonds)then NumUniteFonds:=RUniteFonds.NumUniteFonds+1;
                end;
                finally
                CloseFile(FUniteFonds);
                end;

                FSGenerateurBase.TableauIndiceNumUniteFonds.RowCount:=NumUniteFonds+1;

                R:=1;
                OKUniteFonds:=false;
                while(R<=FSGenerateurBase.TableauIndiceNumUniteFonds.RowCount-1)and(OKUniteFonds=false)do
                begin
                     if(FSGenerateurBase.TableauIndiceNumUniteFonds.Cells[0,R]='')then
                     begin
                          OKUniteFonds:=true;
                          FSGenerateurBase.EditNumUniteFonds.Text:=inttostr(R);
