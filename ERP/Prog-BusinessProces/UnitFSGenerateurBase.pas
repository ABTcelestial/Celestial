                                                 Seek(FListeFichierConcernePartageReseauxCopie1,i);
                                                 write(FListeFichierConcernePartageReseauxCopie1,RListeFichierConcernePartageReseaux);
                                                 i:=i+1;

                                                 FSMenuPrincipal.EditRapport.Lines.Add('Poste: '+RListeFichierConcernePartageReseaux.NomPosteReseaux+', Fichier:  '+RListeFichierConcernePartageReseaux.FichierConcerne);
                                            end;
                                            finally
                                            CloseFile(FListeFichierConcernePartageReseaux);
                                            end;

                                            FSMenuPrincipal.EditRapport.Lines.Add('Enregistrement Local '+'FListeFichierConcernePartageReseaux'+' '+RAdresseProces.Repertoire+' effťctuť avec succťs ! {'+inttostr(i)+' Enregistrements} "Source: '+ExtractFileDir(ExtractFileDir(ChListeFichierConcernePartageReseaux))+'"');
                                       end;
                                       finally
                                       CloseFile(FListeFichierConcernePartageReseauxCopie1);
                                       end;
                                 end;

                                 if(OKDossierPartagerReseaux=true)and(DirectoryExists(RAdresseProces.AdresseProces)=true)then
                                 begin
                                       // Indiquer les adresses rťseaux aux clients
                                       ChListeFichierConcernePartageReseauxCopie2:=RAdresseProces.AdresseProces+'\FListeFichierConcernePartageReseaux'+DataIdentificateurReseaux+' '+NomDossierLocal;

                                       assignfile(FListeFichierConcernePartageReseauxCopie2,ChListeFichierConcernePartageReseauxCopie2);
                                       try
                                       if FileExists(ChListeFichierConcernePartageReseauxCopie2)
