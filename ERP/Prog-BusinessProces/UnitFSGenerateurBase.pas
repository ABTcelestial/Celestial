              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinConsultation:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeAjouter:=false;
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutAjouter:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinAjouter:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeModifier:=false;
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutModifier:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinModifier:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeSupprimer:=false;
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutSupprimer:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinSupprimer:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.ModeImprimer:=false;
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateDebutImprimer:='';
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.DateFinImprimer:='';

              write(FListeFichierConcernePartageReseaux,RListeFichierConcernePartageReseaux);
              i:=i+1;
         end;
    R:=R+1;
    end;
    finally
    CloseFile(FListeFichierConcernePartageReseaux);
    end;
    ListeFichierConecernePartageReseaux(FSGenerateurBase.TableauxFichierConcernePartageReseaux,FSGenerateurBase.EditNumAdresseProces.Text,'');
    ///////////////////////////////////////////////////

    TrierTableauARowSpecial(FSGenerateurBase.TableauListeFichierConcerne,1,FSGenerateurBase.TableauListeFichierConcerne.RowCount+-1,1,'4','','-');

    FSGenerateurBase.EditNomFichierConcerneRecherche.Text:='';
