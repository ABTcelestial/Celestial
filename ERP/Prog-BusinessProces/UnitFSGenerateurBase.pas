     FSMenuPrincipal.EditRapport.Lines.Add('Indiquer liste fichier partagťs aux clients rťseaux !!!');

     //////////////////////////
     // Indiquer les adresses rťseaux aux clients

     AdresseDossierLocal:=ProcAdresseDossierPartageReseaux('','Local',NomDossierLocal,EmlacementLocalOuReseauxOut);

     if(DirectoryExists(AdresseDossierLocal))then
     begin
FSMenuPrincipal.EditDetailRapport.Lines.Add('le dossier '+AdresseDossierLocal+' existe');
