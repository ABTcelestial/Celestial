              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.NumeroAcces:=i;
              RListeFichierConcernePartageReseaux.RAccesPrivilegieReseaux.CodeUtilisateur:=FSMenuPrincipal.EditCodeUtilisateur.Text;
