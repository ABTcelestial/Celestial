          ChTypeFichierTiers:=Adresse;
          assignfile(FTypeFichierTiers,ChTypeFichierTiers);
          try
          if FileExists(ChTypeFichierTiers)then
          Reset(FTypeFichierTiers)
          else Rewrite(FTypeFichierTiers);
          Seek(FTypeFichierTiers,0);
          i:=0;
          OKTypeFichierTiers:=false;
          while not eof(FTypeFichierTiers)and(OKTypeFichierTiers=false)do
          begin
               read(FTypeFichierTiers,RTypeFichierTiers);
               if(inttostr(RTypeFichierTiers.OrdreTypeFichierTiers)=FSGenerateurBase.EditOrdreTypeFichierTiers.Text)
               then OKTypeFichierTiers:=true
               else i:=i+1;
          end;

          RTypeFichierTiers.OrdreTypeFichierTiers:=i;
          RTypeFichierTiers.TypeProces:=FSGenerateurBase.EditTypeProcesTypeFichierTiers.Text;
          RTypeFichierTiers.FichierConcerne:='F'+FSGenerateurBase.EditFichierConcerneTypeFichierTiers.Text;
          RTypeFichierTiers.BaseAvis:=FSGenerateurBase.EditBaseAvis.Text;
          Seek(FTypeFichierTiers,i);
          write(FTypeFichierTiers,RTypeFichierTiers);

          finally
          CloseFile(FTypeFichierTiers);
          end;
     end;

     if(FSGenerateurBase.BitOperationTypeFichierTiers.Caption='Supprimer')then
     begin
          SupprimerTypeFichierTiers(FSGenerateurBase.EditOrdreTypeFichierTiers.Text,RExistant,RSupprimer,RSauvgarder);
          if(RSupprimer>0)
          then AfficherMessage('Suppression rťussie ! FTotal: '+inttostr(RExistant)+' FSupprimer: '+inttostr(RSupprimer)+' FSauvgarder: '+inttostr(RSauvgarder))
          else AfficherMessage('Aucun Registre Supprimer ! FTotal: '+inttostr(RExistant)+' FSupprimer: '+inttostr(RSupprimer)+' FSauvgarder: '+inttostr(RSauvgarder));
     end;

ListeTypeFichierTiers(FSGenerateurBase.TableauTypeFichierTiers,FSGenerateurBase.EditSelectTypeProces.Text,strtointeger(FSGenerateurBase.EditIndiceRubriqueTrie.Text));
FSGenerateurBase.AfficheOperationTypeFichierTiers.Visible:=false;

FSGenerateurBase.TableauTypeFichierTiers.SetFocus;
end;

