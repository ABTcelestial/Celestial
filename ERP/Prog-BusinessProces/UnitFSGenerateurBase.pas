Function ControleStockLimiteProjet(OKAfficheListeStockLimite,InclureStockLimiteNonRepertotie:boolean; var RowOut:integer):boolean;
var  R:integer; TypeStock:string;  OKAlerteStockLimite:boolean;
begin
     ControleStockLimiteProjet:=false;

     TypeStock:='Article';
     OpenFParc(RParc);
     ChProjetFinanceControle:=RParc.Parcours+'\'+Exercice+'FProjetFinance';
     assignfile(FProjetFinanceControle,ChProjetFinanceControle);
     if FileExists(ChProjetFinanceControle)then
     begin
          try
          Reset(FProjetFinanceControle);
          Seek(FProjetFinanceControle,0);
          R:=0;
          OKAlerteStockLimite:=false;

          if(ControleAlerteStockLimite('')=true)then
          begin
               StockLimite(TypeStock,'',false,InclureStockLimiteNonRepertotie,R,R); ///ContrŰle tous les projets
               OKAlerteStockLimite:=true;
          end;

          while not eof(FProjetFinanceControle)do
          begin
               read(FProjetFinanceControle,RProjetFinanceControle); Application.ProcessMessages;
               if(ControleAlerteStockLimite(RProjetFinanceControle.NumProjetFinance)=true)then
               begin
                    StockLimite(TypeStock,RProjetFinanceControle.NumProjetFinance,false,InclureStockLimiteNonRepertotie,R,R);
                    OKAlerteStockLimite:=true;
               end;
          end;
     finally
     CloseFile(FProjetFinanceControle);
     end;
     end;


     if(OKAlerteStockLimite=true)
     then StockLimite('','',OKAfficheListeStockLimite,InclureStockLimiteNonRepertotie,R,R);

     if(R>0)then ControleStockLimiteProjet:=true;
     RowOut:=R;
end;
  
