          FSGenerateurBase.TableauPlanComptableChois.ColCount:=FSGenerateurBase.TableauPlanComptableChois.ColCount+1;
          FSGenerateurBase.TableauPlanComptableChois.Cols[FSGenerateurBase.TableauPlanComptableChois.ColCount-1].Text:='Sťlect';
          NotCol:='3-'+inttostr(FSGenerateurBase.TableauPlanComptableChois.ColCount-2);
