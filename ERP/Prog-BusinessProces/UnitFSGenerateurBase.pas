procedure TFSGenerateurBase.BitBtn59Click(Sender: TObject);
var  i:integer;
begin
     ChArchivePrelevementCompteur:=RParc.Parcours+'\'+Exercice+'FArchivePrelevementCompteur';
     assignfile(FArchivePrelevementCompteur,ChArchivePrelevementCompteur);
     try
     if FileExists(ChArchivePrelevementCompteur)then
     Reset(FArchivePrelevementCompteur)
     else Rewrite(FArchivePrelevementCompteur);
     Seek(FArchivePrelevementCompteur,0);
     i:=0;
     while not eof(FArchivePrelevementCompteur)do
     begin
          read(FArchivePrelevementCompteur,RArchivePrelevementCompteur);

          RStock:=ChercherStockArticle('Article',FSGenerateurBase.EditNumProjet.Text,RArchivePrelevementCompteur.CodeArticle,'',OKStockRecherche,RubriqueRecherche);

          if(RArchivePrelevementCompteur.CoutUnitaire=0)and(RStock.CoutUnitaire<>0)then
          begin
               RArchivePrelevementCompteur.CoutUnitaire:=RStock.CoutUnitaire;
               Seek(FArchivePrelevementCompteur,i);
               write(FArchivePrelevementCompteur,RArchivePrelevementCompteur);
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FArchivePrelevementCompteur);
     end;

     ChArchiveDetailArticlePrelevementUniteFonds:=RParc.Parcours+'\'+Exercice+'FArchiveDetailArticlePrelevementUniteFonds';
     assignfile(FArchiveDetailArticlePrelevementUniteFonds,ChArchiveDetailArticlePrelevementUniteFonds);
     try
     if FileExists(ChArchiveDetailArticlePrelevementUniteFonds)then
     Reset(FArchiveDetailArticlePrelevementUniteFonds)
     else Rewrite(FArchiveDetailArticlePrelevementUniteFonds);
     Seek(FArchiveDetailArticlePrelevementUniteFonds,0);
     i:=0;
     while not eof(FArchiveDetailArticlePrelevementUniteFonds)do
     begin
          read(FArchiveDetailArticlePrelevementUniteFonds,RArchiveDetailArticlePrelevementUniteFonds);

          RStock:=ChercherStockArticle('Article',FSGenerateurBase.EditNumProjet.Text,RArchiveDetailArticlePrelevementUniteFonds.CodeArticle,'',OKStockRecherche,RubriqueRecherche);

          if(RStock.CoutUnitaire<>0)then
          begin
               if(RArchiveDetailArticlePrelevementUniteFonds.CoutUnitaire<=0)then
               begin
                    RArchiveDetailArticlePrelevementUniteFonds.CoutUnitaire:=RStock.CoutUnitaire;
                    Seek(FArchiveDetailArticlePrelevementUniteFonds,i);
                    write(FArchiveDetailArticlePrelevementUniteFonds,RArchiveDetailArticlePrelevementUniteFonds);
               end;
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FArchiveDetailArticlePrelevementUniteFonds);
     end;


     ChTypeMouvement:=RParc.Parcours+'\'+Exercice+'FTypeMouvement';
     assignfile(FTypeMouvement,ChTypeMouvement);
     try
     if FileExists(ChTypeMouvement)then
     Reset(FTypeMouvement)
     else Rewrite(FTypeMouvement);
     Seek(FTypeMouvement,0);
     while not eof(FTypeMouvement)do
     begin
           read(FTypeMouvement,RTypeMouvement);
           ChDetailMouvement:=RParc.Parcours+'\'+Exercice+'DťtailMouvement '+RTypeMouvement.DesignationTypeMouvement;
           assignfile(FDetailMouvement,ChDetailMouvement);
           try
           if FileExists(ChDetailMouvement)then
           Reset(FDetailMouvement)
           else Rewrite(FDetailMouvement);
           Seek(FDetailMouvement,0);
           i:=0;
           while not eof(FDetailMouvement)do
           begin
                read(FDetailMouvement,RDetailMouvement);

                RStock:=ChercherStockArticle('Article',FSGenerateurBase.EditNumProjet.Text,RDetailMouvement.CodeArticle,'',OKStockRecherche,RubriqueRecherche);

                if(RStock.CoutUnitaire<>0)then
                begin
                     if(RDetailMouvement.CoutUnitaireArticle<=0)then
                     begin
                          RDetailMouvement.CoutUnitaireArticle:=RStock.CoutUnitaire;
                          Seek(FDetailMouvement,i);
                          write(FDetailMouvement,RDetailMouvement);
                     end;
                end;
           i:=i+1;
           end;
           finally
           CloseFile(FDetailMouvement);
           end;
     end;
     finally
     CloseFile(FTypeMouvement);
     end;
end;

Procedure ProcAfficheListeStockAnomalie(TableauStock:TStringGrid; FichierConcerne,CodeSFamille,CodeArticleRowSelect,ListeCompteConcerne:string);
var  k,ARowSelect:integer; OKStock:boolean;  NotCol,TypeData,MessageErreure:string;
begin

TableauStock.ColCount:=19;
TableauStock.Cols[0].Text:='Nį';
TableauStock.Cols[1].Text:='Code';
TableauStock.Cols[2].Text:='Dťsignation';
TableauStock.Cols[3].Text:='Rťference';
TableauStock.Cols[4].Text:='UM';
TableauStock.Cols[5].Text:='Qte.Entrťe';
TableauStock.Cols[6].Text:='Qte.Sortie';
TableauStock.Cols[7].Text:='Qte en Stock';
TableauStock.Cols[8].Text:='Qte.Initial';
TableauStock.Cols[9].Text:='Qte.Limite';
TableauStock.Cols[10].Text:='Prix d''Achat';
TableauStock.Cols[11].Text:='P.V.D';
TableauStock.Cols[12].Text:='P.V.G';
TableauStock.Cols[13].Text:='Emplacement';
TableauStock.Cols[14].Text:='Code Bare';
TableauStock.Cols[15].Text:='Formule';
TableauStock.Cols[16].Text:='Observation';
TableauStock.Cols[17].Text:='Enreg';
TableauStock.Cols[18].Text:='Informations';

TableauStock.RowCount:=2;
TableauStock.Rows[1].Text:='';

OpenFParc(RParc);
ChStock:=FichierConcerne;
assignfile(FStock,ChStock);
try
if FileExists(ChStock)then
Reset(FStock)
else Rewrite(FStock);
Seek(FStock,0);
k:=0;
ARowSelect:=1;
while not eof(FStock)do
begin
     read(FStock,RStock);

     MessageErreure:='';

     if(CodeSFamille<>'')then
     begin
          if(Firstlaters(RStock.Code,longueur(CodeSFamille))=CodeSFamille)
          then OKStock:=true
          else OKStock:=false;
     end
     else OKStock:=true;

     if(OKStock=true)then
     begin
          if(ListeCompteConcerne<>'')then
          begin
               if ExisteFirstLatersNuminTexte(RStock.Code,ListeCompteConcerne)
               then OKStock:=true
          else OKStock:=false;
          end;
     end;


     if(RStock.PrixVenteDetaille>0)and(RStock.CoutUnitaire>=RStock.PrixVenteDetaille)then MessageErreure:='CoŻt supťrieur au prix dťtail !';
     if(RStock.PrixVenteDemiGros>0)and(RStock.CoutUnitaire>=RStock.PrixVenteDemiGros)then MessageErreure:='CoŻt supťrieur au prix demi-gros !';
     if(RStock.PrixVenteGros>0)and(RStock.CoutUnitaire>=RStock.PrixVenteGros)then MessageErreure:='CoŻt supťrieur au prix gros !';

     if(OKStock=true)and(MessageErreure<>'')then
     begin
          k:=k+1;
          TableauStock.Rows[k].Text:=inttostr(k);
          TableauStock.Cells[1,k]:=RStock.Code;
          TableauStock.Cells[2,k]:=RStock.Design;
          TableauStock.Cells[3,k]:=RStock.Ref;
          TableauStock.Cells[4,k]:=RStock.UM;
          TableauStock.Cells[5,k]:=Vergule(floattostr(RStock.QteEntree),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[6,k]:=Vergule(floattostr(RStock.QteSortie),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[7,k]:=Vergule(floattostr(RStock.QteStock),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[8,k]:=Vergule(floattostr(RStock.QteInitial),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[9,k]:=Vergule(floattostr(RStock.QteLimite),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[10,k]:=Vergule(floattostr(RStock.CoutUnitaire),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[11,k]:=Vergule(floattostr(RStock.PrixVenteDetaille),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[12,k]:=Vergule(floattostr(RStock.PrixVenteGros),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[13,k]:=RStock.Emplace;
          TableauStock.Cells[14,k]:=RStock.CodeBarre;
          TableauStock.Cells[15,k]:=RStock.Formule;
          TableauStock.Cells[16,k]:=RStock.Observ;
          TableauStock.Cells[17,k]:=RStock.enregistrement;
          TableauStock.Cells[18,k]:=MessageErreure;

          if(CodeArticleRowSelect<>'')then
          begin
               if(RStock.Code=CodeArticleRowSelect)then ARowSelect:=k;
          end;
     end;
end;
finally
closefile(FStock);
end;

if(k>0)then TableauStock.RowCount:=k+1
       else TableauStock.RowCount:=2;

NotCol:='5-9;13-17';
for k:=1 to TableauStock.ColCount-1 do if existenumintexte(inttostr(k),NotCol)then TableauStock.ColWidths[k]:=0;
AjusterColWidth(TableauStock,'',NotCol);

TableauStock.Row:=ARowSelect;
TypeData:='';
//TrierTableauARowSpecial(TableauStock,1,TableauStock.RowCount-1,1,strtointeger(FSGenerateurBase.EditRubriqueTrie.Text),TypeData,FSGenerateurBase.EditTypeTrie.Text);
TableauStock.SetFocus;
end;

