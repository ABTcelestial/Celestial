Function CardinalCodeBarre(FichierConcerne,SerieCodeBarre:string):string;
var  CardinaleMax:integer; CodeBarreTeste:string;
begin
     CardinaleMax:=1;

     ChStock:=FichierConcerne;
     assignfile(FStock,ChStock);
     try
     if FileExists(ChStock)then
     Reset(FStock)
     else Rewrite(FStock);
     Seek(FStock,0);
     while not eof(FStock)do
     begin
          read(FStock,RStock);

          if(longueur(RStock.CodeBarre)=8)then
          begin
               CodeBarreTeste:=firstlaters(RStock.CodeBarre,7);

               if(SerieCodeBarre<>'')then
               begin
                    if(firstlaters(CodeBarreTeste,longueur(SerieCodeBarre))=SerieCodeBarre)then
                    begin
                         if(CardinaleMax<=strtointeger(lastlaters(CodeBarreTeste,7-longueur(SerieCodeBarre))))then CardinaleMax:=strtointeger(lastlaters(CodeBarreTeste,7-longueur(SerieCodeBarre)))+1;
                    end;
               end
               else
               begin
                    if(CardinaleMax<=strtointeger(lastlaters(CodeBarreTeste,7-longueur(SerieCodeBarre))))then CardinaleMax:=strtointeger(lastlaters(CodeBarreTeste,7-longueur(SerieCodeBarre)))+1;
               end;
          end;
     end;
     finally
     CloseFile(FStock);
     end;

     CardinalCodeBarre:=CompleteZeroGauche(inttostr(CardinaleMax),inttostr(7-longueur(SerieCodeBarre)));
end;


