procedure TFSGenerateurBase.RBExerciceAutomatiqueClick(Sender: TObject);
var  OKRegistre:boolean;    AdresseTypeProces:string;
begin
     if(FSGenerateurBase.RBExerciceAutomatique.Checked=true)then
     begin
          FSGenerateurBase.EditExercice.Text:='Auto';
          FSGenerateurBase.EditExercice.Color:=$00E4E4E4;
     end
     else
     begin
          if(FSGenerateurBase.EditTypeProces.Text='Business')then AdresseTypeProces:='C:\WinBuss.dll';
          if(FSGenerateurBase.EditTypeProces.Text='Comptabilitť')then AdresseTypeProces:='C:\WinComptas.dll';
          if(FSGenerateurBase.EditTypeProces.Text='Commercial')then AdresseTypeProces:='C:\Windll.dll';
          if(FSGenerateurBase.EditTypeProces.Text='Social')then AdresseTypeProces:='C:\WinSCdll.dll';
          if(FSGenerateurBase.EditTypeProces.Text='Paie')then AdresseTypeProces:='C:\WinPaies.dll';

          FSGenerateurBase.EditExercice.Text:='';
          FSGenerateurBase.EditExercice.Color:=clWindow;
          if FileExists(AdresseTypeProces)then
          begin
               assignfile(FRegistre,AdresseTypeProces);
               try
               reset(FRegistre);
               Seek(FRegistre,0);
               OKRegistre:=false;
               while not eof(FRegistre)and(OKRegistre=false)do
               begin
                    Read(FRegistre,RRegistre);
                    if(AnsiUpperCase(RRegistre.Repertoire)=AnsiUpperCase(FSGenerateurBase.EditRepertoire.Text))
                    and(AnsiUpperCase(RRegistre.Adresse)=AnsiUpperCase(FSGenerateurBase.EditAdresseProces.Text))
                    then
                    begin
                         OKRegistre:=true;
                         FSGenerateurBase.EditExercice.Text:=RRegistre.Exercice;
                    end;
               end;
               finally
               CloseFile(FRegistre);
               end;
          end
          else showmessage(AdresseTypeProces+' n''ťxiste pas !');
     end;

     FSGenerateurBase.EditExercice.ReadOnly:=FSGenerateurBase.RBExerciceAutomatique.Checked;
end;

