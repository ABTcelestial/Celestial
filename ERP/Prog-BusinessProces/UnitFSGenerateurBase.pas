var  R:integer;  OKProjetFichTech,OKProjetRubrique:boolean;
begin
     OKProjetFichTech:=false;
     OKProjetRubrique:=false;

     OpenFParc(RParc);
     ChRubriqueFicheTechnique:=RParc.Parcours+'\'+Exercice+'FRubriqueFicheTechnique';
     assignfile(FRubriqueFicheTechnique,ChRubriqueFicheTechnique);
     try
     if FileExists(ChRubriqueFicheTechnique)then
     Reset(FRubriqueFicheTechnique)
     else Rewrite(FRubriqueFicheTechnique);
     Seek(FRubriqueFicheTechnique,0);
     while not eof(FRubriqueFicheTechnique)and(OKProjetRubrique=false)do
     begin
          read(FRubriqueFicheTechnique,RRubriqueFicheTechnique);
          RubriqueArborescence('',inttostr(RRubriqueFicheTechnique.NumRubrique),RRubriqueFicheTechniqueCopie,RFicheTechniqueCopie,RTypeAvis);
          R:=1;
          while(R<=FSGenerateurBase.TableauProjetFinancePropose.RowCount-1)and(OKProjetRubrique=false)do
          begin
               if(RFicheTechniqueCopie.CodeProjet=FSGenerateurBase.TableauProjetFinancePropose.Cells[1,R])then
               begin
                    OKProjetRubrique:=true;
               end;
          R:=R+1;
          end;
     end;
     finally
     closefile(FRubriqueFicheTechnique);
     end;

     if(OKProjetRubrique=false)then
     begin
           OpenFParc(RParc);
           ChFicheTechnique:=RParc.Parcours+'\'+Exercice+'FFicheTechnique';
           assignfile(FFicheTechnique,ChFicheTechnique);
           try
           if FileExists(ChFicheTechnique)then
           Reset(FFicheTechnique)
           else Rewrite(FFicheTechnique);
           Seek(FFicheTechnique,0);
           while not eof(FFicheTechnique)and(OKProjetFichTech=false)do
           begin
                read(FFicheTechnique,RFicheTechnique);
                R:=1;
                while(R<=FSGenerateurBase.TableauProjetFinancePropose.RowCount-1)and(OKProjetFichTech=false)do
                begin
                     if(RFicheTechnique.CodeProjet=FSGenerateurBase.TableauProjetFinancePropose.Cells[1,R])then
                     begin
                          OKProjetFichTech:=true;
                     end;
                R:=R+1;
                end;
           end;
           finally
           closefile(FFicheTechnique);
           end;
     end;


     if(OKProjetRubrique=true)then
     begin
          ProcAfficheMessage('Il existe une Rubrique pour le projet sťlectionnť, vťrifier vos donnťes SVP !');
     end;

     if(OKProjetFichTech=true)then
     begin
          ProcAfficheMessage('Il existe une fiche technique pour le projet sťlectionnť, vťrifier vos donnťes SVP !');
     end;

     if(OKProjetRubrique=false)and(OKProjetFichTech=false)then
     begin
          FSGenerateurBase.AfficheOptionValiderProposition.Visible:=true;
          FSGenerateurBase.AfficheOptionValiderProposition.Caption:='Confirmer la validation de la Proposition SVP !';
