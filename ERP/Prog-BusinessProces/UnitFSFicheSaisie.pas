     else begin affichermessage('Attention ! {'+ChPrelevementUniteFonds+'} n''existe pas !'); exit; end;//Rewrite(FPrelevementUniteFonds);
     Seek(FPrelevementUniteFonds,0);
     IndiceFinControleTrieRow:=1;
