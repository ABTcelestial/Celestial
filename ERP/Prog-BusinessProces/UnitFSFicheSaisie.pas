procedure TFSFicheSaisie.EditNumListeMouvementDblClick(Sender: TObject);
var  R,l,NumListeMouvement:integer; NotRow,TypeProces,FichierConserne,Adresse:string; OKListeMouvement:boolean;
begin
     if(strtointeger(FSFicheSaisie.EditNumListeMouvement.Text)=1)then
     begin
          FSFicheSaisie.EditNumListeMouvement.ReadOnly:=false;
     end
     else
     if(FSFicheSaisie.EditNumListeMouvement.Text<>'')and(FSFicheSaisie.EditOrdreListeMouvement.Text<>'')then
     begin

          FSFicheSaisie.TableauNewNumListeMouvement.ColCount:=2;
          FSFicheSaisie.TableauNewNumListeMouvement.Cols[0].Text:='Num';
          FSFicheSaisie.TableauNewNumListeMouvement.Cols[1].Text:='Existe';

          FSFicheSaisie.TableauNewNumListeMouvement.RowCount:=2;
          FSFicheSaisie.TableauNewNumListeMouvement.Rows[1].Text:='';

          FSFicheSaisie.TableauNewNumListeMouvementCopie.ColCount:=2;
          FSFicheSaisie.TableauNewNumListeMouvementCopie.Cols[0].Text:='Num';
          FSFicheSaisie.TableauNewNumListeMouvementCopie.Cols[1].Text:='Existe';

          FSFicheSaisie.TableauNewNumListeMouvementCopie.RowCount:=2;
          FSFicheSaisie.TableauNewNumListeMouvementCopie.Rows[1].Text:='';

          TypeProces:='Business';   FichierConserne:='FListeMouvement';
          if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
          end;

          ChListeMouvement:=IndiqueAdresseListeMouvement('',TypeProcesReseauxListeMouvement);
          assignfile(FListeMouvement,ChListeMouvement);
          try
          if FileExists(ChListeMouvement)then
          Reset(FListeMouvement)
          else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
          Seek(FListeMouvement,0);
          R:=0;
          NumListeMouvement:=1;
          OKListeMouvement:=false;
          while not eof(FListeMouvement)and(OKListeMouvement=false)do
          begin
               read(FListeMouvement,RListeMouvement);

               if(RListeMouvement.ValidationListeMouvement=true)then
               begin
                    //if(FSFicheSaisie.EditOrdreListeMouvement.Text=inttostr(RListeMouvement.OrdreListeMouvement))then
                    //begin
                         //OKListeMouvement:=true;
                    //end
                    //else
                    begin
                         if(RListeMouvement.CodeTypeFormule=FSFicheSaisie.EditCodeTypeFormuleBase.Text)
                         then
                         begin
                              if(FSFicheSaisie.RBNouvelleNumerotationPourChaqueExercice.Checked=true)then
                              begin
                                   if(Lastlaters(RListeMouvement.DateMouvement,4)=Lastlaters(FSFicheSaisie.EditAnnee.Text,4))then
                                   begin
                                        if(R<RListeMouvement.NumListeMouvement)then R:=RListeMouvement.NumListeMouvement;
                                        FSFicheSaisie.TableauNewNumListeMouvementCopie.Cells[0,RListeMouvement.NumListeMouvement]:=inttostr(RListeMouvement.NumListeMouvement);
                                        FSFicheSaisie.TableauNewNumListeMouvementCopie.Cells[1,RListeMouvement.NumListeMouvement]:='OK';
                                   end;
                              end
                              else
                              begin
                                   if(R<RListeMouvement.NumListeMouvement)then R:=RListeMouvement.NumListeMouvement;
                                   FSFicheSaisie.TableauNewNumListeMouvementCopie.Cells[0,RListeMouvement.NumListeMouvement]:=inttostr(RListeMouvement.NumListeMouvement);
                                   FSFicheSaisie.TableauNewNumListeMouvementCopie.Cells[1,RListeMouvement.NumListeMouvement]:='OK';
                              end;
                         end;
                    end;
               end;
          end;
          finally
          CloseFile(FListeMouvement);
          end;

          if(R>0)then FSFicheSaisie.TableauNewNumListeMouvementCopie.RowCount:=R+1
                      else FSFicheSaisie.TableauNewNumListeMouvementCopie.RowCount:=2;

          if(OKListeMouvement=false)then
          begin
               l:=0;
               for R:=1 to FSFicheSaisie.TableauNewNumListeMouvementCopie.RowCount-1 do
               begin
                    if(FSFicheSaisie.TableauNewNumListeMouvementCopie.Cells[1,R]<>'OK')then
                    begin
                         l:=l+1;
                         FSFicheSaisie.TableauNewNumListeMouvement.Cells[0,l]:=inttostr(R);
                         FSFicheSaisie.TableauNewNumListeMouvement.Cells[1,l]:='Insérer le numéro: '+inttostr(R);
                    end;
               end;

               if(l>0)then
                      begin
                           FSFicheSaisie.TableauNewNumListeMouvement.RowCount:=l+2;
                           FSFicheSaisie.TableauNewNumListeMouvement.Cells[0,l+1]:=inttostr(R);
                           FSFicheSaisie.TableauNewNumListeMouvement.Cells[1,l+1]:='Nouveau numéro: '+inttostr(R);
                           FSFicheSaisie.AfficheTableauNewNumListeMouvement.Visible:=true;
                           AjusterColWidth(FSFicheSaisie.TableauNewNumListeMouvement,'','');
                           FSFicheSaisie.TableauNewNumListeMouvement.SetFocus;
                      end
                      else showmessage('Aucun nouveau mouvement n''est opéré !');
          end
          else showmessage('Aucun nouveau mouvement n''est opéré !');
     end;
end;

