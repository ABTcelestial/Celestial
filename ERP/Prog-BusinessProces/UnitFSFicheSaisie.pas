Procedure EnregistrementOptionsFicheSaisie(CodeMouvement,TitreOptionIn,DataOptionIn:string);
var  i:integer; FichierTexte:TextFile; AdresseFichierTexte,TexteLigne,TitreOptionTeste,DataOptionTeste:string;
     OKData:boolean;
     Source:file;
begin
     FSFicheSaisie.FichierMemo.Clear;

     OpenFParc(RParc);
     AdresseFichierTexte:=RParc.Parcours+'\'+Exercice+'FRegistreOptionsFicheSaisie'+CodeMouvement+'.txt';
     AssignFile(FichierTexte,AdresseFichierTexte);
     if FileExists(AdresseFichierTexte)then
     begin
          try
          Reset(FichierTexte);
          while not eof(FichierTexte)do
          begin
               Readln(FichierTexte,TexteLigne);
               FSFicheSaisie.FichierMemo.Lines.Add(TexteLigne);
          end;
          finally
          CloseFile(FichierTexte);
          end;
     end;

     i:=0;
     OKData:=false;
     while(i<=FSFicheSaisie.FichierMemo.Lines.Capacity)and(OKData=false)do
     begin
          TexteLigne:=FSFicheSaisie.FichierMemo.Lines.Strings[i];
          DataOptionsFicheSaisie(TexteLigne,TitreOptionTeste,DataOptionTeste);
          if(TitreOptionTeste=TitreOptionIn)
          then OKData:=true
          else i:=i+1;
     end;

     TexteLigne:='§'+TitreOptionIn+'§'+DataOptionIn;

     if(OKData=true)then
     begin
          FSFicheSaisie.FichierMemo.Lines.Delete(i);
          FSFicheSaisie.FichierMemo.Lines.Insert(i,TexteLigne);
     end
     else
     begin
          FSFicheSaisie.FichierMemo.Lines.Add(TexteLigne);
     end;

     if FileExists(AdresseFichierTexte)then
     begin
          AssignFile(Source,AdresseFichierTexte);
          Erase(Source);
     end;

     FSFicheSaisie.FichierMemo.Lines.SaveToFile(AdresseFichierTexte);

end;

Procedure DataOptionsFicheSaisie(TexteLigne:string; var TitreOptionOut,DataOptionOut:string);
var  i,LTexte:integer;
begin
//  §TitreOption§Option
     TitreOptionOut:='';
     DataOptionOut:='';
     LTexte:=longueur(TexteLigne);

     if(LTexte>0)then
     begin
          if(TexteLigne[1]='§')then
          begin
               i:=2;
               while(i<=LTexte)and(TexteLigne[i]<>'§')do
               begin
                    TitreOptionOut:=TitreOptionOut+TexteLigne[i];
               i:=i+1;
               end;

               if(TexteLigne[i]='§')then
               begin
                    i:=i+1;
                    while(i<=LTexte)and(TexteLigne[i]<>'§')do
                    begin
                         DataOptionOut:=DataOptionOut+TexteLigne[i];
                    i:=i+1;
                    end;
               end;
          end;
     end;
end;

Function FindDataOptionsFicheSaisie(CodeMouvement,TitreOptionIn:string):string;
var  FichierTexte:TextFile; AdresseFichierTexte,TexteLigne,TitreOptionTeste,DataOptionTeste:string;
     OKData:boolean;
begin
     FindDataOptionsFicheSaisie:='';

     OpenFParc(RParc);
     AdresseFichierTexte:=RParc.Parcours+'\'+Exercice+'FRegistreOptionsFicheSaisie'+CodeMouvement+'.txt';
     AssignFile(FichierTexte,AdresseFichierTexte);
     if FileExists(AdresseFichierTexte)then
     begin
          try
          Reset(FichierTexte);

          OKData:=false;
          while not eof(FichierTexte)and(OKData=false)do
          begin
               Readln(FichierTexte,TexteLigne);
               DataOptionsFicheSaisie(TexteLigne,TitreOptionTeste,DataOptionTeste);
               if(TitreOptionTeste=TitreOptionIn)then
               begin
                    OKData:=true;
                    FindDataOptionsFicheSaisie:=DataOptionTeste;
              end;
         end;
         finally
         CloseFile(FichierTexte);
         end;
     end;
end;

