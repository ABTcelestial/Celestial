procedure TFSFicheSaisie.EditQuantiteMouvementKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
var R,RowEditing:integer; QteCalcule,QteStckCalcule:real;  OKArticle,OKQteStock:boolean;
begin
     if key in[VK_ESCAPE]then
     begin
          FSFicheSaisie.AfficheDetailMouvement.Visible:=false;
          FSFicheSaisie.TableauDetaiMouvement.SetFocus;
     end;

     if key in[VK_RETURN]then
     begin
          if(FSFicheSaisie.EditRowEditing.Text<>'')
          then RowEditing:=strtointeger(FSFicheSaisie.EditRowEditing.Text)
          else RowEditing:=FSFicheSaisie.TableauDetaiMouvement.Row;

          QteCalcule:=strtoreal(FSFicheSaisie.EditQuantiteMouvement.Text);

          R:=6;
          OKArticle:=false;
          while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OKArticle=false)do
          begin
               if(R<>RowEditing)
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R]='')
               then
               begin
                    if (FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]=FSFicheSaisie.LabelCodeArticle.Caption)
                    and(FSFicheSaisie.TableauDetaiMouvement.Cells[2,R]=FSFicheSaisie.LabelDesignationArticle.Caption)
                    and(FSFicheSaisie.TableauDetaiMouvement.Cells[3,R]=FSFicheSaisie.LabelRefArticle.Caption)
                    and(FSFicheSaisie.TableauDetaiMouvement.Cells[7,R]=FSFicheSaisie.EditPrixMouvement.Text)
                    then
                    begin
                         OKArticle:=true;
                         RowEditing:=R;
                         QteCalcule:=QteCalcule+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]);
                    end;
               end;
               R:=R+1;
          end;

          FSFicheSaisie.EditQuantiteMouvement.Text:=WithoutPoint(FSFicheSaisie.EditQuantiteMouvement.Text);
          FSFicheSaisie.EditQuantiteMouvement.Text:=Vergule(FSFicheSaisie.EditQuantiteMouvement.Text,FunctionNombreChiffreApresVerguleQte(FSFicheSaisie.EditQuantiteMouvement.Text,FSFicheSaisie.EditUniteMesure.Text,FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,FSFicheSaisie.RBNbrChiffreApresVerguleAutomatique.Checked),'C','');

          OKQteStock:=true;

          QteStckCalcule:=strtoreal(FSFicheSaisie.EditQuantiteStock.Text)-(QteCalcule-strtoreal(FSFicheSaisie.EditQuantiteMouvement.Text));

          if(FSFicheSaisie.EditSigneMouvement.Text='-')
          and(FSFicheSaisie.RBAutoriserVide.Checked=false)then
          begin
              if(FSFicheSaisie.EditUniteMesure.Text<>'Pst')
              and(QteCalcule>strtoreal(FSFicheSaisie.EditQuantiteStock.Text))
              then
              begin
                   OKQteStock:=false;
                   
                   showmessage('La quantité réstante est insufusante ! {Quantité Stock='+Vergule(floattostr(QteStckCalcule),'2','C','')+' '+FSFicheSaisie.LabelUniteMusure.Caption+'}');

                   FSFicheSaisie.EditQuantiteMouvement.Text:='';
                   
                   if(QteStckCalcule>0)then
                   begin
                        if(FSFicheSaisie.AfficheDetailMouvement.Visible=true)
                        then FSFicheSaisie.EditQuantiteMouvement.SetFocus
                        else FSFicheSaisie.TableauDetaiMouvement.SetFocus;
                   end
                   else
                   begin
                        FSFicheSaisie.AfficheDetailMouvement.Visible:=false;
                        FSFicheSaisie.TableauDetaiMouvement.SetFocus;
                   end;
              FSFicheSaisie.TableauDetaiMouvement.Rows[FSFicheSaisie.TableauDetaiMouvement.Row].Text:='';
              end;
          end;

          if(OKQteStock=true)
          and(FSFicheSaisie.AfficheDetailMouvement.Visible=true)then
          begin
              if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)
              then FSFicheSaisie.BitOptionDetailMouvementClick(FSFicheSaisie.BitOptionDetailMouvement)
              else FSFicheSaisie.EditUniteMesure.SetFocus;
          end
          else FSFicheSaisie.TableauDetaiMouvement.SetFocus;
     end;
end;

