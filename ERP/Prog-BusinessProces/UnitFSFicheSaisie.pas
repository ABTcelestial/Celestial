Procedure ReindixationPositionListeMouvement;
var i:integer; TypeProces,FichierConcerne,Adresse:string;  valeurLast,ValeurNext,SoldeTransfert:real;
begin
     PointeurListeMouvement:=TList.Create;

     TypeProces:='Business';
     FichierConcerne:='FListeMouvement';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChListeMouvementCopie:=Adresse+' '+'Transfert';
     assignfile(FListeMouvementCopie,ChListeMouvementCopie);
     try
     if FileExists(ChListeMouvementCopie)then
     Reset(FListeMouvementCopie)
     else Rewrite(FListeMouvementCopie); //création nouveau fichier
     Seek(FListeMouvementCopie,0);
     Truncate(FListeMouvementCopie);

     ChListeMouvement:=Adresse;
     assignfile(FListeMouvement,ChListeMouvement);
     if FileExists(ChListeMouvement)then
     begin
           try
           Reset(FListeMouvement);
           Seek(FListeMouvement,0);
           i:=0;
           valeurLast:=0;
           while not eof(FListeMouvement)do
           begin
                read(FListeMouvement,RListeMouvement);
                if(RListeMouvement.ValidationListeMouvement=true)then
                begin
                     valeurLast:=valeurLast+RListeMouvement.MontantMouvement;
                     RegistrePointeurListeMouvement:=TRegistrePointeurListeMouvement.Create;
                     RegistrePointeurListeMouvement.PositionInitiale:=i;
                     RegistrePointeurListeMouvement.CodeTrie:=MidelLaters(RListeMouvement.DateMouvement,7,10)+MidelLaters(RListeMouvement.DateMouvement,4,5)+MidelLaters(RListeMouvement.DateMouvement,1,2)+Completezerogauche(inttostr(RListeMouvement.NumListeMouvement),'5');
                     PointeurListeMouvement.Add(RegistrePointeurListeMouvement);
                end;
           i:=i+1;
           end;

           PointeurListeMouvement.Sort(TriePointeurListeMouvementStringPlus);

           Seek(FListeMouvementCopie,0);
           ValeurNext:=0;
           for i:=0 to PointeurListeMouvement.Count-1 do
           begin
                Seek(FListeMouvement,TRegistrePointeurListeMouvement(PointeurListeMouvement[i]).PositionInitiale);
                read(FListeMouvement,RListeMouvement);
                ValeurNext:=ValeurNext+RListeMouvement.MontantMouvement;
                Seek(FListeMouvementCopie,i);
                write(FListeMouvementCopie,RListeMouvement);
           end;
           finally
           CloseFile(FListeMouvement);
           end;
     end;

     finally
     CloseFile(FListeMouvementCopie);
     end;
     

     SoldeTransfert:=ValePrecis(valeurLast,2)-ValePrecis(ValeurNext,2);

     FSFicheSaisie.AfficheResultatReindixationListeMouvement.Caption:='Valeure avant: '+Vergule(floattostr(valeurLast),'2','C','')+' Valeure aprés: '+Vergule(floattostr(ValeurNext),'2','C','')+' ecart: '+Vergule(floattostr(SoldeTransfert),'2','C','');

     if(SoldeTransfert=0)
     then FSFicheSaisie.AfficheResultatReindixationListeMouvement.Color:=clLime
     else FSFicheSaisie.AfficheResultatReindixationListeMouvement.Color:=clYellow;

     LibererMemoireProcessus('BusinessProces.exe',true);

     ValiderReindixationPositionListeMouvement;
end;

Procedure ValiderReindixationPositionListeMouvement;
var  i,PBegin,PEnd:integer;   TypeProces,FichierConcerne,Adresse,TypeProcesDM,FichierConcerneDM,AdresseDM,TypeProcesReseauxDM,AdresseLocal,NomDossierPartageOut,EmlacementLocalOuReseauxOut,AdresseFMouvementArchive:string;
begin
     TypeProces:='Business';
     FichierConcerne:='FListeMouvement';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
