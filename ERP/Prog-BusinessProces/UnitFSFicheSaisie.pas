     begin
          FSFicheSaisie.AfficheDataCibleDetailMouvement.Visible:=true;
          FSFicheSaisie.EditCodeAutorisation.Text:='';
     end;

     if(FSFicheSaisie.EditCodeAutorisation.Text='000')then
     begin
