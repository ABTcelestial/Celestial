Procedure FinancePeriodique(TableauListeMouvementSource,TableauListeMouvementPeriodique,TableauFinancePeriodique:TStringGrid; CodeUtilisateur,NumLMBegin,NumLMEnd,DateLMBegin,DateLMEnd,HeureLMBegin,HeureLMEnd:string);
var   R,C,l,RTFP:integer;  OKType,OKLM:boolean;   MontantTotal:real;   NotCol:string;
begin
     TableauListeMouvementPeriodique.ColCount:=TableauListeMouvementSource.ColCount;
     TableauListeMouvementPeriodique.RowCount:=2;
     TableauListeMouvementPeriodique.Rows[0].Text:=TableauListeMouvementSource.Rows[0].Text;
     TableauListeMouvementPeriodique.Rows[1].Text:='';

     l:=0;
     R:=1;
     while(R<=TableauListeMouvementSource.RowCount-1)do
     begin
          OKLM:=true;

          if(OKLM=true)then
          begin
               if(CodeUtilisateur<>'')then
               begin
                    if(TableauListeMouvementSource.Cells[41,R]>=CodeUtilisateur)
                    then OKLM:=true
                    else OKLM:=false;
               end;
          end;

          if(OKLM=true)then
          begin
               if(NumLMBegin<>'')then
               begin
                    if(strtointeger(TableauListeMouvementSource.Cells[2,R])>=strtointeger(NumLMBegin))
                    then OKLM:=true
                    else OKLM:=false;
               end;
          end;

          if(OKLM=true)then
          begin
               if(NumLMEnd<>'')then
               begin
                    if(strtointeger(TableauListeMouvementSource.Cells[2,R])<=strtointeger(NumLMEnd))
                    then OKLM:=true
                    else OKLM:=false;
               end;
          end;

          if(OKLM=true)then
          begin
               if(Datecorrecte(DateLMBegin)and(Datecorrecte(TableauListeMouvementSource.Cells[50,R])))then
               begin
                    if(strtodate(TableauListeMouvementSource.Cells[50,R])>=strtodate(DateLMBegin))
                    then OKLM:=true
                    else OKLM:=false;
               end
               else if(FSFicheSaisie.RBAfficheCacheDate.Checked=true)and(Datecorrecte(TableauListeMouvementSource.Cells[50,R])=false)then OKLM:=false;
          end;

          if(OKLM=true)then
          begin
               if(Datecorrecte(DateLMEnd)and(Datecorrecte(TableauListeMouvementSource.Cells[50,R])))then
               begin
                    if(strtodate(TableauListeMouvementSource.Cells[50,R])<=strtodate(DateLMEnd))
                    then OKLM:=true
                    else OKLM:=false;
               end
               else if(FSFicheSaisie.RBAfficheCacheDate.Checked=true)and(Datecorrecte(TableauListeMouvementSource.Cells[50,R])=false)then OKLM:=false;
          end;

          if(OKLM=true)then
          begin
               if(TimeCorrecte(HeureLMBegin)and(TimeCorrecte(TableauListeMouvementSource.Cells[51,R])))then
               begin
                    if(strtotime(TableauListeMouvementSource.Cells[51,R])>=strtotime(HeureLMBegin))
                    then OKLM:=true
                    else OKLM:=false;
               end
               else if(FSFicheSaisie.RBAfficheCacheHeure.Checked=true)and(TimeCorrecte(TableauListeMouvementSource.Cells[51,R])=false)then OKLM:=false;
          end;

          if(OKLM=true)then
          begin
               if(TimeCorrecte(HeureLMEnd)and(TimeCorrecte(TableauListeMouvementSource.Cells[51,R])))then
               begin
                    if(strtotime(TableauListeMouvementSource.Cells[51,R])<=strtotime(HeureLMEnd))
                    then OKLM:=true
                    else OKLM:=false;
               end
               else if(FSFicheSaisie.RBAfficheCacheHeure.Checked=true)and(TimeCorrecte(TableauListeMouvementSource.Cells[51,R])=false)then OKLM:=false;
          end;

          if(OKLM=true)then
          begin
               l:=l+1;
               TableauListeMouvementPeriodique.Rows[l].Text:=TableauListeMouvementSource.Rows[R].Text;
          end;
     R:=R+1;
     end;

     if(l>0)then TableauListeMouvementPeriodique.RowCount:=l+1
            else TableauListeMouvementPeriodique.RowCount:=2;

     TrierTableauARowSpecial(TableauListeMouvementPeriodique,1,TableauListeMouvementPeriodique.RowCount-1,1,'27','','+');

     NotCol:='1;3;4;6-8;12-26;28-54';

     for C:=1 to TableauListeMouvementPeriodique.ColCount-1 do
     if ExisteNumInTexte(inttostr(C),NotCol)then TableauListeMouvementPeriodique.ColWidths[C]:=0;

     AjusterColWidth(TableauListeMouvementPeriodique,'',NotCol);

     TableauFinancePeriodique.ColCount:=3;
     TableauFinancePeriodique.Cols[0].Text:='Nbr pičce';
     TableauFinancePeriodique.Cols[1].Text:='Type payement';
     TableauFinancePeriodique.Cols[2].Text:='Montant';

     TableauFinancePeriodique.RowCount:=2;
     TableauFinancePeriodique.Rows[1].Text:='';

     RTFP:=0;
     R:=1;
     MontantTotal:=0;
     while(R<=TableauListeMouvementPeriodique.RowCount-1)do
     begin
          l:=1;
          OKType:=false;
          while(l<=RTFP)and(OKType=false)do
          begin
               if(TableauFinancePeriodique.Cells[1,l]=TableauListeMouvementPeriodique.Cells[27,R])then
               begin
                    OKType:=true;
                    TableauFinancePeriodique.Cells[0,l]:=inttostr(strtointeger(TableauFinancePeriodique.Cells[0,l])+1);
                    TableauFinancePeriodique.Cells[2,l]:=floattostr(strtoreal(TableauFinancePeriodique.Cells[2,l])+strtoreal(TableauListeMouvementPeriodique.Cells[11,R]));
               end;
          l:=l+1
          end;

          if(OKType=false)then
          begin
               RTFP:=RTFP+1;
               TableauFinancePeriodique.Rows[RTFP].Text:='1';
               TableauFinancePeriodique.Cells[1,RTFP]:=TableauListeMouvementPeriodique.Cells[27,R];
               TableauFinancePeriodique.Cells[2,RTFP]:=TableauListeMouvementPeriodique.Cells[11,R];
          end;

          MontantTotal:=MontantTotal+strtoreal(TableauListeMouvementPeriodique.Cells[11,R]);
     R:=R+1;
     end;

     if(RTFP>0)then
               begin
                    TableauFinancePeriodique.RowCount:=RTFP+3;
                    TableauFinancePeriodique.Rows[RTFP+1].Text:='';
                    TableauFinancePeriodique.Rows[RTFP+2].Text:='';

                    TableauFinancePeriodique.Cells[1,RTFP+2]:='Total';
                    TableauFinancePeriodique.Cells[2,RTFP+2]:=floattostr(MontantTotal);

                    l:=1;
                    while(l<=TableauFinancePeriodique.RowCount-1)do
                    begin
                         if(TableauFinancePeriodique.Cells[2,l]<>'')
                         then TableauFinancePeriodique.Cells[2,l]:=Vergule(TableauFinancePeriodique.Cells[2,l],'2','C','');
                    l:=l+1;
                    end;
               end
               else TableauFinancePeriodique.RowCount:=2;

     

     AjusterColWidth(TableauFinancePeriodique,'','');
end;

