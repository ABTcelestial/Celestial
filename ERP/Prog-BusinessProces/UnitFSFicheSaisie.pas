Function ControleDateExecutionAlerte(TableauListeMouvement:TStringGrid; TypeProces,ActionSourceAlerte,ExecuterNonExecuter:string; AfficherValeursMonetaires,AfficherTotal:boolean; var ValeurAlerte:integer; var UniteDureeAlerte,DateExecutionPrevue,HeureExecutionPrevue:string):boolean;
var R,C,RubriqueTrie:integer; NotRow,NotCol,TypeProcesCherche,FichierConserneCherche,AdresseCherche,TypeProcesMouvement,FichierConserneMouvement,AdresseMouvement,PositionTypeMouvement:string;
    OKListeMouvement,OKAlerte:boolean;
    TotalGeneral:real;
begin
     TypeProcesMouvement:='Business';   FichierConserneMouvement:='FMouvement';
     if not(FunctionAdresseProces(TypeProcesMouvement,FichierConserneMouvement,'',AdresseMouvement,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConserneMouvement<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneMouvement+' recherché !');
     end;

     PositionTypeMouvement:='';
     if(PositionTypeMouvement<>'')
     then ChMouvement:=IndiqueAdresseMouvement(PositionTypeMouvement,TypeProcesReseaux)
     else ChMouvement:=AdresseMouvement;
     assignfile(FMouvement,ChMouvement);
     OKAlerte:=false;
     if FileExists(ChMouvement)then
     begin
          Try
          Reset(FMouvement);
          Seek(FMouvement,0);
          while(not eof(FMouvement))and(OKAlerte=false)do
          begin
               Read(FMouvement,RMouvement);
               OKAlerte:=RMouvement.AvecDateExecution;
          end;
     finally
     CloseFile(FMouvement);
     end;
     end;

     if(OKAlerte=true)then
     begin
           AccelerationAffichageTableau(TableauListeMouvement,true);

           TableauListeMouvement.ColCount:=24;
           TableauListeMouvement.RowCount:=2;
           TableauListeMouvement.Rows[1].Text:='';
           TableauListeMouvement.Cols[0].Text:='N°';
           TableauListeMouvement.Cols[1].Text:='Ordre';
           TableauListeMouvement.Cols[2].Text:='Num';
           TableauListeMouvement.Cols[3].Text:='P°TM';
           TableauListeMouvement.Cols[4].Text:='P°M';
           TableauListeMouvement.Cols[5].Text:='Date.Etablis.';
           TableauListeMouvement.Cols[6].Text:='Code Type F';
           TableauListeMouvement.Cols[7].Text:='Type Proc';
           TableauListeMouvement.Cols[8].Text:='Fichier Tičrs Consern';
           TableauListeMouvement.Cols[9].Text:='Code Tiers';
           TableauListeMouvement.Cols[10].Text:='Tiers';
           TableauListeMouvement.Cols[11].Text:='Montant Mouvement';
           TableauListeMouvement.Cols[12].Text:='Date Exécution';
           TableauListeMouvement.Cols[13].Text:='C°Payés';
           TableauListeMouvement.Cols[14].Text:='Payés';
           TableauListeMouvement.Cols[15].Text:='C°Wilaya';
           TableauListeMouvement.Cols[16].Text:='Wilaya';
           TableauListeMouvement.Cols[17].Text:='C°Daira';
           TableauListeMouvement.Cols[18].Text:='Daira';
           TableauListeMouvement.Cols[19].Text:='C°Commune';
           TableauListeMouvement.Cols[20].Text:='Commune';
           TableauListeMouvement.Cols[21].Text:='Adresse';
           TableauListeMouvement.Cols[22].Text:='Exécution !';
           TableauListeMouvement.Cols[23].Text:='Adresse';

           OpenFParc(RParc);
           ChTempsAlerteAvantAction:=RParc.Parcours+'\'+Exercice+'TempsAlerteAvantAction';
           assignfile(FTempsAlerteAvantAction,ChTempsAlerteAvantAction);
           try
           if FileExists(ChTempsAlerteAvantAction)then
           Reset(FTempsAlerteAvantAction)
           else begin affichermessage('Attention ! {'+ChTempsAlerteAvantAction+'} n''existe pas !'); exit; end;//Rewrite(FTempsAlerteAvantAction);
           Seek(FTempsAlerteAvantAction,0);
           OKAlerte:=false;
           ValeurAlerte:=0;
           UniteDureeAlerte:='Jours';
           DateExecutionPrevue:=datetostr(date);
           HeureExecutionPrevue:='08:00:00';
           while not eof(FTempsAlerteAvantAction)and(OKAlerte=false)do
           begin
                read(FTempsAlerteAvantAction,RTempsAlerteAvantAction);
                if(RTempsAlerteAvantAction.TypeProces=TypeProces)
                and(RTempsAlerteAvantAction.ActionSourceAlerte=ActionSourceAlerte)
                then
                begin
                     OKAlerte:=true;
                     ValeurAlerte:=RTempsAlerteAvantAction.ValeurTempsAlerte;
                     UniteDureeAlerte:=RTempsAlerteAvantAction.UniteTempsAlerte;
                     PrevoirDateHeure(datetostr(date),'08:00:00',ValeurAlerte,UniteDureeAlerte,DateExecutionPrevue,HeureExecutionPrevue);
                end;
           end;
           finally
           CloseFile(FTempsAlerteAvantAction);
           end;

           if(OKAlerte=true)then
           begin
                TypeProcesCherche:='Business';   FichierConserneCherche:='FListeMouvement';
                if not(FunctionAdresseProces(TypeProcesCherche,FichierConserneCherche,'',AdresseCherche,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                begin
                     AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneCherche+' recherché !');
                end;

                ChListeMouvement:=IndiqueAdresseListeMouvement('',TypeProcesReseauxListeMouvement);
                assignfile(FListeMouvement,ChListeMouvement);
                try
                if FileExists(ChListeMouvement)then
                Reset(FListeMouvement)
                else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
                Seek(FListeMouvement,0);
                TotalGeneral:=0;
                R:=0;
                while not eof(FListeMouvement)do
                begin
                     read(FListeMouvement,RListeMouvement); Application.ProcessMessages;
                     RMouvement:=ChercherMouvement(inttostr(RListeMouvement.PositionTypeMouvement),RListeMouvement.PositionMouvement,AdresseFichierConcerne);

                     if(RMouvement.AvecDateExecution=true)then
                     begin
                          if(ExecuterNonExecuter='Tous')or(ExecuterNonExecuter='')then OKListeMouvement:=true
                          else
                          if(strtoboolean(ExecuterNonExecuter)=RListeMouvement.OKExecution)then OKListeMouvement:=true;

                          if(OKListeMouvement=true)then
                          begin
                               if(datecorrecte(DateExecutionPrevue)and datecorrecte(RListeMouvement.DateExecutionMouvement))then
                               begin
                                    if(strtodate(RListeMouvement.DateExecutionMouvement)<=strtodate(DateExecutionPrevue))
                                    then OKListeMouvement:=true
                                    else OKListeMouvement:=false;
                               end;
                          end;
                     end
                     else OKListeMouvement:=false;

                     if(OKListeMouvement=true)then
                     begin
                          R:=R+1;
                          TableauListeMouvement.Rows[R].Text:=inttostr(R);
                          TableauListeMouvement.Cells[1,R]:=inttostr(RListeMouvement.OrdreListeMouvement);
                          TableauListeMouvement.Cells[2,R]:=inttostr(RListeMouvement.NumListeMouvement);
                          TableauListeMouvement.Cells[3,R]:=inttostr(RListeMouvement.PositionTypeMouvement);
                          TableauListeMouvement.Cells[4,R]:=inttostr(RListeMouvement.PositionMouvement);
                          TableauListeMouvement.Cells[5,R]:=RListeMouvement.DateMouvement;
                          TableauListeMouvement.Cells[6,R]:=RListeMouvement.CodeTypeFormule;
                          TableauListeMouvement.Cells[7,R]:=RListeMouvement.TypeProces;
                          TableauListeMouvement.Cells[8,R]:=RListeMouvement.FichierTiersConserne;
                          TableauListeMouvement.Cells[9,R]:=RListeMouvement.CodeTiers;
                          RTier:=ChercherTiers(RListeMouvement.TypeProces,RListeMouvement.FichierTiersConserne,RListeMouvement.CodeTiers,'');
                          TableauListeMouvement.Cells[10,R]:=RTier.NomTiers+' '+RTier.PrenomTiers;
                          TableauListeMouvement.Cells[11,R]:=Vergule(floattostr(RListeMouvement.MontantMouvement),'2','C','');
                          TableauListeMouvement.Cells[12,R]:=RListeMouvement.DateExecutionMouvement;
                          TableauListeMouvement.Cells[13,R]:=RListeMouvement.CodePaysExecutionMouvement;
                          TableauListeMouvement.Cells[14,R]:=ChercherLocalisationGeographique(RListeMouvement.CodePaysExecutionMouvement,'FPays').IntitulleLocalisationGeographique;
                          TableauListeMouvement.Cells[15,R]:=RListeMouvement.CodeWilayaExecutionMouvement;
                          TableauListeMouvement.Cells[16,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeWilayaExecutionMouvement,'FWilaya').IntitulleLocalisationGeographique;
                          TableauListeMouvement.Cells[17,R]:=RListeMouvement.CodeDairaExecutionMouvement;
                          TableauListeMouvement.Cells[18,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeDairaExecutionMouvement,'FDaira').IntitulleLocalisationGeographique;
                          TableauListeMouvement.Cells[19,R]:=RListeMouvement.CodeCommuneExecutionMouvement;
                          TableauListeMouvement.Cells[20,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeCommuneExecutionMouvement,'FCommune').IntitulleLocalisationGeographique;
                          TableauListeMouvement.Cells[21,R]:=RListeMouvement.AdresseExecutionMouvement;
                          TableauListeMouvement.Cells[22,R]:=booleantostr(RListeMouvement.OKExecution);
                          TableauListeMouvement.Cells[23,R]:=RListeMouvement.AdresseExecutionMouvement;

                          if(AfficherTotal=true)and(AfficherValeursMonetaires=true)
                          then TotalGeneral:=TotalGeneral+RListeMouvement.MontantMouvement;
                     end;
                end;
                finally
                CloseFile(FListeMouvement);
                end;

                if(R>0)then
                       begin
                            ControleDateExecutionAlerte:=true;
                            if(AfficherTotal=true)and(AfficherValeursMonetaires=true)then
                            begin
                                 TableauListeMouvement.RowCount:=R+3;
                                 TableauListeMouvement.Cells[11,TableauListeMouvement.RowCount-2]:='';
                                 TableauListeMouvement.Cells[10,TableauListeMouvement.RowCount-1]:='Total:';
                                 TableauListeMouvement.Cells[11,TableauListeMouvement.RowCount-1]:=Vergule(floattostr(TotalGeneral),'2','C','');;
                            end
                            else TableauListeMouvement.RowCount:=R+1;
                       end
                       else
                       begin
                            ControleDateExecutionAlerte:=false;
                            TableauListeMouvement.RowCount:=2;
                       end;

                NotRow:='';

                if(AfficherValeursMonetaires=false)
                then NotCol:='1-4;6-8;11;13;15;17;19'
                else NotCol:='1-4;6-8;13;15;17;19';

                for C:=1 to TableauListeMouvement.ColCount-1 do
                if ExisteNumInTexte(inttostr(C),NotCol)then TableauListeMouvement.ColWidths[C]:=0;
                AjusterColWidth(TableauListeMouvement,NotRow,NotCol);

                RubriqueTrie:=12;
                if(R>0)then TrierTableauARowSpecial(TableauListeMouvement,1,TableauListeMouvement.RowCount-1,1,inttostr(RubriqueTrie),'Date','+');
           end
           else
           begin
                ControleDateExecutionAlerte:=false;
           end;

           AccelerationAffichageTableau(TableauListeMouvement,false);
     end;
end;

Function  ControleEnregistrementMouvement:boolean;
var  R:integer;    OKEnregistrement:boolean;
begin
     OKEnregistrement:=true;
     if(FSFicheSaisie.EditNumListeMouvement.Text<>'')then
     begin
          R:=1;
          while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OKEnregistrement=true)do
          begin
               if(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R]='')
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]<>'')
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R]<>'')
               then
               begin
                    OKEnregistrement:=false;
                    FSFicheSaisie.TableauDetaiMouvement.Col:=1;
                    FSFicheSaisie.TableauDetaiMouvement.Row:=R;
                    AfficherMessage('Veuillez terminer les opérations avant de quitter SVP !');
               end;
          R:=R+1;
          end;
     end;

     ControleEnregistrementMouvement:=OKEnregistrement;
end;

procedure TFSFicheSaisie.FormClose(Sender: TObject;
  var Action: TCloseAction);
begin
     if not ControleEnregistrementMouvement then Action:=caNone;

     ActiverNomForm(0,(Sender as TComponent).Name);
end;

