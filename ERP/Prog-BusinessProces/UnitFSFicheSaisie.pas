begin
      FSAvis.Show;

      FSAvis.RBPieceMaitenue.Checked:=true;

      FSAvis.EditDate.Enabled:=true;
      NouvelAvis;

      FSFicheSaisie.EditNumAvis.Text:=inttostr(strtointeger(FSAvis.EditNumAvis.Text));

