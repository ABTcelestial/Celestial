Procedure OperationAutoSelection(DateBegin,DateEnd:string);
var  i,R:integer; OKFichierConcerne:boolean;  AdresseMouvement:string;
begin
     if(DateBegin<>'')and(DateEnd<>'')then
     begin
          FSFicheSaisie.EditMontantGlobaleAppartenanceMouvement.Text:='';
          FSFicheSaisie.EditOrdreListeMouvementAppartenant.Text:='';

          ProcAfficheListePrelevementUFAppartenance(FSFicheSaisie.TableauListeAppartenanceMouvement,FSFicheSaisie.EditListeAppartenanceCodeMouvement.Text,DateBegin,DateEnd,FSFicheSaisie.EditExerciceSourceA.Text,FSFicheSaisie.EditCodeTiersConserne.Text,FSFicheSaisie.OptionAvecAvisAppartenanceMouvement.Text,0,R);

          ProcAfficheListeMouvementAppartenance(FSFicheSaisie.TableauListeAppartenanceMouvement,FSFicheSaisie.EditListeAppartenanceCodeMouvement.Text,DateBegin,DateEnd,FSFicheSaisie.EditExerciceSourceA.Text,FSFicheSaisie.EditCodeTiersConserne.Text,FSFicheSaisie.OptionAvecAvisAppartenanceMouvement.Text,R,R);
     end;

     FSFicheSaisie.TableauDetaiMouvementAppartenanceMouvemant.RowCount:=2;
     FSFicheSaisie.TableauDetaiMouvementAppartenanceMouvemant.Rows[1].Text:='';

     FSFicheSaisie.TableauPositionMouvement.ColCount:=1;
     FSFicheSaisie.TableauPositionMouvement.Cols[0].Text:='P°M';

     FSFicheSaisie.TableauPositionMouvement.RowCount:=2;
     FSFicheSaisie.TableauPositionMouvement.Rows[1].Text:='';
     R:=0;
     i:=0;
     while(i<=100)do
     begin
          if ExisteNumInTexte(inttostr(i),FSFicheSaisie.EditListeAppartenanceCodeMouvement.Text)then
          begin
               RMouvementCopie:=ChercherMouvement('',i,AdresseMouvement);
               RMouvementCopie:=ChercherMouvement(inttostr(RMouvementCopie.PositionTypeMouvement),i,AdresseMouvement);
               if FunctionFichierInclu(FSFicheSaisie.EditFunctionFichierConcerne.Text,RMouvementCopie.FichierTiersConserne)
               then OKFichierConcerne:=true
               else OKFichierConcerne:=false;

               if(OKFichierConcerne=true)then
               begin
                    R:=R+1;
                    FSFicheSaisie.TableauPositionMouvement.Rows[R].Text:=inttostr(i);
               end;
          end;
     i:=i+1;
     end;

     if(R>0)then FSFicheSaisie.TableauPositionMouvement.RowCount:=R+1
            else FSFicheSaisie.TableauPositionMouvement.RowCount:=2;

     if(DateBegin<>'')and(DateEnd<>'')then FSFicheSaisie.TableauListeAppartenanceMouvement.SetFocus;
end;

