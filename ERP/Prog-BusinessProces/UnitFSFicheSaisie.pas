Procedure ImprimerTicket;
var  R,l,TailleTotale,TailleDesignation,TailleUnitM,TailleQuantite,TaillePrixU,TailleMontant,NbrParType:integer;  NbrParProduit:real;
     OK:boolean; Designation,DesignationTeste,UnitM,Quantite,PrixU,Montant,ModePaiement,NumPiece,Domiciliation,TextePayement:string; Separateur:char;
     i,Nombre,Diviseur,Resultat,Reste:integer;
begin
     Separateur:=' ';
     ModePaiement:=FSFicheSaisie.EditModePayement.Text;
     Domiciliation:=FSFicheSaisie.EditDomiciliation.Text;
     NumPiece:=FSFicheSaisie.EditNumPiece.Text;

     TextePayement:='';
     if(ModePaiement<>'')then
     begin
          TextePayement:='Payement: '+ModePaiement
     end;
     if(Domiciliation<>'')then
     begin
          TextePayement:=TextePayement+' '+Domiciliation
     end;
     if(NumPiece<>'')then
     begin
          TextePayement:=TextePayement+' n° '+NumPiece
     end;

     {TailleTotale:=48;
     TailleUnitM:=3;
     TailleQuantite:=6;
     TaillePrixU:=10;
     TailleMontant:=10;
     TailleDesignation:=TailleTotale-TailleUnitM-TailleQuantite-TaillePrixU-TailleMontant;}

     TailleTotale:=-1;
     TailleUnitM:=-1;
     TailleQuantite:=-1;
     TaillePrixU:=-1;
     TailleMontant:=-1;
     TailleDesignation:=-1;

     if(FSTicketTexte.RBInclureTailleTotale.Checked=true)then TailleTotale:=FSTicketTexte.IncrimenteEditTailleTotale.Position;
     if(FSTicketTexte.RBInclureTailleUnitM.Checked=true)then TailleUnitM:=FSTicketTexte.IncrimenteEditTailleUnitM.Position;
     if(FSTicketTexte.RBInclureTailleQuantite.Checked=true)then TailleQuantite:=FSTicketTexte.IncrimenteEditTailleQuantite.Position;
     if(FSTicketTexte.RBInclureTaillePrixU.Checked=true)then TaillePrixU:=FSTicketTexte.IncrimenteEditTaillePrixU.Position;
     if(FSTicketTexte.RBInclureTailleMontant.Checked=true)then TailleMontant:=FSTicketTexte.IncrimenteEditTailleMontant.Position;
     if(FSTicketTexte.RBInclureTailleDesignation.Checked=true)then TailleDesignation:=FSTicketTexte.IncrimenteEditTailleDesignation.Position;
                     
R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
     if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
     then
