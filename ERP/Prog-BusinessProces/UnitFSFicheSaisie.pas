Function ControleNextFicheSaisie(EditClasse:TEdit):boolean;
begin
     ControleNextFicheSaisie:=true;
     if(EditClasse<>FSFicheSaisie.ClasseDetailMouvement)then if(strtointeger(FSFicheSaisie.ClasseDetailMouvement.Text)>strtointeger(EditClasse.Text))then if(FSFicheSaisie.RBDetailMouvement.Checked=true)then ControleNextFicheSaisie:=false;
     if(EditClasse<>FSFicheSaisie.ClasseRecapeMouvement)then if(strtointeger(FSFicheSaisie.ClasseRecapeMouvement.Text)>strtointeger(EditClasse.Text))then if(FSFicheSaisie.RBRecapeMouvement.Checked=true)then ControleNextFicheSaisie:=false;
end;

Procedure NumClasseFicheSaisie(EditClasse:TEdit; OKClassement:boolean);
var   Ordre:integer;
begin

if(OKClassement=true)then
begin
     Ordre:=0;
     if(EditClasse<>FSFicheSaisie.ClasseDetailMouvement)then if(Ordre<=strtointeger(FSFicheSaisie.ClasseDetailMouvement.Text))then Ordre:=strtointeger(FSFicheSaisie.ClasseDetailMouvement.Text)+1;
     if(EditClasse<>FSFicheSaisie.ClasseRecapeMouvement)then if(Ordre<=strtointeger(FSFicheSaisie.ClasseRecapeMouvement.Text))then Ordre:=strtointeger(FSFicheSaisie.ClasseRecapeMouvement.Text)+1;

     EditClasse.Text:=inttostr(Ordre);
end
else
begin
     Ordre:=strtointeger(EditClasse.Text);
     EditClasse.Text:='';
     if(EditClasse<>FSFicheSaisie.ClasseDetailMouvement)then if(strtointeger(FSFicheSaisie.ClasseDetailMouvement.Text)>Ordre)then FSFicheSaisie.ClasseDetailMouvement.Text:=inttostr(strtointeger(FSFicheSaisie.ClasseDetailMouvement.Text)-1);
     if(EditClasse<>FSFicheSaisie.ClasseRecapeMouvement)then if(strtointeger(FSFicheSaisie.ClasseRecapeMouvement.Text)>Ordre)then FSFicheSaisie.ClasseRecapeMouvement.Text:=inttostr(strtointeger(FSFicheSaisie.ClasseRecapeMouvement.Text)-1);
end;

end;

Function ControleNumDetailMouvement(EditNumDetailMouvement:TEdit):boolean;
var  TypeAffichage,DateMouvementDebut,DateMouvementFin,OKExecution:string;
begin
     TypeAffichage:='Edition';
     if(strtointeger(EditNumDetailMouvement.Text)=0)then
     begin
          FSFicheSaisie.RBSuspendreTraitement.Checked:=true;
          
          ControleNumDetailMouvement:=false;
          EditNumDetailMouvement.SetFocus;
          showmessage('Veuillez choisir une opération SVP !');
          OuvrirOptionDetailMouvement;
          DetailPeriodeListeMouvement(FSFicheSaisie.RBListeDetailMouvementParDate,FSFicheSaisie.RBListeDetailMouvementParMois,DateMouvementDebut,DateMouvementFin);
          OKExecution:='';

          ProcAfficheListeMouvementPointeur(FSFicheSaisie.TableauListeMouvement,FSFicheSaisie.EditPositionTypeMouvement.Text,FSFicheSaisie.EditPositionMouvement.Text,FSFicheSaisie.EditPositionListeMouvementBegin.Text,FSFicheSaisie.EditPositionListeMouvementEnd.Text,DateMouvementDebut,DateMouvementFin,'','','','','',OKExecution,'','',FSFicheSaisie.RBChargerPointeurListeMouvement.Checked,false,FSFicheSaisie.RBChargerPointeurListeMouvement.Checked,FSFicheSaisie.RBAfficherValeurNulle.Checked,FSFicheSaisie.RBAfficherInfoTiersSupplementaire.Checked,FSFicheSaisie.RBUtiliserIndexation.Checked,'');
     end
     else ControleNumDetailMouvement:=true;
end;

Procedure InitialisationFicheSaisie(InitialisationProjet,InitialisationTypeMouvement,InitialisationMouvement,InitialisationTiers,InitialisationTableauDetailleMouvement,InitialisationData:boolean);
begin
     FSFicheSaisie.AfficherOperationDetailMouvement.Visible:=false;
     FSFicheSaisie.TableauTypeMouvement.Visible:=false;
     FSFicheSaisie.TableauMouvement.Visible:=false;
     FSFicheSaisie.TableauTypeFormule.Visible:=false;
     FSFicheSaisie.AfficheTableauTiersConserne.Visible:=false;
     FSFicheSaisie.TableauCompteConcerne.Visible:=false;
     FSFicheSaisie.AfficheDetailMouvement.Visible:=false;
     FSFicheSaisie.AfficheListeAvis.Visible:=false;
     FSFicheSaisie.AfficheListeAppartenanceMouvement.Visible:=false;

     if(InitialisationData=true)then
     begin
          FSFicheSaisie.EditOrdreListeMouvement.Text:='';
