procedure TFSFicheSaisie.TimerClickTableauListeMouvementTimer(
  Sender: TObject);
var  R:integer; OKDetailMouvementNonEnregistre:boolean;
     TypeData,TexteFicheSaisie:string;
begin
     FSFicheSaisie.TimerClickTableauListeMouvement.Enabled:=false;

     FSFicheSaisie.EditModeSelection.Text:='Affichage';

     if(FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text='-1')then Exit;

     if(FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text<>'0')then Exit;

     if(GetTickCount-TimeKeyUp<FSFicheSaisie.TimerClickTableauListeMouvement.Interval-5)then
     begin
          if(strtointeger(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row])<>strtointeger(FSFicheSaisie.EditOrdreListeMouvement.Text))
          then FSFicheSaisie.TableauListeMouvementClick(FSFicheSaisie.TableauListeMouvement);
          Exit;
     end;

     FSFicheSaisie.AfficheListeMouvementPeriodique.Visible:=false;
     FSFicheSaisie.RBModificationPontBascule.Checked:=false;

     FSFicheSaisie.AffichePrintBordereauRemiseCodeBarre.Visible:=false;
     FSFicheSaisie.TimerPontBascule.Enabled:=false;
     FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text:=FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditMatriculePontBascule.Text:=FSFicheSaisie.TableauListeMouvement.Cells[42,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditTypeVehiculePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[43,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditTonageVehiculePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[44,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditCodeResponsablePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[45,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditNomResponsablePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[46,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditPrenomResponsablePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[47,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditIndiceInialPontBascule.Text:=FSFicheSaisie.TableauListeMouvement.Cells[48,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditIndiceFinalPontBascule.Text:=FSFicheSaisie.TableauListeMouvement.Cells[49,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditIndiceCalculePontBascule.Text:=Vergule(floattostr(strtoreal(FSFicheSaisie.EditIndiceFinalPontBascule.Text)-
                                                                              strtoreal(FSFicheSaisie.EditIndiceInialPontBascule.Text)),FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,'C','');

     FSFicheSaisie.EditDateIndiceInitial.Text:=FSFicheSaisie.TableauListeMouvement.Cells[50,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditHeureIndiceInitial.Text:=FSFicheSaisie.TableauListeMouvement.Cells[51,FSFicheSaisie.TableauListeMouvement.Row];

     RUtilisateurCopie:=ChercherUtilisateur(FSFicheSaisie.TableauListeMouvement.Cells[41,FSFicheSaisie.TableauListeMouvement.Row]);
     FSFicheSaisie.InfoUtilisateurDateHeure.Caption:='Utilisateur: '+RUtilisateurCopie.Nom+' '+RUtilisateurCopie.Prenom+'. '+
                                                     'le: '+FSFicheSaisie.TableauListeMouvement.Cells[50,FSFicheSaisie.TableauListeMouvement.Row]+'. '+
                                                     'ŕ: '+FSFicheSaisie.TableauListeMouvement.Cells[51,FSFicheSaisie.TableauListeMouvement.Row]+'. ';

     if(datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[52,FSFicheSaisie.TableauListeMouvement.Row]))
     then FSFicheSaisie.EditDateIndiceFinal.Date:=stringtodate(FSFicheSaisie.TableauListeMouvement.Cells[52,FSFicheSaisie.TableauListeMouvement.Row],'')
     else FSFicheSaisie.EditDateIndiceFinal.Date:=date;
     if(timecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[53,FSFicheSaisie.TableauListeMouvement.Row]))
     then FSFicheSaisie.EditHeureIndiceFinal.Time:=strtotime(FSFicheSaisie.TableauListeMouvement.Cells[53,FSFicheSaisie.TableauListeMouvement.Row])
     else FSFicheSaisie.EditHeureIndiceFinal.Time:=time;

     FSFicheSaisie.EditNumeroPont.Text:=FSFicheSaisie.TableauListeMouvement.Cells[54,FSFicheSaisie.TableauListeMouvement.Row];
              
     if(FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text<>'-1')
     then FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text:='0';

     FSFicheSaisie.TableauChercherTiers.Visible:=false;
     FSFicheSaisie.TableauLocalisationGeographique.Visible:=false;

     if(FSFicheSaisie.RBActiveTableauListeMouvementClick.Checked=false)then
     begin
          Exit;
     end;

     R:=6;
     OKDetailMouvementNonEnregistre:=false;
     while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OKDetailMouvementNonEnregistre=false)do
     begin
          if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]<>'')
          and(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R]<>'')
          and(FSFicheSaisie.TableauDetaiMouvement.Cells[7,R]<>'')
          then
          begin // Controle Ligne non vide
               if(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R]='')then OKDetailMouvementNonEnregistre:=true;
          end;
     R:=R+1;
     end;

     if(OKDetailMouvementNonEnregistre=true)then
     begin
          FSFicheSaisie.RBActiveTableauListeMouvementClick.Checked:=false;
          FSFicheSaisie.TableauListeMouvement.Row:=strtointeger(FSFicheSaisie.TableauListeMouvement.Cells[0,0]);
          if nonoui('Des modifications opérées, voulez vous enregistrer ?')then
          begin
               BitValidationListeMouvementClick(FSFicheSaisie.BitValidationListeMouvement);
               FSFicheSaisie.RBActiveTableauListeMouvementClick.Checked:=true;
               Exit;
          end
          else FSFicheSaisie.RBActiveTableauListeMouvementClick.Checked:=true;
     end
     else FSFicheSaisie.RBActiveTableauListeMouvementClick.Checked:=true;

     FSFicheSaisie.TableauListeMouvement.Cells[0,0]:=inttostr(FSFicheSaisie.TableauListeMouvement.Row);

     if(FSFicheSaisie.RBListeDetailMouvementParMois.Checked=true)then
     begin
          if(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
          begin
               if(datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])=true)then
               begin
                    FSFicheSaisie.EditMois.ItemIndex:=strtointeger(Midellaters(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row],4,5))-1;
                    FSFicheSaisie.EditAnnee.Text:=Midellaters(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row],7,10);
               end
               else
               begin
                    FSFicheSaisie.EditMois.ItemIndex:=strtointeger(Midellaters(datetostr(date),4,5))-1;
                    FSFicheSaisie.EditAnnee.Text:=Midellaters(datetostr(date),7,10);
               end;
          end;
     end;

     if(FSFicheSaisie.RBListeDetailMouvementParDate.Checked=true)then
     begin
          if(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
          begin
               if(datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])=true)
               then FSFicheSaisie.EditChercheDateDetailMouvement.Date:=strtodate(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])
               else FSFicheSaisie.EditChercheDateDetailMouvement.Date:=date;
          end;
     end;

     if(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>'')
     and(datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])=true)
     and(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]<>'')
     then
     begin
          if(FSFicheSaisie.EditOrdreListeMouvement.Text<>FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row])
          or(
             (datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])=true)
              and(strtodate(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date))<>strtodate(TableauListeMouvement.Cells[5,TableauListeMouvement.Row]))
              )
          or(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]))
          then
          begin
               FSFicheSaisie.TableauLocalisationGeographique.Visible:=false;
               FSFicheSaisie.EditMontantMouvement.Text:='';
               FSFicheSaisie.EditNumAvis.Text:='';
               //FSFicheSaisie.RBSuspendreDetailMouvement.Checked:=true;

               {while(GetTickCount-TimeKeyUp<100)do
               begin
                     Application.ProcessMessages;
               end;
               FSFicheSaisie.TimerImporterDetailListeMouvement.Enabled:=true;}

               FSFicheSaisie.TimerLancerImporterDetailListeMouvement.Enabled:=true;

               FSFicheSaisie.AfficheCliqueDroitTableauListeMouvement.Visible:=false;
          end;
     end
     else InitialisationFicheSaisie(true,false,false,true,true,true);
     
     if(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>FSFicheSaisie.EditLastOrdreImprimerPlusieursFois.Text)then
     begin
          FSFicheSaisie.EditEtatImprimerPlusieursFois.Text:='OK';
          FSFicheSaisie.EditLastOrdreImprimerPlusieursFois.Text:='';
     end;
end;

