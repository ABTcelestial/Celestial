            //-----------------------------Suite enregistrement liste mouvement-------------
            if(PositionDetailMouvementBegin=999999999)and(PositionDetailMouvementEnd=0)then begin PositionDetailMouvementBegin:=0; PositionDetailMouvementEnd:=999999999 end;
