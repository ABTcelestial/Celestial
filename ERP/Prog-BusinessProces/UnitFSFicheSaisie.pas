procedure TFSFicheSaisie.BitOptionDetailMouvementClick(Sender: TObject);
var  i,R,C,E,l,ARow,RowEditing:integer;
     Registre,RegistreCopie:Registres;
     Variable,Resultat,ListeColWidthsZero,NotRow,NotCol,PositionParametreTaxeAjouter:string;
     OKFormule,OKPositifMontant,OKArticle,OKOperation:boolean;
     QteCalcule,QteStckCalcule:real;
begin
FSFicheSaisie.RBControleExitQuatiteMouvement.Checked:=false;

OKOperation:=true;

if(strtoreal(FSFicheSaisie.EditQuantiteMouvement.Text)=0)then
begin
     showmessage('Veuillez saisire une valeur SVP !');
     if(FSFicheSaisie.AfficheDetailMouvement.Visible=true)then FSFicheSaisie.EditQuantiteMouvement.SetFocus;

     OKOperation:=false;
     Exit;
end;

if(FSFicheSaisie.EditSigneMouvement.Text='-')
and(FSFicheSaisie.RBAutoriserVide.Checked=false)then
begin
     QteCalcule:=strtoreal(FSFicheSaisie.EditQuantiteMouvement.Text);

     R:=6;
     OKArticle:=false;
     while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OKArticle=false)do
     begin
          if(R<>RowEditing)
          and(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R]='')
          then
          begin
               if (FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]=FSFicheSaisie.LabelCodeArticle.Caption)
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[2,R]=FSFicheSaisie.LabelDesignationArticle.Caption)
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[3,R]=FSFicheSaisie.LabelRefArticle.Caption)
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[7,R]=FSFicheSaisie.EditPrixMouvement.Text)
               then
               begin
                    OKArticle:=true;
                    RowEditing:=R;
                    QteCalcule:=QteCalcule+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]);
               end;
          end;
          R:=R+1;
     end;

     QteStckCalcule:=strtoreal(FSFicheSaisie.EditQuantiteStock.Text)-(QteCalcule-strtoreal(FSFicheSaisie.EditQuantiteMouvement.Text));

     if(FSFicheSaisie.EditUniteMesure.Text<>'Pst')
     and(QteCalcule>strtoreal(FSFicheSaisie.EditQuantiteStock.Text))
     then
     begin
          OKOperation:=false;
          showmessage('La quantité réstante est insufusante !{Quantité Stock='+Vergule(floattostr(QteStckCalcule),'2','C','')+' '+FSFicheSaisie.LabelUniteMusure.Caption+'}');

          if(QteStckCalcule>0)then
          begin
               if(FSFicheSaisie.AfficheDetailMouvement.Visible=true)then FSFicheSaisie.EditQuantiteMouvement.SetFocus;
               FSFicheSaisie.EditQuantiteMouvement.Text:='';
          end
          else
          begin
               FSFicheSaisie.AfficheDetailMouvement.Visible:=false;
               FSFicheSaisie.TableauDetaiMouvement.SetFocus;

          end;
     FSFicheSaisie.TableauDetaiMouvement.Rows[FSFicheSaisie.TableauDetaiMouvement.Row].Text:='';
     Exit;
     end;
end;

if(OKOperation=true)then
begin
     if(FSFicheSaisie.EditRowEditing.Text<>'')
     then RowEditing:=strtointeger(FSFicheSaisie.EditRowEditing.Text)
     else RowEditing:=FSFicheSaisie.TableauDetaiMouvement.Row;

     FSFicheSaisie.EditRowEditing.Text:='';

     if(FSFicheSaisie.RBActiverCalculePrixUnitaireParMHT.Checked=true)then
     begin
          FSFicheSaisie.EditPrixMouvement.Text:=floattostr(strtoreal(FSFicheSaisie.EditPrixMouvement.Text)/strtoreal(FSFicheSaisie.EditQuantiteMouvement.Text));
     end;

     R:=6;
     OKArticle:=false;
     while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OKArticle=false)do
     begin
          if(R<>RowEditing)then
          begin
               if (FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]=FSFicheSaisie.LabelCodeArticle.Caption)
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[2,R]=FSFicheSaisie.LabelDesignationArticle.Caption)
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[3,R]=FSFicheSaisie.LabelRefArticle.Caption)
               and(FSFicheSaisie.TableauDetaiMouvement.Cells[7,R]=FSFicheSaisie.EditPrixMouvement.Text)
               then
               begin
                    OKArticle:=true;
                    RowEditing:=R;
                    FSFicheSaisie.EditQuantiteMouvement.Text:=floattostr(strtoreal(FSFicheSaisie.EditQuantiteMouvement.Text)+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]));
               end;
          end;
          R:=R+1;
     end;

     FSFicheSaisie.TableauDetaiMouvement.Cells[1,RowEditing]:=FSFicheSaisie.LabelCodeArticle.Caption;
     FSFicheSaisie.TableauDetaiMouvement.Cells[2,RowEditing]:=FSFicheSaisie.LabelDesignationArticle.Caption;
     FSFicheSaisie.TableauDetaiMouvement.Cells[3,RowEditing]:=FSFicheSaisie.LabelRefArticle.Caption;
     //FSFicheSaisie.TableauDetaiMouvement.Cells[4,RowEditing]:=FSFicheSaisie.LabelUniteMusure.Caption;
     FSFicheSaisie.TableauDetaiMouvement.Cells[4,RowEditing]:=FSFicheSaisie.EditUniteMesure.Text;
     FSFicheSaisie.TableauDetaiMouvement.Cells[5,RowEditing]:=Vergule(FSFicheSaisie.LabelCout.Caption,'2','C','');

     if(FSFicheSaisie.EditTaxeAjouter.Text='')then
     begin
          FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]:=FSFicheSaisie.EditQuantiteMouvement.Text;
          FSFicheSaisie.TableauDetaiMouvement.Cells[7,RowEditing]:=FSFicheSaisie.EditPrixMouvement.Text;
     end
     else
     if(Firstlaters(FSFicheSaisie.EditTaxeAjouter.Text,6)='Barčme')then
     begin
          if(FSFicheSaisie.RBAppliquerResultatBaremeQuantite.Checked=false)
          then FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]:='1'
          else FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]:=FSFicheSaisie.EditQuantiteMouvement.Text;
          FSFicheSaisie.TableauDetaiMouvement.Cells[7,RowEditing]:=FSFicheSaisie.EditPrixMouvement.Text;
     end
     else
     if strtoreal(FSFicheSaisie.EditTaxeAjouter.Text)>=0then
     begin
           FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]:=FSFicheSaisie.EditQuantiteMouvement.Text;
           FSFicheSaisie.TableauDetaiMouvement.Cells[7,RowEditing]:=floattostr(strtoreal(FSFicheSaisie.EditPrixMouvement.Text)+strtoreal(FSFicheSaisie.EditTaxeAjouter.Text));
     end;

     if(FSFicheSaisie.RBPrixUnitaireTTC.Checked=true)then
     begin
           FSFicheSaisie.TableauDetaiMouvement.Cells[7,RowEditing]:=FSFicheSaisie.TableauDetaiMouvement.Cells[7,RowEditing];
     end;

     FSFicheSaisie.AfficheDetailMouvement.Visible:=false;

     ///******************************************************************************
     CalculeFicheSaisie(FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable,FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.EditModePayement.Text,FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,RowEditing,FSFicheSaisie.EditCodeTypeFormuleAfficher,true);
     AfficherRecapeFicheSaisie(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.EditChiffreEnLettres,FSFicheSaisie.EditTitreChiffreEnLettres,FSFicheSaisie.EditMontantMouvement);

     FSFicheSaisie.TableauDetaiMouvement.Cells[5,RowEditing]:=Vergule(Floattostr(strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[5,RowEditing])),FSFicheSaisie.EditNbrChiffreApresVerguleCout.Text,'C','');
     FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing]:=Vergule(Floattostr(strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,RowEditing])),FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,'C','');
     for C:=7 to FSFicheSaisie.TableauDetaiMouvement.ColCount-1 do
     begin
          FSFicheSaisie.TableauDetaiMouvement.Cells[C,RowEditing]:=Vergule(FSFicheSaisie.TableauDetaiMouvement.Cells[C,RowEditing],FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,'C','')
     end;

     FSFicheSaisie.TableauDetaiMouvement.SetFocus;
     if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then
     begin
          FSFicheSaisie.TableauDetaiMouvement.Col:=1;
          FSFicheSaisie.TableauDetaiMouvement.Row:=FSFicheSaisie.TableauDetaiMouvement.RowCount-1;
          if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row]<>'')
          and(FSFicheSaisie.TableauDetaiMouvement.Cells[2,FSFicheSaisie.TableauDetaiMouvement.Row]<>'')
          and(FSFicheSaisie.TableauDetaiMouvement.Cells[6,FSFicheSaisie.TableauDetaiMouvement.Row]<>'')
          and(FSFicheSaisie.TableauDetaiMouvement.Row=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)
          then
          begin
               FSFicheSaisie.TableauDetaiMouvement.RowCount:=FSFicheSaisie.TableauDetaiMouvement.RowCount+1;
               RowEditing:=FSFicheSaisie.TableauDetaiMouvement.RowCount-1;
               FSFicheSaisie.TableauDetaiMouvement.Rows[RowEditing].Text:='';
               FSFicheSaisie.TableauDetaiMouvement.Col:=1;
          end
          else
          begin
               RowEditing:=FSFicheSaisie.TableauDetaiMouvement.RowCount-1;
          end;
     end;
     ///******************************************************************************

     FSFicheSaisie.TableauDetaiMouvement.Row:=RowEditing;
end;

end;

