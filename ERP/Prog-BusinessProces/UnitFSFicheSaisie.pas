Function NatureOperationMouvement(DesignationTypeMouvement,OrdreListeMouvement:string; InclureQuantite:boolean):string;
var   NatureMouvement,QuantiteTexte,TypeProcesNOM,FichierConserneNOM,AdresseNOM:string;  OKDetailMouvement:boolean;
begin
     TypeProcesNOM:='Business';   FichierConserneNOM:='DétailMouvement '+DesignationTypeMouvement;
     if not(FunctionAdresseProces(TypeProcesNOM,FichierConserneNOM,'',AdresseNOM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneNOM+' recherché !');
     end;

     ChDetailMouvement:=AdresseNOM;
     assignfile(FDetailMouvement,ChDetailMouvement);
     try
     if FileExists(ChDetailMouvement)then
     Reset(FDetailMouvement)
     else begin affichermessage('Attention ! {'+ChDetailMouvement+'} n''existe pas !'); exit; end;//Rewrite(FDetailMouvement);
     Seek(FDetailMouvement,0);
     NatureMouvement:='';
     while not eof(FDetailMouvement)do
     begin
          read(FDetailMouvement,RDetailMouvement);

          OKDetailMouvement:=RDetailMouvement.ValidationDetailMouvement;

          if(OKDetailMouvement=true)then
          begin
               if(inttostr(RDetailMouvement.OrdreListeMouvement)=OrdreListeMouvement)
               then OKDetailMouvement:=true
               else OKDetailMouvement:=false;
          end;

          if(OKDetailMouvement=true)then
          begin
               if(InclureQuantite=true)
               then QuantiteTexte:=Vergule(floattostr(RDetailMouvement.Quantite),'2','C','')+' '+RDetailMouvement.UMArticle+' '
               else QuantiteTexte:='';

               if(NatureMouvement='')then
               begin
                    NatureMouvement:=QuantiteTexte+RDetailMouvement.DesignationArticle+' '+RDetailMouvement.ReferenceArticle;
               end
               else
               begin
                    NatureMouvement:=NatureMouvement+'; '+QuantiteTexte+RDetailMouvement.DesignationArticle+' '+RDetailMouvement.ReferenceArticle;
               end;
          end;

     end;
     finally
     CloseFile(FDetailMouvement);
     end;

     NatureOperationMouvement:=NatureMouvement;
end;

procedure TFSFicheSaisie.EditTiersConserneKeyPress(Sender: TObject;
  var Key: Char);
var i,R,RowCout,OrdreClient:integer;  TypeProces,FichierConcerne,Adresse,CompteTiers:string;   OKTiers,Confirme,OKCompteTiers:boolean;
begin
if key='+'then
begin
     FSFicheSaisie.AfficheTableauTiersConserne.Visible:=false;
     Key:=#0;
     FSFicheSaisie.AfficheNouveauTiers.Visible:=true;
     FSFicheSaisie.EditCodeTiers.Text:='';
     FSFicheSaisie.EditNomTiers.Text:='';
     FSFicheSaisie.EditPrenomTiers.Text:='';
     FSFicheSaisie.EditAdresseTiers.Text:='';
     FSFicheSaisie.EditCompteTiersRecherche.Text:='';
     FSFicheSaisie.EditCodeTiersConserne.Text:='';
     FSFicheSaisie.EditTiersConserne.Text:='';
     FSFicheSaisie.EditNomTiers.SetFocus;

     TypeProces:=FSFicheSaisie.EditTypeProces.Text;
     FichierConcerne:=FSFicheSaisie.EditFichierTiersConserne.Text;
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
          Exit;
     end;

     if(FSFicheSaisie.EditTiersConserne.Text<>'+')then
     begin
          FSFicheSaisie.TableauCompteTiers.ColCount:=4;
          FSFicheSaisie.TableauCompteTiers.Cols[0].Text:='N°';
          FSFicheSaisie.TableauCompteTiers.Cols[1].Text:='Code';
          FSFicheSaisie.TableauCompteTiers.Cols[2].Text:='Nom';
          FSFicheSaisie.TableauCompteTiers.Cols[3].Text:='Prénom';

          FSFicheSaisie.TableauCompteTiers.RowCount:=2;
          FSFicheSaisie.TableauCompteTiers.Rows[1].Text:='';

          if(TypeProces='Commercial')or(TypeProces='Business')then
          begin
               if(FichierConcerne<>'FProjetFinance')then
               begin
                    ChTiers:=Adresse;
                    assignfile(FTiers,ChTiers);
                    try
                    if FileExists(ChTiers)then
                    Reset(FTiers)
                    else begin affichermessage('Attention ! {'+ChTiers+'} n''existe pas !'); exit; end;//Rewrite(FTiers);
                    Seek(FTiers,0);
                    OKTiers:=false;
                    i:=0;
                    RowCout:=0;
                    FSFicheSaisie.EditCompteTiersRecherche.Text:='';
                    while not eof(FTiers)and(OKTiers=false)do
                    begin
                         read(FTiers,RTiers);

                         if(RTiers.CodeTiers<>'')then
                         begin
                              if(longueur(RTiers.CodeTiers)=10)
                              then CompteTiers:=Firstlaters(RTiers.CodeTiers,6)
                              else CompteTiers:='';

                              if(FSFicheSaisie.EditCompteTiersRecherche.Text='')then FSFicheSaisie.EditCompteTiersRecherche.Text:=CompteTiers;

                              R:=1;
                              OKCompteTiers:=false;
                              While(R<=FSFicheSaisie.TableauCompteTiers.RowCount-1)and(OKCompteTiers=false)do
                              begin
                                   if(FSFicheSaisie.TableauCompteTiers.Cells[1,R]=CompteTiers)then
                                   begin
                                        OKCompteTiers:=true;
                                   end;
                              R:=R+1;
                              end;

                              if(OKCompteTiers=false)then
                              begin
                                   RowCout:=RowCout+1;
                                   FSFicheSaisie.TableauCompteTiers.Rows[RowCout].Text:=inttostr(RowCout);
                                   FSFicheSaisie.TableauCompteTiers.Cells[1,RowCout]:=CompteTiers;
                                   if(ChercherCompteComptable(CompteTiers,'','PlanComptable',RRegistreCompte))
                                   then FSFicheSaisie.TableauCompteTiers.Cells[2,RowCout]:=RRegistreCompte.Designation
                                   else FSFicheSaisie.TableauCompteTiers.Cells[2,RowCout]:='Pas d''information';
                              end;
                         end;
                    end;
                    finally
                    Closefile(FTiers);
                    end;

                    if(RowCout>1)then
                    begin
                         FSFicheSaisie.TableauCompteTiers.Visible:=true;
                         FSFicheSaisie.TableauCompteTiers.RowCount:=RowCout+1;
                         AjusterColWidth(FSFicheSaisie.TableauCompteTiers,'','');
                         FSFicheSaisie.TableauCompteTiers.SetFocus;
                    end
                    else
                    begin
                         FSFicheSaisie.TableauCompteTiers.Visible:=false;
                         ChClient:=Adresse;
                         assignfile(FClient,ChClient);
                         try
                         if FileExists(ChClient)then
                         Reset(FClient)
                         else begin affichermessage('Attention ! {'+ChClient+'} n''existe pas !'); exit; end;//Rewrite(FClient);
                         Seek(FClient,0);
                         OrdreClient:=1;
                         while not eof(FClient)do
                         begin
                              read(FClient,RClient);
                              if(FSFicheSaisie.EditTiersConserne.Text<>'')then
                              begin
                                   if(Firstlaters(RClient.CodeTiers,6)=FSFicheSaisie.EditTiersConserne.Text)then
                                   begin
                                        if(strtointeger(lastlaters(RClient.CodeTiers,4))>=OrdreClient)then OrdreClient:=strtointeger(lastlaters(RClient.CodeTiers,4))+1;
                                   end;
                              end
                              else
                              begin
