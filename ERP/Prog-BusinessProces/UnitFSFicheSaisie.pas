                                         ProcAfficheStockArticleListe(FSFicheSaisie.TableauCompteConcerne,FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.EditCompteConserne.Text,'','','',FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row],FSFicheSaisie.RBDistingueDesigRef.Checked,0,RowOut);
                                         NotCol:='5;6;8-'+inttostr(FSFicheSaisie.TableauCompteConcerne.ColCount-1);
