procedure TFSFicheSaisie.TableauListeMouvementKeyPress(Sender: TObject;
  var Key: Char);
var  TypeData:string;
     DebitAvis,CreditAvis,DebitCreditAvis,DebitMouvement,CreditMouvement,DebitCreditMouvement,DebitPrelevement,CreditPrelevement,DebitCreditPrelevement,DebitSituation,CreditSituation,DebitCreditSituation:real;
begin
     if(FSFicheSaisie.AfficherChercherNumeroListeMouvement.Visible=true)
     and(key in['0'..'9','/','a'..'z','A'..'Z',' ',DecimalSeparator])then
     begin
          FSFicheSaisie.EditChercherNumeroListeMouvement.Text:=FSFicheSaisie.EditChercherNumeroListeMouvement.Text+key;
     end;
     
     if(key in['r','R','?'])then
     begin
          FSFicheSaisie.AfficherChercherNumeroListeMouvement.Left:=8;
          FSFicheSaisie.AfficherChercherNumeroListeMouvement.Top:=10;
          FSFicheSaisie.AfficherChercherNumeroListeMouvement.Visible:=true;
          FSFicheSaisie.AfficherChercherNumeroListeMouvement.Height:=215;
          FSFicheSaisie.EditChercherNumeroListeMouvement.Text:='';
          FSFicheSaisie.EditChercherNumeroListeMouvement.SetFocus;

          FSFicheSaisie.EditPositionTypeMouvementRecherche.Text:=FSFicheSaisie.EditPositionTypeMouvement.Text;
          FSFicheSaisie.EditPositionMouvementRecherche.Text:=FSFicheSaisie.EditPositionMouvement.Text;
          FSFicheSaisie.EditCodeTypeFormuleBaseRecherche.Text:=FSFicheSaisie.EditCodeTypeFormuleBase.Text;

          FSFicheSaisie.EditDesignationMouvementRecherche.Caption:=FSFicheSaisie.EditDesignationMouvement.Text;
          FSFicheSaisie.EditDesignationTypeMouvementRecherche.Caption:=FSFicheSaisie.EditDesignationTypeMouvement.Text;
     end;

     if(key in['t','T'])then
     begin
          if FSFicheSaisie.TableauListeMouvement.Col in[5,12]then TypeData:='Date'
          else
          if FSFicheSaisie.TableauListeMouvement.Col in[0,1,2,3,4,11,38,39,40]then TypeData:='Num'
