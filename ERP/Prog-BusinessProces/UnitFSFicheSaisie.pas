                                RDetailMouvement.RRegistreFormule5.Active:=strtoboolean(FSFicheSaisie.TableauDetaiMouvement.Cells[C,4]);
                                RDetailMouvement.RRegistreFormule5.ValeurFormule:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[C,R]);
                           end;
                      14:  begin
