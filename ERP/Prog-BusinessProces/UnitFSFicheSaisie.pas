procedure TFSFicheSaisie.TableauSFamilleKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var   m:integer; TypeProces,FichierConcerne,Adresse,CodeStockArticle:string;  OKStock:boolean;
begin

if key in[VK_RETURN] then
begin
     FSFicheSaisie.EditRechercheCodeSFamille.Text:=FSFicheSaisie.TableauSFamille.Cells[1,FSFicheSaisie.TableauSFamille.Row];
     FSFicheSaisie.EditRechercheDesigSFamille.Text:='Liste de produits de la S/Famille: '+FSFicheSaisie.TableauSFamille.Cells[2,FSFicheSaisie.TableauSFamille.Row];

     if(FSFicheSaisie.EditRequette.Text='Nouveau')then
     begin
          InitialisationFicheSaisieProduit;
          m:=1;
          OpenFParc(RParc);
          //////////////////////////////////////////////////////////////////////////////
          if(FunctCreationStockLibre=true)
          then CodeStockArticle:=FSFicheSaisie.EditNumProjet.Text
          else CodeStockArticle:='';

          if(FunctStockSpecifierParStructure(false)=false)then CodeStockArticle:='';
          FichierConcerne:='FStock'+FSFicheSaisie.EditTypeStock.Text;
          if(FSFicheSaisie.EditTypeStock.Text<>'Marche')then FichierConcerne:=FichierConcerne+CodeStockArticle;
          //////////////////////////////////////////////////////////////////////////////
          TypeProces:='Commercial';
          Adresse:='';
          if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
              ChStockArticle:=Adresse;
              assignfile(FStockArticle,ChStockArticle);
              try
              if FileExists(ChStockArticle)then
              Reset(FStockArticle)
              else begin affichermessage('Attention ! {'+ChStockArticle+'} n''existe pas !'); exit; end;//Rewrite(FStockArticle);
              Seek(FStockArticle,0);
              while not eof(FStockArticle) do
              begin
                   Read(FStockArticle,RStockArticle);
                   if(FirstLaters(RStockArticle.Code,6)=FSFicheSaisie.TableauSFamille.Cells[1,FSFicheSaisie.TableauSFamille.Row])then
                   begin
                        if(m<=strtoint(LastLaters(RStockArticle.Code,4)))then m:=strtoint(LastLaters(RStockArticle.Code,4))+1;
                   end;
              end;
              finally
              CloseFile(FStockArticle);
              end;
          end
          else
          begin
               ChStock:=RParc.Parcours+'\'+Exercice+FichierConcerne;
               assignfile(FStock,ChStock);
               try
               if FileExists(ChStock)then
               Reset(FStock)
               else begin affichermessage('Attention ! {'+ChStock+'} n''existe pas !'); exit; end;//Rewrite(FStock);
               Seek(FStock,0);
               while not eof(FStock)do
               begin
                    read(FStock,RStock);
                    if(FirstLaters(RStock.Code,6)=FSFicheSaisie.TableauSFamille.Cells[1,FSFicheSaisie.TableauSFamille.Row])then
                    begin
                         if(m<=strtoint(LastLaters(RStock.Code,4)))then m:=strtoint(LastLaters(RStock.Code,4))+1;
                    end;
               end;
               finally
               CloseFile(FStock);
               end;
          end;
          FSFicheSaisie.EditCodeProduit.Text:=FSFicheSaisie.TableauSFamille.Cells[1,FSFicheSaisie.TableauSFamille.Row]+CompleteZeroGauche(inttostr(m),'4');
          FSFicheSaisie.EditDesig.Lines.Text:=FSFicheSaisie.TableauSFamille.Cells[2,FSFicheSaisie.TableauSFamille.Row];

          //// VERIFICATION DANS TOUTES LES STRUCTURES//////////////////////////
          ChStock:=RParc.Parcours+'\'+Exercice+'FStock'+FSFicheSaisie.EditTypeStock.Text;
          assignfile(FStock,ChStock);
          try
          if FileExists(ChStock)then
          Reset(FStock)
          else begin affichermessage('Attention ! {'+ChStock+'} n''existe pas !'); exit; end;//Rewrite(FStock);
          Seek(FStock,0);
          OKStock:=false;
          while not eof(FStock)and(OKStock=false)do
          begin
               read(FStock,RStock);
               if(RStock.Code=FSFicheSaisie.EditCodeProduit.Text)then
               begin
                    OKStock:=true;
                    showmessage('Le code existe dans la base touts les structures !');
                    FSFicheSaisie.EditDesig.Lines.Text:=RStock.Design;
                    FSFicheSaisie.EditRef.Text:=RStock.Ref;
                    FSFicheSaisie.EditUM.Text:=RStock.UM;
                    FSFicheSaisie.EditPrixVente.Text:=floattostr(RStock.PrixVenteDetaille);
               end;
          end;
          finally
          CloseFile(FStock);
          end;
          //////////////////////////////////////////////////////////////////////

          FSFicheSaisie.BitValiderProduit.Visible:=true;
          FSFicheSaisie.EditRef.SetFocus;
     end;
FSFicheSaisie.AfficheNewArticle.Height:=153;
end;
end;

