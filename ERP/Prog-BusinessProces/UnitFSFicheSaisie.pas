Procedure DetailPeriodeListeMouvement(RBListeDetailMouvementParDate,RBListeDetailMouvementParMois:TRadioButton; var DateMouvementDebut,DateMouvementFin:string);
begin
     if(RBListeDetailMouvementParDate.Checked=true)then
     begin
          DateMouvementDebut:=datetostr(FSFicheSaisie.EditChercheDateDetailMouvement.Date);
          DateMouvementFin:=datetostr(FSFicheSaisie.EditChercheDateDetailMouvement.Date);
     end
     else
     if(RBListeDetailMouvementParMois.Checked=true)then       
     begin
          if(strtointeger(FSFicheSaisie.EditAnnee.Text)=0)then FSFicheSaisie.EditAnnee.Text:=lastlaters(datetostr(date),4);
          if(FSFicheSaisie.EditMois.Text='')then FSFicheSaisie.EditMois.ItemIndex:=strtointeger(midellaters(datetostr(date),4,5))-1;
          
          DateMouvementDebut:='01/'+Completezerogauche(inttostr(FSFicheSaisie.EditMois.ItemIndex+1),'2')+'/'+FSFicheSaisie.EditAnnee.Text;
          DateMouvementFin:=Completezerogauche(inttostr(LastDay(DateMouvementDebut)),'2')+'/'+Completezerogauche(inttostr(FSFicheSaisie.EditMois.ItemIndex+1),'2')+'/'+FSFicheSaisie.EditAnnee.Text;
     end
     else
     begin
          DateMouvementDebut:=datetostr(date);
          DateMouvementFin:=datetostr(date);
     end
end;

Procedure AutoLocalisationGeographique(RBPaysExecutionMouvement,RBWilayaExecutionMouvement,RBDairaExecutionMouvement,RBCommuneExecutionMouvement,RBZoneExecutionMouvement,RBAdresseExecutionMouvement:TCheckBox; EditCodePaysExecutionMouvement,EditPaysExecutionMouvement,EditCodeWilayaExecutionMouvement,EditWilayaExecutionMouvement,EditCodeDairaExecutionMouvement,EditDairaExecutionMouvement,EditCodeCommuneExecutionMouvement,EditCommuneExecutionMouvement,EditCodeZoneExecutionMouvement,EditZoneExecutionMouvement,EditAdresseExecutionMouvement:TEdit);
var  OKSetFocused:boolean;
begin
     OKSetFocused:=false;

if(EditPaysExecutionMouvement.Text='')and(OKSetFocused=false)then
begin
     if(RBPaysExecutionMouvement.Checked=false)then
     begin
          OKSetFocused:=false;
          OpenFParc(RParc);
          ChLocalisationGeographique:=RParc.Parcours+'\'+Exercice+'FPays';
          assignfile(FLocalisationGeographique,ChLocalisationGeographique);
          if FileExists(ChLocalisationGeographique)then
          begin
               try
               Reset(FLocalisationGeographique);
               Seek(FLocalisationGeographique,0);
               while not eof(FLocalisationGeographique)and(EditPaysExecutionMouvement.Text='')do
               begin
                    read(FLocalisationGeographique,RLocalisationGeographique);
                    EditCodePaysExecutionMouvement.Text:=RLocalisationGeographique.CodeLocalisationGeographique;
                    EditPaysExecutionMouvement.Text:=RLocalisationGeographique.IntitulleLocalisationGeographique;
               end;
               finally
               CloseFile(FLocalisationGeographique);
               end;
          end;
     end
     else
     begin
          OKSetFocused:=true;
          EditPaysExecutionMouvement.SetFocus;
