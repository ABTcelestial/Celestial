               begin
                    FSFicheSaisie.EditInfoControleCouleur.Text:='Avis Non Etabli';
                    FSFicheSaisie.TimerControleCouleur.Enabled:=true;
               end;
          end;
     end
     else
     begin
          FSFicheSaisie.TimerControleCouleur.Enabled:=false;
          FSFicheSaisie.AfficheAutoImporteAvis.Color:=clBtnFace;

          if(FSFicheSaisie.EditModePayement.Text<>'')
          or(FSFicheSaisie.EditDomiciliation.Text<>'')
          or(FSFicheSaisie.EditNumPiece.Text<>'')then
          begin
               FSFicheSaisie.EditInfoControleCouleur.Text:='Avis Non Etabli';
               FSFicheSaisie.TimerControleCouleur.Enabled:=true;
          end;
     end;

     if(TableauDetaiMouvement.Cells[1,TableauDetaiMouvement.Row]<>'')then
     begin
          for C:=8 to TableauDetaiMouvement.ColCount-1 do
          begin
               if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
               for R:=1 to TableauVariable.RowCount-1 do
               begin
                    if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
