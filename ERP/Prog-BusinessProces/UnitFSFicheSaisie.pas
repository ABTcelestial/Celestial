Procedure MiseAJourPositionBeginEndListeMouvementInFMouvement(PositionTypeMouvement,PositionMouvement:string);
var  PTM,PM,R,PBegin,PEnd:integer;  TypeProces,FichierConcerne,Adresse:string;  OKTypeMouvement,OKMouvement:boolean;
begin
     TypeProces:='Business';
     FichierConcerne:='FTypeMouvement';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChTypeMouvement:=Adresse;     FSFicheSaisie.AfficheAdresseTypeMouvement.Caption:=ChTypeMouvement;///////////////////Affichage adresse
     assignfile(FTypeMouvement,ChTypeMouvement);
     try
     if FileExists(ChTypeMouvement)then
     Reset(FTypeMouvement)
     else begin affichermessage('Attention ! {'+ChTypeMouvement+'} n''existe pas !'); exit; end;//Rewrite(FTypeMouvement);
     Seek(FTypeMouvement,0);
     PTM:=0;
     while not eof(FTypeMouvement)do
     begin
           read(FTypeMouvement,RTypeMouvement);

           if(PositionTypeMouvement<>'')then
           begin
                if(RTypeMouvement.PositionTypeMouvement=strtointeger(PositionTypeMouvement))
                then OKTypeMouvement:=true
                else OKTypeMouvement:=false;
           end
           else OKTypeMouvement:=true;

           if(OKTypeMouvement=true)then
           begin
                 ChMouvement:=IndiqueAdresseMouvement(inttostr(RTypeMouvement.PositionTypeMouvement),TypeProcesReseaux);  FSFicheSaisie.AfficheAdresseMouvement.Caption:=ChMouvement; ///////////////////Affichage adresse
                 assignfile(FMouvement,ChMouvement);
                 try
                 if FileExists(ChMouvement)then
                 Reset(FMouvement)
                 else begin affichermessage('Attention ! {'+ChMouvement+'} n''existe pas !'); exit; end;//Rewrite(FMouvement);
                 Seek(FMouvement,0);
                 PM:=0;
                 while not eof(FMouvement)do
                 begin
                      read(FMouvement,RMouvement);

                      if(RMouvement.PositionTypeMouvement=RTypeMouvement.PositionTypeMouvement)
                      then OKMouvement:=true
                      else OKMouvement:=false;

                      if(OKMouvement=true)then
                      begin
                           if(PositionMouvement<>'')then
                           begin
                                if(RMouvement.PositionMouvement=strtointeger(PositionMouvement))
                                then OKMouvement:=true
                                else OKMouvement:=false;
                           end
                           else OKMouvement:=true;
                      end;

                      if(OKMouvement=true)then
                      begin
                           IndiquerPositionListeMouvement(RMouvement.PositionMouvement,inttostr(RMouvement.PositionTypeMouvement),ExerciceAnnee,PBegin,PEnd,RegistrePositionListeMouvementParPeriode);

                           RMouvement.PositionListeMouvementBegin:=PBegin;
                           RMouvement.PositionListeMouvementEnd:=PEnd;
                           RMouvement.RegistrePositionListeMouvementParPeriode:=RegistrePositionListeMouvementParPeriode;

                           Seek(FMouvement,PM);
                           write(FMouvement,RMouvement);
                      end;

                 PM:=PM+1;
                 LibererMemoireProcessus('BusinessProces.exe',true);
                 end;
                 finally
                 CloseFile(FMouvement);
                 end;
           end;

     PTM:=PTM+1;
     end;
     finally
     CloseFile(FTypeMouvement);
     end;

     RemplireTableauPositionListeMouvementPeriode(FSFicheSaisie.TableauPositionListeMouvementPeriode,FSFicheSaisie.EditPositionListeMouvementBegin,FSFicheSaisie.EditPositionListeMouvementEnd,FSFicheSaisie.EditAnnee.Text,PositionTypeMouvement,PositionMouvement);
end;

