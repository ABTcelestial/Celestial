procedure TFSFicheSaisie.EditQuantiteMouvementCodeBarreKeyDown(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var  Index:integer; OKArticleCodeBare:boolean;
begin
     if key in[VK_UP,VK_DOWN]then
     begin
          if key in[VK_UP]then Index:=FSFicheSaisie.EditQuantiteMouvementCodeBarre.ItemIndex-1;
          if key in[VK_DOWN]then Index:=FSFicheSaisie.EditQuantiteMouvementCodeBarre.ItemIndex+1;

          FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text:=FSFicheSaisie.EditQuantiteMouvementCodeBarre.Items.Strings[Index];
     end;

     if key in[VK_RETURN]then
     begin
          OKArticleCodeBare:=false;

          if(longueur(FSFicheSaisie.EditQuantiteMouvementCodeBarre.Text)<=10)and(longueur(FSFicheSaisie.EditQuantiteMouvementCodeBarre.Text)>=8)then
          begin
               if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)then
               begin
                    if(FSFicheSaisie.EditQuantiteMouvementCodeBarre.Text=FSFicheSaisie.EditCodeBareArticleSelect.Text)then
                    begin
                         FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text:=floattostr(strtoreal(FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text)+1);
                         //FSFicheSaisie.EditQuantiteMouvementCodeBarre.Text:=FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text;

                         if(strtoreal(FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text)<=1)then
                         begin
                              FSFicheSaisie.EditQuantiteMouvementCodeBarre.ItemIndex:=ValeAbsolue((strtoreal(FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text)*10)-1);
                         end
                         else
                         begin
                              FSFicheSaisie.EditQuantiteMouvementCodeBarre.ItemIndex:=ValeAbsolue(7+(strtoreal(FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text)*10)/5);
                         end;

                         OKArticleCodeBare:=true;
                         FSFicheSaisie.EditQuantiteMouvementCodeBarre.SelectAll;
                    end;
               end;
          end;

          if(OKArticleCodeBare=false)then
          begin
               if(strtoreal(FSFicheSaisie.EditQuantiteMouvementCodeBarre.Text)<>strtoreal(FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text))
               then FSFicheSaisie.EditQuantiteMouvementCodeBarre.Text:=FSFicheSaisie.EditQuantiteMouvementCodeBarreSelect.Text;
               FSFicheSaisie.EditQuantiteMouvement.Text:=FSFicheSaisie.EditQuantiteMouvementCodeBarre.Text;
               FSFicheSaisie.BitOptionDetailMouvementClick(FSFicheSaisie.BitOptionDetailMouvement);
               FSFicheSaisie.AfficheDetailMouvementCodeBarre.Visible:=false;
          end;
     end;
end;

