procedure TFSFicheSaisie.BitNouveauMouvementClick(Sender: TObject);
var  R,C,OrdreListeMouvement,NumListeMouvement,PLMEnd,iMois:integer;
     TypeProces,FichierConserne,Adresse,ExerciceAfficher,DateSelect,DateRecherche,CodeTiers,Tiers:string;
begin
     FSFicheSaisie.AfficherChercherNumeroListeMouvement.Visible:=false;
     FSFicheSaisie.TableauChercherTiers.Visible:=false;

     FSFicheSaisie.EditAutoSelectionArticle.Text:=FSFicheSaisie.EditListeAppartenanceCodeMouvement.Text;

     if(FSFicheSaisie.RBToujourNouvelleDateMouvement.Checked=true)then FSFicheSaisie.EditDateDetailMouvement.Date:=date;

     if(FSFicheSaisie.AfficheParMois.Visible=true)then
     begin
           if(lastlaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),4)<>FSFicheSaisie.EditAnnee.Text)then
           begin
                showmessage('Année hors période {'+FSFicheSaisie.EditAnnee.Text+'}');
                exit;
           end;

           if(strtointeger(MidelLaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),4,5))<>(FSFicheSaisie.EditMois.ItemIndex+1))then
           begin
                showmessage('Mois hors période {'+FSFicheSaisie.EditMois.Text+'}');
                FSFicheSaisie.EditDateDetailMouvement.Date:=strtodate('01/'+CompleteZeroGauche(inttostr(FSFicheSaisie.EditMois.ItemIndex+1),'2')+'/'+FSFicheSaisie.EditAnnee.Text);
                exit;
           end;
     end
     else
     begin
           FSFicheSaisie.EditDateDetailMouvement.Date:=FSFicheSaisie.EditChercheDateDetailMouvement.Date;
           
           DateSelect:=datetostr(FSFicheSaisie.EditDateDetailMouvement.Date);
           DateRecherche:='31/12/'+lastlaters(datetostr(EditChercheDateDetailMouvement.Date),4);
           if(strtodate(DateSelect)>strtodate(DateRecherche))then
           begin
                showmessage('Date hors période {'+lastlaters(datetostr(EditChercheDateDetailMouvement.Date),4)+'}');
                exit;
           end;
     end;

     FSFicheSaisie.TableauSelections.Visible:=false;
     FSFicheSaisie.RBDetailMouvementAfficher.Checked:=true;
     FSFicheSaisie.RBValidationDetailMouvement.Checked:=true;

     if(FSFicheSaisie.AfficheMouvement.Caption='')or(FSFicheSaisie.TypeFormuleAfficher.Caption='')then
     begin
          FSFicheSaisie.RBDetailMouvementAfficher.Checked:=true;
          FSFicheSaisie.RBValidationDetailMouvement.Checked:=true;
          InitialisationFicheSaisie(false,true,true,true,false,false);

          FSFicheSaisie.TableauTypeMouvement.Left:=FSFicheSaisie.AfficheMouvement.Left;
          FSFicheSaisie.TableauTypeMouvement.Top:=FSFicheSaisie.AfficheMouvement.Top+FSFicheSaisie.AfficheMouvement.Height+2;
          FSFicheSaisie.TableauTypeMouvement.Visible:=true;
          ProcListeTypeMouvement(FSFicheSaisie.TableauTypeMouvement);
          FSFicheSaisie.TableauTypeMouvement.SetFocus;

     Exit;
     end;

     TypeProces:='Business';   FichierConserne:='FListeMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
     end;

     ChListeMouvement:=IndiqueAdresseListeMouvement(FSFicheSaisie.EditPositionTypeMouvement.Text,TypeProcesReseauxListeMouvement);

     if(TypeProcesReseauxListeMouvement='Réseaux')then
     begin
          showmessage('Opération réseaux non autorisé !');
          Exit;
     end;

     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else
     begin
          if(NonOui('Attention ! '+ChListeMouvement+' n''existe pas ! Voulez vous le crié ?'))then
          begin
               Rewrite(FListeMouvement);
          end;

          Exit;
     end;
     Seek(FListeMouvement,0);
     OrdreListeMouvement:=1;
     NumListeMouvement:=1;
     PLMEnd:=0;
     while not eof(FListeMouvement)do
     begin
          read(FListeMouvement,RListeMouvement);

          if(OrdreListeMouvement<=RListeMouvement.OrdreListeMouvement)then OrdreListeMouvement:=RListeMouvement.OrdreListeMouvement+1;

          if(RListeMouvement.CodeTypeFormule=FSFicheSaisie.EditCodeTypeFormuleBase.Text)then
          begin
               if(FSFicheSaisie.RBNouvelleNumerotationPourChaqueExercice.Checked=true)then
               begin
                    ExerciceAfficher:=lastlaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),4);
                    if(Lastlaters(RListeMouvement.DateMouvement,4)=ExerciceAfficher)then
                    begin
                         if(NumListeMouvement<=RListeMouvement.NumListeMouvement)then NumListeMouvement:=RListeMouvement.NumListeMouvement+1;
                    end;
               end
               else
               begin
                    if(NumListeMouvement<=RListeMouvement.NumListeMouvement)then NumListeMouvement:=RListeMouvement.NumListeMouvement+1;
               end;
          end;
     PLMEnd:=PLMEnd+1;
     end;
     finally
     CloseFile(FListeMouvement);
     end;

     FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text:='';
     FSFicheSaisie.EditCodePaysExecutionMouvement.Text:='';
     FSFicheSaisie.EditPaysExecutionMouvement.Text:='';
     FSFicheSaisie.EditCodeWilayaExecutionMouvement.Text:='';
     FSFicheSaisie.EditWilayaExecutionMouvement.Text:='';
     FSFicheSaisie.EditCodeDairaExecutionMouvement.Text:='';
     FSFicheSaisie.EditDairaExecutionMouvement.Text:='';
     FSFicheSaisie.EditCodeCommuneExecutionMouvement.Text:='';
     FSFicheSaisie.EditCommuneExecutionMouvement.Text:='';
     FSFicheSaisie.EditCodeZoneExecutionMouvement.Text:='';
     FSFicheSaisie.EditZoneExecutionMouvement.Text:='';
     FSFicheSaisie.EditAdresseExecutionMouvement.Text:='';
     FSFicheSaisie.EditOrdreListeMouvement.Text:=inttostr(OrdreListeMouvement);
     FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text:=inttostr(OrdreListeMouvement);
     FSFicheSaisie.EditPositionDetailMouvementBegin.Text:='0';
     FSFicheSaisie.EditPositionDetailMouvementEnd.Text:='0';
     FSFicheSaisie.EditNumListeMouvement.Text:=inttostr(NumListeMouvement);
     FSFicheSaisie.EditDataTiersSupplementaire.Text:='';
     FSFicheSaisie.EditInfoMoyenTransport.Text:='';
     FSFicheSaisie.EditMontantMouvement.Text:='';
     FSFicheSaisie.EditNumProjet.Text:='';
     FSFicheSaisie.EditNomProjet.Text:='';                       

     if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)or(FSFicheSaisie.RBAutoNouveauMouvement.Checked=true)then
     begin
          if(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then FSFicheSaisie.AfficheIndiceListeMouvement.Visible:=true;
          
          TiersDivers(FSFicheSaisie.EditTypeProces.Text,FSFicheSaisie.EditFichierTiersConserne.Text,CodeTiers,Tiers);
          FSFicheSaisie.EditCodeTiersConserne.Text:=CodeTiers;
          FSFicheSaisie.EditTiersConserne.Text:=Tiers;
          FSFicheSaisie.EditModePayement.Text:='Espčce';
          FSFicheSaisie.EditDomiciliation.Text:='CAISSE';
     end
     else
     begin
          FSFicheSaisie.EditCodeTiersConserne.Text:='';
          FSFicheSaisie.EditTiersConserne.Text:='';
          FSFicheSaisie.EditNumProjet.Text:='';
          FSFicheSaisie.EditNomProjet.Text:='';
          FSFicheSaisie.EditModePayement.Text:='';
          FSFicheSaisie.EditDomiciliation.Text:='';
     end;
     
     FSFicheSaisie.EditNumPiece.Text:='';
     FSFicheSaisie.EditNumAvis.Text:='';
     FSFicheSaisie.EditOrdreListeMouvementAppartenantSauvgarde.Text:='';
     FSFicheSaisie.EditReferenceListeMouvement.Text:='';
     FSFicheSaisie.EditMontantAvis.Text:='';
     FSFicheSaisie.EditPositionListeMouvementEnd.Text:=inttostr(PLMEnd);
     FSFicheSaisie.EditPositionListeMouvementEndNew.Text:=inttostr(PLMEnd);

     RemplireTableauPositionListeMouvementPeriode(FSFicheSaisie.TableauPositionListeMouvementPeriode,EditPositionListeMouvementBegin,EditPositionListeMouvementEnd,FSFicheSaisie.EditAnnee.Text,FSFicheSaisie.EditPositionTypeMouvement.Text,FSFicheSaisie.EditPositionMouvement.Text);

     FSFicheSaisie.RBListeMouvementMaintenue.Checked:=true;
     ProcAfficheFormuleFS(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable,FSFicheSaisie.EditCodeTypeFormuleAfficher.Text,true);

     if(FSFicheSaisie.RBAvecDateExecution.Checked=true)or(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
     begin
          FSFicheSaisie.AfficheExecutionMouvement.Visible:=true;

          FSFicheSaisie.EditCodePaysExecutionMouvement.Text:='';
          FSFicheSaisie.EditPaysExecutionMouvement.Text:='';
          FSFicheSaisie.EditCodeWilayaExecutionMouvement.Text:='';
          FSFicheSaisie.EditWilayaExecutionMouvement.Text:='';
          FSFicheSaisie.EditCodeDairaExecutionMouvement.Text:='';
          FSFicheSaisie.EditDairaExecutionMouvement.Text:='';
          FSFicheSaisie.EditCodeCommuneExecutionMouvement.Text:='';
          FSFicheSaisie.EditCommuneExecutionMouvement.Text:='';
          FSFicheSaisie.EditCodeZoneExecutionMouvement.Text:='';
          FSFicheSaisie.EditZoneExecutionMouvement.Text:='';
          FSFicheSaisie.EditAdresseExecutionMouvement.Text:='';
          FSFicheSaisie.EditDateExecutionMouvement.Date:=date;
          FSFicheSaisie.OKExecutionOui.Checked:=false;

          if(FSFicheSaisie.RBAvecDateExecution.Checked=true)or(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
          begin
               FSFicheSaisie.TableauListeMouvement.Height:=FSFicheSaisie.AfficheOptionDetailMouvement.Height-
                                                           FSFicheSaisie.AfficheExecutionMouvement.Height-
                                                           FSFicheSaisie.TableauListeMouvement.Top-36;
               FSFicheSaisie.AfficheExecutionMouvement.Visible:=true;

               FSFicheSaisie.AfficheAvecLocalisationGeographique.Visible:=FSFicheSaisie.RBAvecLocalisationGeographique.Checked;
               FSFicheSaisie.AfficheAvecDateExecution.Visible:=FSFicheSaisie.RBAvecDateExecution.Checked;

               if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
               begin
                    AutoLocalisationGeographique(FSFicheSaisie.RBPaysExecutionMouvement,FSFicheSaisie.RBWilayaExecutionMouvement,
                                                 FSFicheSaisie.RBDairaExecutionMouvement,FSFicheSaisie.RBCommuneExecutionMouvement,
                                                 FSFicheSaisie.RBZoneExecutionMouvement,FSFicheSaisie.RBAdresseExecutionMouvement,EditCodePaysExecutionMouvement,EditPaysExecutionMouvement,EditCodeWilayaExecutionMouvement,EditWilayaExecutionMouvement,EditCodeDairaExecutionMouvement,EditDairaExecutionMouvement,EditCodeCommuneExecutionMouvement,EditCommuneExecutionMouvement,EditCodeZoneExecutionMouvement,EditZoneExecutionMouvement,EditAdresseExecutionMouvement);
               end;

               if(FSFicheSaisie.RBAvecDateExecution.Checked=true)then
               begin
                    FSFicheSaisie.EditDateExecutionMouvement.SetFocus;
               end;
          end
          else
          begin
               FSFicheSaisie.TableauListeMouvement.Height:=FSFicheSaisie.AfficheOptionDetailMouvement.Height-
                                                           FSFicheSaisie.TableauListeMouvement.Top-36;
               FSFicheSaisie.AfficheExecutionMouvement.Visible:=false;
          end;
     end
     else
     begin
          FermerOptionDetailMouvement;
          FSFicheSaisie.TableauDetaiMouvement.Col:=1;
          FSFicheSaisie.OKExecutionOui.Checked:=true;
     end;

     if(FSFicheSaisie.BitNouveauMouvement.Caption='Importer le mouvement transféré')then
     begin
          if(FSFicheSaisie.EditFichierTiersConserne.Text<>FSFicheSaisie.TableauListeMouvementTransfert.Cells[8,1])then
          begin
               AfficherMessage('Le type de mouvement choisi n''est pas valide pour le transfert !');
               Exit;
          end;

          FSFicheSaisie.EditModePayement.Text:=FSFicheSaisie.TableauDataTransfert.Cells[1,1];
          FSFicheSaisie.EditDomiciliation.Text:=FSFicheSaisie.TableauDataTransfert.Cells[1,2];
          FSFicheSaisie.EditNumPiece.Text:=FSFicheSaisie.TableauDataTransfert.Cells[1,3];

          FSFicheSaisie.EditCodeTiersConserne.Text:=FSFicheSaisie.TableauListeMouvementTransfert.Cells[9,1];
          if(FSFicheSaisie.TableauListeMouvementTransfert.Cells[35,1]<>'')
          then FSFicheSaisie.EditTiersConserne.Text:=FSFicheSaisie.TableauListeMouvementTransfert.Cells[10,1]+' {'+FSFicheSaisie.TableauListeMouvementTransfert.Cells[35,1]+'}'
          else FSFicheSaisie.EditTiersConserne.Text:=FSFicheSaisie.TableauListeMouvementTransfert.Cells[10,1];
          FSFicheSaisie.EditDataTiersSupplementaire.Text:=FSFicheSaisie.TableauListeMouvementTransfert.Cells[35,1];

          for R:=1 to FSFicheSaisie.TableauDetaiMouvementTransfert.RowCount-1 do
          begin
               FSFicheSaisie.TableauDetaiMouvement.Rows[R+5].Text:='';
               FSFicheSaisie.TableauDetaiMouvement.Cells[1,R+5]:=FSFicheSaisie.TableauDetaiMouvementTransfert.Cells[1,R];
               FSFicheSaisie.TableauDetaiMouvement.Cells[2,R+5]:=FSFicheSaisie.TableauDetaiMouvementTransfert.Cells[2,R];
               FSFicheSaisie.TableauDetaiMouvement.Cells[3,R+5]:=FSFicheSaisie.TableauDetaiMouvementTransfert.Cells[3,R];
               FSFicheSaisie.TableauDetaiMouvement.Cells[4,R+5]:=FSFicheSaisie.TableauDetaiMouvementTransfert.Cells[4,R];
               FSFicheSaisie.TableauDetaiMouvement.Cells[5,R+5]:=FSFicheSaisie.TableauDetaiMouvementTransfert.Cells[5,R];
               FSFicheSaisie.TableauDetaiMouvement.Cells[6,R+5]:=FSFicheSaisie.TableauDetaiMouvementTransfert.Cells[6,R];
               FSFicheSaisie.TableauDetaiMouvement.Cells[7,R+5]:=FSFicheSaisie.TableauDetaiMouvementTransfert.Cells[7,R];

               ///******************************************************************************
               CalculeFicheSaisie(FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable,FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.EditModePayement.Text,FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,R+5,FSFicheSaisie.EditCodeTypeFormuleAfficher,true);
               ///******************************************************************************
          end;
          FSFicheSaisie.TableauDetaiMouvement.RowCount:=R+5;
          AfficherRecapeFicheSaisie(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.EditChiffreEnLettres,FSFicheSaisie.EditTitreChiffreEnLettres,FSFicheSaisie.EditMontantMouvement);
          FSFicheSaisie.TableauDetaiMouvement.SetFocus;
     end
     else
     begin
          if(FSFicheSaisie.TableauLocalisationGeographique.Visible=true)then
          begin
               FSFicheSaisie.TableauLocalisationGeographique.SetFocus
          end
          else
          begin                              
               if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBAutoNouveauMouvement.Checked=true)then
               begin
                    FSFicheSaisie.TableauDetaiMouvement.SetFocus
               end
               else
               if(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)
               and(FSFicheSaisie.AfficheIndiceListeMouvement.Visible=true)then
               begin
                    FSFicheSaisie.EditMatriculePontBascule.SetFocus;
               end
               else FSFicheSaisie.EditModePayement.SetFocus;                
          end;
     end;

     FSFicheSaisie.EditEtatImprimerPlusieursFois.Text:='';
     FSFicheSaisie.EditLastOrdreImprimerPlusieursFois.Text:=FSFicheSaisie.EditOrdreListeMouvement.Text;

     FSFicheSaisie.EditModeSelection.Text:='Nouveau';
end;
  
procedure TFSFicheSaisie.TableauListeMouvementDblClick(
  Sender: TObject);
