          FSFicheSaisie.EditIndiceFinalPontBascule.SelectAll;
          FSFicheSaisie.RBModificationPontBascule.Checked:=true;
     end
     else
     begin
          FSFicheSaisie.RBDetailMouvementAfficher.Checked:=true;
          FSFicheSaisie.RBValidationDetailMouvement.Checked:=true;
          ImporterDetailListeMouvement(FSFicheSaisie.TableauListeMouvement,FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable);
          FermerOptionDetailMouvement;
     end;
end;

procedure TFSFicheSaisie.TableauListeMouvementKeyDown(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var   R,C:integer;  OKListeMouvement:boolean;
begin

if key in[VK_RETURN]then
begin
     if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)then
     begin
          FSFicheSaisie.TableauDetaiMouvement.SetFocus;
     end
     else
     begin
          FermerOptionDetailMouvement;
          C:=FSFicheSaisie.TableauListeMouvement.Col;
          R:=1;
          OKListeMouvement:=false;
          while(R<=FSFicheSaisie.TableauListeMouvement.RowCount-1)and(OKListeMouvement=false)do
          begin
               if(Firstlaters(FSFicheSaisie.TableauListeMouvement.Cells[C,R],longueur(FSFicheSaisie.EditChercherNumeroListeMouvement.Text))=FSFicheSaisie.EditChercherNumeroListeMouvement.Text)
               then OKListeMouvement:=true
               else R:=R+1;
          end;

          if(OKListeMouvement=true)and(R>0)and(R<=FSFicheSaisie.TableauListeMouvement.RowCount-1)then FSFicheSaisie.TableauListeMouvement.Row:=R;
          FSFicheSaisie.EditChercherNumeroListeMouvement.Text:='';
     end;
end;

if(key in[VK_DELETE])then
begin
     if(FSFicheSaisie.RBActiverAutorisationsManipulations.Checked=true)
     and(FSFicheSaisie.RBAutoriserSuppression.Checked=false)then
     begin
          showmessage('Suppression non autorisé !');
          Exit;
     end;

     ChListeMouvement:=IndiqueAdresseListeMouvement(FSFicheSaisie.EditPositionTypeMouvement.Text,TypeProcesReseauxListeMouvement);

     if(TypeProcesReseauxListeMouvement='Réseaux')then
     begin
          showmessage('Opération réseaux non autorisé !');
          Exit;
     end;

     FSFicheSaisie.AfficherOperationDetailMouvement.Visible:=true;
     FSFicheSaisie.BitOperationDetailMouvement.Kind:=bkCancel;
     FSFicheSaisie.BitOperationDetailMouvement.Caption:='Supprimer';
     FSFicheSaisie.EditOperationOrdreListeMouvement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.EditOperationPositionDetailMouvement.Text:='';
     FSFicheSaisie.AfficherOperationDetailMouvement.Caption:='Supprimer le mouvement Ordre: '+FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row];
     FSFicheSaisie.BitOperationDetailMouvement.SetFocus;
end; 

if key in[VK_F3]then
begin
     if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)then
     begin
          if(FSFicheSaisie.EditChercheDateDetailMouvement.Visible=true)
          then FSFicheSaisie.EditChercheDateDetailMouvement.SetFocus
          else
          if(FSFicheSaisie.AfficheParMois.Visible=true)
          then FSFicheSaisie.EditMois.SetFocus;
     end;
end;

end;

procedure TFSFicheSaisie.AfficheOptionDetailMouvementExit(Sender: TObject);
begin
FermerOptionDetailMouvement;
end;

procedure TFSFicheSaisie.TableauMouvementKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
begin

     if key in[VK_ESCAPE]then
     begin
          FSFicheSaisie.TableauMouvement.Visible:=false;
     end;

