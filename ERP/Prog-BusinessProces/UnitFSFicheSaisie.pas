                           end;
                      end;
                 C:=C+1;
                 end;

                 Seek(FDetailMouvement,lDM);
                 write(FDetailMouvement,RDetailMouvement);
                 FSFicheSaisie.TableauDetaiMouvement.Cells[0,R]:=inttostr(lDM);
                 if(PositionDetailMouvementBegin>lDM)then PositionDetailMouvementBegin:=lDM;
                 if(PositionDetailMouvementEnd<lDM)then PositionDetailMouvementEnd:=lDM;

                 if(OKMAJStockAOperer=true)then
                 begin
                      if(SigneMouvementAOperer<>'*')then
                      begin
                           ProcMiseAJourStockArticle(CodeStockConcerneSource,CodeStockConcerneSource,CodeArticleAOperer,FSFicheSaisie.EditTypeStock.Text,SigneMouvementAOperer,QteAOperer,PrixAOperer,NbrNewArticle,NbrChargeArticle,PrixAOperer,NbrNewArticle,NbrChargeArticle,OKMiseAJour);

                           if(FSFicheSaisie.RBAppliquerFormuleComposition.Checked=true)then
