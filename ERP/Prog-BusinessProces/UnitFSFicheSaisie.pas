Procedure AjustementTableauDetaiMouvement(TableauDetaiMouvement:TStringGrid);
var  R,C,CIndice:integer; NotRow,NotCol,ListeColWidthsZero:string;  OKValeZero:boolean;
begin
ListeColWidthsZero:=ListeTypeAffichageFormuleNonVisible(FSFicheSaisie.EditCodeTypeFormuleBase.Text,'TableauDetailMouvement');
//Exit;// ???????????????????????????????????????????????????????????????????????
NotRow:='0-4';

R:=0;
while(R<=TableauDetaiMouvement.RowCount-1)do
begin
     if(ExisteNuminTexte(inttostr(TableauDetaiMouvement.Row),NotRow))
     then TableauDetaiMouvement.RowHeights[R]:=0;
R:=R+1;
end;

NotCol:=InfoNotColTableaux(TableauDetaiMouvement,'TableauDetaiMouvement'+FSFicheSaisie.EditDesignationMouvement.Text)+';0;5';
C:=8;
while(C<=TableauDetaiMouvement.ColCount-1)do
begin
     OKValeZero:=true;
     R:=6;
     while(R<=TableauDetaiMouvement.RowCount-1)and(OKValeZero=true)do
     begin
          if(TableauDetaiMouvement.Cells[1,R]<>'')and(strtoreal(TableauDetaiMouvement.Cells[C,R])>0)
          then OKValeZero:=false;
     R:=R+1;
     end;

     if(strtoboolean(TableauDetaiMouvement.Cells[C,4])=false)
     or(ExisteCharInString(TableauDetaiMouvement.Cells[C,3],ListeColWidthsZero))
     or(OKValeZero=true)
     then
     begin
          if(NotCol='')
          then NotCol:=inttostr(C)
          else NotCol:=NotCol+';'+inttostr(C);
     end;
C:=C+1;
end;

C:=0;
while(C<=TableauDetaiMouvement.ColCount-1)do
begin
     if(ExisteNuminTexte(inttostr(C),NotCol))then
     begin
          TableauDetaiMouvement.ColWidths[C]:=0;
     end;
C:=C+1;
end;

AjusterColWidth(TableauDetaiMouvement,NotRow,NotCol);
end;                          

Procedure AjustementTableauFormules(TableauFormules:TStringGrid);
var  i,R:integer; NotRow,NotCol,ListeRowWidthsZero,ListeColWidthsZero:string;
begin
ListeColWidthsZero:=ListeTypeAffichageFormuleNonVisible(FSFicheSaisie.EditCodeTypeFormuleBase.Text,'TableauFormules');
// ???????????????????????????????????????????????????????????????????????

NotCol:='0;1;3;4';
for i:=0 to TableauFormules.ColCount-1 do
begin
     if ExisteNuminTexte(inttostr(i),NotCol)
     then
     begin
          TableauFormules.ColWidths[i]:=0;
     end;
end;

NotRow:='';
for R:=0 to TableauFormules.RowCount-1 do
begin
     if(strtoreal(TableauFormules.Cells[5,R])=0)
     or(strtoboolean(TableauFormules.Cells[4,R])=false)
     or(ExisteCharInString(TableauFormules.Cells[3,R],ListeColWidthsZero))
     then
     begin
          if(NotRow='')then NotRow:=inttostr(R) else NotRow:=NotRow+';'+inttostr(R);
          TableauFormules.RowHeights[R]:=0;
     end;
end;
AjusterColWidth(TableauFormules,NotRow,NotCol);
end;

Procedure AjustementTableauVariable(TableauVariable:TStringGrid);
var  j:integer; ListeRowWidthsZero,ListeColWidthsZero:string;
begin
//Exit;// ???????????????????????????????????????????????????????????????????????
     ListeColWidthsZero:='1;2;5';
     for j:=1 to 5 do
     begin
          if ExisteNuminTexte(inttostr(j),ListeColWidthsZero)then
          TableauVariable.ColWidths[j]:=0;
     end;
     AjusterColWidth(TableauVariable,'',ListeColWidthsZero);
