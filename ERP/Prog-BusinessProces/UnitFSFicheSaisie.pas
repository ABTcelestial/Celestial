Procedure MiseAJourOptionsFicheSaisieExercice;
var  FichierTexte,FichierTexteCopie:TextFile; AdresseFichierTexte,TexteLigne,AdresseFichierTexteCopie,TexteLigneCopie:string;
     OKData:boolean;
     Source:File;
begin
     TypeProces:='Business';   FichierConcerne:='FMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          if(FichierConcerne<>'')then AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChMouvement:=Adresse;
     assignfile(FMouvement,ChMouvement);
     if FileExists(ChMouvement)then
     begin
          try
          Reset(FMouvement);
          Seek(FMouvement,0);
          While(not eof(FMouvement))do
          begin
               Read(FMouvement,RMouvement);

               OpenFParc(RParc);
               AdresseFichierTexte:=RParc.Parcours+'\'+Exercice+'FRegistreOptionsFicheSaisie'+RMouvement.CodeMouvement+'.txt';
               AssignFile(FichierTexte,AdresseFichierTexte);

               if Not FileExists(AdresseFichierTexte)then
               begin
                    FSFicheSaisie.FichierMemo.Clear;

                    AdresseFichierTexteCopie:=RParc.Parcours+'\'+'FRegistreOptionsFicheSaisie'+RMouvement.CodeMouvement+'.txt';
                    AssignFile(FichierTexteCopie,AdresseFichierTexteCopie);
                    if FileExists(AdresseFichierTexteCopie)then
                    begin
                         try
                         Reset(FichierTexteCopie);
                         while not eof(FichierTexteCopie)do
                         begin
                              Readln(FichierTexteCopie,TexteLigneCopie);
                              FSFicheSaisie.FichierMemo.Lines.Add(TexteLigneCopie);
                         end;
                         finally
                         CloseFile(FichierTexteCopie);
                         end;
                    end;

                    if FileExists(AdresseFichierTexte)then
                    begin
                         AssignFile(Source,AdresseFichierTexte);
                         Erase(Source);
                    end;

                    FSFicheSaisie.FichierMemo.Lines.SaveToFile(AdresseFichierTexte);
               end;
          end;
          finally
          CloseFile(FMouvement);
          end;
     end;

end;

