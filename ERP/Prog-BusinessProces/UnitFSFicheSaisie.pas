Procedure ProcAfficheAnomalieListeMouvement(TableauListeMouvement:TStringGrid; DateMouvementDebut,DateMouvementFin,DateLimiteExecution,CodePays,CodeWilaya,CodeDaira,CodeCommune,OKExecution,CodeTiers,AvisEtablis:string; AfficherValeursMonetaires,AfficherTotal:boolean);
var  R,C,RubriqueTrie,IndiceFinControleTrieRow:integer;  OKMouvement:boolean;  NotRow,NotCol,TypeProces,FichierConserne,Adresse:string;  TotalGeneral:real;
begin
     TableauListeMouvement.ColCount:=33;
     TableauListeMouvement.RowCount:=2;
     TableauListeMouvement.Rows[1].Text:='';
     TableauListeMouvement.Cols[0].Text:='N°';
     TableauListeMouvement.Cols[1].Text:='Ordre';
     TableauListeMouvement.Cols[2].Text:='Num';
     TableauListeMouvement.Cols[3].Text:='P°TM';
     TableauListeMouvement.Cols[4].Text:='P°M';
     TableauListeMouvement.Cols[5].Text:='Date.Etablis.';
     TableauListeMouvement.Cols[6].Text:='Code Type F';
     TableauListeMouvement.Cols[7].Text:='Type Proc';
     TableauListeMouvement.Cols[8].Text:='Fichier Tičrs Consern';
     TableauListeMouvement.Cols[9].Text:='Code Tiers';
     TableauListeMouvement.Cols[10].Text:='Tiers';
     TableauListeMouvement.Cols[11].Text:='Montant Mouvement';
     TableauListeMouvement.Cols[12].Text:='Date Exécution';
     TableauListeMouvement.Cols[13].Text:='C°Payés';
     TableauListeMouvement.Cols[14].Text:='Payés';
     TableauListeMouvement.Cols[15].Text:='C°Wilaya';
     TableauListeMouvement.Cols[16].Text:='Wilaya';
     TableauListeMouvement.Cols[17].Text:='C°Daira';
     TableauListeMouvement.Cols[18].Text:='Daira';
     TableauListeMouvement.Cols[19].Text:='C°Commune';
     TableauListeMouvement.Cols[20].Text:='Commune';
     TableauListeMouvement.Cols[21].Text:='C°Zone';
     TableauListeMouvement.Cols[22].Text:='Zone';
     TableauListeMouvement.Cols[23].Text:='Adresse';
     TableauListeMouvement.Cols[24].Text:='Exécution !';
     TableauListeMouvement.Cols[25].Text:='NumProjet ';
     TableauListeMouvement.Cols[26].Text:='Projet';
     TableauListeMouvement.Cols[27].Text:='Mode Paiement';
     TableauListeMouvement.Cols[28].Text:='Num Domiciliation';
     TableauListeMouvement.Cols[29].Text:='Domiciliation';
     TableauListeMouvement.Cols[30].Text:='Num Pičce';
     TableauListeMouvement.Cols[31].Text:='Num Avis';
     TableauListeMouvement.Cols[32].Text:='OdrMAp';

     TypeProces:='Business';   FichierConserne:='FListeMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
     end;

     ChListeMouvement:=Adresse;
     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
     Seek(FListeMouvement,0);
     R:=0;
     IndiceFinControleTrieRow:=1;
     TotalGeneral:=0;
     while not eof(FListeMouvement)do
     begin
          read(FListeMouvement,RListeMouvement);

          OKMouvement:=not(ControlePositionMouvementTypeMouvement(inttostr(RListeMouvement.PositionTypeMouvement),inttostr(RListeMouvement.PositionMouvement)));

          if(OKMouvement=true)then
          begin
               if(AvisEtablis<>'')and(AvisEtablis<>'Tous')then
               begin
                    if(strtoboolean(AvisEtablis)=true)then
                    begin
                         if(RListeMouvement.ListeNumAvis<>'')
                         then OKMouvement:=true
                         else OKMouvement:=false;
                    end
                    else
                    begin
                         if(RListeMouvement.ListeNumAvis='')
                         then OKMouvement:=true
                         else OKMouvement:=false;
                    end
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(DateMouvementDebut<>'')and(DateMouvementFin<>'')then
               begin
                    if(datecorrecte(DateMouvementDebut)and datecorrecte(DateMouvementFin)and datecorrecte(RListeMouvement.DateMouvement))then
                    begin
                         if(strtodate(RListeMouvement.DateMouvement)>=strtodate(DateMouvementDebut))
                         and(strtodate(RListeMouvement.DateMouvement)<=strtodate(DateMouvementFin))
                         then OKMouvement:=true
                         else OKMouvement:=false;
                    end
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(DateLimiteExecution<>'')then
               begin
                    if(datecorrecte(DateLimiteExecution)and datecorrecte(RListeMouvement.DateExecutionMouvement))then
                    begin
                         if(strtodate(RListeMouvement.DateExecutionMouvement)<=strtodate(DateLimiteExecution))
                         then OKMouvement:=true
                         else OKMouvement:=false;
                    end
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(OKExecution<>'')and(OKExecution<>'Tous')then
               begin
                    if strtoboolean(OKExecution)=RListeMouvement.OKExecution
                    then OKMouvement:=true
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(CodePays<>'')then
               begin
                    if(RListeMouvement.CodePaysExecutionMouvement=CodePays)
                    then OKMouvement:=true
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(CodeWilaya<>'')then
               begin
                    if(RListeMouvement.CodeWilayaExecutionMouvement=CodeWilaya)
                    then OKMouvement:=true
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(CodeTiers<>'')then
               begin
                    if(RListeMouvement.CodeTiers=CodeTiers)
                    then OKMouvement:=true
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(CodeDaira<>'')then
               begin
                    if(RListeMouvement.CodeDairaExecutionMouvement=CodeDaira)
                    then OKMouvement:=true
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               if(CodeCommune<>'')then
               begin
                    if(RListeMouvement.CodeCommuneExecutionMouvement=CodeCommune)
                    then OKMouvement:=true
                    else OKMouvement:=false;
               end;
          end;

          if(OKMouvement=true)then
          begin
               R:=R+1;
               TableauListeMouvement.Rows[R].Text:=inttostr(R);
               TableauListeMouvement.Cells[1,R]:=inttostr(RListeMouvement.OrdreListeMouvement);
               TableauListeMouvement.Cells[2,R]:=inttostr(RListeMouvement.NumListeMouvement);
               TableauListeMouvement.Cells[3,R]:=inttostr(RListeMouvement.PositionTypeMouvement);
               TableauListeMouvement.Cells[4,R]:=inttostr(RListeMouvement.PositionMouvement);
               TableauListeMouvement.Cells[5,R]:=RListeMouvement.DateMouvement;
               TableauListeMouvement.Cells[6,R]:=RListeMouvement.CodeTypeFormule;
               TableauListeMouvement.Cells[7,R]:=RListeMouvement.TypeProces;
               TableauListeMouvement.Cells[8,R]:=RListeMouvement.FichierTiersConserne;
               TableauListeMouvement.Cells[9,R]:=RListeMouvement.CodeTiers;
               RTier:=ChercherTiers(RListeMouvement.TypeProces,RListeMouvement.FichierTiersConserne,RListeMouvement.CodeTiers,'');
               TableauListeMouvement.Cells[10,R]:=RTier.NomTiers+' '+RTier.PrenomTiers;
               TableauListeMouvement.Cells[11,R]:=Vergule(floattostr(RListeMouvement.MontantMouvement),'2','C','');
               TableauListeMouvement.Cells[12,R]:=RListeMouvement.DateExecutionMouvement;
               TableauListeMouvement.Cells[13,R]:=RListeMouvement.CodePaysExecutionMouvement;
               TableauListeMouvement.Cells[14,R]:=ChercherLocalisationGeographique(RListeMouvement.CodePaysExecutionMouvement,'FPays').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[15,R]:=RListeMouvement.CodeWilayaExecutionMouvement;
               TableauListeMouvement.Cells[16,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeWilayaExecutionMouvement,'FWilaya').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[17,R]:=RListeMouvement.CodeDairaExecutionMouvement;
               TableauListeMouvement.Cells[18,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeDairaExecutionMouvement,'FDaira').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[19,R]:=RListeMouvement.CodeCommuneExecutionMouvement;
               TableauListeMouvement.Cells[20,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeCommuneExecutionMouvement,'FCommune').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[21,R]:=RListeMouvement.CodeZoneExecutionMouvement;
               TableauListeMouvement.Cells[22,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeZoneExecutionMouvement,'FZone').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[23,R]:=RListeMouvement.AdresseExecutionMouvement;
               TableauListeMouvement.Cells[24,R]:=booleantostr(RListeMouvement.OKExecution);
               TableauListeMouvement.Cells[25,R]:=RListeMouvement.NumProjetFinance;
               TableauListeMouvement.Cells[26,R]:=ChercherProjetFinance(RListeMouvement.NumProjetFinance,PositionProjetFinancesRecherche).DesignationProjetFinance;
               TableauListeMouvement.Cells[27,R]:=RListeMouvement.ModePaiement;
               TableauListeMouvement.Cells[28,R]:=RListeMouvement.NumDomiciliation;
               TableauListeMouvement.Cells[29,R]:=RListeMouvement.Domiciliation;
               TableauListeMouvement.Cells[30,R]:=RListeMouvement.NumPiece;
               TableauListeMouvement.Cells[31,R]:=RListeMouvement.ListeNumAvis;
               TableauListeMouvement.Cells[32,R]:=RListeMouvement.OrdreListeMouvementAppartenant;

               if(AfficherTotal=true)and(AfficherValeursMonetaires=true)
               then TotalGeneral:=TotalGeneral+RListeMouvement.MontantMouvement;
          end;
     end;
     finally
     CloseFile(FListeMouvement);
     end;

     if(R>0)then
            begin
                  IndiceFinControleTrieRow:=R;
                  if(AfficherTotal=true)and(AfficherValeursMonetaires=true)then
                  begin
                       TableauListeMouvement.RowCount:=R+3;
                       TableauListeMouvement.Rows[TableauListeMouvement.RowCount-1].Text:='';
                       TableauListeMouvement.Rows[TableauListeMouvement.RowCount-2].Text:='';
                       TableauListeMouvement.Cells[11,TableauListeMouvement.RowCount-2]:='';
                       TableauListeMouvement.Cells[10,TableauListeMouvement.RowCount-1]:='Total:';
                       TableauListeMouvement.Cells[11,TableauListeMouvement.RowCount-1]:=Vergule(floattostr(TotalGeneral),'2','C','');;
                  end
                  else TableauListeMouvement.RowCount:=R+1;
            end
            else TableauListeMouvement.RowCount:=2;

     NotRow:='';

     if(AfficherValeursMonetaires=false)
     then NotCol:='1;3;4;6-8;11;13;15;17;19;21'
     else NotCol:='1;3;4;6-8;13;15;17;19;21';

     for C:=1 to TableauListeMouvement.ColCount-1 do
     if ExisteNumInTexte(inttostr(C),NotCol)then TableauListeMouvement.ColWidths[C]:=0;
     AjusterColWidth(TableauListeMouvement,NotRow,NotCol);

     if(DateLimiteExecution<>'')then
     begin
          RubriqueTrie:=12;
     end
     else
     begin
          RubriqueTrie:=5;
     end;

     TrierTableauARowSpecial(TableauListeMouvement,1,IndiceFinControleTrieRow,1,inttostr(RubriqueTrie),'Date','+');

     TableauListeMouvement.Row:=TableauListeMouvement.RowCount-1;
end;

Function ControlePositionMouvementTypeMouvement(PositionTypeMouvement,PositionMouvement:string):boolean;
var  OKControle,OKTypeMouvement,OKMouvement:boolean; TypeProces,FichierConserne,Adresse:string;
begin
     OKControle:=true;

     if(PositionTypeMouvement<>'')then
     begin
          TypeProces:='Business';   FichierConserne:='FTypeMouvement';
          if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
          end;

          ChTypeMouvement:=Adresse;
          assignfile(FTypeMouvement,ChTypeMouvement);
          try
          if FileExists(ChTypeMouvement)then
          Reset(FTypeMouvement)
          else begin affichermessage('Attention ! {'+ChTypeMouvement+'} n''existe pas !'); exit; end;//Rewrite(FTypeMouvement);
          Seek(FTypeMouvement,0);
          OKTypeMouvement:=false;
          while(not eof(FTypeMouvement)and(OKTypeMouvement=false))do
          begin
               Read(FTypeMouvement,RTypeMouvement);
               if(strtointeger(PositionTypeMouvement)=RTypeMouvement.PositionTypeMouvement)then OKTypeMouvement:=true;
          end;
          finally
          CloseFile(FTypeMouvement);
          end;
     end
     else OKControle:=false;

     if(OKControle=true)and(PositionMouvement<>'')and(OKTypeMouvement=true)then
     begin
          TypeProces:='Business';   FichierConserne:='FMouvement';
          if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
          end;

          ChMouvement:=Adresse;
          assignfile(FMouvement,ChMouvement);
          try
          if FileExists(ChMouvement)then
          Reset(FMouvement)
          else begin affichermessage('Attention ! {'+ChMouvement+'} n''existe pas !'); exit; end;//Rewrite(FMouvement);
          Seek(FMouvement,0);
          OKMouvement:=false;
          while(not eof(FMouvement)and(OKMouvement=false))do
          begin
               Read(FMouvement,RMouvement);
               if(strtointeger(PositionTypeMouvement)=RMouvement.PositionTypeMouvement)
               and(strtointeger(PositionMouvement)=RMouvement.PositionMouvement)
               then OKMouvement:=true;
          end;
          finally
          CloseFile(FMouvement);
          end;
     end
     else OKControle:=false;

     if(OKTypeMouvement=true)and(OKMouvement=true)then ControlePositionMouvementTypeMouvement:=true;
end;

