procedure TFSFicheSaisie.EditPositionChercherDetailMouvementKeyDown(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var   OKDetailMouvementExiste:boolean; TypeProcesNOM,FichierConserneNOM,AdresseNOM:string;
      PositionMouvement,CodeTypeFormuleBase,NumLiseMouvementSelect,ChercherNumeroListeMouvement:string;
begin
     if key in[VK_RETURN]then
     begin
          OKDetailMouvementExiste:=false;

          TypeProcesNOM:='Business';   FichierConserneNOM:='DétailMouvement '+FSFicheSaisie.EditDesignationTypeMouvement.Text;
          if not(FunctionAdresseProces(TypeProcesNOM,FichierConserneNOM,'',AdresseNOM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneNOM+' recherché !');
          end;
          ChDetailMouvement:=AdresseNOM;
          assignfile(FDetailMouvement,ChDetailMouvement);
          if FileExists(ChDetailMouvement)then
          begin
               try
               Reset(FDetailMouvement);
               if(FSFicheSaisie.EditPositionChercherDetailMouvement.Text<>'')then
               begin
                    OKDetailMouvementExiste:=true;

                    Seek(FDetailMouvement,strtointeger(FSFicheSaisie.EditPositionChercherDetailMouvement.Text));
                    if not eof(FDetailMouvement)then
                    begin
                         read(FDetailMouvement,RDetailMouvement);
                         RListeMouvementCopie:=ChercherListeMouvement(FSFicheSaisie.EditPositionTypeMouvementRecherche.Text,inttostr(RDetailMouvement.OrdreListeMouvement));
                         ChercherNumeroListeMouvement:=inttostr(RListeMouvementCopie.NumListeMouvement);

                         NumLiseMouvementSelect:='';
                         FSFicheSaisie.EditModeRecherche.Text:='Num';
                         if(FSFicheSaisie.RBSpecifierMouvement.Checked=true)
                         then PositionMouvement:=FSFicheSaisie.EditPositionMouvementRecherche.Text
                         else PositionMouvement:='';

                         if(FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked=true)
                         then CodeTypeFormuleBase:=FSFicheSaisie.EditCodeTypeFormuleBaseRecherche.Text
                         else CodeTypeFormuleBase:='';

                         RTypeMouvement:=ChercherTypeMouvement(strtointeger(FSFicheSaisie.EditPositionTypeMouvementRecherche.Text),'',AdresseFichierConcerne);
                         RMouvement:=ChercherMouvement(FSFicheSaisie.EditPositionTypeMouvementRecherche.Text,strtointeger(FSFicheSaisie.EditPositionMouvementRecherche.Text),AdresseFichierConcerne);

                         FSFicheSaisie.EditDesignationTypeMouvementRecherche.Caption:=RTypeMouvement.DesignationTypeMouvement;
                         FSFicheSaisie.EditDesignationMouvementRecherche.Caption:=RMouvement.DesignationMouvement;


                         ProcAfficheListeMouvementErrones(FSFicheSaisie.TableauListeMouvement,FSFicheSaisie.EditPositionTypeMouvementRecherche.Text,PositionMouvement,CodeTypeFormuleBase,ChercherNumeroListeMouvement,FSFicheSaisie.EditTypeProces.Text,FSFicheSaisie.EditFunctionFichierConcerne.Text,FSFicheSaisie.EditChercherCodeTiers.Text,FSFicheSaisie.EditChercherReferenceMouvement.Text,'',FSFicheSaisie.EditModeRecherche.Text,NumLiseMouvementSelect,FSFicheSaisie.RBChargerPointeurListeMouvement.Checked);
                    end;
               end;
               finally
               CloseFile(FDetailMouvement);
               end;
          end;

          if(OKDetailMouvementExiste=false)then
          begin
               FSFicheSaisie.EditChercherNumeroListeMouvement.SetFocus;
          end;
     end;

     if key in [VK_ESCAPE]then
     begin
          FSFicheSaisie.TableauListeMouvement.SetFocus;
          FSFicheSaisie.AfficherChercherNumeroListeMouvement.Visible:=false;
     end;

     if key in[VK_DOWN]then
     begin
          if(FSFicheSaisie.RBSpecifierMouvement.Checked=true)then FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked:=true
          else
          if(FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked=true)then FSFicheSaisie.RBTousMouvement.Checked:=true
          else
          if(FSFicheSaisie.RBTousMouvement.Checked=true)then FSFicheSaisie.RBSpecifierMouvement.Checked:=true;
     end;

     if key in[VK_UP]then
     begin
          if(FSFicheSaisie.RBSpecifierMouvement.Checked=true)then FSFicheSaisie.RBTousMouvement.Checked:=true
          else
          if(FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked=true)then FSFicheSaisie.RBSpecifierMouvement.Checked:=true
          else
          if(FSFicheSaisie.RBTousMouvement.Checked=true)then FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked:=true;
     end;
end;

