                    end;

                    if(OKFormule=false)
                    and(TableauDetaiMouvement.Cells[C,0]<>'')
                    and(TableauDetaiMouvement.Cells[C,0]=inttostr(RDetailMouvement.RRegistreFormule9.PositionFormule))
