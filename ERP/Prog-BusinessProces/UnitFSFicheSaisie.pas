                                RDetailMouvement.RRegistreFormule4.CodeFormule:=FSFicheSaisie.TableauDetaiMouvement.Cells[C,1];
                                RDetailMouvement.RRegistreFormule4.LibelleFormule:=FSFicheSaisie.TableauDetaiMouvement.Cells[C,2];
