Procedure InitialiserTableauFormules(TableauFormules:TStringGrid);
var R,C:integer;
begin
     TableauFormules.Width:=313;
     TableauFormules.Left:=472;      

     for R:=1 to TableauFormules.RowCount-1 do
     begin
          for C:=5 to TableauFormules.ColCount-1 do
          begin
               TableauFormules.Cells[C,R]:='';
          end;
     end;
end;

Procedure InitialiserTableauDetaiMouvement(TableauDetaiMouvement:TStringGrid; Rownitialise:integer);
var R,C:integer;
begin
     for C:=8 to TableauDetaiMouvement.ColCount-1 do
     begin
          TableauDetaiMouvement.Cells[C,Rownitialise]:='';
     end;
end;

Procedure CalculeFicheSaisie(TableauFormules,TableauVariable,TableauDetaiMouvement:TStringGrid; ModePayement,NbrDecimalePrix:string; RowCalcule:integer; EditCodeTypeFormuleAfficher:TEdit; SetFocusTableauDetaiMouvement:boolean);
var  R,C,l:integer;
     Registre,RegistreCopie:Registres;
     Variable,Resultat,NbrDecimale,NotRows,NotCols:string;
     OKFormule,OKPositifMontant:boolean;
begin
InitialiserRegistre(Registre);
InitialiserTableauDetaiMouvement(TableauDetaiMouvement,RowCalcule);

for C:=8 to TableauDetaiMouvement.ColCount-1 do
begin
     Application.ProcessMessages;
     RFormuleCopie:=ChercherFormule(EditCodeTypeFormuleAfficher.Text,TableauDetaiMouvement.Cells[C,0]);
     RTypeFormuleCopie:=ChercherTypeFormule(EditCodeTypeFormuleAfficher.Text,'');

     if(TableauDetaiMouvement.Cells[C,1]<>'')then
     begin
          l:=1;
          OKFormule:=false;
          Variable:='';
          while(l<=TableauVariable.RowCount-1)and(OKFormule=false)do
          begin
               if(TableauVariable.Cells[2,l]=RFormuleCopie.CodeFormule)then
               begin
                    OKFormule:=true;
                    InitialiserRegistre(RegistreCopie);
                    CalculeFormule('','','','',TableauVariable.Cells[4,l],EditCodeTypeFormuleAfficher.Text,TableauDetaiMouvement,ModePayement,RowCalcule,C,RegistreCopie,RegistreCopie,Variable);
               end;
          l:=l+1;
          end;

          if(ResultCondition(RFormuleCopie.Condition,EditCodeTypeFormuleAfficher.Text,Registre))then
          begin
               CalculeFormule(Variable,
                              RFormuleCopie.CodeFormule,
                              RTypeFormuleCopie.DesignationTypeFormule,
                              RFormuleCopie.Accumuler,
                              RFormuleCopie.FormuleTexte,
                              EditCodeTypeFormuleAfficher.Text,
                              TableauDetaiMouvement,
                              ModePayement,RowCalcule,C,
                              Registre,Registre,Resultat);

               if(TableauDetaiMouvement.Cells[C,3]='%')then
               begin
                    TableauDetaiMouvement.Cells[C,RowCalcule]:=Vergule(floattostr(strtoreal(Resultat)*100),FuncNbrDecimale(floattostr(strtoreal(Resultat)*100)),'C','')+'%';
               end
               else
               begin
                    TableauDetaiMouvement.Cells[C,RowCalcule]:=Vergule(Resultat,NbrDecimalePrix,'C','');
               end;
          end;
     end;
LibererMemoireProcessus('BusinessProces.exe',True);
end;
AjustementTableauDetaiMouvement(TableauDetaiMouvement);

NotRows:='0-4';
AppliquerActiveColsTableaux(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauDetaiMouvement.Name+FSFicheSaisie.EditDesignationMouvement.Text,NotRows,NotCols);

end;

Procedure CalculeRecapeFormules(TableauFormules:TStringGrid; ModePayement,CodeTypeFormule:string);
var  R,C,l:integer;
     Registre,RegistreCopie:Registres;
     Variable,Resultat,NbrDecimale,NbrDecimalePrix,NotRows,NotCols:string;
     OKFormule,OKPositifMontant:boolean;
begin
NbrDecimalePrix:=FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text;

InitialiserRegistre(Registre);

for R:=1 to TableauFormules.RowCount-1 do
begin
     Application.ProcessMessages;
     RFormuleCopie:=ChercherFormule(CodeTypeFormule,TableauFormules.Cells[0,R]);
     RTypeFormuleCopie:=ChercherTypeFormule(CodeTypeFormule,'');

     if(TableauFormules.Cells[1,R]<>'')then
     begin
          if(ResultCondition(RFormuleCopie.Condition,CodeTypeFormule,Registre))then
          begin
               CalculeFormule(Variable,
                              RFormuleCopie.CodeFormule,
                              RTypeFormuleCopie.DesignationTypeFormule,
                              RFormuleCopie.Accumuler,
                              RFormuleCopie.FormuleTexte,
                              CodeTypeFormule,
                              TableauFormules,                              
                              ModePayement,R,2,
                              Registre,Registre,Resultat);

               if(TableauFormules.Cells[3,R]='%')then
               begin
                    TableauFormules.Cells[5,R]:=Vergule(floattostr(strtoreal(Resultat)*100),FuncNbrDecimale(floattostr(strtoreal(Resultat)*100)),'C','')+'%';
               end
               else
               begin
                    TableauFormules.Cells[5,R]:=Vergule(Resultat,NbrDecimalePrix,'C','');
               end;
          end;
     end;
LibererMemoireProcessus('BusinessProces.exe',True);
end;
AjustementTableauFormules(TableauFormules);
end;

Procedure AfficherRecapeFicheSaisie(TableauDetaiMouvement,TableauFormules:TStringGrid; MemoChiffreEnLettres,MemoTitreChiffreEnLettres:TMemo; EditMontantMouvement:TMemo);
var   R,C,m,p,l,n,RowVariable,Long1,Long5,Long6,Long7,LongMax:integer;
      OKVariable,OKFormule,OKFormuleDown:boolean;
      RFormuleTeste,RFormuleTesteDown:RFormules;
begin
     InitialiserTableauFormules(TableauFormules);

     l:=1;
     while(l<=TableauFormules.RowCount-1)do
     begin
          if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
          Application.ProcessMessages;
          C:=8;
          while(C<=TableauDetaiMouvement.ColCount-1)do
          begin
               if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
               Application.ProcessMessages;
               if(TableauFormules.Cells[0,l]=TableauDetaiMouvement.Cells[C,0])then
               begin
                    Application.ProcessMessages;
                    R:=6;
                    while(R<=TableauDetaiMouvement.RowCount-1)do
                    begin
                         if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
                         Application.ProcessMessages;
                         if(TableauFormules.Cells[3,l]='%')then
                         begin
                              if(strtoreal(TableauFormules.Cells[5,l])<>0)then
                              begin
                                   if(strtoreal(TableauDetaiMouvement.Cells[C,R])<>0)
                                   then TableauFormules.Cells[5,l]:=floattostr((strtoreal(TableauFormules.Cells[5,l])+strtoreal(TableauDetaiMouvement.Cells[C,R]))/2);
                              end
                              else
                              begin
                                   if(strtoreal(TableauDetaiMouvement.Cells[C,R])<>0)
                                   then TableauFormules.Cells[5,l]:=TableauDetaiMouvement.Cells[C,R];
                              end;
                         end
                         else
                         begin
                              TableauFormules.Cells[5,l]:=Vergule(floattostr(strtoreal(TableauFormules.Cells[5,l])+strtoreal(TableauDetaiMouvement.Cells[C,R])),'2','C',TableauFormules.Cells[3,l]);
                         end;
                    R:=R+1;
                    end;

                    if(TableauFormules.Cells[3,l]='%')
                    then TableauFormules.Cells[5,l]:=Vergule(TableauFormules.Cells[5,l],FuncNbrDecimale(floattostr(strtoreal(TableauFormules.Cells[5,l])*100)),'C',TableauFormules.Cells[3,l]);
               end;
          C:=C+1;
          end;
     l:=l+1;
     end;

     if(WithoutChar(FSFicheSaisie.EditCodeTypeFormuleRecape.Text,'')<>'')then CalculeRecapeFormules(TableauFormules,FSFicheSaisie.EditModePayement.Text,FSFicheSaisie.EditCodeTypeFormuleRecape.Text);

     if(FSFicheSaisie.RBAfficherTauxFormules.Checked=true)then AssocierTauxFormule;
     AjustementTableauFormules(TableauFormules);

     // TableauValeurParVariable************************************************
     FSFicheSaisie.TableauValeurParVariable.ColCount:=8;
     FSFicheSaisie.TableauValeurParVariable.Cols[0].Text:='P°';
     FSFicheSaisie.TableauValeurParVariable.Cols[1].Text:='Code';
     FSFicheSaisie.TableauValeurParVariable.Cols[2].Text:='Libellé';
     FSFicheSaisie.TableauValeurParVariable.Cols[3].Text:='Type Aff.';
     FSFicheSaisie.TableauValeurParVariable.Cols[4].Text:='Validité';
     FSFicheSaisie.TableauValeurParVariable.Cols[5].Text:='Base';
     FSFicheSaisie.TableauValeurParVariable.Cols[6].Text:='Taux';
     FSFicheSaisie.TableauValeurParVariable.Cols[7].Text:='Valeur';

     FSFicheSaisie.TableauValeurParVariable.RowCount:=2;
     FSFicheSaisie.TableauValeurParVariable.Rows[1].Text:='';

     FSFicheSaisie.MemoValeurParVariable.Lines.Text:='';

     TFormuleCopie:=RemplireTFormule(FSFicheSaisie.EditCodeTypeFormuleAfficher.Text);

     if(FSFicheSaisie.RBAfficherDetailVariable.Checked=true)then
     begin
           //if(FSFicheSaisie.EditCodeTypeFormuleRecape.Text='')then //Par Tableau DétailMouvements

           begin
                 RowVariable:=0;
                 C:=8;
                 while(C<=TableauDetaiMouvement.ColCount-1)do
                 begin
                      if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
                      Application.ProcessMessages;
                      if(strtoboolean(TableauDetaiMouvement.Cells[C,4])=true)and(TableauDetaiMouvement.Cells[C,3]='%')and(TableauDetaiMouvement.Cells[C,2]<>FSFicheSaisie.EditVariableConcerneTypeFormule.Text)then
                      begin
                           Application.ProcessMessages;
                           R:=6;
                           while(R<=TableauDetaiMouvement.RowCount-1)do
                           begin
                                if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
                                Application.ProcessMessages;

                                n:=1;
                                OKVariable:=false;
                                while(n<=RowVariable)and(OKVariable=false)do
                                begin
                                     if(FSFicheSaisie.TableauValeurParVariable.Cells[0,n]=TableauDetaiMouvement.Cells[C,0])
                                     and(FSFicheSaisie.TableauValeurParVariable.Cells[6,n]=TableauDetaiMouvement.Cells[C,R])
                                     then
                                     begin
                                          OKVariable:=true;

                                          m:=C+1;
                                          OKFormule:=false;
                                          while(m<=TableauDetaiMouvement.ColCount-1)and(OKFormule=false)do
                                          begin
                                               if ExisteCharInString(WithoutChar(TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[C,0])].Accumuler,'='),TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[m,0])].FormuleTexte)then
                                               begin
                                                    OKFormule:=true;
                                                    FSFicheSaisie.TableauValeurParVariable.Cells[7,n]:=floattostr(strtoreal(FSFicheSaisie.TableauValeurParVariable.Cells[7,n])+strtoreal(TableauDetaiMouvement.Cells[m,R]));

                                                    ////////////////////////////////////////
                                                    p:=C-1;
                                                    OKFormuleDown:=false;
                                                    while(p>=8)and(OKFormuleDown=false)do
                                                    begin
                                                         if(ExisteCharInString('+'+TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[m,0])].Base,TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[p,0])].Accumuler))then
                                                         begin
                                                              FSFicheSaisie.TableauValeurParVariable.Cells[5,n]:=floattostr(strtoreal(FSFicheSaisie.TableauValeurParVariable.Cells[5,n])+strtoreal(TableauDetaiMouvement.Cells[p,R]));
                                                         end
                                                         else
                                                         if(ExisteCharInString('-'+TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[m,0])].Base,TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[p,0])].Accumuler))then
                                                         begin
                                                              FSFicheSaisie.TableauValeurParVariable.Cells[5,n]:=floattostr(strtoreal(FSFicheSaisie.TableauValeurParVariable.Cells[5,n])-strtoreal(TableauDetaiMouvement.Cells[p,R]));
                                                         end
                                                         else
                                                         if(ExisteCharInString('='+TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[m,0])].Base,TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[p,0])].Accumuler))or(ExisteCharInString(TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[m,0])].Base,TFormuleCopie[strtointeger(TableauDetaiMouvement.Cells[p,0])].FormuleTexte))then
                                                         begin
                                                              OKFormuleDown:=true;
                                                              FSFicheSaisie.TableauValeurParVariable.Cells[5,n]:=floattostr(strtoreal(FSFicheSaisie.TableauValeurParVariable.Cells[5,n])+strtoreal(TableauDetaiMouvement.Cells[p,R]));
                                                         end;
                                                    p:=p-1;
                                                    end;
                                                    ////////////////////////////////////////
                                               end;
                                          m:=m+1;
                                          end;
                                     end;
                                n:=n+1;
                                end;

                                if(OKVariable=false)then
                                begin
                                     RowVariable:=RowVariable+1;
                                     FSFicheSaisie.TableauValeurParVariable.Rows[RowVariable].Text:='';
                                     FSFicheSaisie.TableauValeurParVariable.Cells[0,RowVariable]:=TableauDetaiMouvement.Cells[C,0];
                                     FSFicheSaisie.TableauValeurParVariable.Cells[1,RowVariable]:=TableauDetaiMouvement.Cells[C,1];
                                     FSFicheSaisie.TableauValeurParVariable.Cells[2,RowVariable]:=TableauDetaiMouvement.Cells[C,2];
                                     FSFicheSaisie.TableauValeurParVariable.Cells[3,RowVariable]:=TableauDetaiMouvement.Cells[C,3];
                                     FSFicheSaisie.TableauValeurParVariable.Cells[4,RowVariable]:=TableauDetaiMouvement.Cells[C,4];
                                     FSFicheSaisie.TableauValeurParVariable.Cells[5,RowVariable]:='';
                                     FSFicheSaisie.TableauValeurParVariable.Cells[6,RowVariable]:=TableauDetaiMouvement.Cells[C,R];

                                     m:=C+1;
                                     OKFormule:=false;
                                     while(m<=TableauDetaiMouvement.ColCount-1)and(OKFormule=false)do
