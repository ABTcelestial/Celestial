     begin
          FSFicheSaisie.TableauMultiArticle.RowCount:=2;
          FSFicheSaisie.TableauMultiArticle.Rows[1].Text:='';

          if strtointeger(Firstlaters(FSFicheSaisie.EditOrdreCompteComptableArticleMAJ.Text,2))in[1..6]then
          begin
               FSFicheSaisie.EditRechercheCodeSFamilleMAJ.Text:=FSFicheSaisie.TableauRechercheFamille.Cells[1,FSFicheSaisie.TableauRechercheFamille.Row];
               FSFicheSaisie.EditRechercheDesigSFamilleMAJ.Text:=FSFicheSaisie.TableauRechercheFamille.Cells[2,FSFicheSaisie.TableauRechercheFamille.Row];

               TypeStock:='Article';
               NumProjet:='';
               CodeSFamille:=FSFicheSaisie.EditRechercheCodeSFamilleMAJ.Text;
               TypeProces:='Commercial';   FichierConcerne:='FStock'+TypeStock+NumProjet;
               if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
               begin
                    AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
               end;
               ChStockArticle:=Adresse;
               ProcListeStockSaisieGlobale(FSFicheSaisie.TableauMultiArticle,ChStockArticle,'','',CodeSFamille);

               FSFicheSaisie.TableauRechercheFamille.Visible:=false;
               FSFicheSaisie.TableauMultiArticle.SetFocus;
          end;

          if strtointeger(Firstlaters(FSFicheSaisie.EditOrdreCompteComptableArticleMAJ.Text,2))in[10]then
          begin
               FSFicheSaisie.EditRechercheCodeSFamilleMAJ.Text:='';
               FSFicheSaisie.EditRechercheDesigSFamilleMAJ.Text:='';

               FSFicheSaisie.TableauMultiArticle.ColCount:=FSFicheSaisie.TableauRechercheFamille.ColCount;

               FSFicheSaisie.TableauMultiArticle.ColCount:=11;
               FSFicheSaisie.TableauMultiArticle.Cols[0].Text:='N°';
               FSFicheSaisie.TableauMultiArticle.Cols[1].Text:='Code';
               FSFicheSaisie.TableauMultiArticle.Cols[2].Text:='Désignation';
               FSFicheSaisie.TableauMultiArticle.Cols[3].Text:='Réference';
               FSFicheSaisie.TableauMultiArticle.Cols[4].Text:='UM';
               FSFicheSaisie.TableauMultiArticle.Cols[5].Text:='Qte en Stock';
               FSFicheSaisie.TableauMultiArticle.Cols[6].Text:='Prix d''Achat';
               FSFicheSaisie.TableauMultiArticle.Cols[7].Text:='Prix VD';
               FSFicheSaisie.TableauMultiArticle.Cols[8].Text:='Prix VG';
               FSFicheSaisie.TableauMultiArticle.Cols[9].Text:='Prix VDG';
               FSFicheSaisie.TableauMultiArticle.Cols[10].Text:='Quantité Opération';

               if(TypeStock='Marche')
               then FSFicheSaisie.TableauMultiArticle.Cols[6].Text:='Coűt Unitaire'
               else FSFicheSaisie.TableauMultiArticle.Cols[6].Text:='Prix d''Achat';

               if(TypeStock='Marche')
               then FSFicheSaisie.TableauMultiArticle.Cols[7].Text:='Prix Marché'
               else FSFicheSaisie.TableauMultiArticle.Cols[7].Text:='P.V.D';

               if(TypeStock='Marche')
               then FSFicheSaisie.TableauMultiArticle.Cols[8].Text:='Prix Soutraitance'
               else FSFicheSaisie.TableauMultiArticle.Cols[8].Text:='P.V.G';

               if(TypeStock='Marche')
               then FSFicheSaisie.TableauMultiArticle.Cols[9].Text:='Prix Attache'
               else FSFicheSaisie.TableauMultiArticle.Cols[9].Text:='P.V.D.G';

               FSFicheSaisie.TableauMultiArticle.RowCount:=2;
               FSFicheSaisie.TableauMultiArticle.Rows[1].Text:='';

               l:=0;
               R:=1;
               while R<=FSFicheSaisie.TableauRechercheFamille.RowCount-1 do
               begin
                    if(FSFicheSaisie.TableauRechercheFamille.Cells[10,R]='OK')then
                    begin
                         l:=l+1;
                         FSFicheSaisie.TableauMultiArticle.Rows[l].Text:=FSFicheSaisie.TableauRechercheFamille.Rows[R].Text;
                         FSFicheSaisie.TableauMultiArticle.Cells[10,l]:='';
                         FSFicheSaisie.TableauMultiArticle.Cells[0,l]:=inttostr(l);
                    end;
               R:=R+1;
               end;

               if(l>0)then
               begin
                    FSFicheSaisie.TableauMultiArticle.RowCount:=l+1;

                    if(l=1)
                    then FSFicheSaisie.EditRechercheDesigSFamilleMAJ.Text:='Un Article'
                    else FSFicheSaisie.EditRechercheDesigSFamilleMAJ.Text:= inttostr(l)+' Articles';
               end
               else
               begin
                    FSFicheSaisie.TableauMultiArticle.RowCount:=2;
                    FSFicheSaisie.EditRechercheDesigSFamilleMAJ.Text:='Pas d''Article'
               end;

               AjusterColWidth(FSFicheSaisie.TableauMultiArticle,'','');

               FSFicheSaisie.TableauRechercheFamille.Visible:=false;
               FSFicheSaisie.TableauMultiArticle.SetFocus;
          end;

          FSFicheSaisie.TableauMultiArticle.ColWidths[2]:=FSFicheSaisie.TableauMultiArticle.Width-
                                                          FSFicheSaisie.TableauMultiArticle.ColWidths[0]-
                                                          FSFicheSaisie.TableauMultiArticle.ColWidths[1]-
                                                          FSFicheSaisie.TableauMultiArticle.ColWidths[10]-10;

          FSFicheSaisie.TableauMultiArticle.Col:=10;
     end;
end;

