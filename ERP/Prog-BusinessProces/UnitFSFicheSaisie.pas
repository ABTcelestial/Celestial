Function MiseAJourStockFormuleComposition(CodeStockStructure,TypeStock,CodeArticle,SigneMouvement:string; QuantiteProdAOperer:real; RowIn:integer; var RowOut:integer):boolean;
var  NbrNewArticle,NbrChargeArticle:integer;
     OKFormule:boolean;
     QuantiteFormule,PrixFormule,CoutArticle:real;
     OKMiseAJour,MemoirOKMAJout:boolean;
begin
     OKMiseAJour:=false;
     MemoirOKMAJout:=false;

     OpenFParc(RParc);
     ChFormuleComposition:=RParc.Parcours+'\'+Exercice+'FFormuleComposition';
     assignfile(FFormuleComposition,ChFormuleComposition);
     if FileExists(ChFormuleComposition)then
     begin
          Reset(FFormuleComposition);
          Seek(FFormuleComposition,0);
          while not eof(FFormuleComposition) do
          begin
               Read(FFormuleComposition,RFormuleComposition);
               
               if(RFormuleComposition.CodeStockStructure=CodeStockStructure)
               and(RFormuleComposition.TypeStock=TypeStock)
               and(RFormuleComposition.CodeProd=CodeArticle)
               then
               begin
                    QuantiteFormule:=QuantiteProdAOperer*(RFormuleComposition.CoefficientComposition+(RFormuleComposition.CoefficientPerte*RFormuleComposition.NbMat));

                    PrixFormule:=0;
                    NbrNewArticle:=0;
                    NbrChargeArticle:=0;
                    CoutArticle:=0;
                    ProcMiseAJourStockArticle(RFormuleComposition.CodeStockStructure,RFormuleComposition.CodeStockStructure,RFormuleComposition.CodeMat,RFormuleComposition.TypeStock,SigneMouvement,QuantiteFormule,PrixFormule,NbrNewArticle,NbrChargeArticle,PrixFormule,NbrNewArticle,NbrChargeArticle,OKMiseAJour);

                    if(CoutArticle=0)then CoutArticle:=PrixFormule;

                    if(OKMiseAJour=true)then
                    begin
                         MemoirOKMAJout:=true;

                         if(QuantiteFormule>=0)then
                         begin
                              if(SigneMouvement='+')then FSFormuleComposition.RBEntreeStock.Checked:=true;
                              if(SigneMouvement='-')then FSFormuleComposition.RBSortieStock.Checked:=true;
                         end
                         else                                                              
                         begin
                              if(SigneMouvement='+')then FSFormuleComposition.RBRegularisationEntreeStock.Checked:=true;
                              if(SigneMouvement='-')then FSFormuleComposition.RBRegularisationSortieStock.Checked:=true;
                         end;

                         RowIn:=RowIn+1;
                         FSFormuleComposition.TableauDetailOperationFormuleComposition.Cells[1,RowIn]:=RFormuleComposition.CodeMat;
                         FSFormuleComposition.TableauDetailOperationFormuleComposition.Cells[2,RowIn]:=RFormuleComposition.DesignMat;
                         FSFormuleComposition.TableauDetailOperationFormuleComposition.Cells[3,RowIn]:=RFormuleComposition.RefMat;
                         FSFormuleComposition.TableauDetailOperationFormuleComposition.Cells[4,RowIn]:=RFormuleComposition.UMMat;
                         FSFormuleComposition.TableauDetailOperationFormuleComposition.Cells[5,RowIn]:=Vergule(floattostr(CoutArticle),'2','C','');
                         FSFormuleComposition.TableauDetailOperationFormuleComposition.Cells[6,RowIn]:=Vergule(floattostr(QuantiteFormule),'2','C','');
                         FSFormuleComposition.TableauDetailOperationFormuleComposition.Cells[7,RowIn]:=Vergule(floattostr(PrixFormule),'2','C','');
                    end;
               end;
          end;
          CloseFile(FFormuleComposition);
     end;
             
     MiseAJourStockFormuleComposition:=MemoirOKMAJout;
     FSFormuleComposition.RBConfirmeFormuleCompositionApplique.Checked:=MemoirOKMAJout;
     RowOut:=RowIn;
end;

Procedure ProcAfficheStockArticleListe(TableauStockArticle:TStringGrid; TypeStock,CodeStockArticle,CompteConcerne,CodeSFamille,CodeArticle,DesignationArticle,CodeArticleSelection:string; DistinguerDesignationReference:boolean; RowIn:integer; var RowOut:integer);
const NbrALire=100;

var
    k,l,ARowSelect:integer;
    OKStockArticle:boolean;
    TypeProces,FichierConcerne,Adresse,NotCol,Indice:string;
    TableauRStockArticle:array[1..NbrALire]of RStocks;
    NbrRStockArticleLus,Nbr:integer;
begin
if(CompteConcerne<>'X')then
begin
     FSFicheSaisie.TableauCompteConcerne.Visible:=true;
     if(RowIn=0)then
     begin
           TableauStockArticle.ColCount:=19;
           TableauStockArticle.Cols[0].Text:='N°';
           TableauStockArticle.Cols[1].Text:='Code';
           TableauStockArticle.Cols[2].Text:='Désignation';
           TableauStockArticle.Cols[3].Text:='Réference';
           TableauStockArticle.Cols[4].Text:='UM';
           TableauStockArticle.Cols[5].Text:='Qte.Entrée';
           TableauStockArticle.Cols[6].Text:='Qte.Sortie';
           TableauStockArticle.Cols[7].Text:='Qte en Stock';
           TableauStockArticle.Cols[8].Text:='Qte.Initial';
           TableauStockArticle.Cols[9].Text:='Qte.Limite';

           if(TypeStock='Marche')
           then TableauStockArticle.Cols[10].Text:='Coűt Unitaire'
           else TableauStockArticle.Cols[10].Text:='Prix d''Achat';

           if(TypeStock='Marche')
           then TableauStockArticle.Cols[11].Text:='Prix Marché'
           else TableauStockArticle.Cols[11].Text:='P.V.D';

           if(TypeStock='Marche')
           then TableauStockArticle.Cols[12].Text:='Prix Soutraitance'
           else TableauStockArticle.Cols[12].Text:='P.V.G';

           if(TypeStock='Marche')
           then TableauStockArticle.Cols[13].Text:='Prix Attache'
           else TableauStockArticle.Cols[13].Text:='P.V.D.G';

           TableauStockArticle.Cols[14].Text:='Emplacement';
           TableauStockArticle.Cols[15].Text:='Code Barre';
           TableauStockArticle.Cols[16].Text:='Formule';
           TableauStockArticle.Cols[17].Text:='Observation';
           TableauStockArticle.Cols[18].Text:='Enreg';
           TableauStockArticle.RowCount:=2;
           TableauStockArticle.Rows[1].Text:='';

           Indice:='';
     end
     else
     begin
          Indice:=' BDP';
     end;

     k:=RowIn; 

     TypeProces:='Commercial';

     if(FunctStockSpecifierParStructure(false)=false)then CodeStockArticle:='';
     if(TypeStock<>'Marche')
     then FichierConcerne:='FStock'+TypeStock+CodeStockArticle
     else FichierConcerne:='FStock'+TypeStock;

     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChStockArticle:=Adresse;
     assignfile(FStockArticle,ChStockArticle);
     Try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else begin affichermessage('Attention ! {'+ChStockArticle+'} n''existe pas !'); exit; end;//Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     ARowSelect:=1;
     while not eof(FStockArticle)do
     begin
          //read(FStockArticle,RStockArticle);  //Application.ProcessMessages;

          BlockRead(FStockArticle,TableauRStockArticle,NbrALire,NbrRStockArticleLus);

          Nbr:=1;
          while Nbr<=NbrRStockArticleLus do
          begin
               RStockArticle:=TableauRStockArticle[Nbr];

          if(CompteConcerne<>'')then
          begin
               if(ExisteFirstLatersNuminTexte(AnsiUpperCase(RStockArticle.Code),AnsiUpperCase(CompteConcerne)))
               then OKStockArticle:=true
               else OKStockArticle:=false;
          end
          else OKStockArticle:=true;

          if(OKStockArticle=true)then
          begin
               if(CodeSFamille<>'')then
               begin
                    if(AnsiUpperCase(Firstlaters(RStockArticle.Code,longueur(CodeSFamille)))=AnsiUpperCase(CodeSFamille))
                    then OKStockArticle:=true
                    else OKStockArticle:=false;
               end
               else OKStockArticle:=true;
          end;

          if(OKStockArticle=true)then
          begin
               if(CodeArticle<>'')then
               begin
                    if(AnsiUpperCase(Firstlaters(RStockArticle.Code,Longueur(CodeArticle)))=AnsiUpperCase(CodeArticle))
                    then OKStockArticle:=true
                    else OKStockArticle:=false;
               end
               else OKStockArticle:=true;
          end;

          if(OKStockArticle=true)then
          begin
               if(DesignationArticle<>'')then
               begin
                    {if(ExisteCharInString(AnsiUpperCase(DesignationArticle),AnsiUpperCase(RStockArticle.Design+' '+RStockArticle.Ref)))
                    //if(AnsiUpperCase(Firstlaters(RStockArticle.Design+' '+RStockArticle.Ref,Longueur(DesignationArticle)))=AnsiUpperCase(DesignationArticle))
                    then OKStockArticle:=true
                    else OKStockArticle:=false; }

                    OKStockArticle:=RechercheSequenceParMotsCle(AnsiUpperCase(DesignationArticle),AnsiUpperCase(RStockArticle.Design+' '+RStockArticle.Ref));
               end
               else OKStockArticle:=true;
          end;

          if(RowIn>0)and(OKStockArticle=true)then
          begin
               l:=1;
               while(l<=RowIn)and(OKStockArticle=true)do
               begin
                    if(DistinguerDesignationReference=true)then
                    begin
                         if(TableauStockArticle.Cells[1,l]=RStockArticle.Code)
                         and(TableauStockArticle.Cells[2,l]=RStockArticle.Design)
                         and(TableauStockArticle.Cells[3,l]=RStockArticle.Ref)
                         and(TableauStockArticle.Cells[4,l]=RStockArticle.UM)
                         then OKStockArticle:=false;
                    end
                    else
                    begin
                         if(TableauStockArticle.Cells[1,l]=RStockArticle.Code)
                         and((TableauStockArticle.Cells[2,l]+' '+TableauStockArticle.Cells[3,l]=RStockArticle.Design+RStockArticle.Ref)or(TableauStockArticle.Cells[2,l]+TableauStockArticle.Cells[3,l]=RStockArticle.Design+' '+RStockArticle.Ref)or(TableauStockArticle.Cells[2,l]+' '+TableauStockArticle.Cells[3,l]=RStockArticle.Design+' '+RStockArticle.Ref)or(TableauStockArticle.Cells[2,l]+TableauStockArticle.Cells[3,l]=RStockArticle.Design+RStockArticle.Ref))
                         and(TableauStockArticle.Cells[4,l]=RStockArticle.UM)
                         then OKStockArticle:=false;
                    end;

               l:=l+1;
               end;
          end;

          if(OKStockArticle=true)then
          begin
               k:=k+1;
               TableauStockArticle.Rows[k].Text:=inttostr(k)+Indice;
               TableauStockArticle.Cells[1,k]:=RStockArticle.Code;
               TableauStockArticle.Cells[2,k]:=RStockArticle.Design;
               TableauStockArticle.Cells[3,k]:=RStockArticle.Ref;
               TableauStockArticle.Cells[4,k]:=RStockArticle.UM;
               TableauStockArticle.Cells[5,k]:=floattostr(RStockArticle.QteEntree);
               TableauStockArticle.Cells[6,k]:=floattostr(RStockArticle.QteSortie);
               TableauStockArticle.Cells[7,k]:=floattostr(RStockArticle.QteStock);
               TableauStockArticle.Cells[8,k]:=floattostr(RStockArticle.QteInitial);
               TableauStockArticle.Cells[9,k]:=floattostr(RStockArticle.QteLimite);
               TableauStockArticle.Cells[10,k]:=floattostr(RStockArticle.CoutUnitaire);
               TableauStockArticle.Cells[11,k]:=floattostr(RStockArticle.PrixVenteDetaille);
               TableauStockArticle.Cells[12,k]:=floattostr(RStockArticle.PrixVenteGros);
               TableauStockArticle.Cells[13,k]:=floattostr(RStockArticle.PrixVenteDemiGros);
               TableauStockArticle.Cells[14,k]:=RStockArticle.Emplace;
               TableauStockArticle.Cells[15,k]:=RStockArticle.CodeBarre;
               TableauStockArticle.Cells[16,k]:=RStockArticle.Formule;
               TableauStockArticle.Cells[17,k]:=RStockArticle.Observ;
               TableauStockArticle.Cells[18,k]:=RStockArticle.enregistrement;

               if(CodeArticleSelection<>'')and((CodeArticleSelection=RStockArticle.Code)or(RStockArticle.CodeBarre=CodeArticleSelection))then ARowSelect:=k;
          end;
          Nbr:=Nbr+1;
          end;
     end;
     finally
     closefile(FStockArticle);
     end;

     RowOut:=k;

     if(k>0)then TableauStockArticle.RowCount:=k+1
            else TableauStockArticle.RowCount:=2;

     TableauStockArticle.Row:=ARowSelect;

     if(TypeStock='Marche')
     then NotCol:='5-9;14-18'
     else NotCol:='14-18';

     for k:=1 to TableauStockArticle.ColCount-1 do if existenumintexte(inttostr(k),NotCol)then TableauStockArticle.ColWidths[k]:=0;
     AjusterColWidth(TableauStockArticle,'',NotCol);
     if(TableauStockArticle.ColWidths[2]>500)then TableauStockArticle.ColWidths[2]:=500;
end;
end;

Procedure TrierFormuleFS(Indice:integer);
var OK:boolean; R,m,i,j,ARow,VarA,VarB:integer;
begin
R:=FSFicheSaisie.TableauFormules.RowCount;
FSFicheSaisie.TableauFormules.Rows[R].Text:='';
OK:=true;
while(OK=true)do
begin
OK:=false;
for i:=1 to FSFicheSaisie.TableauFormules.RowCount-2 do
begin
     if(FSFicheSaisie.TableauFormules.Cells[Indice,i]>FSFicheSaisie.TableauFormules.Cells[Indice,i+1])then
     begin
          OK:=true;
          for m:=1 to 3 do
          begin
               if m=1 then begin VarA:=R; VarB:=i;end;
               if m=2 then begin VarA:=i; VarB:=i+1;end;
               if m=3 then begin VarA:=i+1; VarB:=R;end;
               for j:=0 to FSFicheSaisie.TableauFormules.ColCount-1 do
               begin
                    FSFicheSaisie.TableauFormules.Cells[j,VarA]:=FSFicheSaisie.TableauFormules.Cells[j,VarB];
               end;
          end;
          FSFicheSaisie.TableauFormules.Rows[R].Text:='';
     end;
end;
end;

for i:=1 to FSFicheSaisie.TableauFormules.RowCount-1 do
begin
     FSFicheSaisie.TableauFormules.Cells[0,i]:=inttostr(i);
end;

end;

