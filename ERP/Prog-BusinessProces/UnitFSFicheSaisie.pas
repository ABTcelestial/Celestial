Procedure ImprimerBonQuantitatif(ApercuAvantImpression:boolean);
var R,m,NPage:integer;  OK,OKAvis:boolean; Origine,ModePaiement:string;
begin
PrintBonQuantitatif.ModePaiementCheque.Enabled:=false;
PrintBonQuantitatif.ModePaiementEspece.Enabled:=false;
PrintBonQuantitatif.ModePaiementATerme.Enabled:=false;
PrintBonQuantitatif.ModePaiement.Caption:='Chčque N°:';

PrintBonQuantitatif.TitreSignataire.Caption:=FSFicheSaisie.EditSignataire.Text;

ModePaiement:=FSFicheSaisie.EditModePayement.Text;

OKAvis:=false;

if(OKAvis=true)then
begin
     if(ModePaiement='Chčque')
     or(ModePaiement='Bon')
     or(ModePaiement='Virement')
     then
     begin
          PrintBonQuantitatif.ModePaiementCheque.Enabled:=true;
          PrintBonQuantitatif.ModePaiement.Caption:=ModePaiement;
     end;

     if(ModePaiement='Espčce')then
     begin
          PrintBonQuantitatif.ModePaiementEspece.Enabled:=true;
     end;

     if(ModePaiement<>'Chčque')
     and(ModePaiement<>'Bon')
     and(ModePaiement<>'Virement')
     and(ModePaiement<>'Espčce')
     then
     begin
          PrintBonQuantitatif.ModePaiementATerme.Enabled:=true;
     end;

end
else
begin
     if(ModePaiement<>'')then
     begin
          if(ModePaiement='Chčque')
          or(ModePaiement='Bon')
          or(ModePaiement='Virement')
          then
          begin
               PrintBonQuantitatif.ModePaiementCheque.Enabled:=true;
               PrintBonQuantitatif.ModePaiement.Caption:=ModePaiement;
          end;

          if(ModePaiement='Espčce')
          then
          begin
               PrintBonQuantitatif.ModePaiementEspece.Enabled:=true;
          end;

          if(ModePaiement='A Terme')
          then
          begin
               PrintBonQuantitatif.ModePaiementATerme.Enabled:=true;
          end;

          if(ModePaiement='Autres')
          then
          begin
               PrintBonQuantitatif.ModePaiementCheque.Enabled:=true;
               PrintBonQuantitatif.ModePaiement.Caption:=ModePaiement;
          end;
     end;
