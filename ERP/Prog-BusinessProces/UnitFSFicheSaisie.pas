          else
          if(strtoreal(TableauListeMouvement.Cells[11,TableauListeMouvement.Row])<MontantListeAvis)
          then FSFicheSaisie.EditNumAvis.Color:=clYellow
          else FSFicheSaisie.EditNumAvis.Color:=clRed;

          FSFicheSaisie.EditMontantAvis.Text:=vergule(floattostr(MontantListeAvis),'2','C','');
          FSFicheSaisie.EditMontantAvis.Color:=FSFicheSaisie.EditNumAvis.Color;
     end;

     if(FSFicheSaisie.RBTailleColonneMax.Checked=true)then
     begin
          for C:=1 to TableauDetaiMouvement.ColCount-1 do
