                    end;
               end;
          end;
     end;

     LibererMemoireProcessus('BusinessProces.exe',True);

     AfficherDetailMoyenTransport('','Mouvement',FSFicheSaisie.EditPositionMouvement.Text,FSFicheSaisie.EditOrdreListeMouvement.Text,'',FSFicheSaisie.EditCodeTiersConserne.Text,
                                  FSFicheSaisie.EditPositionMoyenTransport,
                                  FSFicheSaisie.EditTypeFiche,
                                  FSFicheSaisie.EditNumMovementPrelevement,
                                  FSFicheSaisie.EditNumFiche,
                                  FSFicheSaisie.EditMatriculeEffectifValider,
                                  FSFicheSaisie.EditMoyenTransport,
                                  FSFicheSaisie.EditMatriculeTransport,
                                  FSFicheSaisie.EditNomChauffeur,
                                  FSFicheSaisie.EditPrenomChauffeur,
                                  FSFicheSaisie.EditPieceIdentite,
                                  FSFicheSaisie.EditCodeTiersValider);

     if(FSFicheSaisie.EditMatriculeTransport.Text<>'')then FSFicheSaisie.EditInfoMoyenTransport.Text:=FSFicheSaisie.EditMatriculeTransport.Text
     else
     if(FSFicheSaisie.EditMoyenTransport.Text<>'')then FSFicheSaisie.EditInfoMoyenTransport.Text:=FSFicheSaisie.EditMoyenTransport.Text
     else
     if(FSFicheSaisie.EditNomChauffeur.Text<>'')or(FSFicheSaisie.EditPrenomChauffeur.Text<>'')then FSFicheSaisie.EditInfoMoyenTransport.Text:=FSFicheSaisie.EditNomChauffeur.Text+' '+FSFicheSaisie.EditPrenomChauffeur.Text
     else
     if(FSFicheSaisie.EditPieceIdentite.Text<>'')then FSFicheSaisie.EditInfoMoyenTransport.Text:=FSFicheSaisie.EditPieceIdentite.Text
     else FSFicheSaisie.EditInfoMoyenTransport.Text:='';

     FSFicheSaisie.EditNumAvis.Color:=clSilver;
     FSFicheSaisie.EditMontantAvis.Color:=clSilver;

     if(FSFicheSaisie.EditNumAvis.Text<>'')then
     begin
          MontantListeAvis:=0;
          for R:=1 to FSFicheSaisie.TableauListeAvisTrouver.RowCount-1 do
          begin
               if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
               MontantListeAvis:=MontantListeAvis+strtoreal(FSFicheSaisie.TableauListeAvisTrouver.Cells[6,R]);
          end;

          if(strtoreal(TableauListeMouvement.Cells[11,TableauListeMouvement.Row])=MontantListeAvis)
