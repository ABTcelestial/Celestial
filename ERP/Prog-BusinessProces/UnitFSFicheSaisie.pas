Procedure ProcActionTypeMouvement(PoitionTypeMouvement:string; ActiverAutoAfficheListeMouvement:boolean);
begin     
     if(PoitionTypeMouvement='')then PoitionTypeMouvement:=FSFicheSaisie.TableauTypeMouvement.Cells[1,FSFicheSaisie.TableauTypeMouvement.Row];
     RTypeMouvement:=ChercherTypeMouvement(strtointeger(PoitionTypeMouvement),ExerciceAnnee,AdresseFichierConcerne);
     FSFicheSaisie.AfficheAdresseTypeMouvement.Caption:=AdresseFichierConcerne;
     FSFicheSaisie.EditPositionTypeMouvement.Text:=inttostr(RTypeMouvement.PositionTypeMouvement);//FSFicheSaisie.TableauTypeMouvement.Cells[1,FSFicheSaisie.TableauTypeMouvement.Row];
     FSFicheSaisie.EditCodeTypeMouvement.Text:=RTypeMouvement.CodeTypeMouvement;//FSFicheSaisie.TableauTypeMouvement.Cells[2,FSFicheSaisie.TableauTypeMouvement.Row];
     FSFicheSaisie.EditDesignationTypeMouvement.Text:=RTypeMouvement.DesignationTypeMouvement;//FSFicheSaisie.TableauTypeMouvement.Cells[3,FSFicheSaisie.TableauTypeMouvement.Row];
     FSFicheSaisie.TableauTypeMouvement.Visible:=false;

     FSFicheSaisie.AfficheMouvement.Caption:='  Type de mouvement: '+RTypeMouvement.DesignationTypeMouvement;

     FSFicheSaisie.TableauMouvement.Left:=FSFicheSaisie.CadreAffichageMouvement.Left+FSFicheSaisie.AfficheMouvement.Left;
