            RListeMouvement.PositionDetailMouvementEnd:=PositionDetailMouvementEnd;

     finally
     closefile(FFormule);
     end;
     end;

Seek(FListeMouvement,lLM);
write(FListeMouvement,RListeMouvement);
finally
CloseFile(FListeMouvement);
