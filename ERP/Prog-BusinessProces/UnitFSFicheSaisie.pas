     FSFicheSaisie.EditSourceName.Text:=TableauListeMouvement.Cells[33,TableauListeMouvement.Row];
     FSFicheSaisie.EditDataSourceName.Text:=TableauListeMouvement.Cells[34,TableauListeMouvement.Row];
