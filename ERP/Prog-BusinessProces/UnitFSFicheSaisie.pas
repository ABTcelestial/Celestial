Procedure ImprimerFactureAutre(ApercuAvantImpression:boolean);
var R,m,NPage,NbrChiffreCode:integer;  OK,OKAvis:boolean; Origine,ModePaiement,Domiciliation,NumPiece,DataTiersSupplementaire:string;
begin
ModePaiement:=FSFicheSaisie.EditModePayement.Text;
NumPiece:=FSFicheSaisie.EditNumPiece.Text;
Domiciliation:=FSFicheSaisie.EditDomiciliation.Text;

if(FSFicheSaisie.RBAfficherCodeArticleComplet.Checked=true)
then NbrChiffreCode:=10
else NbrChiffreCode:=4;

OKAvis:=false;


PrintFactureAutre.TextPayement.Lines.Text:=ModePaiement+' '+Domiciliation+' N°: '+NumPiece;

if(FSFicheSaisie.EditDataSourceName.Text<>'')then
begin
     PrintFactureAutre.TextPayement.Lines.Add(FSFicheSaisie.EditSourceName.Text+FSFicheSaisie.EditDataSourceName.Text);
end;

if(FSFicheSaisie.RBInfoAdresseExecutionMouvement.Checked=true)then
begin
     if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
     begin
          if(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text<>'')then
          begin
               PrintFactureAutre.Projet.Caption:='Destination: ';
               PrintFactureAutre.TextProjet.Lines.Text:=FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text;
          end
          else
          begin
               PrintFactureAutre.Projet.Caption:='Adresse: ';
               PrintFactureAutre.TextProjet.Lines.Text:=FSFicheSaisie.EditAdresseExecutionMouvement.Text;
          end;
     end
     else
     begin
          if(FSFicheSaisie.RBAfficheReferenceListeMouvement.Checked=true)and(FSFicheSaisie.EditReferenceListeMouvement.Text<>'')then
          begin
               PrintFactureAutre.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
               PrintFactureAutre.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;
          end
          else
          begin
               PrintFactureAutre.Projet.Caption:='';
               PrintFactureAutre.TextProjet.Lines.Text:='';
          end;
     end;
end;

R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
