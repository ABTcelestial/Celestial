Procedure ImprimerEtatStandard(ApercuAvantImpression:boolean);
var C,DebutRow,EcartTableau,Ordre:integer;  ImprimeEtat:boolean;
    FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,DataTiersSupplementaire:string;
begin
DebutRow:=0;
if strtointeger(FSFicheSaisie.EditEcartLigne.Text)<=0
then EcartTableau:=-1
else EcartTableau:=strtointeger(FSFicheSaisie.EditEcartLigne.Text);
ImprimeEtat:=false;
RTier:=ChercherTiers(FSFicheSaisie.EditTypeProces.Text,FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row],FSFicheSaisie.EditCodeTiersConserne.Text,FSFicheSaisie.EditTiersConserne.Text);

FSFicheSaisie.EditTitreEtat.Text:='';
FSFicheSaisie.EditTitreEtat.Lines.Add(FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
                                      CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'6'));
FSFicheSaisie.EditTitreEtat.Lines.Add('Date: '+datetostr(FSFicheSaisie.EditDateDetailMouvement.Date));

if(FSFicheSaisie.EditDataTiersSupplementaire.Text<>'')
then DataTiersSupplementaire:=' {'+FSFicheSaisie.EditDataTiersSupplementaire.Text+'}'
else DataTiersSupplementaire:='';
FSFicheSaisie.EditTitreEtat.Lines.Add(FichierTiersCourt(FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row])+': '+RTier.NomTiers+' '+RTier.PrenomTiers+DataTiersSupplementaire);

if(FSFicheSaisie.EditNomProjet.Text<>'')then FSFicheSaisie.EditTitreEtat.Lines.Add(FSFicheSaisie.LabelIndiquerTypeProjet.Caption+' '+FSFicheSaisie.EditNomProjet.Text);

if(FSFicheSaisie.RBAfficheReferenceListeMouvement.Checked=true)and(FSFicheSaisie.EditReferenceListeMouvement.Text<>'')then
begin
     FSFicheSaisie.EditTitreEtat.Lines.Add('Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text+' '+FSFicheSaisie.EditReferenceListeMouvement.Text);
end;

if(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text<>'')then FSFicheSaisie.EditTitreEtat.Lines.Add(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text);

for Ordre:=1 to 2 do
begin
     if(FSFicheSaisie.RBDetailMouvement.Checked=true)and(strtointeger(FSFicheSaisie.ClasseDetailMouvement.Text)=Ordre)then
     begin
          FontGrasARow:='5';
          FontGrasACol:='0';
          AlignementCenterARow:='5';
          AlignementCenterACol:='0;1;4';
          AlignementRightARow:='';
          AlignementRightACol:='';
          for C:=5 to FSFicheSaisie.TableauDetaiMouvement.ColCount-1 do
          begin
               if(AlignementRightACol='')then AlignementRightACol:=inttostr(C)
                                         else AlignementRightACol:=AlignementRightACol+';'+inttostr(C);
          end;
          ImprimeEtat:=ControleNextFicheSaisie(FSFicheSaisie.ClasseDetailMouvement);
          OptionsImpression(FSFicheSaisie.TableauDetaiMouvement,'',DebutRow,1,FSFicheSaisie.EditTitreEtat.Text,FSFicheSaisie.RBAjusterDetailMouvement.Checked,FSFicheSaisie.RBOrientationPapier.Text,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,FSFicheSaisie.ImageCodebarre,ApercuAvantImpression,DebutRow);
     end;

     if(FSFicheSaisie.RBRecapeMouvement.Checked=true)and(strtointeger(FSFicheSaisie.ClasseRecapeMouvement.Text)=Ordre)then
     begin
          FontGrasARow:='0';
          FontGrasACol:='2';
          AlignementCenterARow:='0';
          AlignementCenterACol:='';
          AlignementRightARow:='';
          AlignementRightACol:='5';
          ImprimeEtat:=ControleNextFicheSaisie(FSFicheSaisie.ClasseRecapeMouvement);
          OptionsImpression(FSFicheSaisie.TableauFormules,'',DebutRow,1,FSFicheSaisie.EditTitreEtat.Text,FSFicheSaisie.RBAjusterRecapeMouvement.Checked,FSFicheSaisie.RBOrientationPapier.Text,FontGrasARow,FontGrasACol,AlignementCenterARow,AlignementCenterACol,AlignementRightARow,AlignementRightACol,ImprimeEtat,EcartTableau,FSFicheSaisie.ImageCodebarre,ApercuAvantImpression,DebutRow);
     end;
end;
end;

procedure TFSFicheSaisie.BitImprimerAfficheOptionImpressionClick(Sender: TObject);
begin
FSFicheSaisie.AfficheOptionImpression.Visible:=false;
ImprimerEtatStandard(FSFicheSaisie.RBApercuAvantImpression.Checked);
end;

procedure TFSFicheSaisie.BitImprimerMouvementClick(Sender: TObject);
var  R,C,l,Capacity,RowTTCFormule,ColTTCDetaille:integer;
     PrixSimplifier,TotalSimplifier:real;
     CodeTexte,TypeProces,FichierTiersConcerne,NotRow,NotCol:string;
     OK,OKRowTTCFormule,OKColTTCDetaille:boolean;
     DebitAvis,CreditAvis,DebitCreditAvis,DebitMouvement,CreditMouvement,DebitCreditMouvement,DebitPrelevement,CreditPrelevement,DebitCreditPrelevement,DebitSituationMarche,CreditSituationMarche,DebitCreditSituationMarche,SoldeAnterieur:real;
     InclureAvis,InclureListeMouvement,InclureSituationMarche,InclureArchivePrelevementUniteFond:boolean;
     TableauDetaiMouvementSelect,TableauFormulesSelect:TStringGrid;
begin
     TableauDetaiMouvementSelect:=FSFicheSaisie.TableauDetaiMouvement;
     TableauFormulesSelect:=FSFicheSaisie.TableauFormules;

     if(FSFicheSaisie.RBAfficherSoldeAnterieur.Checked=false)then
     begin
          FSFicheSaisie.DebitCreditSoldeAnterieur.Caption:='';
          FSFicheSaisie.EditSoldeAnterieur.Lines.Text:='';
     end;

     if(FSFicheSaisie.RBAfficherSoldeAnterieur.Checked=true)
     and(FSFicheSaisie.RBConfirmerSoldeAnterieur.Checked=false)
     then
     begin
          FSFicheSaisie.DebitCreditSoldeAnterieur.Caption:='';
          FSFicheSaisie.EditSoldeAnterieur.Lines.Text:='';

          InclureAvis:=true;
          InclureListeMouvement:=true;
          InclureSituationMarche:=false;
          InclureArchivePrelevementUniteFond:=false;

          FSFicheSaisie.ProgresseSoldeAnterieur.Visible:=true;
          FSFicheSaisie.ProgresseSoldeAnterieur.Max:=MaxProgresseSoldeAnterieur(InclureAvis,InclureListeMouvement,InclureSituationMarche,InclureArchivePrelevementUniteFond);
          FSFicheSaisie.ProgresseSoldeAnterieur.Position:=0;
          FSFicheSaisie.AfficheSoldeAnterieur.Visible:=true;

          FSFicheSaisie.EditSoldeAnterieur.SelectAll;
          FSFicheSaisie.EditSoldeAnterieur.SetFocus;

          SoldeAnterieur:=SoldeTiers(TableauListeMouvement.Cells[7,TableauListeMouvement.Row],TableauListeMouvement.Cells[8,TableauListeMouvement.Row],TableauListeMouvement.Cells[9,TableauListeMouvement.Row],datetostr(date),false,DebitAvis,CreditAvis,DebitCreditAvis,DebitMouvement,CreditMouvement,DebitCreditMouvement,DebitPrelevement,CreditPrelevement,DebitCreditPrelevement,DebitSituationMarche,CreditSituationMarche,DebitCreditSituationMarche);

          if(SoldeAnterieur=0)then
          begin
               FSFicheSaisie.DebitCreditSoldeAnterieur.Caption:='Soldé';
               FSFicheSaisie.EditSoldeAnterieur.Lines.Text:=Vergule(floattostr(SoldeAnterieur),'2','C','');
          end
          else
          if(SoldeAnterieur>0)then
          begin
               FSFicheSaisie.DebitCreditSoldeAnterieur.Caption:='Débiteur';
               FSFicheSaisie.EditSoldeAnterieur.Lines.Text:=Vergule(floattostr(SoldeAnterieur),'2','C','');
          end
          else
          begin
               FSFicheSaisie.DebitCreditSoldeAnterieur.Caption:='Créditeur';
               FSFicheSaisie.EditSoldeAnterieur.Lines.Text:=Vergule(floattostr(SoldeAnterieur*(-1)),'2','C','');
          end;

          FSFicheSaisie.ProgresseSoldeAnterieur.Visible:=false;
     end
     else
     begin
          //////////////////////////////////////////////////////////////////////
          if(FSFicheSaisie.RBEtatSimplifier.Checked=true)then
          begin
               TableauDetaiMouvementSelect:=FSFicheSaisie.TableauDetaiMouvementSimplifier;
               TableauFormulesSelect:=FSFicheSaisie.TableauFormulesSimplifier;

               R:=1;
               RowTTCFormule:=R;
               OKRowTTCFormule:=false;
               while(R<=FSFicheSaisie.TableauFormules.RowCount-1)and(OKRowTTCFormule=false)do
               begin
                    if(FSFicheSaisie.TableauFormules.Cells[2,R]=FSFicheSaisie.EditListeRubriqueFormuleTTC.Text)then
                    begin
                         OKRowTTCFormule:=true;
                         RowTTCFormule:=R;
                    end;
               R:=R+1;
               end;

               C:=0;
               ColTTCDetaille:=FSFicheSaisie.TableauDetaiMouvement.ColCount-1;
               OKColTTCDetaille:=false;
               while(C<=FSFicheSaisie.TableauDetaiMouvement.ColCount-1)and(OKColTTCDetaille=false)do
               begin
                    if(FSFicheSaisie.TableauDetaiMouvement.Cells[C,2]=FSFicheSaisie.TableauFormules.Cells[2,RowTTCFormule])then
                    begin
                         OKColTTCDetaille:=true;
                         ColTTCDetaille:=C;
                    end;
               C:=C+1;
               end;

               TableauDetaiMouvementSelect.RowCount:=FSFicheSaisie.TableauDetaiMouvement.RowCount;
               TableauDetaiMouvementSelect.ColCount:=9;

               TotalSimplifier:=0;
               R:=0;
               while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
               begin
                    TableauDetaiMouvementSelect.Cells[0,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[0,R];//N°
                    TableauDetaiMouvementSelect.Cells[1,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[1,R];//Code
                    TableauDetaiMouvementSelect.Cells[2,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[2,R];//Désignation
                    TableauDetaiMouvementSelect.Cells[3,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[3,R];//Réf
                    TableauDetaiMouvementSelect.Cells[4,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[4,R];//UM
                    TableauDetaiMouvementSelect.Cells[5,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[5,R];//Coűt
                    TableauDetaiMouvementSelect.Cells[6,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[6,R];//Quantité
                    TableauDetaiMouvementSelect.Cells[7,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[7,R];//Prix
                    TableauDetaiMouvementSelect.Cells[8,R]:=FSFicheSaisie.TableauDetaiMouvement.Cells[ColTTCDetaille,R];//Total

                    if(R>5)then
                    begin
                         if(strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R])<>0)
                         then PrixSimplifier:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColTTCDetaille,R])/strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R])
                         else PrixSimplifier:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColTTCDetaille,R]);

                         TableauDetaiMouvementSelect.Cells[7,R]:=Vergule(floattostr(PrixSimplifier),'2','C','');//Prix
                         PrixSimplifier:=strtoreal(TableauDetaiMouvementSelect.Cells[7,R]);
                         TableauDetaiMouvementSelect.Cells[8,R]:=Vergule(floattostr(PrixSimplifier*strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R])),'2','C','');//Total géneral
                         TotalSimplifier:=TotalSimplifier+strtoreal(TableauDetaiMouvementSelect.Cells[8,R]);
                    end;
               
               R:=R+1;
               end;

               TableauFormulesSelect.ColCount:=FSFicheSaisie.TableauFormules.ColCount;
               TableauFormulesSelect.RowCount:=2;
               TableauFormulesSelect.Rows[0].Text:=FSFicheSaisie.TableauFormules.Rows[0].Text;
               TableauFormulesSelect.Rows[1].Text:='';

               l:=0;
               for R:=RowTTCFormule to FSFicheSaisie.TableauFormules.RowCount-1 do
               begin
                    l:=l+1;
                    TableauFormulesSelect.Rows[l].Text:=FSFicheSaisie.TableauFormules.Rows[R].Text;
               end;

               if(l>0)then TableauFormulesSelect.RowCount:=l+1;
               TableauFormulesSelect.Cells[2,1]:='Total';
               TableauFormulesSelect.Cells[5,1]:=Vergule(floattostr(TotalSimplifier),'2','C','');

               TableauDetaiMouvementSelect.Cells[7,5]:='Prix U';
               TableauDetaiMouvementSelect.Cells[8,5]:='Total';

               NotRow:='';
               for R:=0 to FSFicheSaisie.TableauDetaiMouvement.RowCount-1 do
               if FSFicheSaisie.TableauDetaiMouvement.RowHeights[R]<10 then
               if(NotRow='')then NotRow:=inttostr(R)
                            else NotRow:=NotRow+';'+inttostr(R);

               for R:=0 to TableauDetaiMouvementSelect.RowCount-1 do if ExisteNumInTexte(inttostr(R),NotRow)then TableauDetaiMouvementSelect.RowHeights[R]:=0;

               NotCol:='';
               for C:=0 to 6 do
               if FSFicheSaisie.TableauDetaiMouvement.ColWidths[C]<10 then
               if(NotCol='')then NotCol:=inttostr(C)
                            else NotCol:=NotCol+';'+inttostr(C);

               for C:=0 to TableauDetaiMouvementSelect.ColCount-1 do if ExisteNumInTexte(inttostr(C),NotCol)then TableauDetaiMouvementSelect.ColWidths[C]:=0;

               AjusterColWidth(TableauDetaiMouvementSelect,NotRow,NotCol);
               AjustementTableauFormules(TableauFormulesSelect);
          end;
          //////////////////////////////////////////////////////////////////////

          FSFicheSaisie.RBConfirmerSoldeAnterieur.Checked:=false;

          TypeProces:=FSFicheSaisie.TableauListeMouvement.Cells[7,FSFicheSaisie.TableauListeMouvement.Row];
          FichierTiersConcerne:=FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row];
          FSAvis.EditBaseAvis.Text:=IndiqueBaseAvis(FichierTiersConcerne);

          R:=6;
          OK:=false;
          while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
          begin
               if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
               then
               begin
                    OK:=true;
                    FSFicheSaisie.BitEchapClick(FSFicheSaisie.BitEchap);
                    Exit;
               end;
               R:=R+1;
          end;

          if(FSFicheSaisie.RBImprimerPlusiersFois.Checked=false)then
          begin
               if(FSFicheSaisie.EditEtatImprimerPlusieursFois.Text<>'')then
               begin
                    FSFicheSaisie.BitEchapClick(FSFicheSaisie.BitEchap);
                    Exit;
               end;
          end;

          if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=false)and(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=false)then
          begin
               FSFicheSaisie.TableauListeMouvement.SetFocus;

               if(FSFicheSaisie.EditNumListeMouvement.Text<>'')and(FSFicheSaisie.EditNumListeMouvement.Text=FSFicheSaisie.TableauListeMouvement.Cells[2,FSFicheSaisie.TableauListeMouvement.Row])and(FSFicheSaisie.EditMontantMouvement.Text<>'')and(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]<>'')and(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]))then
               begin
                    AfficherMessage('Attention ! Le montant du mouvement enregistré, diffčre de ce lui calculé !');
                    Exit;
               end;

               if(strtodate(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date))<>strtodate(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]))then
               begin
                    AfficherMessage('Attention ! la date affichée différente de celle enregistrée ! '+datetostr(FSFicheSaisie.EditDateDetailMouvement.Date)+' et '+FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]);
                    Exit;
               end;

               FSFicheSaisie.EditModePayementImporter.Text:='';

               if ChercherAvis(FSFicheSaisie.EditNumAvis.Text,FSAvis.EditBaseAvis.Text,TypeProces,FichierTiersConcerne,FSFicheSaisie.RBModePayementNumAvis.Checked,FSFicheSaisie.RBModePayementModePayement.Checked,FSFicheSaisie.RBModePayementDomiciliation.Checked,FSFicheSaisie.RBModePayementNumPiece.Checked,FSFicheSaisie.RBModePayementDateAvis.Checked,FSFicheSaisie.RBModePayementDateExecution.Checked,FSFicheSaisie.TableauListeAvisTrouver,FSFicheSaisie.EditListeNumAvisTrouver,FSFicheSaisie.EditListeModePaiementTrouver,FSFicheSaisie.EditListeDomiciliationAvisTrouver,FSFicheSaisie.EditListeDomiciliationPieceTrouver,FSFicheSaisie.EditListeNumPieceTrouver,FSFicheSaisie.EditListeDateTrouver,FSFicheSaisie.EditMemoLiseAvisTrouver)then
               begin
                    if(FSFicheSaisie.RBModePayementNumAvis.Checked)then
                    begin
                         FSFicheSaisie.EditModePayementImporter.Text:=FSFicheSaisie.EditModePayementImporter.Text+'Avis N°: '+FSFicheSaisie.EditMemoLiseAvisTrouver.Text;
                    end;

                    if(FSFicheSaisie.RBModePayementModePayement.Checked)then
                    begin
                         FSFicheSaisie.EditModePayementImporter.Text:=FSFicheSaisie.EditModePayementImporter.Text+' '+FSFicheSaisie.EditListeModePaiementTrouver.Text;
                    end;

                    if(FSFicheSaisie.RBModePayementDomiciliation.Checked)then
                    begin
                         FSFicheSaisie.EditModePayementImporter.Text:=FSFicheSaisie.EditModePayementImporter.Text+' '+FSFicheSaisie.EditListeDomiciliationAvisTrouver.Text;
                    end;

                    if(FSFicheSaisie.RBModePayementNumPiece.Checked)then
                    begin
                         FSFicheSaisie.EditModePayementImporter.Text:=FSFicheSaisie.EditModePayementImporter.Text+' N° '+FSFicheSaisie.EditListeNumPieceTrouver.Text;
                    end;

                    if(FSFicheSaisie.RBModePayementDateAvis.Checked)then
                    begin
                         FSFicheSaisie.EditModePayementImporter.Text:=FSFicheSaisie.EditModePayementImporter.Text+' du '+FSFicheSaisie.EditListeDateTrouver.Text;
                    end;

                    if(FSFicheSaisie.RBModePayementDateExecution.Checked)then
                    begin
                         FSFicheSaisie.EditModePayementImporter.Text:=FSFicheSaisie.EditModePayementImporter.Text+' du '+FSFicheSaisie.EditListeDateTrouver.Text;
                    end;
               end;
          end;

          if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=false)then
          begin
               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Etat Double')then
               begin
                    ImprimerEtatDouble(TableauDetaiMouvementSelect,TableauFormulesSelect,FSFicheSaisie.RBApercuAvantImpression.Checked);
               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Bon Quantitatif')then
               begin
                    {if(FSFicheSaisie.RBImprimePortrait.Checked=true)
                    then ImprimerBonQuantitatif(FSFicheSaisie.RBApercuAvantImpression.Checked)
                    else ImprimerBonQuantitatifPaysage(FSFicheSaisie.RBApercuAvantImpression.Checked); }

                    ImprimerBonQuantitatifDynamique(FSFicheSaisie.RBApercuAvantImpression.Checked)
               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Bon Valorisé')then
               begin
                    ImprimerBonValorise(FSFicheSaisie.RBApercuAvantImpression.Checked);
               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Facture')then
               begin
                    PrintFacture.DataDateHeure.Visible:=FSFicheSaisie.RBAfficherHeureImpression.Checked;
                    PrintFactureSimple.DataDateHeure.Visible:=FSFicheSaisie.RBAfficherHeureImpression.Checked;
                    PrintFactureSimple1.DataDateHeure.Visible:=FSFicheSaisie.RBAfficherHeureImpression.Checked;
                    PrintFactureAutre.DataDateHeure.Enabled:=FSFicheSaisie.RBAfficherHeureImpression.Checked;
                    PrintFactureAutre1.DataDateHeure.Enabled:=FSFicheSaisie.RBAfficherHeureImpression.Checked;


                    PrintFacture.Projet.Caption:='';
                    PrintFacture.TextProjet.Lines.Text:='';

                    PrintFactureSimple.Projet.Caption:='';
                    PrintFactureSimple.TextProjet.Lines.Text:='';

                    PrintFactureSimple1.Projet.Caption:='';
                    PrintFactureSimple1.TextProjet.Lines.Text:='';

                    PrintFactureAutre.Projet.Caption:='';
                    PrintFactureAutre.TextProjet.Lines.Text:='';

                    PrintFactureAutre1.Projet.Caption:='';
                    PrintFactureAutre1.TextProjet.Lines.Text:='';

                    if(FSFicheSaisie.RBAfficheReferenceListeMouvement.Checked=true)and(FSFicheSaisie.EditReferenceListeMouvement.Text<>'')then
                    begin
                         PrintFacture.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
                         PrintFacture.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;

                         PrintFactureSimple.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
                         PrintFactureSimple.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;

                         PrintFactureSimple1.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
                         PrintFactureSimple1.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;

                         PrintFactureAutre.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
                         PrintFactureAutre.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;

                         PrintFactureAutre1.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
                         PrintFactureAutre1.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;
                    end;

                    PrintFacture.TitreSignataire.Caption:=FSFicheSaisie.EditSignataire.Text;
                    PrintFactureSimple.TitreSignataire.Caption:=FSFicheSaisie.EditSignataire.Text;
                    PrintFactureAutre1.TitreSignataire.Caption:=FSFicheSaisie.EditSignataire.Text;

                    if(FSFicheSaisie.RBAfficheCryptageEtat.Checked=true)then
                    begin
                         CodeTexte:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
                         Midellaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),9,10)+'/'+
                         Midellaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),4,5)+'/'+
                         CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'4');
                         PrintFactureSimple.DataCodageEtat.Caption:='Edition: Business Proces '+CodageTexteSpeciale(CodeTexte);
                         PrintFactureSimple1.DataCodageEtat.Caption:='Edition: Business Proces '+CodageTexteSpeciale(CodeTexte);
                         PrintFactureAutre.DataCodageEtat.Caption:='Edition: Business Proces '+CodageTexteSpeciale(CodeTexte);
                         PrintFactureAutre1.DataCodageEtat.Caption:='Edition: Business Proces '+CodageTexteSpeciale(CodeTexte);
                    end
                    else
                    begin
                         PrintFactureSimple.DataCodageEtat.Caption:='';
                         PrintFactureSimple1.DataCodageEtat.Caption:='';
                         PrintFactureAutre.DataCodageEtat.Caption:='';
                         PrintFactureAutre1.DataCodageEtat.Caption:='';
                    end;

                    if(FSFicheSaisie.RBUtiliserEtatDinamique.Checked=true)then
                    begin
                         if(FSFicheSaisie.RBFacturePortrait.Checked=true)
                         then ImprimerFactureDinamique(FSFicheSaisie.RBApercuAvantImpression.Checked)
                         else ImprimerFactureDinamiquePaysage(FSFicheSaisie.RBApercuAvantImpression.Checked);
                    end
                    else
                    if(FSFicheSaisie.RBAfficherCodeArticleComplet.Checked=true)then
                    begin
                         if(AnsiUpperCase(FSFicheSaisie.EditModePayement.Text)=AnsiUpperCase('Espčce'))
                         then ImprimerFactureSimple1(FSFicheSaisie.RBApercuAvantImpression.Checked)
                         else ImprimerFactureSimple(FSFicheSaisie.RBApercuAvantImpression.Checked);
                    end
                    else
                    begin
                         if(AnsiUpperCase(FSFicheSaisie.EditModePayement.Text)=AnsiUpperCase('Espčce'))
                         then ImprimerFactureAutre1(FSFicheSaisie.RBApercuAvantImpression.Checked)
                         else ImprimerFactureAutre(FSFicheSaisie.RBApercuAvantImpression.Checked);
                    end;

               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Etat standard')then
               begin
                    InitialisationFicheSaisie(false,false,false,false,false,false);

                    if(FSFicheSaisie.RBApercuAvantImpression.Checked=true)then
                    begin
                         FSFicheSaisie.AfficheOptionImpression.Left:=8;
                         FSFicheSaisie.AfficheOptionImpression.Top:=152;
                         FSFicheSaisie.AfficheOptionImpression.Visible:=true;

                         FSFicheSaisie.BitImprimerAfficheOptionImpression.SetFocus;
                    end
                    else
                    begin
                         FSFicheSaisie.BitImprimerAfficheOptionImpressionClick(FSFicheSaisie.BitImprimerAfficheOptionImpression);
                    end;
               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Ticket')then
               begin
                    ImprimerTicket;
               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Ticket Pont Bascule')then
               begin
                    if(FSFicheSaisie.RBDemiEtat.Checked=true)
                    then ImprimerDemiTicketPontBascule(FSFicheSaisie.RBApercuAvantImpression.Checked)
                    else ImprimerTicketPontBascule(FSFicheSaisie.RBApercuAvantImpression.Checked)
               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: Bon de Route')then
               begin
                    if(FSFicheSaisie.RBDemiEtat.Checked=true)
                    then ImprimerDemiBondeRoute(FSFicheSaisie.RBApercuAvantImpression.Checked)
                    else ImprimerBondeRoute(FSFicheSaisie.RBApercuAvantImpression.Checked);
               end;

               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: Pont Bascule')then
               begin
                    if(FSFicheSaisie.RBDemiEtat.Checked=true)then
                    begin
                         ImprimerDemiTicketPontBascule(FSFicheSaisie.RBApercuAvantImpression.Checked);
                         ImprimerDemiBondeRoute(FSFicheSaisie.RBApercuAvantImpression.Checked);
                    end
                    else
                    begin
                         ImprimerTicketPontBascule(FSFicheSaisie.RBApercuAvantImpression.Checked);
                         ImprimerBondeRoute(FSFicheSaisie.RBApercuAvantImpression.Checked);
                    end;
               end;

               if(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then
               begin
                    FSFicheSaisie.AfficheIndiceListeMouvement.Visible:=true;
                    FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text:='';
                    FSFicheSaisie.EditMatriculePontBascule.Text:='';
                    FSFicheSaisie.EditIndiceFinalPontBascule.Text:='';
                    FSFicheSaisie.EditIndiceInialPontBascule.Text:='';
                    FSFicheSaisie.EditIndiceCalculePontBascule.Text:='';
                    FSFicheSaisie.EditDateIndiceInitial.Text:='';
                    FSFicheSaisie.EditHeureIndiceInitial.Text:='';

                    FSFicheSaisie.EditCodeResponsablePrelevement.Text:='';
                    FSFicheSaisie.EditNomResponsablePrelevement.Text:='';
                    FSFicheSaisie.EditPrenomResponsablePrelevement.Text:='';
                    FSFicheSaisie.EditNumeroPont.Text:='1';
                    FSFicheSaisie.EditTypeVehiculePrelevement.Text:='';
                    FSFicheSaisie.EditTonageVehiculePrelevement.Text:='';

                    FSFicheSaisie.EditMatriculePontBascule.SetFocus;
               end
               else
               begin
                    FSFicheSaisie.BitNouveauMouvement.SetFocus;
               end;
          end
          else
          begin
               FSFicheSaisie.BitNouveauMouvement.SetFocus;

               if(FSFicheSaisie.EditEtatUtilise.Text='Etat Utilisé: '+'Ticket')then
               begin
                    ImprimerTicket;
               end
               else ImprimerTicket;

               if(FSTicketTexte.Showing=false)then
               begin
                    FSFicheSaisie.BitNouveauMouvementClick(FSFicheSaisie.BitNouveauMouvement);
               end;
          end;

          //FSFicheSaisie.EditEtatImprimerPlusieursFois.Text:='OK';
          //FSFicheSaisie.EditLastOrdreImprimerPlusieursFois.Text:='';
     end;
end;

