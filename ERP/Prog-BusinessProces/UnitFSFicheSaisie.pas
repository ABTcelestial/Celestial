      FSAvis.BitAfficheFicheTechnique.Cancel:=false;
      FSAvis.AfficheProjet.Height:=26;
      FSAvis.TableauSelections.Visible:=false;

      TypeProces:='Business';   FichierConserne:=FSAvis.EditBaseAvis.Text;
      if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
      begin
             AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
      end;

      ChAvis:=Adresse;
      assignfile(FAvis,ChAvis);
      try
      if FileExists(ChAvis)then
      Reset(FAvis)
      else begin affichermessage('Attention ! {'+ChAvis+'} n''existe pas !'); exit; end;//Rewrite(FAvis);
      Seek(FAvis,0);
      i:=0;
      IndiceAvis:=0;
      FSAvis.EditNumAvis.Items.Text:='';
      FSAvis.EditNumAvis.Items.Add('Aucun');
      NumAvisConfirmer:='';
      ModePaiementAvis:='';
      NumDomiciliationAvis:='';
      DomiciliationAvis:='';
      NumPieceAvis:='';
      OKAvisConfirmer:=false;
      while not eof(FAvis)and(OKAvisConfirmer=false)do
      begin
           read(FAvis,RAvis);
           i:=i+1;
           FSAvis.EditNumAvis.Items.Add(Completezerogauche(inttostr(RAvis.NumAvis),'5'));

           if(ExisteNumAvisinTexte(FichierConserne,inttostr(RAvis.NumAvis),FSFicheSaisie.EditNumAvis.Text))then OKAvisConfirmer:=true;

           if(RAvis.NumPiece<>'')
           and(RAvis.NumPiece=FSFicheSaisie.EditNumPiece.Text)and(RAvis.CodeTiers=FSFicheSaisie.EditCodeTiersConserne.Text)
           then OKAvisConfirmer:=true;

           if(RAvis.Origine='FSC'+FSFicheSaisie.EditOrdreListeMouvement.Text)then OKAvisConfirmer:=true;
           
           if(OKAvisConfirmer=true)then
           begin
                IndiceAvis:=i;
                NumAvisConfirmer:=inttostr(RAvis.NumAvis);
                ModePaiementAvis:=RAvis.ModePaiement;
                NumDomiciliationAvis:=RAvis.NumDomiciliationPiece;
                DomiciliationAvis:=RAvis.DomiciliationPiece;
                NumPieceAvis:=RAvis.NumPiece;
           end;
      end;
      finally
      Closefile(FAvis);
      end;

      FSAvis.EditNumAvis.ItemIndex:=IndiceAvis;

      if(FSAvis.EditNumRubrique.Text='')and(FSAvis.EditNumFiche.Text='')then
      begin
           DesignationTypeAvis:=FSAvis.EditTypeAvis.Text;
      end
      else
      begin
           RubriqueArborescence(FSAvis.EditNumFiche.Text,FSAvis.EditNumRubrique.Text,RRubriqueFicheTechniqueCopie,RFicheTechnique,RTypeAvis);
           DesignationTypeAvis:=RTypeAvis.DesignationTypeAvis;
      end;

if(NumAvisConfirmer<>'')then
begin
      if(FSFicheSaisie.EditNumAvis.Text<>'')then
      begin
           FSAvis.Show;

           AfficerDataContrePartieAvis(DesignationTypeAvis,FSAvis.EditBaseAvis.Text);

           AfficheAvis(NumAvisConfirmer,FSAvis.EditBaseAvis.Text);

           if(FSAvis.EditOrigine.Text='')then
           begin
                FSAvis.EditOrigine.Text:='FSC'+FSFicheSaisie.EditOrdreListeMouvement.Text
           end
           else
           begin
                if not FunctionFichierInclu('FSC'+FSFicheSaisie.EditOrdreListeMouvement.Text,FSAvis.EditOrigine.Text)
                then FSAvis.EditOrigine.Text:=FSAvis.EditOrigine.Text+';'+'FSC'+FSFicheSaisie.EditOrdreListeMouvement.Text;
           end;
      end
      else
      begin
           FSFicheSaisie.EditNumAvis.Text:='{'+FichierConserne+'}'+NumAvisConfirmer;
           FSFicheSaisie.EditModePayement.Text:=ModePaiementAvis;
           FSFicheSaisie.EditNumDomiciliation.Text:=NumDomiciliationAvis;
           FSFicheSaisie.EditDomiciliation.Text:=DomiciliationAvis;
           FSFicheSaisie.EditNumPiece.Text:=NumPieceAvis;
           Exit;
      end;
end
