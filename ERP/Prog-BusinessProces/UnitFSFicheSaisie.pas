Function ListeOrdreMouvementAppartenanceGlobal(ExerciceSource,CodeTiers:string):string;
var     ListeOrdreMouvemen:string;  OKTiers:boolean;
begin
     {TypeProces:='Business';   FichierConserne:='FListeMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChListeMouvement:=Adresse;}

     OpenFParc(RParc);
     ChListeMouvement:=RParc.Parcours+'\'+Entreprise+'-'+ExerciceSource+'FListeMouvement';
     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
     Seek(FListeMouvement,0);
     ListeOrdreMouvemen:='';
     while not eof(FListeMouvement)do
     begin
          read(FListeMouvement,RListeMouvement);

          if(CodeTiers<>'')then
          begin
               if(RListeMouvement.CodeTiers=CodeTiers)
               then OKTiers:=true
               else OKTiers:=false;
          end
          else OKTiers:=true;

          if(OKTiers=true)and(RListeMouvement.OrdreListeMouvementAppartenant<>'')then
          begin
               if(ListeOrdreMouvemen='')
               then ListeOrdreMouvemen:=RListeMouvement.OrdreListeMouvementAppartenant
               else ListeOrdreMouvemen:=ListeOrdreMouvemen+';'+RListeMouvement.OrdreListeMouvementAppartenant;
          end;
     end;
     finally
     CloseFile(FListeMouvement);
     end;

     ListeOrdreMouvementAppartenanceGlobal:=ListeOrdreMouvemen;
end;

