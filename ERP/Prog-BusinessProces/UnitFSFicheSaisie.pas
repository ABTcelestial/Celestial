begin
     ListePositionTypeMouvement:='';
     TypeProces:='Business';   FichierConcerne:='FMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChMouvement:=Adresse;
     assignfile(FMouvement,ChMouvement);
     try
     if FileExists(ChMouvement)then
     Reset(FMouvement)
     else begin affichermessage('Attention ! {'+ChMouvement+'} n''existe pas !'); exit; end;//Rewrite(FMouvement);
     Seek(FMouvement,0);
     while not eof(FMouvement)do
     begin
          read(FMouvement,RMouvement);
          if ExisteNuminTexte(inttostr(RMouvement.PositionMouvement),ListePositionMouvementAppartenance)then
          begin
               if not(ExisteNuminTexte(inttostr(RMouvement.PositionTypeMouvement),ListePositionTypeMouvement))then
               begin
                    if(ListePositionTypeMouvement='')
                    then ListePositionTypeMouvement:=inttostr(RMouvement.PositionTypeMouvement)
                    else
                    ListePositionTypeMouvement:=ListePositionTypeMouvement+';'+inttostr(RMouvement.PositionTypeMouvement)
               end;
          end;
     end;
     finally
     CloseFile(FMouvement);
     end;

     AfficherIndiqueAdresseTypeMouvement(FSFicheSaisie.TableauIndiqueAdresseListeMouvement,ListePositionTypeMouvement);

     if(ExerciceAnnee=ExerciceSource)
     then ListeOrdreMouvementAnnee:=ListeOrdreMouvementAppartenanceGlobal(ExerciceSource,CodeTiers)
     else
     begin
          ListeOrdreMouvementSource:=ListeOrdreMouvementAppartenanceGlobal(ExerciceSource,CodeTiers);
          ListeOrdreMouvementAnnee:=ListeOrdreMouvementAppartenanceGlobal(ExerciceAnnee,CodeTiers);
     end;

     if(NbrRowIn=0)then
     begin
          TableauListeMouvement.ColCount:=35;
          TableauListeMouvement.RowCount:=2;
          TableauListeMouvement.Rows[1].Text:='';

          TableauListeMouvement.Cols[0].Text:='N°';
          TableauListeMouvement.Cols[1].Text:='Ordre';
          TableauListeMouvement.Cols[2].Text:='Num';
          TableauListeMouvement.Cols[3].Text:='P°TM';
          TableauListeMouvement.Cols[4].Text:='P°M';
          TableauListeMouvement.Cols[5].Text:='Date.Etablis.';
          TableauListeMouvement.Cols[6].Text:='Mode Payement';
          TableauListeMouvement.Cols[7].Text:='Code Type F';
          TableauListeMouvement.Cols[8].Text:='Type Proc';
          TableauListeMouvement.Cols[9].Text:='Fichier Tičrs Consern';
          TableauListeMouvement.Cols[10].Text:='Code Tiers';
          TableauListeMouvement.Cols[11].Text:='Tiers';
          TableauListeMouvement.Cols[12].Text:='Montant Mouvement';
          TableauListeMouvement.Cols[13].Text:='Sélection';
          TableauListeMouvement.Cols[14].Text:='Date Exécution';
          TableauListeMouvement.Cols[15].Text:='C°Payés';
          TableauListeMouvement.Cols[16].Text:='Payés';
          TableauListeMouvement.Cols[17].Text:='C°Wilaya';
          TableauListeMouvement.Cols[18].Text:='Wilaya';
          TableauListeMouvement.Cols[19].Text:='C°Daira';
          TableauListeMouvement.Cols[20].Text:='Daira';
          TableauListeMouvement.Cols[21].Text:='C°Commune';
          TableauListeMouvement.Cols[22].Text:='Commune';
          TableauListeMouvement.Cols[23].Text:='C°Zone';
          TableauListeMouvement.Cols[24].Text:='Zone';
          TableauListeMouvement.Cols[25].Text:='Adresse';
          TableauListeMouvement.Cols[26].Text:='Exécution !';
          TableauListeMouvement.Cols[27].Text:='NumProjet ';
          TableauListeMouvement.Cols[28].Text:='Projet';
          TableauListeMouvement.Cols[29].Text:='Mode Paiement';
          TableauListeMouvement.Cols[30].Text:='Num Domiciliation';
          TableauListeMouvement.Cols[31].Text:='Domiciliation';
          TableauListeMouvement.Cols[32].Text:='Num Pičce';
          TableauListeMouvement.Cols[33].Text:='Num Avis';
          TableauListeMouvement.Cols[34].Text:='OdrMAp';
     end;

     R:=NbrRowIn;
     IndiceFinControleTrieRow:=1;
     TotalGeneral:=0;

     ExerciceSelect:=ExerciceSource;
     repeat
     if(ExerciceSelect='')then  ExerciceSelect:=ExerciceAnnee;

     DateMouvementDebut:='01/01/'+ExerciceSelect;
     DateMouvementFin:='31/12/'+ExerciceSelect;

     TypeProces:='Business';   FichierConcerne:='FListeMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     l:=1;
     while(l<=FSFicheSaisie.TableauIndiqueAdresseListeMouvement.RowCount-1)do
     begin
           Adresse:=FSFicheSaisie.TableauIndiqueAdresseListeMouvement.Cells[2,l];//RParc.Parcours+'\'+Exercice+'FListeMouvement';

           if(ExerciceSelect=ExerciceAnnee)
           then ChListeMouvement:=Adresse
           else ChListeMouvement:=ConvertirAdresseExerciceAnnee(Adresse,ExerciceAnnee,ExerciceSelect);

           assignfile(FListeMouvement,ChListeMouvement);
           try
           if FileExists(ChListeMouvement)then
           Reset(FListeMouvement)
           else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
           Seek(FListeMouvement,0);
           while not eof(FListeMouvement)do
           begin
                read(FListeMouvement,RListeMouvement);

                if(CodeTiers<>'')then
                begin
                     if(RListeMouvement.CodeTiers=CodeTiers)
                     then OKMouvement:=true
                     else OKMouvement:=false;
                end
                else OKMouvement:=false;

                if(OKMouvement=true)then
                begin
                     if(DateMouvementDebut<>'')and(DateMouvementFin<>'')then
                     begin
                          if(datecorrecte(DateMouvementDebut)and datecorrecte(DateMouvementFin)and datecorrecte(RListeMouvement.DateMouvement))then
                          begin
                               if(strtodate(RListeMouvement.DateMouvement)>=strtodate(DateMouvementDebut))
                               and(strtodate(RListeMouvement.DateMouvement)<=strtodate(DateMouvementFin))
                               then OKMouvement:=true
                               else OKMouvement:=false;
                          end
                          else OKMouvement:=false;
                     end;
                end;

                if(OKMouvement=true)then
                begin
                     if(ExisteIndexNuminTexte('LM',inttostr(RListeMouvement.OrdreListeMouvement),ListeOrdreMouvementSource+';'+ListeOrdreMouvementAnnee)or ExisteIndexNuminTexte('',inttostr(RListeMouvement.OrdreListeMouvement),ListeOrdreMouvementSource+';'+ListeOrdreMouvementAnnee))
                     then OKMouvement:=false
                     else OKMouvement:=true;
                end;

                if(OKMouvement=true)then
                begin
                     if(AvisEtablis<>'')and(AvisEtablis<>'Tous')then
                     begin
                          if(strtoboolean(AvisEtablis)=true)then
                          begin
                               if(RListeMouvement.ListeNumAvis<>'')
                               then OKMouvement:=true
                               else OKMouvement:=false;
                          end
                          else
                          begin
                               if(RListeMouvement.ListeNumAvis='')
                               then OKMouvement:=true
                               else OKMouvement:=false;
                          end
                     end;
                end;

                if(OKMouvement=true)then
                begin
                     if(ListePositionMouvementAppartenance<>'')then
                     begin
                          if ExisteNuminTexte(inttostr(RListeMouvement.PositionMouvement),ListePositionMouvementAppartenance)
                          then OKMouvement:=true
                          else OKMouvement:=false;
                     end;
                end;

                if(OKMouvement=true)then
                begin
                     R:=R+1;
                     TableauListeMouvement.Rows[R].Text:=inttostr(R);
                     TableauListeMouvement.Cells[1,R]:=inttostr(RListeMouvement.OrdreListeMouvement);
                     TableauListeMouvement.Cells[2,R]:=inttostr(RListeMouvement.NumListeMouvement);
                     TableauListeMouvement.Cells[3,R]:=inttostr(RListeMouvement.PositionTypeMouvement);
                     TableauListeMouvement.Cells[4,R]:=inttostr(RListeMouvement.PositionMouvement);
                     TableauListeMouvement.Cells[5,R]:=RListeMouvement.DateMouvement;
                     TableauListeMouvement.Cells[6,R]:=RListeMouvement.ModePaiement+' '+RListeMouvement.Domiciliation;
                     TableauListeMouvement.Cells[7,R]:=RListeMouvement.CodeTypeFormule;
                     TableauListeMouvement.Cells[8,R]:=RListeMouvement.TypeProces;
                     TableauListeMouvement.Cells[9,R]:=RListeMouvement.FichierTiersConserne;
                     TableauListeMouvement.Cells[10,R]:=RListeMouvement.CodeTiers;
                     RTier:=ChercherTiers(RListeMouvement.TypeProces,RListeMouvement.FichierTiersConserne,RListeMouvement.CodeTiers,'');
                     TableauListeMouvement.Cells[11,R]:=RTier.NomTiers+' '+RTier.PrenomTiers;
                     TableauListeMouvement.Cells[12,R]:=Vergule(floattostr(RListeMouvement.MontantMouvement),'2','C','');
                     TableauListeMouvement.Cells[13,R]:='';
                     TableauListeMouvement.Cells[14,R]:=RListeMouvement.DateExecutionMouvement;
                     TableauListeMouvement.Cells[15,R]:=RListeMouvement.CodePaysExecutionMouvement;
                     TableauListeMouvement.Cells[16,R]:=ChercherLocalisationGeographique(RListeMouvement.CodePaysExecutionMouvement,'FPays').IntitulleLocalisationGeographique;
                     TableauListeMouvement.Cells[17,R]:=RListeMouvement.CodeWilayaExecutionMouvement;
                     TableauListeMouvement.Cells[18,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeWilayaExecutionMouvement,'FWilaya').IntitulleLocalisationGeographique;
                     TableauListeMouvement.Cells[19,R]:=RListeMouvement.CodeDairaExecutionMouvement;
                     TableauListeMouvement.Cells[20,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeDairaExecutionMouvement,'FDaira').IntitulleLocalisationGeographique;
                     TableauListeMouvement.Cells[21,R]:=RListeMouvement.CodeCommuneExecutionMouvement;
                     TableauListeMouvement.Cells[22,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeCommuneExecutionMouvement,'FCommune').IntitulleLocalisationGeographique;
                     TableauListeMouvement.Cells[23,R]:=RListeMouvement.CodeZoneExecutionMouvement;
                     TableauListeMouvement.Cells[24,R]:=ChercherLocalisationGeographique(RListeMouvement.CodeZoneExecutionMouvement,'FZone').IntitulleLocalisationGeographique;
                     TableauListeMouvement.Cells[25,R]:=RListeMouvement.AdresseExecutionMouvement;
                     TableauListeMouvement.Cells[26,R]:=booleantostr(RListeMouvement.OKExecution);
                     TableauListeMouvement.Cells[27,R]:=RListeMouvement.NumProjetFinance;
                     TableauListeMouvement.Cells[28,R]:=ChercherProjetFinance(RListeMouvement.NumProjetFinance,PositionProjetFinancesRecherche).DesignationProjetFinance;
                     TableauListeMouvement.Cells[29,R]:=RListeMouvement.ModePaiement;
                     TableauListeMouvement.Cells[30,R]:=RListeMouvement.NumDomiciliation;
                     TableauListeMouvement.Cells[31,R]:=RListeMouvement.Domiciliation;
                     TableauListeMouvement.Cells[32,R]:=RListeMouvement.NumPiece;
                     TableauListeMouvement.Cells[33,R]:=RListeMouvement.ListeNumAvis;
                     TableauListeMouvement.Cells[34,R]:='LM';
                end;
           end;
           finally
           CloseFile(FListeMouvement);
           end;
     l:=l+1;
     end;
     if(ExerciceSelect<>ExerciceAnnee)then ExerciceSelect:='';
     until ExerciceSelect=ExerciceAnnee;

     if(R>0)then TableauListeMouvement.RowCount:=R+1
            else TableauListeMouvement.RowCount:=2;

     NbrRowOut:=R;

     NotRow:='';

     NotCol:='1;3;4;6-11;14-34';

     for C:=1 to TableauListeMouvement.ColCount-1 do
     if ExisteNumInTexte(inttostr(C),NotCol)then TableauListeMouvement.ColWidths[C]:=0;
