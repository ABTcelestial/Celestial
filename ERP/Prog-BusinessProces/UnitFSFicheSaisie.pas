Procedure CummulerAticleTableau(TableauDetaiMouvementAppartenanceMouvemant,TableauCummulerArticle:TStringGrid; SigneDebitCredit:integer);
var  R,l,RowCountCummuler:integer; OKArticle:boolean;
     CoutAnterieur,CoutActuel,PrixAnterieur,PrixActuel,QuantiteAnterieur,QuantiteActuelle:real;
begin
     FSTraitementDonnees.Rapport.Lines.Add('Cummule Articles');

     TableauCummulerArticle.ColCount:=TableauDetaiMouvementAppartenanceMouvemant.ColCount;
     TableauCummulerArticle.Rows[0]:=TableauDetaiMouvementAppartenanceMouvemant.Rows[0];

     TableauCummulerArticle.RowCount:=2;
     TableauCummulerArticle.Rows[1].Text:='';
     RowCountCummuler:=0;
     R:=1;
     while(R<=TableauDetaiMouvementAppartenanceMouvemant.RowCount-1)do
     begin
          Application.ProcessMessages;  if(FSTraitementDonnees.RBSuspendreTBohr.Checked)then Exit;

          l:=1;
          OKArticle:=false;
          while(l<=RowCountCummuler)and(OKArticle=false)do
          begin
               Application.ProcessMessages;  if(FSTraitementDonnees.RBSuspendreTBohr.Checked)then Exit;

               if(TableauDetaiMouvementAppartenanceMouvemant.Cells[1,R]=TableauCummulerArticle.Cells[1,l])then
               begin
                    OKArticle:=true;
                    FSTraitementDonnees.Rapport.Lines.Add('Article Cummulé');

                    CoutAnterieur:=strtoreal(TableauCummulerArticle.Cells[5,l]);
                    CoutActuel:=strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[5,R]);
                    PrixAnterieur:=strtoreal(TableauCummulerArticle.Cells[7,l]);
                    PrixActuel:=strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[7,R]);
                    QuantiteAnterieur:=strtoreal(TableauCummulerArticle.Cells[6,l]);
                    QuantiteActuelle:=strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,R])*SigneDebitCredit;

                    if((QuantiteAnterieur<>0)or(QuantiteActuelle<>0))then
                    begin
                         if((QuantiteAnterieur+QuantiteActuelle)<>0)then
                         begin
                              TableauCummulerArticle.Cells[5,l]:=floattostr(((CoutAnterieur*QuantiteAnterieur)+
                                                                             (CoutActuel*QuantiteActuelle))/
                                                                              (QuantiteAnterieur+QuantiteActuelle));

                              TableauCummulerArticle.Cells[7,l]:=floattostr(((PrixAnterieur*QuantiteAnterieur)+
                                                                             (PrixActuel*QuantiteActuelle))/
                                                                             (QuantiteAnterieur+QuantiteActuelle));
                         end
                         else
                         begin
                              if(QuantiteAnterieur>0)then
                              begin
                                   TableauCummulerArticle.Cells[5,l]:=floattostr(CoutAnterieur);
                                   TableauCummulerArticle.Cells[7,l]:=floattostr(PrixAnterieur);
                              end
                              else
                              if(QuantiteActuelle>0)then
                              begin
                                   TableauCummulerArticle.Cells[5,l]:=floattostr(CoutActuel);
                                   TableauCummulerArticle.Cells[7,l]:=floattostr(PrixActuel);
                              end;
                         end;

                         TableauCummulerArticle.Cells[6,l]:=floattostr(QuantiteAnterieur+QuantiteActuelle);
                    end;

                    if(not ExisteNumIntexte(inttostr(RDetailMouvement.OrdreListeMouvement),TableauCummulerArticle.Cells[22,l]))
                    then TableauCummulerArticle.Cells[22,l]:=TableauCummulerArticle.Cells[22,l]+';'+inttostr(RDetailMouvement.OrdreListeMouvement);
               end;
          l:=l+1
          end;

          if(OKArticle=false)then
          begin
               FSTraitementDonnees.Rapport.Lines.Add('Article Saisie');
               RowCountCummuler:=RowCountCummuler+1;
               TableauCummulerArticle.Rows[RowCountCummuler].Text:=TableauDetaiMouvementAppartenanceMouvemant.Rows[R].Text;
          end;
     R:=R+1;
     LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
     end;

     TableauCummulerArticle.RowCount:=RowCountCummuler+1;

     TableauDetaiMouvementAppartenanceMouvemant.ColCount:=TableauCummulerArticle.ColCount;
     TableauDetaiMouvementAppartenanceMouvemant.RowCount:=TableauCummulerArticle.RowCount;

     FSTraitementDonnees.Rapport.Lines.Add('Transfert...');
     R:=1;
     while(R<=RowCountCummuler)do
     begin
          TableauDetaiMouvementAppartenanceMouvemant.Rows[R].Text:=TableauCummulerArticle.Rows[R].Text;
     R:=R+1;
     end;
end;

