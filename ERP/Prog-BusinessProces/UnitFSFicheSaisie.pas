Function MaxProgresseSoldeAnterieur(InclureAvis,InclureListeMouvement,InclureSituationMarche,InclureArchivePrelevementUniteFond:boolean):integer;
var  R,Max:integer;
     FichierConserne,TypeProces,Adresse:string;
begin
     Max:=0;

     if(InclureAvis=true)then
     begin
           if(FunctionAdresseProces('Business','FBaseAvis','',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
           begin
                ChBaseAvisPublication:=Adresse;
                assignfile(FBaseAvisPublication,ChBaseAvisPublication);

                if FileExists(ChBaseAvisPublication)then
                begin
                     Reset(FBaseAvisPublication);
                     Seek(FBaseAvisPublication,0);
                     while not eof(FBaseAvisPublication)do
                     begin
                          read(FBaseAvisPublication,RBaseAvisPublication);   Application.ProcessMessages;
                          FichierConserne:=RBaseAvisPublication.DesignationBaseAvis;

                          if(FichierConserne<>'')then
                          begin
                               TypeProces:='Business';
                               if(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                               begin
                                    ChAvis:=Adresse;
                                    assignfile(FAvis,ChAvis);
                                    if FileExists(ChAvis)then
                                    begin
                                         Reset(FAvis);
                                         Max:=Max+FileSize(FAvis);
                                         CloseFile(FAvis);
                                    end;
                               end;
                          end;
                     end;
                     CloseFile(FBaseAvisPublication);
                end;
           end;
     end;

     if(InclureArchivePrelevementUniteFond=true)then
     begin
          TypeProces:='Business';   FichierConserne:='FArchivePrelevementUniteFonds';
          if(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               ChPrelevementUniteFonds:=Adresse;
               assignfile(FPrelevementUniteFonds,ChPrelevementUniteFonds);
               if FileExists(ChPrelevementUniteFonds)then
               begin
                    Reset(FPrelevementUniteFonds);
                    Max:=Max+FileSize(FPrelevementUniteFonds);
                    CloseFile(FPrelevementUniteFonds);
               end;
          end;
     end;

     if(InclureListeMouvement=true)then
     begin
          R:=1;
          while(R<=FSMenuPrincipal.TableauIndiqueAdresseListeMouvement.RowCount-1)do
          begin
               ChListeMouvement:=FSMenuPrincipal.TableauIndiqueAdresseListeMouvement.Cells[2,R];//RParc.Parcours+'\'+Exercice+'FListeMouvement';
               assignfile(FListeMouvement,ChListeMouvement);
               if FileExists(ChListeMouvement)then
               begin
                    Reset(FListeMouvement);
                    Max:=Max+FileSize(FListeMouvement);
                    CloseFile(FListeMouvement);
               end;
          R:=R+1;
          end;
     end;

     if(InclureSituationMarche=true)then
     begin
          TypeProces:='Business'; FichierConcerne:='FSituationMarche';
          if(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               ChSituationMarche:=Adresse;
               assignfile(FSituationMarche,ChSituationMarche);
               if FileExists(ChSituationMarche)then
               begin
                    Reset(FSituationMarche);
                    Max:=Max+FileSize(FSituationMarche);
                    CloseFile(FSituationMarche);
               end;
          end;
     end;

     MaxProgresseSoldeAnterieur:=Max; 
end;

