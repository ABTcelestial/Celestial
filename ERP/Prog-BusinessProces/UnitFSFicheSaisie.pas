Procedure ImporterDetailListeMouvement(TableauListeMouvement,TableauDetaiMouvement,TableauFormules,TableauVariable:TStringGrid);
var R,C,l:integer;
    MontantListeAvis:real;
    OKCodeTiers:boolean;
    OKAvisTrouver:boolean;
    TypeProces,FichierTiersConcerne,NotRows,NotCols:string;
begin
     TypeProces:=FSFicheSaisie.TableauListeMouvement.Cells[7,FSFicheSaisie.TableauListeMouvement.Row];
     FichierTiersConcerne:=FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row];

     //FSAvis.EditBaseAvis.Text:=IndiqueBaseAvis(FichierTiersConcerne);
     //FSFicheSaisie.EditBaseAvis.Text:=IndiqueBaseAvis(FichierTiersConcerne);

     FSFicheSaisie.RBSuspendreDetailMouvement.Checked:=false;

     InitialisationFicheSaisie(true,true,true,true,true,true);

     if(strtointeger(FSFicheSaisie.EditPositionDetailMouvementBegin.Text)<0)and(strtointeger(FSFicheSaisie.EditPositionDetailMouvementEnd.Text)<0)then Exit;

     if(FSFicheSaisie.AfficherChercherNumeroListeMouvement.Visible=true)then
     begin
          if(FSFicheSaisie.EditModeRecherche.Text='Num')then
          begin
               FSFicheSaisie.EditChercherCodeTiers.Text:=TableauListeMouvement.Cells[9,TableauListeMouvement.Row];
               FSFicheSaisie.EditChercherTiers.Text:=TableauListeMouvement.Cells[10,TableauListeMouvement.Row];
          end;

          if(FSFicheSaisie.EditModeRecherche.Text='Tiers')then
          begin
               FSFicheSaisie.EditChercherNumeroListeMouvement.Text:=TableauListeMouvement.Cells[2,TableauListeMouvement.Row];
          end;
     end;

     FSFicheSaisie.EditNumProjet.Text:=TableauListeMouvement.Cells[25,TableauListeMouvement.Row];
     FSFicheSaisie.LabelIndiquerTypeProjet.Caption:=IndiquerTypeProjet(FSFicheSaisie.EditNumProjet.Text)+':';
     FSFicheSaisie.EditNomProjet.Text:=TableauListeMouvement.Cells[26,TableauListeMouvement.Row];
     FSFicheSaisie.EditModePayement.Text:=TableauListeMouvement.Cells[27,TableauListeMouvement.Row];
     FSFicheSaisie.EditNumDomiciliation.Text:=TableauListeMouvement.Cells[28,TableauListeMouvement.Row];
     FSFicheSaisie.EditDomiciliation.Text:=TableauListeMouvement.Cells[29,TableauListeMouvement.Row];
     FSFicheSaisie.EditNumPiece.Text:=TableauListeMouvement.Cells[30,TableauListeMouvement.Row];

     FSFicheSaisie.EditOrdreListeMouvement.Text:=TableauListeMouvement.Cells[1,TableauListeMouvement.Row];
     FSFicheSaisie.EditNumListeMouvement.Text:=TableauListeMouvement.Cells[2,TableauListeMouvement.Row];
     FSFicheSaisie.EditPositionDetailMouvementBegin.Text:=TableauListeMouvement.Cells[38,TableauListeMouvement.Row];
     FSFicheSaisie.EditPositionDetailMouvementEnd.Text:=TableauListeMouvement.Cells[39,TableauListeMouvement.Row];
     FSFicheSaisie.EditPositionListeMouvementEndNew.Text:='';
     if datecorrecte(TableauListeMouvement.Cells[5,TableauListeMouvement.Row])
     then FSFicheSaisie.EditDateDetailMouvement.Date:=strtodate(TableauListeMouvement.Cells[5,TableauListeMouvement.Row])
     else FSFicheSaisie.EditDateDetailMouvement.Date:=date;

     RTypeMouvement:=ChercherTypeMouvement(strtointeger(TableauListeMouvement.Cells[3,TableauListeMouvement.Row]),ExerciceAnnee,AdresseFichierConcerne);
     FSFicheSaisie.EditPositionTypeMouvement.Text:=inttostr(RTypeMouvement.PositionTypeMouvement);
     FSFicheSaisie.EditCodeTypeMouvement.Text:=RTypeMouvement.CodeTypeMouvement;
     FSFicheSaisie.EditDesignationTypeMouvement.Text:=RTypeMouvement.DesignationTypeMouvement;

     RMouvement:=ChercherMouvement(TableauListeMouvement.Cells[3,TableauListeMouvement.Row],strtointeger(TableauListeMouvement.Cells[4,TableauListeMouvement.Row]),AdresseFichierConcerne);
     FSFicheSaisie.EditPositionMouvement.Text:=inttostr(RMouvement.PositionMouvement);
     FSFicheSaisie.EditCodeMouvement.Text:=RMouvement.CodeMouvement;
     FSFicheSaisie.EditTypeProces.Text:=RMouvement.TypeProces;
     FSFicheSaisie.EditDesignationMouvement.Text:=RMouvement.DesignationMouvement;
     FSFicheSaisie.EditFichierTiersConserne.Text:=RMouvement.FichierTiersConserne;
     FSFicheSaisie.EditTypeStock.Text:=RMouvement.TypeStock;
     FSFicheSaisie.EditCompteConserne.Text:=RMouvement.CompteConserne;
     FSFicheSaisie.EditTypePrixMouvement.Text:=RMouvement.TypePrixMouvement;
     FSFicheSaisie.EditCodeTypeFormuleBase.Text:=RMouvement.CodeTypeFormuleBase;
     FSFicheSaisie.EditSigneMouvement.Text:=RTypeMouvement.SigneTypeMouvement;
     FSFicheSaisie.RBAutoriserVide.Checked:=RTypeMouvement.AutoriserMouvementAVide;
     FSFicheSaisie.RBAvecDateExecution.Checked:=RMouvement.AvecDateExecution;
     FSFicheSaisie.RBAvecLocalisationGeographique.Checked:=RMouvement.AvecLocalisationGeographique;
     FSFicheSaisie.EditCodeTypeFormuleAfficher.Text:=RMouvement.CodeTypeFormuleBase;//FSFicheSaisie.EditCodeTypeFormuleBase.Text;
     FSFicheSaisie.EditEtatUtilise.Text:='Etat Utilisé: '+RMouvement.EtatUtilise;

     FSFicheSaisie.EditDesignationMouvementRecherche.Caption:=FSFicheSaisie.EditDesignationMouvement.Text;
     FSFicheSaisie.EditDesignationTypeMouvementRecherche.Caption:=FSFicheSaisie.EditDesignationTypeMouvement.Text;

     if(FSFicheSaisie.RBDetailMouvementAfficher.Checked=true)then
     begin
          FSFicheSaisie.AfficheMouvement.Caption:='   '+RMouvement.DesignationMouvement+' Concernant: '+RMouvement.FichierTiersConserne;

          if(FSFicheSaisie.RBValidationDetailMouvement.Checked=true)then
          begin
               FSFicheSaisie.TypeFormuleAfficher.Caption:='   '+'Type Formule utilisé: '+ChercherTypeFormule(RMouvement.CodeTypeFormuleBase,'').DesignationTypeFormule;
          end
          else
          begin
               FSFicheSaisie.TypeFormuleAfficher.Caption:='Détails Mouvements Supprimés !';
          end;

          FSFicheSaisie.AfficheMouvement.Caption:='  Type de mouvement: '+RTypeMouvement.DesignationTypeMouvement;
          FSFicheSaisie.TypeFormuleAfficher.Caption:='  Mouvement: '+RMouvement.DesignationMouvement;
     end
     else
     begin
          FSFicheSaisie.AfficheMouvement.Caption:='Détail des Mouvements {'+FSFicheSaisie.EditDesignationTypeMouvement.Text+'}';

          if(FSFicheSaisie.RBValidationDetailMouvement.Checked=true)then
          begin
               FSFicheSaisie.TypeFormuleAfficher.Caption:='Registres Validés !';
          end
          else
          begin
               FSFicheSaisie.TypeFormuleAfficher.Caption:='Registres Supprimés !';
          end;
     end;

     FSFicheSaisie.EditCodeTiersConserne.Text:=TableauListeMouvement.Cells[9,TableauListeMouvement.Row];
     if(TableauListeMouvement.Cells[35,TableauListeMouvement.Row]<>'')and(FSFicheSaisie.RBAfficherInfoTiersSupplementaire.Checked=false)
     then FSFicheSaisie.EditTiersConserne.Text:=TableauListeMouvement.Cells[10,TableauListeMouvement.Row]+' {'+TableauListeMouvement.Cells[35,TableauListeMouvement.Row]+'}'
     else FSFicheSaisie.EditTiersConserne.Text:=TableauListeMouvement.Cells[10,TableauListeMouvement.Row];
     FSFicheSaisie.EditDataTiersSupplementaire.Text:=TableauListeMouvement.Cells[35,TableauListeMouvement.Row];

     if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
     ProcAfficheFormuleFS(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable,FSFicheSaisie.EditCodeTypeFormuleAfficher.Text,true);

     if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
     ProceAfficheDetailMouvementPointeur(TableauFormules,TableauVariable,TableauDetaiMouvement,strtointeger(FSFicheSaisie.EditOrdreListeMouvement.Text),strtointeger(FSFicheSaisie.EditPositionDetailMouvementBegin.Text),strtointeger(FSFicheSaisie.EditPositionDetailMouvementEnd.Text),FSFicheSaisie.RBValidationDetailMouvement.Checked,FSFicheSaisie.RBDetailMouvementAfficher.Checked,FSFicheSaisie.RBChargerPointeurDetailMouvement.Checked);

     if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
     AfficherRecapeFicheSaisie(TableauDetaiMouvement,TableauFormules,FSFicheSaisie.EditChiffreEnLettres,FSFicheSaisie.EditTitreChiffreEnLettres,FSFicheSaisie.EditMontantMouvement);

     if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
     ////////////////////////////////////////////////////////////////////////////////
     AjustementTableauVariable(TableauVariable);

     LibererMemoireProcessus('BusinessProces.exe',True);

     FSFicheSaisie.AfficheExecutionMouvement.Visible:=RMouvement.AvecDateExecution;
     
     if datecorrecte(TableauListeMouvement.Cells[12,TableauListeMouvement.Row])
     then FSFicheSaisie.EditDateExecutionMouvement.Date:=strtodate(TableauListeMouvement.Cells[12,TableauListeMouvement.Row])
     else FSFicheSaisie.EditDateExecutionMouvement.Date:=date;

     FSFicheSaisie.OKExecutionOui.Checked:=strtoboolean(TableauListeMouvement.Cells[24,TableauListeMouvement.Row]);
     FSFicheSaisie.OKExecutionNon.Checked:=Not(strtoboolean(TableauListeMouvement.Cells[24,TableauListeMouvement.Row]));

     if(FSFicheSaisie.AfficheExecutionMouvement.Visible=true)then
     begin
          if(FSFicheSaisie.OKExecutionOui.Checked=true)
          then FSFicheSaisie.AfficheAvecDateExecution.Color:=$0080FF80
          else FSFicheSaisie.AfficheAvecDateExecution.Color:=clRed;
     end;

     FSFicheSaisie.EditCodePaysExecutionMouvement.Text:=TableauListeMouvement.Cells[13,TableauListeMouvement.Row];
     FSFicheSaisie.EditPaysExecutionMouvement.Text:=ChercherLocalisationGeographique(FSFicheSaisie.EditCodePaysExecutionMouvement.Text,'FPays').IntitulleLocalisationGeographique;
     FSFicheSaisie.EditCodeWilayaExecutionMouvement.Text:=TableauListeMouvement.Cells[15,TableauListeMouvement.Row];
     FSFicheSaisie.EditWilayaExecutionMouvement.Text:=ChercherLocalisationGeographique(FSFicheSaisie.EditCodeWilayaExecutionMouvement.Text,'FWilaya').IntitulleLocalisationGeographique;;
     FSFicheSaisie.EditCodeDairaExecutionMouvement.Text:=TableauListeMouvement.Cells[17,TableauListeMouvement.Row];
     FSFicheSaisie.EditDairaExecutionMouvement.Text:=ChercherLocalisationGeographique(FSFicheSaisie.EditCodeDairaExecutionMouvement.Text,'FDaira').IntitulleLocalisationGeographique;
     FSFicheSaisie.EditCodeCommuneExecutionMouvement.Text:=TableauListeMouvement.Cells[19,TableauListeMouvement.Row];
     FSFicheSaisie.EditCommuneExecutionMouvement.Text:=ChercherLocalisationGeographique(FSFicheSaisie.EditCodeCommuneExecutionMouvement.Text,'FCommune').IntitulleLocalisationGeographique;
     FSFicheSaisie.EditCodeZoneExecutionMouvement.Text:=TableauListeMouvement.Cells[21,TableauListeMouvement.Row];
     FSFicheSaisie.EditZoneExecutionMouvement.Text:=ChercherLocalisationGeographique(FSFicheSaisie.EditCodeZoneExecutionMouvement.Text,'FZone').IntitulleLocalisationGeographique;
     FSFicheSaisie.EditAdresseExecutionMouvement.Text:=TableauListeMouvement.Cells[23,TableauListeMouvement.Row];
     FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text:=TableauListeMouvement.Cells[23,TableauListeMouvement.Row];
     FSFicheSaisie.EditInfoAdresseExecutionMouvement.Enabled:=FSFicheSaisie.RBInfoAdresseExecutionMouvement.Checked;
     FSFicheSaisie.EditNumAvis.Text:=TableauListeMouvement.Cells[31,TableauListeMouvement.Row];
