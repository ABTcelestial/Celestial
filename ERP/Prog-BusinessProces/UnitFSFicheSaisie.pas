                                RDetailMouvement.RRegistreFormule3.Active:=strtoboolean(FSFicheSaisie.TableauDetaiMouvement.Cells[C,4]);
                                RDetailMouvement.RRegistreFormule3.ValeurFormule:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[C,R]);
                           end;
                      12:  begin
