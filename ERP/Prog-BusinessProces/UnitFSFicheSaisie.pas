                    RStockArticleCopie:=ChercherStockArticle(FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row],TypeCodeRecherche,OKStockRecherche,RubriqueRecherche);
                    FSFicheSaisie.LabelCodeArticle.Caption:=RStockArticleCopie.Code;
                    FSFicheSaisie.LabelDesignationArticle.Caption:=RStockArticleCopie.Design;
                    FSFicheSaisie.LabelRefArticle.Caption:=RStockArticleCopie.Ref;
                    FSFicheSaisie.LabelUniteMusure.Caption:=RStockArticleCopie.UM;

                    FSFicheSaisie.AfficheArticleSelection.Lines.Text:=RStockArticleCopie.Design+' '+RStockArticleCopie.Ref;
                    FSFicheSaisie.EditQuantiteStock.Text:=floattostr(RStockArticleCopie.QteStock);
                    FSFicheSaisie.EditQuantiteMouvement.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[6,FSFicheSaisie.TableauDetaiMouvement.Row];
                    FSFicheSaisie.EditUniteMesure.Text:=RStockArticleCopie.UM;

                    PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                    if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Vente')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                    if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Achat')then PrixMouvement:=RStockArticleCopie.CoutUnitaire;
                    if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Détail')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                    if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Gros')then PrixMouvement:=RStockArticleCopie.PrixVenteGros;
                    if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix DemiGros')then PrixMouvement:=RStockArticleCopie.PrixVenteDemiGros;
                    FSFicheSaisie.EditPrixMouvement.Text:=floattostr(PrixMouvement);

                    FSFicheSaisie.AfficheDetailMouvementCodeBarre.Visible:=true;
                    FSFicheSaisie.AfficheArticleSelectionCodeBarre.Text:=FSFicheSaisie.AfficheArticleSelection.Text;
                    FSFicheSaisie.EditQuantiteMouvementCodeBarre.SetFocus;
                    FSFicheSaisie.EditCodeBareArticleSelect.Text:=RStockArticleCopie.CodeBarre;
               end;
          end;
     end;

     if key in[VK_UP]then
     begin
          if(FSFicheSaisie.TableauDetaiMouvement.Row>6)
          and(FSFicheSaisie.TableauDetaiMouvement.Cells[6,FSFicheSaisie.TableauDetaiMouvement.Row]='')then
          begin
               FSFicheSaisie.SetFocus;
               //FSFicheSaisie.TableauDetaiMouvement.Row:=MaxInt(FSFicheSaisie.TableauDetaiMouvement.RowCount-1,6);
               FSFicheSaisie.TableauDetaiMouvement.RowCount:=MaxInt(FSFicheSaisie.TableauDetaiMouvement.RowCount-1,7);
               FSFicheSaisie.TableauDetaiMouvement.Col:=1;
               //FSFicheSaisie.TableauDetaiMouvement.SetFocus;
               FSFicheSaisie.TimerVKUP.Enabled:=true;
          end
          else
          if(FSFicheSaisie.TableauDetaiMouvement.Row=6)then
          begin
               FSFicheSaisie.EditTiersConserne.SetFocus;
               FSFicheSaisie.EditTiersConserne.SelectAll;
          end;
          end;

     if key in[VK_DOWN]then
     begin
          if(FSFicheSaisie.TableauDetaiMouvement.Cells[6,FSFicheSaisie.TableauDetaiMouvement.Row]<>'')
          and(FSFicheSaisie.TableauDetaiMouvement.Row=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)
          then
          begin
               FSFicheSaisie.TableauDetaiMouvement.RowCount:=FSFicheSaisie.TableauDetaiMouvement.RowCount+1;
               FSFicheSaisie.TableauDetaiMouvement.Row:=FSFicheSaisie.TableauDetaiMouvement.RowCount-1;
               FSFicheSaisie.TableauDetaiMouvement.Rows[FSFicheSaisie.TableauDetaiMouvement.Row].Text:='';
               FSFicheSaisie.TableauDetaiMouvement.Col:=1;
               FSFicheSaisie.TableauDetaiMouvement.SetFocus;
          end
          else
          begin
               //if(FSFicheSaisie.RBAutoNouveauMouvement.Checked=true)then FSFicheSaisie.BitValidationListeMouvement.SetFocus;

               if(FSFicheSaisie.RBAutoNouveauMouvement.Checked=true)then  BitValidationListeMouvementClick(FSFicheSaisie.BitValidationListeMouvement);
          end;
     end;

     if(key in[VK_DELETE])then
     begin
          if(FSFicheSaisie.RBActiverAutorisationsManipulations.Checked=true)
          and(FSFicheSaisie.RBAutoriserSuppression.Checked=false)then
          begin
               showmessage('Suppression non autorisé !');
               Exit;
          end;

          ChListeMouvement:=IndiqueAdresseListeMouvement(FSFicheSaisie.EditPositionTypeMouvement.Text,TypeProcesReseauxListeMouvement);

          if(TypeProcesReseauxListeMouvement='Réseaux')then
          begin
               showmessage('Opération réseaux non autorisé !');
               Exit;
          end;

          FSFicheSaisie.AfficherOperationDetailMouvement.Visible:=true;
          FSFicheSaisie.EditOperationOrdreListeMouvement.Text:=FSFicheSaisie.EditOrdreListeMouvement.Text;
          FSFicheSaisie.EditOperationPositionDetailMouvement.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[0,FSFicheSaisie.TableauDetaiMouvement.Row];
          FSFicheSaisie.AfficherOperationDetailMouvement.Caption:='Supprimer l''artcle: '+FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row]+' du mouvement Ordre°: '+FSFicheSaisie.EditOrdreListeMouvement.Text;
          FSFicheSaisie.BitOperationDetailMouvement.SetFocus;

          MontantListeMouvement:=strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]);

          C:=FSFicheSaisie.TableauDetaiMouvement.ColCount-1;
          ColVale:=0;
          OKColVale:=false;
          while(C>0)and(OKColVale=false)do
          begin
               if(FSFicheSaisie.TableauDetaiMouvement.ColWidths[C]>0)then
               begin
                    OKColVale:=true;
                    ColVale:=C;
               end;
          C:=C-1;
          end;

          if(ColVale>0)then
          begin
               R:=6;
               MontantTotal:=0;
               MontantSupp:=0;
               while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
               begin
                    MontantTotal:=MontantTotal+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColVale,R]);

                    if ExisteNumInTexte(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R],FSFicheSaisie.EditOperationPositionDetailMouvement.Text)
                    then MontantSupp:=MontantSupp+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColVale,R]);
               R:=R+1;
               end;

               FSFicheSaisie.AfficherOperationDetailMouvementInfo.Caption:='Liste Mouvement: '+Vergule(floattostr(MontantListeMouvement),'2','C','')+', Détail Mouvement: '+Vergule(floattostr(MontantTotal-MontantSupp),'2','C','')+', Ecart: '+Vergule(floattostr(MontantListeMouvement-(MontantTotal-MontantSupp)),'2','C','');

               Ecart:=MontantListeMouvement-(MontantTotal-MontantSupp);
               if(Ecart<0)then Ecart:=Ecart*(-1);
               if(Ecart<=1/100)
               then FSFicheSaisie.AfficherOperationDetailMouvementInfo.Color:=clLime
               else FSFicheSaisie.AfficherOperationDetailMouvementInfo.Color:=clRed;
          end;
     end;

     if key in[VK_F1]then
     begin
          if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then
          begin
               FSFicheSaisie.EditTiersConserne.SetFocus;
               FSFicheSaisie.EditTiersConserne.SelectAll;
          end;
     end;

     if key in[VK_F2]then
     begin
          if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then
          begin
               FSFicheSaisie.AfficheATermeEspeceTiers.Visible:=true;
               FSFicheSaisie.BitEspece.SetFocus;
          end;
     end;

     if key in[VK_F3]then
     begin
          if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then
          begin
               FSFicheSaisie.EditDateDetailMouvement.SetFocus;
          end;
     end;

     if key in[VK_F4]then
     begin
          if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then
          begin
               FSFicheSaisie.TableauListeMouvement.SetFocus;
          end;
     end;
end;

end;

