procedure TFSFicheSaisie.EditMatriculePontBasculeKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  R:integer;  OKListeMouvement:boolean;
begin
     if(key in[VK_RETURN])and(FSFicheSaisie.EditMatriculePontBascule.Text<>'')then
     begin
          R:=1;
          OKListeMouvement:=false;
          while(R<=FSFicheSaisie.TableauListeMouvement.RowCount-1)and(OKListeMouvement=false)do
          begin
               if(FSFicheSaisie.TableauListeMouvement.Cells[42,R]=FSFicheSaisie.EditMatriculePontBascule.Text)
               and(strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,R])=0)
               then
               begin
                    OKListeMouvement:=true;
                    FSFicheSaisie.TableauListeMouvement.Row:=R;
                    FSFicheSaisie.TableauListeMouvementClick(FSFicheSaisie.TableauListeMouvement);
                    FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text:=FSFicheSaisie.TableauListeMouvement.Cells[1,R];
                    FSFicheSaisie.EditTypeVehiculePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[43,R];
                    FSFicheSaisie.EditTonageVehiculePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[44,R];
                    FSFicheSaisie.EditCodeResponsablePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[45,R];
                    FSFicheSaisie.EditNomResponsablePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[46,R];
                    FSFicheSaisie.EditPrenomResponsablePrelevement.Text:=FSFicheSaisie.TableauListeMouvement.Cells[47,R];
                    FSFicheSaisie.EditIndiceInialPontBascule.Text:=FSFicheSaisie.TableauListeMouvement.Cells[48,R];
                    FSFicheSaisie.EditDateIndiceInitial.Text:=FSFicheSaisie.TableauListeMouvement.Cells[50,R];
                    FSFicheSaisie.EditHeureIndiceInitial.Text:=FSFicheSaisie.TableauListeMouvement.Cells[51,R];
                    FSFicheSaisie.EditIndiceCalculePontBascule.Text:='';

                    if(TimeCorrecte(FSFicheSaisie.EditHeureIndiceInitial.Text))
                    then FSFicheSaisie.InfoTempsPasse.Caption:='Temps de chargement: '+timetostr(FSFicheSaisie.EditHeureIndiceFinal.Time-strtotime(FSFicheSaisie.TableauListeMouvement.Cells[51,R]));
               end;
          R:=R+1;
          end;

          if(OKListeMouvement=false)then
          begin
               RVehiculePrelevementTareCopie:=ChercherVehiculePontBascule(FSFicheSaisie.EditMatriculePontBascule.Text,'');

               if(RVehiculePrelevementTareCopie.MatriculeResponsablePrelevement=FSFicheSaisie.EditMatriculePontBascule.Text)then
               begin
                    if(FSFicheSaisie.RBModificationPontBascule.Checked=false) then FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text:='';
                    FSFicheSaisie.EditTypeVehiculePrelevement.Text:=RVehiculePrelevementTareCopie.TypeVehiculePrelevement;
                    FSFicheSaisie.EditTonageVehiculePrelevement.Text:=RVehiculePrelevementTareCopie.TonageVehiculePrelevement;
                    FSFicheSaisie.EditCodeResponsablePrelevement.Text:=RVehiculePrelevementTareCopie.CodeResponsablePrelevement;
                    FSFicheSaisie.EditNomResponsablePrelevement.Text:=RVehiculePrelevementTareCopie.NomResponsablePrelevement;
                    FSFicheSaisie.EditPrenomResponsablePrelevement.Text:=RVehiculePrelevementTareCopie.PrenomResponsablePrelevement;
                    FSFicheSaisie.EditIndiceInialPontBascule.Text:=Vergule(floattostr(RVehiculePrelevementTareCopie.IndiceInialPontBascule),'2','C','');
                    FSFicheSaisie.EditDateIndiceInitial.Text:=datetostr(FSFicheSaisie.EditDateIndiceFinal.Date);
                    FSFicheSaisie.EditHeureIndiceInitial.Text:=timetostr(FSFicheSaisie.EditHeureIndiceFinal.Time);
                    FSFicheSaisie.EditIndiceCalculePontBascule.Text:='';

                    FSFicheSaisie.InfoTempsPasse.Caption:='';
               end
               else
               begin
                    FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text:='';
                    FSFicheSaisie.EditIndiceInialPontBascule.Text:='0';
                    FSFicheSaisie.EditIndiceCalculePontBascule.Text:='';
                    FSFicheSaisie.EditDateIndiceInitial.Text:=datetostr(FSFicheSaisie.EditDateIndiceFinal.Date);
                    FSFicheSaisie.EditHeureIndiceInitial.Text:=timetostr(FSFicheSaisie.EditHeureIndiceFinal.Time);
                    FSFicheSaisie.EditCodeResponsablePrelevement.Text:='';
                    FSFicheSaisie.EditNomResponsablePrelevement.Text:='';
                    FSFicheSaisie.EditPrenomResponsablePrelevement.Text:='';
                    FSFicheSaisie.EditTypeVehiculePrelevement.Text:='';
                    FSFicheSaisie.EditTonageVehiculePrelevement.Text:='';
               end;
          end;

          FSFicheSaisie.EditIndiceFinalPontBascule.Text:='';
          FSFicheSaisie.EditIndiceFinalPontBascule.SetFocus;
     end;
end;

procedure TFSFicheSaisie.EditIndiceFinalPontBasculeKeyUp(
  Sender: TObject; var Key: Word; Shift: TShiftState);
var  T:integer; TTonage:array[1..10]of real;  IndiceTonage:real;  OKTonage:boolean;
begin
     TTonage[1]:= 2;
     TTonage[2]:= 5;
     TTonage[3]:= 7;
     TTonage[4]:= 10;
     TTonage[5]:= 12;
     TTonage[6]:= 14;
     TTonage[7]:= 16;
     TTonage[8]:= 20;
     TTonage[9]:= 25;
     TTonage[10]:=30;

     if(FSFicheSaisie.EditIndiceInialPontBascule.Text<>'')then
     begin
          FSFicheSaisie.EditIndiceCalculePontBascule.Text:=Vergule(floattostr(strtoreal(FSFicheSaisie.EditIndiceFinalPontBascule.Text)-
                                                                              strtoreal(FSFicheSaisie.EditIndiceInialPontBascule.Text)),FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,'C','');

          if(FSFicheSaisie.EditTonageVehiculePrelevement.Text='')then
          begin
               IndiceTonage:=strtoreal(FSFicheSaisie.EditIndiceCalculePontBascule.Text)/2000;
               OKTonage:=false;
               T:=1;
               while(T<=10)and(OKTonage=false)do
               begin
                    if(TTonage[T]=IndiceTonage)then
                    begin
                         OKTonage:=true;
                         IndiceTonage:=TTonage[T]
                    end
                    else
                    if(TTonage[T]>IndiceTonage)then
                    begin
                         OKTonage:=true;
                         if(T>1)then IndiceTonage:=TTonage[T-1]else IndiceTonage:=TTonage[1];
                    end;
               T:=T+1;
               end;

               FSFicheSaisie.EditTonageVehiculePrelevement.Text:=floattostr(IndiceTonage)+' M3';
          end;
     end;
end;

procedure TFSFicheSaisie.EditIndiceFinalPontBasculeKeyDown(
  Sender: TObject; var Key: Word; Shift: TShiftState);
begin
     if(key in[VK_RETURN])and(strtoreal(FSFicheSaisie.EditIndiceFinalPontBascule.Text)<>0)and(strtoreal(FSFicheSaisie.EditIndiceCalculePontBascule.Text)>=0)then
     begin
          if(FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text='')then
          begin
               if(strtoreal(FSFicheSaisie.EditIndiceInialPontBascule.Text)=0)then
               begin
                    FSFicheSaisie.EditIndiceInialPontBascule.Text:=FSFicheSaisie.EditIndiceFinalPontBascule.Text;
                    FSFicheSaisie.EditIndiceFinalPontBascule.Text:='';
                    FSFicheSaisie.EditIndiceCalculePontBascule.Text:='';
                    FSFicheSaisie.BitNouveauMouvementClick(FSFicheSaisie.BitNouveauMouvement);

                    NouveauVehiculePontBascule(FSFicheSaisie.EditMatriculePontBascule.Text,FSFicheSaisie.EditTypeVehiculePrelevement.Text,FSFicheSaisie.EditTonageVehiculePrelevement.Text,FSFicheSaisie.EditCodeResponsablePrelevement.Text,FSFicheSaisie.EditNomResponsablePrelevement.Text,FSFicheSaisie.EditPrenomResponsablePrelevement.Text,FSFicheSaisie.EditIndiceInialPontBascule.Text);
                    NouveauChauffeur(FSFicheSaisie.EditCodeResponsablePrelevement.Text,FSFicheSaisie.EditNomResponsablePrelevement.Text,FSFicheSaisie.EditPrenomResponsablePrelevement.Text);

                    FSFicheSaisie.BitValidationListeMouvementClick(FSFicheSaisie.BitValidationListeMouvement);
               end
               else
               begin
                    FSFicheSaisie.BitNouveauMouvementClick(FSFicheSaisie.BitNouveauMouvement);
                    FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text:=FSFicheSaisie.EditOrdreListeMouvement.Text;

                    NouveauVehiculePontBascule(FSFicheSaisie.EditMatriculePontBascule.Text,FSFicheSaisie.EditTypeVehiculePrelevement.Text,FSFicheSaisie.EditTonageVehiculePrelevement.Text,FSFicheSaisie.EditCodeResponsablePrelevement.Text,FSFicheSaisie.EditNomResponsablePrelevement.Text,FSFicheSaisie.EditPrenomResponsablePrelevement.Text,FSFicheSaisie.EditIndiceInialPontBascule.Text);
                    NouveauChauffeur(FSFicheSaisie.EditCodeResponsablePrelevement.Text,FSFicheSaisie.EditNomResponsablePrelevement.Text,FSFicheSaisie.EditPrenomResponsablePrelevement.Text);

                    FSFicheSaisie.TableauDetaiMouvement.Col:=1;
                    FSFicheSaisie.TableauDetaiMouvement.Row:=6;
                    FSFicheSaisie.AfficheIndiceListeMouvement.Visible:=false;
                    FSFicheSaisie.TableauDetaiMouvement.SetFocus;
               end;
          end
          else
          begin
               NouveauVehiculePontBascule(FSFicheSaisie.EditMatriculePontBascule.Text,FSFicheSaisie.EditTypeVehiculePrelevement.Text,FSFicheSaisie.EditTonageVehiculePrelevement.Text,FSFicheSaisie.EditCodeResponsablePrelevement.Text,FSFicheSaisie.EditNomResponsablePrelevement.Text,FSFicheSaisie.EditPrenomResponsablePrelevement.Text,FSFicheSaisie.EditIndiceInialPontBascule.Text);
               NouveauChauffeur(FSFicheSaisie.EditCodeResponsablePrelevement.Text,FSFicheSaisie.EditNomResponsablePrelevement.Text,FSFicheSaisie.EditPrenomResponsablePrelevement.Text);

               if(strtoreal(FSFicheSaisie.EditIndiceCalculePontBascule.Text)>0)then
               begin
                    FSFicheSaisie.TableauDetaiMouvement.Col:=1;
                    FSFicheSaisie.TableauDetaiMouvement.Row:=6;
                    FSFicheSaisie.AfficheIndiceListeMouvement.Visible:=false;
                    FSFicheSaisie.TableauDetaiMouvement.SetFocus;
               end
               else
               begin
                    FSFicheSaisie.BitValidationListeMouvementClick(FSFicheSaisie.BitValidationListeMouvement);
               end;
          end;
     end;

     if key in[VK_DOWN]then
     begin
          FSFicheSaisie.EditCodeResponsablePrelevement.SetFocus;
     end;

     if key in[VK_UP]then
     begin
          FSFicheSaisie.EditMatriculePontBascule.SetFocus;
     end;
end;

