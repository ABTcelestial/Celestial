                                RDetailMouvement.RRegistreFormule2.Active:=strtoboolean(FSFicheSaisie.TableauDetaiMouvement.Cells[C,4]);
                                RDetailMouvement.RRegistreFormule2.ValeurFormule:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[C,R]);
                           end;
                      11:  begin
                                RDetailMouvement.RRegistreFormule3.PositionFormule:=strtointeger(FSFicheSaisie.TableauDetaiMouvement.Cells[C,0]);
                                RDetailMouvement.RRegistreFormule3.CodeFormule:=FSFicheSaisie.TableauDetaiMouvement.Cells[C,1];
                                RDetailMouvement.RRegistreFormule3.LibelleFormule:=FSFicheSaisie.TableauDetaiMouvement.Cells[C,2];
