procedure TFSFicheSaisie.TableauDetaiMouvementKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var   R,RowOut,C,ColVale,RowEditing:integer;   NotCol,TypeCodeRecherche,RubriqueRecherche:string;
      MontantTotal,MontantSupp,MontantListeMouvement,Ecart,PrixMouvement:real; OKArticle,OKColVale:boolean;
begin

if(FSFicheSaisie.EditModeSelection.Text='Modifier')or(FSFicheSaisie.EditModeSelection.Text='Nouveau')then
begin
     if not ControleNumDetailMouvement(FSFicheSaisie.EditNumListeMouvement)then Exit;

     if key in[VK_ESCAPE]then
     begin
          FSFicheSaisie.BitEchapClick(FSFicheSaisie.BitEchap);
     end;

     if key in[VK_INSERT]then
     begin
          ProcAfficheStockArticleListe(FSFicheSaisie.TableauCompteConcerne,FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.EditCompteConserne.Text,'','','',FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row],FSFicheSaisie.RBDistingueDesigRef.Checked,0,RowOut);
          NotCol:='5;6;8-'+inttostr(FSFicheSaisie.TableauCompteConcerne.ColCount-1);
          for C:=0 to FSFicheSaisie.TableauCompteConcerne.ColCount-1 do if(Existenumintexte(inttostr(C),NotCol))then FSFicheSaisie.TableauCompteConcerne.ColWidths[C]:=0;
          AjusterColWidth(FSFicheSaisie.TableauCompteConcerne,'',NotCol);
          if(FSFicheSaisie.TableauCompteConcerne.Visible=true)then FSFicheSaisie.TableauCompteConcerne.SetFocus;
     end;

     if key in[VK_RETURN]then
     begin
          if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=false)and(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=false)and(FSFicheSaisie.RBAutoNouveauMouvement.Checked=false)then
          begin
                if(FSFicheSaisie.EditCodeTiersConserne.Text='')then
                begin
                     FSFicheSaisie.EditTiersConserne.SetFocus;
                end
                else
                begin
                     if(FSFicheSaisie.EditListeAppartenanceCodeMouvement.Text<>'')and(FSFicheSaisie.EditAutoSelectionArticle.Text<>'')then
                     begin
                          FSFicheSaisie.AffichChoisOperationAppartenance.Visible:=true;
                          FSFicheSaisie.AfficheTitreOperation.Caption:='Choisissez le mode d''opération !';
                          FSFicheSaisie.BitOperationAutoSelection.SetFocus;
                     end
                     else
                     begin
                          ProcAfficheStockArticleListe(FSFicheSaisie.TableauCompteConcerne,FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.EditCompteConserne.Text,'','','',FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row],FSFicheSaisie.RBDistingueDesigRef.Checked,0,RowOut);
                          NotCol:='5;6;8-'+inttostr(FSFicheSaisie.TableauCompteConcerne.ColCount-1);
                          for C:=0 to FSFicheSaisie.TableauCompteConcerne.ColCount-1 do if(Existenumintexte(inttostr(C),NotCol))then FSFicheSaisie.TableauCompteConcerne.ColWidths[C]:=0;
                          AjusterColWidth(FSFicheSaisie.TableauCompteConcerne,'',NotCol);
                          if(FSFicheSaisie.TableauCompteConcerne.Visible=true)then FSFicheSaisie.TableauCompteConcerne.SetFocus;
                     end;
                end;
          end
          else
          begin
               if(FSFicheSaisie.TableauDetaiMouvement.Col=1)then
               begin
                    if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row]='')then
                    begin
                         if strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0 then
                         begin
                              if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)
                              then
                              begin
                                   FSFicheSaisie.BitValidationListeMouvementClick(FSFicheSaisie.BitValidationListeMouvement);
                                   exit;
                              end
                              else
                              if(FSFicheSaisie.RBAutoNouveauMouvement.Checked=false)then
                              begin
                                   FSFicheSaisie.BitValidationListeMouvement.SetFocus;
                                   exit;
                              end;
                         end;
                    end;

                    if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row]<>'')
                    and(longueur(FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row])<=10)then
                    begin
                         if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)
                         then TypeCodeRecherche:='CodeBarre'
                         else
                         if(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)
                         then TypeCodeRecherche:='PontBascule'
                         else
                         if(FSFicheSaisie.RBAutoNouveauMouvement.Checked=true)
                         then TypeCodeRecherche:='CodeArticleAuto'
                         else TypeCodeRecherche:='';

                         RStockArticleCopie:=ChercherStockArticle(FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.TableauDetaiMouvement.Cells[FSFicheSaisie.TableauDetaiMouvement.Col,FSFicheSaisie.TableauDetaiMouvement.Row],TypeCodeRecherche,OKStockRecherche,RubriqueRecherche);

                         if(OKStockRecherche)then
                         begin
                              if(RubriqueRecherche<>'CodeBarre')and(RubriqueRecherche<>'PontBascule')and(RubriqueRecherche<>'CodeArticleAuto')then
                              begin
                                   ProcAfficheStockArticleListe(FSFicheSaisie.TableauCompteConcerne,FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.EditCompteConserne.Text,'','','',FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row],FSFicheSaisie.RBDistingueDesigRef.Checked,0,RowOut);
                                   NotCol:='5;6;8-'+inttostr(FSFicheSaisie.TableauCompteConcerne.ColCount-1);
                                   for C:=0 to FSFicheSaisie.TableauCompteConcerne.ColCount-1 do if(Existenumintexte(inttostr(C),NotCol))then FSFicheSaisie.TableauCompteConcerne.ColWidths[C]:=0;
                                   AjusterColWidth(FSFicheSaisie.TableauCompteConcerne,'',NotCol);
                                   if(FSFicheSaisie.TableauCompteConcerne.Visible=true)then FSFicheSaisie.TableauCompteConcerne.SetFocus;
                              end
                              else
                              begin
                                   if(RubriqueRecherche<>'CodeArticleAuto')then
                                   begin
                                        RowEditing:=FSFicheSaisie.TableauDetaiMouvement.Row;
                                        R:=6;
                                        OKArticle:=false;
                                        while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OKArticle=false)do
                                        begin
                                             if(R<>RowEditing)then
                                             begin
                                                  if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]=RStockArticleCopie.Code)then
                                                  begin
                                                       OKArticle:=true;
                                                       //FSFicheSaisie.TableauDetaiMouvement.Row:=R;
                                                       FSFicheSaisie.EditRowEditing.Text:=inttostr(R);

                                                       FSFicheSaisie.LabelCodeArticle.Caption:=RStockArticleCopie.Code;
                                                       FSFicheSaisie.LabelDesignationArticle.Caption:=RStockArticleCopie.Design;
                                                       FSFicheSaisie.LabelRefArticle.Caption:=RStockArticleCopie.Ref;
                                                       FSFicheSaisie.LabelUniteMusure.Caption:=RStockArticleCopie.UM;

                                                       FSFicheSaisie.AfficheArticleSelection.Lines.Text:=RStockArticleCopie.Design+' '+RStockArticleCopie.Ref;
                                                       FSFicheSaisie.EditQuantiteStock.Text:=floattostr(RStockArticleCopie.QteStock);
                                                       FSFicheSaisie.EditQuantiteMouvement.Text:=Vergule(floattostr(strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R])+1),FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,'C','');
                                                       FSFicheSaisie.EditUniteMesure.Text:=RStockArticleCopie.UM;


                                                       PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                                       if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Vente')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                                       if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Achat')then PrixMouvement:=RStockArticleCopie.CoutUnitaire;
                                                       if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Détail')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                                       if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Gros')then PrixMouvement:=RStockArticleCopie.PrixVenteGros;
                                                       if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix DemiGros')then PrixMouvement:=RStockArticleCopie.PrixVenteDemiGros;

                                                       FSFicheSaisie.EditPrixMouvement.Text:=Vergule(floattostr(PrixMouvement),FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,'C','');

                                                       BitOptionDetailMouvementClick(BitOptionDetailMouvement);

                                                       //FSFicheSaisie.TableauDetaiMouvement.Row:=RowEditing;
                                                       FSFicheSaisie.TableauDetaiMouvement.Cells[FSFicheSaisie.TableauDetaiMouvement.Col,FSFicheSaisie.TableauDetaiMouvement.Row]:='';
                                                       key:=VK_DOWN;
                                                  end;
                                             end;
                                        R:=R+1;
                                        end;

                                        if(OKArticle=false)then
                                        begin
                                             FSFicheSaisie.LabelCodeArticle.Caption:=RStockArticleCopie.Code;
                                             FSFicheSaisie.LabelDesignationArticle.Caption:=RStockArticleCopie.Design;
                                             FSFicheSaisie.LabelRefArticle.Caption:=RStockArticleCopie.Ref;
                                             FSFicheSaisie.LabelUniteMusure.Caption:=RStockArticleCopie.UM;

                                             FSFicheSaisie.AfficheArticleSelection.Lines.Text:=RStockArticleCopie.Design+' '+RStockArticleCopie.Ref;
                                             FSFicheSaisie.EditQuantiteStock.Text:=floattostr(RStockArticleCopie.QteStock);

                                             if(RubriqueRecherche='CodeBarre')then FSFicheSaisie.EditQuantiteMouvement.Text:=Vergule('1',FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,'C','');
                                             if(RubriqueRecherche='PontBascule')then FSFicheSaisie.EditQuantiteMouvement.Text:=Vergule(FSFicheSaisie.EditIndiceCalculePontBascule.Text,FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,'C','');

                                             FSFicheSaisie.EditUniteMesure.Text:=RStockArticleCopie.UM;

                                             PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                             if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Vente')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                             if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Achat')then PrixMouvement:=RStockArticleCopie.CoutUnitaire;
                                             if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Détail')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                             if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Gros')then PrixMouvement:=RStockArticleCopie.PrixVenteGros;
                                             if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix DemiGros')then PrixMouvement:=RStockArticleCopie.PrixVenteDemiGros;
                                             FSFicheSaisie.EditPrixMouvement.Text:=Vergule(floattostr(PrixMouvement),FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,'C','');

                                             if(RubriqueRecherche='CodeBarre')then
                                             begin
                                                  if(AnsiUpperCase(RStockArticleCopie.UM)<>AnsiUpperCase('L'))
                                                  and(AnsiUpperCase(RStockArticleCopie.UM)<>AnsiUpperCase('Kg'))
                                                  then
                                                  begin
                                                       BitOptionDetailMouvementClick(BitOptionDetailMouvement);
                                                       key:=VK_DOWN;
                                                  end
                                                  else
                                                  begin
                                                       FSFicheSaisie.AfficheDetailMouvement.Visible:=true;
                                                       FSFicheSaisie.AfficheDetailMouvementCodeBarre.Visible:=true;
                                                       FSFicheSaisie.AfficheArticleSelectionCodeBarre.Text:=FSFicheSaisie.AfficheArticleSelection.Text;
                                                       FSFicheSaisie.EditQuantiteMouvementCodeBarre.SetFocus;
                                                       FSFicheSaisie.EditCodeBareArticleSelect.Text:=RStockArticleCopie.CodeBarre;
                                                  end;
                                             end
                                             else
                                             begin
                                                  BitOptionDetailMouvementClick(BitOptionDetailMouvement);
                                             end;
                                        end;
                                    end
                                    else
                                    begin
                                         FSFicheSaisie.AfficheDetailMouvementCodeBarre.Visible:=false;
                                         FSFicheSaisie.AfficheDetailMouvement.Visible:=true;
                                         FSFicheSaisie.LabelCodeArticle.Caption:=RStockArticleCopie.Code;
                                         FSFicheSaisie.LabelDesignationArticle.Caption:=RStockArticleCopie.Design;
                                         FSFicheSaisie.LabelRefArticle.Caption:=RStockArticleCopie.Ref;
                                         FSFicheSaisie.LabelUniteMusure.Caption:=RStockArticleCopie.UM;

                                         FSFicheSaisie.AfficheArticleSelection.Lines.Text:=RStockArticleCopie.Design+' '+RStockArticleCopie.Ref;
                                         FSFicheSaisie.EditQuantiteStock.Text:=floattostr(RStockArticleCopie.QteStock);

                                         FSFicheSaisie.EditQuantiteMouvement.Text:='';

                                         FSFicheSaisie.EditUniteMesure.Text:=RStockArticleCopie.UM;

                                         PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                         if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Vente')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                         if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Achat')then PrixMouvement:=RStockArticleCopie.CoutUnitaire;
                                         if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Détail')then PrixMouvement:=RStockArticleCopie.PrixVenteDetaille;
                                         if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Gros')then PrixMouvement:=RStockArticleCopie.PrixVenteGros;
                                         if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix DemiGros')then PrixMouvement:=RStockArticleCopie.PrixVenteDemiGros;
                                         FSFicheSaisie.EditPrixMouvement.Text:=Vergule(floattostr(PrixMouvement),FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,'C','');
                                         FSFicheSaisie.EditQuantiteMouvement.SetFocus;
                                    end;
                              end;
                         end
                         else
                         if(FSFicheSaisie.RBAutoNouveauMouvement.Checked=true)then
                         begin
                              ProcAfficheStockArticleListe(FSFicheSaisie.TableauCompteConcerne,FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.EditCompteConserne.Text,'','','',FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row],FSFicheSaisie.RBDistingueDesigRef.Checked,0,RowOut);
                              NotCol:='5;6;8-'+inttostr(FSFicheSaisie.TableauCompteConcerne.ColCount-1);
                              for C:=0 to FSFicheSaisie.TableauCompteConcerne.ColCount-1 do if(Existenumintexte(inttostr(C),NotCol))then FSFicheSaisie.TableauCompteConcerne.ColWidths[C]:=0;
                              AjusterColWidth(FSFicheSaisie.TableauCompteConcerne,'',NotCol);
                              if(FSFicheSaisie.TableauCompteConcerne.Visible=true)then FSFicheSaisie.TableauCompteConcerne.SetFocus;
                         end
                         else
                         begin
                              if(FSFicheSaisie.RBActiverChargementArticleManuel.Checked=true)then
                              begin
                                    if(NonOui('L''article n''existe pas ! Voulez vous le crier ?'))then
                                    begin
                                         FSMenuPrincipal.GnrateurdArticle1Click(FSMenuPrincipal.GnrateurdArticle1);
                                         TypeProces:='Commercial';
                                         FichierConcerne:='';
                                         Adresse:='';
                                         if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                                         begin
                                              showmessage('Génération locale !');
                                              FSGenerateurBase.AfficheProduits.Visible:=true;
                                              FSGenerateurBase.BitValiderProduit.Kind:=bkAll;
                                              FSGenerateurBase.BitValiderProduit.Caption:='Valider';

                                              FSGenerateurBase.NomSFl.Caption:='Ajouter un produit: ';
                                              InitialisationFicheSaisieProduit;
                                              FSGenerateurBase.EditCodeBarre.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row];
                                              FSGenerateurBase.EditCodeProduit.SetFocus;
                                              exit;
                                         end;
                                         showmessage('Génération externe !');
                                         FichierConcerne:=Adresse+'FStock'+FSGenerateurBase.EditTypeStock.Text+FSGenerateurBase.EditNumProjet.Text;
                                         FSGenerateurBase.AfficheStock.Visible:=true;
                                         ProcAfficheListeStock(FSGenerateurBase.TableauStock,FichierConcerne,'','','',false);
