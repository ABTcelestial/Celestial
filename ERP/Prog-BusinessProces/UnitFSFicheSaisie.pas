Procedure ProcActionMouvement(PoitionTypeMouvement,PositionMouvement:string; ActiverAutoAfficheListeMouvement:boolean);
var R:integer;
begin
     if(PoitionTypeMouvement='')and(FSFicheSaisie.TableauMouvement.Visible=true)then PoitionTypeMouvement:=FSFicheSaisie.TableauMouvement.Cells[0,FSFicheSaisie.TableauMouvement.Row];
     if(PositionMouvement='')and(FSFicheSaisie.TableauMouvement.Visible=true)then PositionMouvement:=FSFicheSaisie.TableauMouvement.Cells[1,FSFicheSaisie.TableauMouvement.Row];

     RTypeMouvement:=ChercherTypeMouvement(strtointeger(PoitionTypeMouvement),ExerciceAnnee,AdresseFichierConcerne);
     FSFicheSaisie.AfficheAdresseTypeMouvement.Caption:=AdresseFichierConcerne;
     RMouvement:=ChercherMouvement(PoitionTypeMouvement,strtointeger(PositionMouvement),AdresseFichierConcerne);
     FSFicheSaisie.EditCodeTypeFormuleAfficher.Text:=RMouvement.CodeTypeFormuleBase;//FSFicheSaisie.EditCodeTypeFormuleBase.Text;
     FSFicheSaisie.AfficheAdresseMouvement.Caption:=AdresseFichierConcerne;
     FSFicheSaisie.EditPositionMouvement.Text:=inttostr(RMouvement.PositionMouvement);//FSFicheSaisie.TableauMouvement.Cells[1,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditCodeMouvement.Text:=RMouvement.CodeMouvement;//FSFicheSaisie.TableauMouvement.Cells[2,FSFicheSaisie.TableauMouvement.Row];

     ChargerOptionsFicheSaisie(FSFicheSaisie.EditCodeMouvement.Text);

     FSFicheSaisie.EditTypeProces.Text:=RMouvement.TypeProces;//FSFicheSaisie.TableauMouvement.Cells[4,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditDesignationMouvement.Text:=RMouvement.DesignationMouvement;//FSFicheSaisie.TableauMouvement.Cells[3,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditFichierTiersConserne.Text:=RMouvement.FichierTiersConserne;//FSFicheSaisie.TableauMouvement.Cells[5,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditTypeStock.Text:=RMouvement.TypeStock;//FSFicheSaisie.TableauMouvement.Cells[18,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditCompteConserne.Text:=RMouvement.CompteConserne;//FSFicheSaisie.TableauMouvement.Cells[6,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditDebitCreditMouvement.Text:=RMouvement.DebitCredit;
     FSFicheSaisie.EditSigneDebitCredit.Text:=inttostr(RMouvement.SigneDebitCredit);
     FSFicheSaisie.EditTypePrixMouvement.Text:=RMouvement.TypePrixMouvement;//FSFicheSaisie.TableauMouvement.Cells[7,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditCodeTypeFormuleBase.Text:=RMouvement.CodeTypeFormuleBase;//FSFicheSaisie.TableauMouvement.Cells[8,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditSigneMouvement.Text:=RTypeMouvement.SigneTypeMouvement;//FSFicheSaisie.TableauMouvement.Cells[10,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.RBAutoriserVide.Checked:=RTypeMouvement.AutoriserMouvementAVide;//strtoboolean(FSFicheSaisie.TableauMouvement.Cells[11,FSFicheSaisie.TableauMouvement.Row]);
     FSFicheSaisie.RBAvecDateExecution.Checked:=RMouvement.AvecDateExecution;
     FSFicheSaisie.RBAvecLocalisationGeographique.Checked:=RMouvement.AvecLocalisationGeographique;

     FSFicheSaisie.EditPositionTypeMouvement.Text:=inttostr(RTypeMouvement.PositionTypeMouvement);
     FSFicheSaisie.EditCodeTypeMouvement.Text:=RTypeMouvement.CodeTypeMouvement;
     FSFicheSaisie.EditDesignationTypeMouvement.Text:=RTypeMouvement.DesignationTypeMouvement;

     FSFicheSaisie.AfficheMouvement.Caption:='  Type de mouvement: '+RTypeMouvement.DesignationTypeMouvement;
     FSFicheSaisie.TypeFormuleAfficher.Caption:='  Mouvement: '+RMouvement.DesignationMouvement;

     FSFicheSaisie.EditEtatUtilise.Text:='Etat Utilisé: '+FSFicheSaisie.TableauMouvement.Cells[14,FSFicheSaisie.TableauMouvement.Row];
     FSFicheSaisie.EditListeAppartenanceCodeMouvement.Text:=RMouvement.ListeAppartenanceCodeMouvement;

     FSFicheSaisie.EditPositionListeMouvementBegin.Text:=inttostr(RMouvement.PositionListeMouvementBegin);
     FSFicheSaisie.EditPositionListeMouvementEnd.Text:=inttostr(RMouvement.PositionListeMouvementEnd);

     RemplireTableauPositionListeMouvementPeriode(FSFicheSaisie.TableauPositionListeMouvementPeriode,FSFicheSaisie.EditPositionListeMouvementBegin,FSFicheSaisie.EditPositionListeMouvementEnd,FSFicheSaisie.EditAnnee.Text,PoitionTypeMouvement,PositionMouvement);

     ProcAfficheFormuleFS(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable,FSFicheSaisie.EditCodeTypeFormuleAfficher.Text,true);

     FSFicheSaisie.TableauMouvement.Visible:=false;

     if(FSFicheSaisie.EditOrdreListeMouvement.Text='')or(FSFicheSaisie.EditNumListeMouvement.Text='')then FSFicheSaisie.BitNouveauMouvement.SetFocus;

     FSFicheSaisie.RBAfficherValeursMonetaires.Checked:=true;

