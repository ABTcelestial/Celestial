procedure TFSFicheSaisie.TableauListeAvisKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  R,l:integer;     ListeNumAvis,ListeModePayement,ListeDomiciliation,ListeNumPiece:string;
begin
     ListeNumAvis:='';
     R:=1;
     l:=0;
     while(R<=FSFicheSaisie.TableauListeAvis.RowCount-1)do
     begin
          if(FSFicheSaisie.TableauListeAvis.Cells[0,R]='OK')then
          begin
               l:=l+1;
               if(ListeNumAvis='')
               then ListeNumAvis:='{'+FSFicheSaisie.TableauListeAvis.Cells[8,R]+'}'+FSFicheSaisie.TableauListeAvis.Cells[1,R]
               else ListeNumAvis:=ListeNumAvis+';'+'{'+FSFicheSaisie.TableauListeAvis.Cells[8,R]+'}'+FSFicheSaisie.TableauListeAvis.Cells[1,R];

               if(ListeModePayement='')
               then ListeModePayement:=FSFicheSaisie.TableauListeAvis.Cells[3,R]
