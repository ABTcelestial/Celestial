Function DecimaleInDevision(NbrDecimaleString:string):string;
var  i:integer; NbrDecimale:real; OKDevision:boolean; ListeResultDevision,ResultDevision:string;
begin
     NbrDecimale:=strtoreal(NbrDecimaleString);
     ListeResultDevision:='';
     OKDevision:=false;
     i:=10;
     while(i>1)do
     begin
          if(i in[4,5])then
          begin
                if(IntegerCorrecte(floattostr(NbrDecimale*i*10/5)))then
                begin
                     if(floattostr(NbrDecimale*i)<>inttostr(i))
                     then ResultDevision:=floattostr(NbrDecimale*i)+'/'+inttostr(i)
                     else ResultDevision:='1';

                     if(NbrDecimale*i<i)then
                     begin
                          if(ListeResultDevision='')
                          then ListeResultDevision:=ResultDevision
                          else
                          if(not Existecharinstring(floattostr(NbrDecimale*i)+'/'+inttostr(i),ListeResultDevision))
                          then ListeResultDevision:=ListeResultDevision+' *** '+ResultDevision
                     end;
                end;
          end;
     i:=i-1;
     end;

     if(ListeResultDevision<>'')
     then DecimaleInDevision:=ListeResultDevision
     else DecimaleInDevision:=floattostr(NbrDecimale);
end;

