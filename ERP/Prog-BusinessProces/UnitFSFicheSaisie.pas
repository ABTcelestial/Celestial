procedure TFSFicheSaisie.EditChercheCodebarreKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  PositionMouvement,CodeTypeFormuleBase,NumLiseMouvementSelect:string;
begin
     if key in [VK_RETURN]then
     begin
          if(FSFicheSaisie.EditChercheCodebarre.Text<>'')then
          begin
               NumLiseMouvementSelect:='';
               FSFicheSaisie.EditModeRecherche.Text:='CB';
               if(FSFicheSaisie.RBSpecifierMouvement.Checked=true)
               then PositionMouvement:=FSFicheSaisie.EditPositionMouvementRecherche.Text
               else PositionMouvement:='';

               if(FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked=true)
               then CodeTypeFormuleBase:=FSFicheSaisie.EditCodeTypeFormuleBaseRecherche.Text
               else CodeTypeFormuleBase:='';

               RTypeMouvement:=ChercherTypeMouvement(strtointeger(FSFicheSaisie.EditPositionTypeMouvementRecherche.Text),'',AdresseFichierConcerne);
               RMouvement:=ChercherMouvement(FSFicheSaisie.EditPositionTypeMouvementRecherche.Text,strtointeger(FSFicheSaisie.EditPositionMouvementRecherche.Text),AdresseFichierConcerne);

               FSFicheSaisie.EditDesignationTypeMouvementRecherche.Caption:=RTypeMouvement.DesignationTypeMouvement;
               FSFicheSaisie.EditDesignationMouvementRecherche.Caption:=RMouvement.DesignationMouvement;

               ProcAfficheListeMouvementErrones(FSFicheSaisie.TableauListeMouvement,FSFicheSaisie.EditPositionTypeMouvementRecherche.Text,PositionMouvement,CodeTypeFormuleBase,FSFicheSaisie.EditChercherNumeroListeMouvement.Text,FSFicheSaisie.EditTypeProces.Text,FSFicheSaisie.EditFunctionFichierConcerne.Text,FSFicheSaisie.EditChercherCodeTiers.Text,FSFicheSaisie.EditChercherReferenceMouvement.Text,FSFicheSaisie.EditChercheCodebarre.Text,FSFicheSaisie.EditModeRecherche.Text,NumLiseMouvementSelect,FSFicheSaisie.RBChargerPointeurListeMouvement.Checked);
          end
          else
          begin
               FSFicheSaisie.EditChercherTiers.SetFocus;
          end;

     FSFicheSaisie.EditChercheCodebarre.SelectAll;
     end;

     if key in [VK_ESCAPE]then
     begin
          //FSFicheSaisie.TableauListeMouvement.SetFocus;
          //FSFicheSaisie.AfficherChercherNumeroListeMouvement.Visible:=false;
          FSFicheSaisie.EditChercherNumeroListeMouvement.SetFocus;
     end;

     if key in[VK_DOWN]then
     begin
          if(FSFicheSaisie.RBSpecifierMouvement.Checked=true)then FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked:=true
          else
          if(FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked=true)then FSFicheSaisie.RBTousMouvement.Checked:=true
          else
          if(FSFicheSaisie.RBTousMouvement.Checked=true)then FSFicheSaisie.RBSpecifierMouvement.Checked:=true;
     end;

     if key in[VK_UP]then
     begin
          if(FSFicheSaisie.RBSpecifierMouvement.Checked=true)then FSFicheSaisie.RBTousMouvement.Checked:=true
          else
          if(FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked=true)then FSFicheSaisie.RBSpecifierMouvement.Checked:=true
          else
          if(FSFicheSaisie.RBTousMouvement.Checked=true)then FSFicheSaisie.RBSpecifierTypeFormuleBase.Checked:=true;
     end;
end;

