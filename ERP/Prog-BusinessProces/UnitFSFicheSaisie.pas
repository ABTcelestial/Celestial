procedure TFSFicheSaisie.BitValidationListeMouvementClick(Sender: TObject);
var  R:integer; OK,OKRapport:boolean;
begin
     if(FSFicheSaisie.RBActiverAutorisationsManipulations.Checked=true)
     and(FSFicheSaisie.RBAutoriserModification.Checked=false)
     and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]=FSFicheSaisie.EditOrdreListeMouvement.Text)then
     begin
          showmessage('Modification non autorisé !');
          Exit;
     end;

     if(FSFicheSaisie.RBActiverAutorisationsManipulations.Checked=true)
     and(FSFicheSaisie.RBManipulationAutresUtilisateurAutorise.Checked=false)
     and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]=FSFicheSaisie.EditOrdreListeMouvement.Text)
     and(FSFicheSaisie.TableauListeMouvement.Cells[41,FSFicheSaisie.TableauListeMouvement.Row]<>FSMenuPrincipal.EditCodeUtilisateur.Text)then
     begin
          RUtilisateurCopie:=ChercherUtilisateur(FSFicheSaisie.TableauListeMouvement.Cells[41,FSFicheSaisie.TableauListeMouvement.Row]);
          showmessage('Saisies effectué par '+RUtilisateurCopie.Nom+' '+RUtilisateurCopie.Prenom);
          FSFicheSaisie.BitEchapClick(FSFicheSaisie.BitEchap);
          Exit;
     end;

     if(FSFicheSaisie.TableauDetaiMouvement.Row>6)
     and(FSFicheSaisie.TableauDetaiMouvement.Cells[6,FSFicheSaisie.TableauDetaiMouvement.Row]='')then
     begin
          FSFicheSaisie.TableauDetaiMouvement.RowCount:=MaxInt(FSFicheSaisie.TableauDetaiMouvement.RowCount-1,7);
          FSFicheSaisie.TableauDetaiMouvement.Row:=MaxInt(FSFicheSaisie.TableauDetaiMouvement.RowCount-2,6);
          FSFicheSaisie.TableauDetaiMouvement.Col:=1;
     end;

     if(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=false)then
     begin
          if(FSFicheSaisie.RBValiderValeurNulle.Checked=false)then
          begin
               if(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)=0)then
               begin
                    FSFicheSaisie.TableauDetaiMouvement.SetFocus;
                    Exit;
               end;
          end;
     end;

     OKRapport:=false;
     FSFicheSaisie.AfficherOperationsListeMouvement.Height:=57;
     FSFicheSaisie.AfficherOperationsListeMouvement.Visible:=true;
     FSFicheSaisie.BitOperationListeMouvement.SetFocus;
     FSFicheSaisie.RapportOperationListeMouvement.Lines.Text:='';
     FSFicheSaisie.RapportOperationListeMouvement.Lines.Add('Notifications !');
     FSFicheSaisie.RapportOperationListeMouvement.Lines.Add('');

     if(FSFicheSaisie.EditNumListeMouvement.Text<>'')and(FSFicheSaisie.EditNumListeMouvement.Text=FSFicheSaisie.TableauListeMouvement.Cells[2,FSFicheSaisie.TableauListeMouvement.Row])and(FSFicheSaisie.EditMontantMouvement.Text<>'')and(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]<>'')and(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]))then
     begin
          FSFicheSaisie.RapportOperationListeMouvement.Lines.Add('Montant du mouvement enregistré, diffčre de ce lui calculé !');
          OKRapport:=true;
     end;

     if datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])then
     begin
          if(strtodate(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date))<>strtodate(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]))then
          begin
               FSFicheSaisie.RapportOperationListeMouvement.Lines.Add('Date affichée différente de celle enregistrée ! '+datetostr(FSFicheSaisie.EditDateDetailMouvement.Date)+' et '+FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]);
               OKRapport:=true;
          end;
     end;

     if(OKRapport=true)then
     begin
          FSFicheSaisie.AfficherOperationsListeMouvement.Height:=170;
          FSFicheSaisie.AfficherNatureOperationsListeMouvement.Caption:='Confirmer la validation du mouvement ! {Malgré les notifications}';
     end
     else
     begin
