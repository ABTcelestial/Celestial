Procedure ProceAfficheDetailMouvementFichierCible(TableauFormules,TableauVariable,TableauDetaiMouvement:TStringGrid; OrdreListeMouvement:string; ValidationDetailMouvement:string; RBDetailMouvementAfficher:boolean; AdresseFichierCible:string; var CMontant:integer);
var  i,j,Row,R,Col,C,T:integer;  OKArticle,OKFormule,OKDetailMouvement:boolean;  TypeProces,FichierConserne,Adresse:string;
begin
     TableauDetaiMouvement.RowCount:=2;
     TableauDetaiMouvement.Rows[1].Text:='';

     TableauDetaiMouvement.ColCount:=22;
     TableauDetaiMouvement.Cols[0].Text:='P°';
     TableauDetaiMouvement.Cols[1].Text:='Num';
     TableauDetaiMouvement.Cols[2].Text:='Ordre';
     TableauDetaiMouvement.Cols[3].Text:='Date';
     TableauDetaiMouvement.Cols[4].Text:='Code';
     TableauDetaiMouvement.Cols[5].Text:='Désignation';
     TableauDetaiMouvement.Cols[6].Text:='Référence';
     TableauDetaiMouvement.Cols[7].Text:='U.M.';
     TableauDetaiMouvement.Cols[8].Text:='Coűt';
     TableauDetaiMouvement.Cols[9].Text:='Quantité';
     TableauDetaiMouvement.Cols[10].Text:='Prix';

     for C:=11 to 20 do TableauDetaiMouvement.Cols[C].Text:=Completezerogauche(inttostr(C),'2');

     TableauDetaiMouvement.Cols[21].Text:='Validité';

     TypeProces:='Business';   FichierConserne:=FSFicheSaisie.EditCodeTypeFormuleBase.Text;
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
     end;

     ChFormule:=Adresse;
     assignfile(FFormule,ChFormule);
     try
     if FileExists(ChFormule)then
     Reset(FFormule)
     else begin affichermessage('Attention ! {'+ChFormule+'} n''existe pas !'); exit; end;//Rewrite(FFormule);
     Seek(FFormule,0);
     C:=11;
     while not eof(FFormule)do
     begin
          read(FFormule,RFormule);
          TableauDetaiMouvement.Cells[C,0]:=inttostr(RFormule.PositionFormule);
          C:=C+1;
     end;
     finally
     closefile(FFormule);
     end;

     CMontant:=C-1;
     
     ChDetailMouvement:=AdresseFichierCible;
     assignfile(FDetailMouvement,ChDetailMouvement);
     try
     if FileExists(ChDetailMouvement)then
     Reset(FDetailMouvement)
     else Rewrite(FDetailMouvement);
     Seek(FDetailMouvement,0);
     Row:=0;
     Col:=5;
     i:=0;
     while not eof(FDetailMouvement)do
     begin
          read(FDetailMouvement,RDetailMouvement);

          if(ValidationDetailMouvement<>'')and(ValidationDetailMouvement<>'Tous')then
          begin
               if(RDetailMouvement.ValidationDetailMouvement=strtoboolean(ValidationDetailMouvement))
               then OKDetailMouvement:=true
               else OKDetailMouvement:=false;
          end
          else OKDetailMouvement:=true;

          if(OKDetailMouvement=true)then
          begin
               if(RBDetailMouvementAfficher=true)then
               begin
                    if(OrdreListeMouvement<>'')then
                    begin
                         if(RDetailMouvement.OrdreListeMouvement=strtointeger(OrdreListeMouvement))
                         then OKDetailMouvement:=true
                         else OKDetailMouvement:=false;
                    end
                    else OKDetailMouvement:=true;

               end;
          end;

          if(OKDetailMouvement=true)then
          begin
               Row:=Row+1;
               TableauDetaiMouvement.Cells[0,Row]:=inttostr(RDetailMouvement.PositionDetailMouvement);
               TableauDetaiMouvement.Cells[1,Row]:=inttostr(RDetailMouvement.NumDetailMouvement);
               TableauDetaiMouvement.Cells[2,Row]:=inttostr(RDetailMouvement.OrdreListeMouvement);
               TableauDetaiMouvement.Cells[3,Row]:=RDetailMouvement.DateMouvement;
               TableauDetaiMouvement.Cells[4,Row]:=RDetailMouvement.CodeArticle;
               TableauDetaiMouvement.Cells[5,Row]:=RDetailMouvement.DesignationArticle;
               TableauDetaiMouvement.Cells[6,Row]:=RDetailMouvement.ReferenceArticle;
               TableauDetaiMouvement.Cells[7,Row]:=RDetailMouvement.UMArticle;
               TableauDetaiMouvement.Cells[8,Row]:=Vergule(floattostr(RDetailMouvement.CoutUnitaireArticle),'2','C','');
               TableauDetaiMouvement.Cells[9,Row]:=Vergule(floattostr(RDetailMouvement.Quantite),'2','C','');
               TableauDetaiMouvement.Cells[10,Row]:=Vergule(floattostr(RDetailMouvement.PrixUnitaire),'2','C','');

               TableauDetaiMouvement.Cells[21,Row]:=booleantostr(RDetailMouvement.ValidationDetailMouvement);

               C:=11;
               while(C<=TableauDetaiMouvement.ColCount-2)do
               begin
                    OKFormule:=false;
                    if(TableauDetaiMouvement.Cells[C,0]<>'')
                    and(TableauDetaiMouvement.Cells[C,0]=inttostr(RDetailMouvement.RRegistreFormule0.PositionFormule))
                    then
                    begin
                         OKFormule:=true;
                         TableauDetaiMouvement.Cells[C,Row]:=Vergule(floattostr(RDetailMouvement.RRegistreFormule0.ValeurFormule),'2','C','');
                    end;

                    if(OKFormule=false)
                    and(TableauDetaiMouvement.Cells[C,0]<>'')
                    and(TableauDetaiMouvement.Cells[C,0]=inttostr(RDetailMouvement.RRegistreFormule1.PositionFormule))
                    then
                    begin
