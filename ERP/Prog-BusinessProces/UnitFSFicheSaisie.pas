Procedure IndiquerPositionDetailMouvementGroupeListeMouvement(ListeOrdreListeMouvement:string; PBeginLM,PEndLM:integer; var PBeginDM,PEndDM:integer);
var   PLM:integer;
      TypeProcesLM,FichierConserneLM,AdresseLM:string;
      OKListeMouvement:boolean;
begin
     PBeginDM:=999999999;
     PEndDM:=0;

     TypeProcesLM:='Business';   FichierConserneLM:='FListeMouvement';
     AdresseLM:='';
     if not(FunctionAdresseProces(TypeProcesLM,FichierConserneLM,'',AdresseLM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneLM+' recherché !');
     end;

     ChListeMouvement:=AdresseLM;
     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
     Seek(FListeMouvement,PBeginLM);
     PLM:=PBeginLM;
     while not eof(FListeMouvement)and(PLM<=PEndLM)do
     begin
          read(FListeMouvement,RListeMouvement); Application.ProcessMessages;  if(FSTraitementDonnees.RBSuspendreTBohr.Checked)then Exit;
          PLM:=PLM+1;

          OKListeMouvement:=RListeMouvement.ValidationListeMouvement;

          if(OKListeMouvement=true)then
          begin
               if(Existenumintexte(inttostr(RListeMouvement.OrdreListeMouvement),ListeOrdreListeMouvement))
               then OKListeMouvement:=true
               else OKListeMouvement:=false;
          end;

          if(OKListeMouvement=true)then
          begin
               if(PBeginDM>RListeMouvement.PositionDetailMouvementBegin)then PBeginDM:=RListeMouvement.PositionDetailMouvementBegin;
               if(PEndDM<RListeMouvement.PositionDetailMouvementEnd)then PEndDM:=RListeMouvement.PositionDetailMouvementEnd;
          end;
     end;
     finally
     CloseFile(FListeMouvement);
     end;

     if(PBeginDM=999999999)and(PEndDM=0)then begin PBeginDM:=0; PEndDM:=999999999; end;
end;

Procedure IndiquerPositionDetailMouvement(DesignationTypeMouvement,ExerciceAnneeConserne:string; OrdreListeMouvement:integer; var PBegin,PEnd:integer);
var  iDM:integer; TypeProcesDM,FichierConserneDM,AdresseDM:string;  OKDetailMouvement:boolean;
begin
     TypeProcesDM:='Business';   FichierConserneDM:='DétailMouvement '+DesignationTypeMouvement;
     AdresseDM:='';
     if not(FunctionAdresseProces(TypeProcesDM,FichierConserneDM,'',AdresseDM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneDM+' recherché !');
     end;

     ChDetailMouvement:=ConvertirAdresseExerciceAnnee(AdresseDM,ExerciceAnnee,ExerciceAnneeConserne);     assignfile(FDetailMouvement,ChDetailMouvement);
     
     if FileExists(ChDetailMouvement)then
     begin
           try
           Reset(FDetailMouvement);
           Seek(FDetailMouvement,0);
           PBegin:=999999999;
           PEnd:=0;
           iDM:=0;
           while not eof(FDetailMouvement)do
           begin
                read(FDetailMouvement,RDetailMouvement);

                OKDetailMouvement:=RDetailMouvement.ValidationDetailMouvement;

                if(OKDetailMouvement=true)then
                begin
                     if(RDetailMouvement.OrdreListeMouvement=OrdreListeMouvement)
                     then OKDetailMouvement:=true
                     else OKDetailMouvement:=false;
                end;

                if(OKDetailMouvement=true)then
                begin
                     if(PBegin>iDM)then PBegin:=iDM;
                     if(PEnd<iDM)then PEnd:=iDM;
                end;

                iDM:=iDM+1;
           end;
           finally
           CloseFile(FDetailMouvement);
           end;
     end;

     if(PBegin=999999999)and(PEnd=0)then begin PBegin:=0; PEnd:=999999999; end;
end;

Procedure MiseAJourPositionDetailMouvement(DesignationTypeMouvement,ExerciceAnneeConserne:string);
var  iDM:integer; TypeProcesDM,FichierConserneDM,AdresseDM:string;  OKDetailMouvement:boolean;
begin
     TypeProcesDM:='Business';   FichierConserneDM:='DétailMouvement '+DesignationTypeMouvement;
     AdresseDM:='';
     if not(FunctionAdresseProces(TypeProcesDM,FichierConserneDM,'',AdresseDM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneDM+' recherché !');
     end;

     ChDetailMouvement:=ConvertirAdresseExerciceAnnee(AdresseDM,ExerciceAnnee,ExerciceAnneeConserne);
     assignfile(FDetailMouvement,ChDetailMouvement);
     if FileExists(ChDetailMouvement)then
     begin
          try
          Reset(FDetailMouvement);
          Seek(FDetailMouvement,0);
          iDM:=0;
          while not eof(FDetailMouvement)do
          begin
               read(FDetailMouvement,RDetailMouvement);
               RDetailMouvement.PositionDetailMouvement:=iDM;
               Seek(FDetailMouvement,iDM);
               write(FDetailMouvement,RDetailMouvement);
               iDM:=iDM+1;
          end;
          finally
          CloseFile(FDetailMouvement);
          end;
     end;
end;
 
