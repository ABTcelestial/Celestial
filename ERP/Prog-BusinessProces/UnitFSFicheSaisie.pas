Procedure ProcTransfertStockArticle(CodeStockConcerneSource,CodeStockConcerneCible,CodeArticle,TypeStock:string; Quantite,CoutStock:real);
var  NbrNewArticle,NbrChargeArticle:integer;  OKMiseAJour:boolean;
begin
     ProcMiseAJourStockArticle(CodeStockConcerneSource,CodeStockConcerneSource,CodeArticle,TypeStock,'-',Quantite,CoutStock,NbrNewArticle,NbrChargeArticle,CoutStock,NbrNewArticle,NbrChargeArticle,OKMiseAJour);
     ProcMiseAJourStockArticle(CodeStockConcerneSource,CodeStockConcerneCible,CodeArticle,TypeStock,'+',Quantite,CoutStock,NbrNewArticle,NbrChargeArticle,CoutStock,NbrNewArticle,NbrChargeArticle,OKMiseAJour);
end;

Procedure ProcMiseAJourStockArticle(CodeStockConcerneSource,CodeStockConcerneCible,CodeArticle,TypeStock,SigneMouvement:string; Quantite,Prix:real; NbrNewArticleIn,NbrChargeArticleIn:integer; var PrixOut:real; var NbrNewArticleOut,NbrChargeArticleOut:integer; var OKMiseAJour:boolean);
var  i,Indice:integer; OKStockArticle:boolean;  CodeStockAnalyse,TypeProces,FichierConcerne,Adresse,RubriqueRecherche:string;
begin
OKMiseAJour:=false;

PrixOut:=Prix;

NbrNewArticleOut:=NbrNewArticleIn;
NbrChargeArticleOut:=NbrChargeArticleIn;

if(SigneMouvement='')then Exit;

//if(SigneMouvement='-')then Quantite:=(-1)*Quantite;

if(CodeArticle<>'')then
begin
     TypeProces:='Commercial';   FichierConcerne:='FStock'+TypeStock;
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     //if(TypeProcesReseaux='Réseaux')then Exit;

     ChStockArticle:=Adresse+CodeStockConcerneCible;
     assignfile(FStockArticle,ChStockArticle);
     try
     if FileExists(ChStockArticle)then
     Reset(FStockArticle)
     else Rewrite(FStockArticle);
     Seek(FStockArticle,0);
     OKStockArticle:=false;
     i:=0;
     while not eof(FStockArticle)and(OKStockArticle=false)do
     begin
          read(FStockArticle,RStockArticle);

          if(RStockArticle.Code=CodeArticle)then
          begin
               OKStockArticle:=true;

               if(Prix=0)then PrixOut:=RStockArticle.CoutUnitaire;

               if(SigneMouvement='-')then
               begin
                    RStockArticle.QteSortie:=RStockArticle.QteSortie+Quantite;
                    RStockArticle.QteStock:=RStockArticle.QteStock-Quantite;
               end;

               if(SigneMouvement='+')then
               begin
                    if(RStockArticle.QteStock>0)then
                    begin
                         //if((RStockArticle.QteStock+Quantite)>0)
                         //then RStockArticle.CoutUnitaire:=((RStockArticle.QteStock*RStockArticle.CoutUnitaire)+(Quantite*Prix))/(RStockArticle.QteStock+Quantite);

                         if(RStockArticle.CoutUnitaire=0)then RStockArticle.CoutUnitaire:=Prix;
                    end
                    else
                    begin
                         if(Prix<>0)then
                         begin
                              RStockArticle.CoutUnitaire:=Prix;
                         end;
                    end;

                    RStockArticle.QteEntree:=RStockArticle.QteEntree+Quantite;
                    RStockArticle.QteStock:=RStockArticle.QteStock+Quantite;
               end;

               Seek(FStockArticle,i);
               write(FStockArticle,RStockArticle);
               OKMiseAJour:=true;
          end;
     i:=i+1;
     end;

     if(OKStockArticle=false)then
     begin
          RStockArticleCopie:=ChercherStockArticle(TypeStock,CodeStockConcerneSource,CodeArticle,'',OKStockRecherche,RubriqueRecherche);
          if(RStockArticleCopie.Code='')then
          begin
               CodeStockAnalyse:=CodeStockConcerneCible+' résultat d''analyse';
               RStockArticleCopie:=ChercherStockArticle(TypeStock,CodeStockAnalyse,CodeArticle,'',OKStockRecherche,RubriqueRecherche);

               NbrNewArticleOut:=NbrNewArticleOut+1;
          end
          else NbrChargeArticleOut:=NbrChargeArticleOut+1;

          RStockArticleCopie.QteEntree:=0;
          RStockArticleCopie.QteSortie:=0;
          RStockArticleCopie.QteStock:=0;
          RStockArticleCopie.QteInitial:=0;
          RStockArticleCopie.QteLimite:=0;
          //RStockArticleCopie.CoutUnitaire:=0;
          //RStockArticleCopie.PrixVenteDetaille:=0;
          //RStockArticleCopie.PrixVenteDemiGros:=0;
          //RStockArticleCopie.PrixVenteGros:=0;
          //RStockArticleCopie.Design:='';
          //RStockArticleCopie.Ref:='';
          //RStockArticleCopie.Observ:='';
          RStockArticleCopie.Emplace:='';
          //RStockArticleCopie.FicheStock:='';
          //RStockArticleCopie.Code:='';
          //RStockArticleCopie.UM:='';
          //RStockArticleCopie.Formule:='';
          //RStockArticleCopie.enregistrement:='';

          if(SigneMouvement='-')then
          begin
               RStockArticleCopie.QteSortie:=Quantite;
               RStockArticleCopie.QteStock:=(-1)*Quantite;
               if(Prix=0)then PrixOut:=RStockArticleCopie.CoutUnitaire;
          end;

          if(SigneMouvement='+')then
          begin
               if(Prix<>0)then
               begin
                    RStockArticleCopie.CoutUnitaire:=Prix;
               end
               else
               begin
                    PrixOut:=RStockArticleCopie.CoutUnitaire;
               end;

               RStockArticleCopie.QteEntree:=Quantite;
               RStockArticleCopie.QteStock:=Quantite;
          end;
          Seek(FStockArticle,i);
          write(FStockArticle,RStockArticleCopie);
          OKMiseAJour:=true;
     end;
     finally
     CloseFile(FStockArticle);
     end;
end;     

