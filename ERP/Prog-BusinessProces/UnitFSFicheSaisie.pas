procedure TFSFicheSaisie.TableauDetaiMouvementContextPopup(Sender: TObject;
  MousePos: TPoint; var Handled: Boolean);
var  R,RowOut,C,ColVale:integer;   NotCol:string;  MontantTotal,MontantSupp,MontantListeMouvement,Ecart:real; OKColVale:boolean;  
begin
     if(FSFicheSaisie.AfficherOperationDetailMouvement.Visible=true)and(FSFicheSaisie.RBAjouterSupprimeDM.Checked=true)then
     begin
          FSFicheSaisie.EditOperationPositionDetailMouvement.Text:='';
          MontantListeMouvement:=strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]);

          C:=FSFicheSaisie.TableauDetaiMouvement.ColCount-1;
          ColVale:=0;
          OKColVale:=false;
          while(C>0)and(OKColVale=false)do
          begin
               if(FSFicheSaisie.TableauDetaiMouvement.ColWidths[C]>0)then
               begin
                    OKColVale:=true;
                    ColVale:=C;
               end;
          C:=C-1;
          end;

          if(ColVale>0)then
          begin
               R:=6;
               MontantTotal:=0;
               MontantSupp:=0;
               while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
               begin
                    MontantTotal:=MontantTotal+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColVale,R]);

                    if ExisteNumInTexte(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R],FSFicheSaisie.EditOperationPositionDetailMouvement.Text)
                    then MontantSupp:=MontantSupp+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColVale,R]);
               R:=R+1;
               end;

               FSFicheSaisie.AfficherOperationDetailMouvementInfo.Caption:='Liste Mouvement: '+Vergule(floattostr(MontantListeMouvement),'2','C','')+', Détail Mouvement: '+Vergule(floattostr(MontantTotal-MontantSupp),'2','C','')+', Ecart: '+Vergule(floattostr(MontantListeMouvement-(MontantTotal-MontantSupp)),'2','C','');

               Ecart:=MontantListeMouvement-(MontantTotal-MontantSupp);
               if(Ecart<0)then Ecart:=Ecart*(-1);
               if(Ecart<=1/100)
               then FSFicheSaisie.AfficherOperationDetailMouvementInfo.Color:=clLime
               else FSFicheSaisie.AfficherOperationDetailMouvementInfo.Color:=clRed;
          end;
     end
     else
     begin
          AjusterColWidth(FSFicheSaisie.TableauDetaiMouvement,'','');
     end;
end;

