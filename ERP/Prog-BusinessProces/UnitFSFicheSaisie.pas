Procedure ProcListeStockSaisieGlobale(TableauStock:TStringGrid; AdresseStock,CodeArticle,DesignationArticle,CodeSFamille:string);
var  k,ARowSelect:integer; OKStock:boolean;  NotCol,TypeData,TypeStock:string;
begin
AccelerationAffichageTableau(TableauStock,true);

TypeStock:='Article';
if(ExisteCharinString('Marche',FichierConcerne)=true)then TypeStock:='Marche';

TableauStock.ColCount:=11;
TableauStock.Cols[0].Text:='N°';
TableauStock.Cols[1].Text:='Code';
TableauStock.Cols[2].Text:='Désignation';
TableauStock.Cols[3].Text:='Réference';
TableauStock.Cols[4].Text:='UM';
TableauStock.Cols[5].Text:='Qte en Stock';
TableauStock.Cols[6].Text:='Prix d''Achat';
TableauStock.Cols[7].Text:='Prix VD';
TableauStock.Cols[8].Text:='Prix VG';
TableauStock.Cols[9].Text:='Prix VDG';
TableauStock.Cols[10].Text:='Quantité Opération';

if(TypeStock='Marche')
then TableauStock.Cols[6].Text:='Coűt Unitaire'
else TableauStock.Cols[6].Text:='Prix d''Achat';

if(TypeStock='Marche')
then TableauStock.Cols[7].Text:='Prix Marché'
else TableauStock.Cols[7].Text:='P.V.D';

if(TypeStock='Marche')
then TableauStock.Cols[8].Text:='Prix Soutraitance'
else TableauStock.Cols[8].Text:='P.V.G';

if(TypeStock='Marche')
then TableauStock.Cols[9].Text:='Prix Attache'
else TableauStock.Cols[9].Text:='P.V.D.G';

TableauStock.RowCount:=2;
TableauStock.Rows[1].Text:='';

ChStock:=AdresseStock;
assignfile(FStock,ChStock);
try
if FileExists(ChStock)then
Reset(FStock)
else Rewrite(FStock);
Seek(FStock,0);
k:=0;
ARowSelect:=1;
while not eof(FStock)do
begin
     read(FStock,RStock);


     if(CodeSFamille<>'')then
     begin
          if(AnsiUpperCase(Firstlaters(RStock.Code,longueur(CodeSFamille)))=AnsiUpperCase(CodeSFamille))
          then OKStock:=true
          else OKStock:=false;
     end
     else OKStock:=true;

     if(OKStock=true)then
     begin
          if(CodeArticle<>'')then
          begin
               if(ExisteFirstLatersNuminTexte(AnsiUpperCase(RStock.Code),AnsiUpperCase(CodeArticle)))
               then OKStock:=true
               else OKStock:=false;
          end;
     end;

     if(OKStock=true)then
     begin
          if(CodeArticle<>'')then
          begin
               if(AnsiUpperCase(Firstlaters(RStock.Code,Longueur(CodeArticle)))=AnsiUpperCase(CodeArticle))
               then OKStock:=true
               else OKStock:=false;
          end;
     end;

     if(OKStock=true)then
     begin
          if(DesignationArticle<>'')then
          begin
               OKStock:=RechercheSequenceParMotsCle(AnsiUpperCase(DesignationArticle),AnsiUpperCase(RStock.Design+' '+RStock.Ref));
          end;
     end;

     if(OKStock=true)then
     begin
          k:=k+1;
          TableauStock.Rows[k].Text:=inttostr(k);
          TableauStock.Cells[1,k]:=RStock.Code;
          TableauStock.Cells[2,k]:=RStock.Design;
          TableauStock.Cells[3,k]:=RStock.Ref;
          TableauStock.Cells[4,k]:=RStock.UM;
          TableauStock.Cells[5,k]:=Vergule(floattostr(RStock.QteStock),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[6,k]:=Vergule(floattostr(RStock.CoutUnitaire),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[7,k]:=Vergule(floattostr(RStock.PrixVenteDetaille),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[8,k]:=Vergule(floattostr(RStock.PrixVenteGros),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[9,k]:=Vergule(floattostr(RStock.PrixVenteDemiGros),FSGenerateurBase.EditNbrChiffreApresVergule.Text,'C','');
          TableauStock.Cells[10,k]:='';
     end;
end;
finally
Closefile(FStock);
end;

if(k>0)then TableauStock.RowCount:=k+1
       else TableauStock.RowCount:=2;

if(TypeStock='Marche')
then NotCol:='5-9;'
else NotCol:='';

for k:=1 to TableauStock.ColCount-1 do if existenumintexte(inttostr(k),NotCol)then TableauStock.ColWidths[k]:=0;
AjusterColWidth(TableauStock,'',NotCol);
if(TableauStock.ColWidths[2]>500)then TableauStock.ColWidths[2]:=500;

AccelerationAffichageTableau(TableauStock,false);
end;

