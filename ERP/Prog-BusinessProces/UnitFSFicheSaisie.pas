procedure TFSFicheSaisie.TimerControleAutoImporteAvisTimer(
  Sender: TObject);
var  OKAvisTrouver:boolean;   BaseAvis:string;
begin
     FSFicheSaisie.TimerControleAutoImporteAvis.Enabled:=false;

     if(FSFicheSaisie.EditNumAvis.Text<>'')then
     begin
          BaseAvis:=IndiqueBaseAvis(FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row]);
          OKAvisTrouver:=ChercherAvis(FSFicheSaisie.EditNumAvis.Text,BaseAvis,FSFicheSaisie.TableauListeMouvement.Cells[7,FSFicheSaisie.TableauListeMouvement.Row],FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row],FSFicheSaisie.RBModePayementNumAvis.Checked,FSFicheSaisie.RBModePayementModePayement.Checked,FSFicheSaisie.RBModePayementDomiciliation.Checked,FSFicheSaisie.RBModePayementNumPiece.Checked,FSFicheSaisie.RBModePayementDateAvis.Checked,FSFicheSaisie.RBModePayementDateExecution.Checked,FSFicheSaisie.TableauListeAvisTrouver,FSFicheSaisie.EditListeNumAvisTrouver,FSFicheSaisie.EditListeModePaiementTrouver,FSFicheSaisie.EditListeDomiciliationAvisTrouver,FSFicheSaisie.EditListeDomiciliationPieceTrouver,FSFicheSaisie.EditListeNumPieceTrouver,FSFicheSaisie.EditListeDateTrouver,FSFicheSaisie.EditMemoLiseAvisTrouver);
     end
     else
     begin
          OKAvisTrouver:=false;
     end;

     if(FSFicheSaisie.EditNumAvis.Text<>'')then
     begin
          if(OKAvisTrouver=true)then
          begin
               if(FSFicheSaisie.EditModePayement.Text<>FSFicheSaisie.EditListeModePaiementTrouver.Text)
               or(FSFicheSaisie.EditDomiciliation.Text<>FSFicheSaisie.EditListeDomiciliationPieceTrouver.Text)
               or(FSFicheSaisie.EditNumPiece.Text<>FSFicheSaisie.EditListeNumPieceTrouver.Text)then
               begin
                    FSFicheSaisie.EditInfoControleCouleur.Text:='Avis Différent';
                    FSFicheSaisie.TimerControleCouleur.Enabled:=true;
               end
               else
               begin
                    FSFicheSaisie.TimerControleCouleur.Enabled:=false;
                    FSFicheSaisie.AfficheAutoImporteAvis.Color:=clLime;
               end;
          end
          else
          begin
               FSFicheSaisie.TimerControleCouleur.Enabled:=false;
               FSFicheSaisie.AfficheAutoImporteAvis.Color:=clBtnFace;

               if(FSFicheSaisie.EditModePayement.Text<>'')
               or(FSFicheSaisie.EditDomiciliation.Text<>'')
               or(FSFicheSaisie.EditNumPiece.Text<>'')then
               begin
                    FSFicheSaisie.EditInfoControleCouleur.Text:='Avis Non Etabli';
                    FSFicheSaisie.TimerControleCouleur.Enabled:=true;
               end;
          end;
     end
     else
     begin
          FSFicheSaisie.TimerControleCouleur.Enabled:=false;
          FSFicheSaisie.AfficheAutoImporteAvis.Color:=clBtnFace;

          if(FSFicheSaisie.EditModePayement.Text<>'')
          or(FSFicheSaisie.EditDomiciliation.Text<>'')
          or(FSFicheSaisie.EditNumPiece.Text<>'')then
          begin
               FSFicheSaisie.EditInfoControleCouleur.Text:='Avis Non Etabli';
               FSFicheSaisie.TimerControleCouleur.Enabled:=true;
          end;
     end;
end;

