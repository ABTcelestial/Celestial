Procedure ImprimerFactureSimple1(ApercuAvantImpression:boolean);
var R,m,NPage:integer;  OK,OKAvis:boolean; Origine,ModePaiement,Domiciliation,NumPiece,DataTiersSupplementaire:string;
begin
ModePaiement:=FSFicheSaisie.EditModePayement.Text;
NumPiece:=FSFicheSaisie.EditNumPiece.Text;
Domiciliation:=FSFicheSaisie.EditDomiciliation.Text;

OKAvis:=false;

{if(FSFicheSaisie.EditModePayementImporter.Text='')
then PrintFactureSimple.TextPayement.Lines.Text:=ModePaiement+' '+Domiciliation+' N°: '+NumPiece
else PrintFactureSimple.TextPayement.Lines.Text:=FSFicheSaisie.EditModePayementImporter.Text;}

PrintFactureSimple1.TextPayement.Lines.Text:=ModePaiement+' '+Domiciliation+' N°: '+NumPiece;

if(FSFicheSaisie.EditDataSourceName.Text<>'')then
begin
     PrintFactureSimple1.TextPayement.Lines.Add(FSFicheSaisie.EditSourceName.Text+FSFicheSaisie.EditDataSourceName.Text);
end;

if(FSFicheSaisie.RBInfoAdresseExecutionMouvement.Checked=true)then
begin
     if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
     begin
          if(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text<>'')then
          begin
               PrintFactureSimple1.Projet.Caption:='Destination: ';
               PrintFactureSimple1.TextProjet.Lines.Text:=FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text;
          end
          else
          begin
               PrintFactureSimple1.Projet.Caption:='Adresse: ';
               PrintFactureSimple1.TextProjet.Lines.Text:=FSFicheSaisie.EditAdresseExecutionMouvement.Text;
          end;
     end
     else
     begin
          if(FSFicheSaisie.RBAfficheReferenceListeMouvement.Checked=true)and(FSFicheSaisie.EditReferenceListeMouvement.Text<>'')then
          begin
               PrintFactureSimple1.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
               PrintFactureSimple1.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;
          end
          else
          begin
               PrintFactureSimple1.Projet.Caption:='';
               PrintFactureSimple1.TextProjet.Lines.Text:='';
          end;
     end;
end;

R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
     if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
     then
     begin
          OK:=true;
          showmessage('Veuillez enregistrer les modifications avant l''impression SVP !');
     end;
     R:=R+1;
end;

if(OK=false)
and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
begin
Division(FSFicheSaisie.TableauDetaiMouvement.RowCount-5,15,NPage,m);
if(m>0)then NPage:=NPage+1;
{*******************Entreprise***************}
OpenFParc(RParc);
PrintFactureSimple1.TextEntreprise.Caption:=RParc.Text1;

PrintFactureSimple1.DataEntreprise.Lines.Text:='';
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text2);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text3);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text4);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text5);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text6);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text7);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text8);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text9);
PrintFactureSimple1.DataEntreprise.Lines.Add(RParc.Text10);
{***************Fin Entreprise***************}

PrintFactureSimple1.TitreSignataire.Caption:=FSFicheSaisie.EditSignataire.Text;

{***************Tiers***************}
PrintFactureSimple1.TextClient.Caption:=FichierTiersCourt(lastlaters(FSFicheSaisie.EditFunctionFichierConcerne.Text,longueur(FSFicheSaisie.EditFunctionFichierConcerne.Text)-1));
if(FSFicheSaisie.EditDataTiersSupplementaire.Text<>'')
then DataTiersSupplementaire:=' {'+FSFicheSaisie.EditDataTiersSupplementaire.Text+'}'
else DataTiersSupplementaire:='';
RTier:=ChercherTiers(FSFicheSaisie.EditTypeProces.Text,FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row],FSFicheSaisie.EditCodeTiersConserne.Text,FSFicheSaisie.EditTiersConserne.Text);

PrintFactureSimple1.DataTiers.Lines.Text:='';
PrintFactureSimple1.DataTiers.Lines.Add(RTier.NomTiers+' '+RTier.PrenomTiers+DataTiersSupplementaire);
PrintFactureSimple1.DataTiers.Lines.Add(RTier.AdresseTiers);
PrintFactureSimple1.DataTiers.Lines.Add(RTier.Data1);
PrintFactureSimple1.DataTiers.Lines.Add(RTier.Data2);
PrintFactureSimple1.DataTiers.Lines.Add(RTier.Data3);
PrintFactureSimple1.DataTiers.Lines.Add(RTier.Data4);
PrintFactureSimple1.DataTiers.Lines.Add(RTier.Data5);
