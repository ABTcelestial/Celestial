Procedure EcritureMultiLigne(TitreTexte,TexteRubrique:string; TailleMaxLigne:integer);
var  i,Nombre,Diviseur,Resultat,Reste:integer; TesteTexte,TitreTexteVide:string;
begin
     TesteTexte:='';
     TailleMaxLigne:=TailleMaxLigne-longueur(TitreTexte);

     if(FSTicketTexte.RBDesignationPlusieursLignes.Checked=true)and(Longueur(TexteRubrique)>(TailleMaxLigne))then
     begin
          TitreTexteVide:=CompleteCharDroite(' ',' ',longueur(TitreTexte));
          Nombre:=Longueur(TexteRubrique);
          Diviseur:=TailleMaxLigne;
          Division(Nombre,Diviseur,Resultat,Reste);

          for i:=1 to  Resultat do
          begin
               if(i=1)then
               begin
                    TesteTexte:=TitreTexte+MidelLaters(TexteRubrique,1,TailleMaxLigne);
               end
               else
               begin
                    TesteTexte:=TitreTexteVide+WithoutCharGauche(MidelLaters(TexteRubrique,(i-1)*(TailleMaxLigne)+1,(i*(TailleMaxLigne))),' ');
               end;

               FSTicketTexte.EditTicket.Lines.Add('   '+TesteTexte);
          end;

          if(Reste>0)then
          begin
               TesteTexte:=TitreTexteVide+WithoutCharGauche(Lastlaters(TexteRubrique,Reste),' ');
               FSTicketTexte.EditTicket.Lines.Add('   '+TesteTexte);
          end;
     end
     else
     begin
          TesteTexte:=TitreTexte+Firstlaters(TexteRubrique,TailleMaxLigne);
          FSTicketTexte.EditTicket.Lines.Add('   '+TesteTexte);
     end;
end;

