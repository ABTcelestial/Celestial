Procedure ImprimerFactureSimple(ApercuAvantImpression:boolean);
var R,m,NPage:integer;  OK,OKAvis:boolean; Origine,ModePaiement,Domiciliation,NumPiece,DataTiersSupplementaire:string;
begin
ModePaiement:=FSFicheSaisie.EditModePayement.Text;
NumPiece:=FSFicheSaisie.EditNumPiece.Text;
Domiciliation:=FSFicheSaisie.EditDomiciliation.Text;

OKAvis:=false; 

{if(FSFicheSaisie.EditModePayementImporter.Text='')
then PrintFactureSimple.TextPayement.Lines.Text:=ModePaiement+' '+Domiciliation+' N°: '+NumPiece
else PrintFactureSimple.TextPayement.Lines.Text:=FSFicheSaisie.EditModePayementImporter.Text;}

PrintFactureSimple.TextPayement.Lines.Text:=ModePaiement+' '+Domiciliation+' N°: '+NumPiece;

if(FSFicheSaisie.EditDataSourceName.Text<>'')then
begin
     PrintFactureSimple.TextPayement.Lines.Add(FSFicheSaisie.EditSourceName.Text+FSFicheSaisie.EditDataSourceName.Text);
end;


if(FSFicheSaisie.RBInfoAdresseExecutionMouvement.Checked=true)then
begin
     if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
     begin
          if(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text<>'')then
          begin
               PrintFactureSimple.Projet.Caption:='Destination: ';
               PrintFactureSimple.TextProjet.Lines.Text:=FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text;
          end
          else
          begin                
               PrintFactureSimple.Projet.Caption:='Adresse: ';
               PrintFactureSimple.TextProjet.Lines.Text:=FSFicheSaisie.EditAdresseExecutionMouvement.Text;
          end;
     end
     else
     begin
          if(FSFicheSaisie.RBAfficheReferenceListeMouvement.Checked=true)and(FSFicheSaisie.EditReferenceListeMouvement.Text<>'')then
          begin
               PrintFactureSimple.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
               PrintFactureSimple.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;
          end
          else
          begin
               PrintFactureSimple.Projet.Caption:='';
               PrintFactureSimple.TextProjet.Lines.Text:='';
          end;
     end;
end;

R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
     if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
     then
     begin
          OK:=true;
          showmessage('Veuillez enregistrer les modifications avant l''impression SVP !');
     end;
     R:=R+1;
end;

if(OK=false)
and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
begin
Division(FSFicheSaisie.TableauDetaiMouvement.RowCount-5,15,NPage,m);
if(m>0)then NPage:=NPage+1;
{*******************Entreprise***************}
OpenFParc(RParc);
PrintFactureSimple.TextEntreprise.Caption:=RParc.Text1;

PrintFactureSimple.DataEntreprise.Lines.Text:='';
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text2);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text3);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text4);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text5);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text6);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text7);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text8);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text9);
PrintFactureSimple.DataEntreprise.Lines.Add(RParc.Text10);
{***************Fin Entreprise***************}

