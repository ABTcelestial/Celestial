procedure TFSFicheSaisie.PageAnalyseDonneesgeostrategiquesShow(
  Sender: TObject);
var  ValeurAlerte:integer; DateMouvementDebut,DateMouvementFin,DateLimiteExecution,OKExecution:string[10];
     TypeProces,ActionSourceAlerte,DateExecutionPrevue,HeureExecutionPrevue,UniteDureeAlerte:string;   OKAlerte:boolean;
begin
     FSFicheSaisie.RBSuspendreTraitement.Checked:=true;
     
     TypeProces:='BusinessProces';
     ActionSourceAlerte:='Fiche de Saisie commerciale';

     OpenFParc(RParc);
     ChTempsAlerteAvantAction:=RParc.Parcours+'\'+Exercice+'TempsAlerteAvantAction';
     assignfile(FTempsAlerteAvantAction,ChTempsAlerteAvantAction);
     try
     if FileExists(ChTempsAlerteAvantAction)then
     Reset(FTempsAlerteAvantAction)
     else begin affichermessage('Attention ! {'+ChTempsAlerteAvantAction+'} n''existe pas !'); exit; end;//Rewrite(FTempsAlerteAvantAction);
     Seek(FTempsAlerteAvantAction,0);
     OKAlerte:=false;
     ValeurAlerte:=0;
     UniteDureeAlerte:='Jours';
     DateExecutionPrevue:=datetostr(date);
     HeureExecutionPrevue:='08:00:00';
     while not eof(FTempsAlerteAvantAction)and(OKAlerte=false)do
     begin
          read(FTempsAlerteAvantAction,RTempsAlerteAvantAction);
          if(RTempsAlerteAvantAction.TypeProces=TypeProces)
          and(RTempsAlerteAvantAction.ActionSourceAlerte=ActionSourceAlerte)
          then
          begin
               OKAlerte:=true;
               ValeurAlerte:=RTempsAlerteAvantAction.ValeurTempsAlerte;
               UniteDureeAlerte:=RTempsAlerteAvantAction.UniteTempsAlerte;
               PrevoirDateHeure(datetostr(date),'08:00:00',ValeurAlerte,UniteDureeAlerte,DateExecutionPrevue,HeureExecutionPrevue);
          end;
     end;
     finally
     CloseFile(FTempsAlerteAvantAction);
     end;

     FSFicheSaisie.EditDateMouvementDebut.Date:=strtodate('01/01/'+ExerciceAnnee);
     FSFicheSaisie.EditDateMouvementFin.Date:=Date;
     FSFicheSaisie.EditDateLimiteExecution.Date:=strtodate(DateExecutionPrevue);

     if(FSFicheSaisie.RBDateLimiteExecution.Checked=true)
     then DateLimiteExecution:=datetostr(FSFicheSaisie.EditDateLimiteExecution.Date)
     else DateLimiteExecution:='';
     DateMouvementDebut:=datetostr(FSFicheSaisie.EditDateMouvementDebut.Date);
     DateMouvementFin:=datetostr(FSFicheSaisie.EditDateMouvementFin.Date);
     OKExecution:=FSFicheSaisie.EditOKExecution.Text;

     ProcListeTypeMouvement(FSFicheSaisie.TableauAnalyseTypeMouvement);
     FSFicheSaisie.TableauAnalyseTypeMouvementClick(FSFicheSaisie.TableauAnalyseTypeMouvement);
end;
   
