Procedure ImprimerBonQuantitatifDynamique(ApercuAvantImpression:boolean);
var i,R,m,NPage,CapacyteMax,Capacyte,LigneInsert:integer;  OK,OKAvis:boolean; Origine,ModePaiement:string;
begin
CapacyteMax:=26;

PrintBonQuantitatifDynamique.DataNumOrdre.Lines.Clear;
PrintBonQuantitatifDynamique.DataDesigne.Lines.Clear;
PrintBonQuantitatifDynamique.DataRef.Lines.Clear;
PrintBonQuantitatifDynamique.DataQDemmande.Lines.Clear;
PrintBonQuantitatifDynamique.DataQRecue.Lines.Clear;
PrintBonQuantitatifDynamique.DataObservation.Lines.Clear;
for i:=0 to CapacyteMax do
begin
     PrintBonQuantitatifDynamique.DataNumOrdre.Lines.Add('');
     //PrintBonQuantitatifDynamique.DataDesigne.Lines.Add('');
     PrintBonQuantitatifDynamique.DataRef.Lines.Add('');
     PrintBonQuantitatifDynamique.DataQDemmande.Lines.Add('');
     PrintBonQuantitatifDynamique.DataQRecue.Lines.Add('');
     PrintBonQuantitatifDynamique.DataObservation.Lines.Add('');
end;

PrintBonQuantitatifDynamique.ModePaiementCheque.Enabled:=false;
PrintBonQuantitatifDynamique.ModePaiementEspece.Enabled:=false;
PrintBonQuantitatifDynamique.ModePaiementATerme.Enabled:=false;
PrintBonQuantitatifDynamique.ModePaiement.Caption:='';

PrintBonQuantitatifDynamique.TitreSignataire.Caption:=FSFicheSaisie.EditSignataire.Text;

ModePaiement:=AnsiUpperCase(FSFicheSaisie.EditModePayement.Text);

OKAvis:=false;

if(OKAvis=true)then
begin
     if(ModePaiement=AnsiUpperCase('Chčque'))
     or(ModePaiement=AnsiUpperCase('Bon'))
     or(ModePaiement=AnsiUpperCase('Virement'))
     then
     begin
          PrintBonQuantitatifDynamique.ModePaiementCheque.Enabled:=true;
          PrintBonQuantitatifDynamique.ModePaiement.Caption:=ModePaiement+' '+FSFicheSaisie.EditDomiciliation.Text+' '+FSFicheSaisie.EditNumPiece.Text;
     end
     else
     if(ModePaiement=AnsiUpperCase('Espčce'))then
     begin
          PrintBonQuantitatifDynamique.ModePaiementEspece.Enabled:=true;
     end
     else
     if(ModePaiement<>AnsiUpperCase('Chčque'))
     and(ModePaiement<>AnsiUpperCase('Bon'))
     and(ModePaiement<>AnsiUpperCase('Virement'))
     and(ModePaiement<>AnsiUpperCase('Espčce'))
     then
     begin
          PrintBonQuantitatifDynamique.ModePaiementATerme.Enabled:=true;
     end;

end
else
begin
     if(ModePaiement<>'')then
     begin
          if(ModePaiement=AnsiUpperCase('Chčque'))
          or(ModePaiement=AnsiUpperCase('Bon'))
          or(ModePaiement=AnsiUpperCase('Virement'))
          then
          begin
               PrintBonQuantitatifDynamique.ModePaiementCheque.Enabled:=true;
               PrintBonQuantitatifDynamique.ModePaiement.Caption:=ModePaiement+' '+FSFicheSaisie.EditDomiciliation.Text+' '+FSFicheSaisie.EditNumPiece.Text;
          end
          else
          if(ModePaiement=AnsiUpperCase('Espčce'))
          then
          begin
               PrintBonQuantitatifDynamique.ModePaiementEspece.Enabled:=true;
          end
          else
          if(ModePaiement=AnsiUpperCase('A Terme'))
          then
          begin
               PrintBonQuantitatifDynamique.ModePaiementATerme.Enabled:=true;
          end
          else
          if(ModePaiement=AnsiUpperCase('Autres'))
          then
          begin
               PrintBonQuantitatifDynamique.ModePaiementCheque.Enabled:=true;
               PrintBonQuantitatifDynamique.ModePaiement.Caption:=ModePaiement+' '+FSFicheSaisie.EditDomiciliation.Text+' '+FSFicheSaisie.EditNumPiece.Text;
          end;
     end;
end;

R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
     if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
     then
     begin
          OK:=true;
          showmessage('Veuillez enregistrer les modifications avant l''impression SVP !');
     end;
     R:=R+1;
end;

if(OK=false)
and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
begin
     Capacyte:=0;
     for R := 6 to FSFicheSaisie.TableauDetaiMouvement.RowCount-1 do
     begin
          FSFicheSaisie.TesteMemoLigneaire.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[2,R]+' '+FSFicheSaisie.TableauDetaiMouvement.Cells[3,R];
          for i:=0 to FSFicheSaisie.TesteMemoLigneaire.Lines.Capacity do
          begin
               if(FSFicheSaisie.TesteMemoLigneaire.Lines.Strings[i]<>'')then
               begin
                    Capacyte:=Capacyte+1;
               end;
          end;

          if(Capacyte>0)then Capacyte:=Capacyte+1;
     end;

Division(Capacyte,CapacyteMax,NPage,m);
if(m>0)then NPage:=NPage+1;
{*******************Entreprise***************}
OpenFParc(RParc);
PrintBonQuantitatifDynamique.TextEntreprise.Caption:=RParc.Text1;

PrintBonQuantitatifDynamique.DataEntreprise.Lines.Text:='';
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text2);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text3);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text4);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text5);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text6);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text7);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text8);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text9);
PrintBonQuantitatifDynamique.DataEntreprise.Lines.Add(RParc.Text10);
{***************Fin Entreprise***************}

{***************Fournisseur***************}
PrintBonQuantitatifDynamique.TitreFournisseur.Caption:=lastlaters(FSFicheSaisie.EditFunctionFichierConcerne.Text,longueur(FSFicheSaisie.EditFunctionFichierConcerne.Text)-1);
RTier:=ChercherTiers(FSFicheSaisie.EditTypeProces.Text,FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row],FSFicheSaisie.EditCodeTiersConserne.Text,FSFicheSaisie.EditTiersConserne.Text);

PrintBonQuantitatifDynamique.DataTiers.Lines.Text:='';
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.NomTiers+' '+RTier.PrenomTiers);
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.AdresseTiers);
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.Data1);
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.Data2);
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.Data3);
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.Data4);
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.Data5);
PrintBonQuantitatifDynamique.DataTiers.Lines.Add(RTier.Data6);
{***************Fin Fournisseur***************}

if(FSFicheSaisie.RBNumEtatType1.Checked=true)then
begin
     PrintBonQuantitatifDynamique.EnteteTitre.Caption:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
     CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'7');
end
else
if(FSFicheSaisie.RBNumEtatType2.Checked=true)then
begin
     PrintBonQuantitatifDynamique.EnteteTitre.Caption:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
     Midellaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),9,10)+'-'+
     CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'5');
end
else
if(FSFicheSaisie.RBNumEtatType3.Checked=true)then
begin
     PrintBonQuantitatifDynamique.EnteteTitre.Caption:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
     Midellaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),7,10)+'-'+
     CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'3');
end
else
if(FSFicheSaisie.RBNumEtatType4.Checked=true)then
begin
     PrintBonQuantitatifDynamique.EnteteTitre.Caption:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
     Lastlaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),2)+CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'5');
end
else
begin
     PrintBonQuantitatifDynamique.EnteteTitre.Caption:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
     CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'7');
end;

if(FSFicheSaisie.RBAfficherInfosBasPage.Checked=true)then
begin
     PrintBonQuantitatifDynamique.DataEntrepriseBasPage.Enabled:=true;
     PrintBonQuantitatifDynamique.DataEntrepriseBasPage.Lines.Text:=FSFicheSaisie.EditBasPage.Lines.Text;
end
else
begin
     PrintBonQuantitatifDynamique.DataEntrepriseBasPage.Lines.Text:='';
     PrintBonQuantitatifDynamique.DataEntrepriseBasPage.Enabled:=false;
end;

PrintBonQuantitatifDynamique.TextDate.Caption:='Date: '+datetostr(FSFicheSaisie.EditDateDetailMouvement.Date);

PrintBonQuantitatifDynamique.Total.Enabled:=false;
PrintBonQuantitatifDynamique.TitreTotal.Enabled:=false;
PrintBonQuantitatifDynamique.CTotal.Enabled:=false;
PrintBonQuantitatifDynamique.CTitreTotal.Enabled:=false;
PrintBonQuantitatifDynamique.TitreSoit.Enabled:=false;
PrintBonQuantitatifDynamique.TotalEnLettre.Enabled:=false;

PrintBonQuantitatifDynamique.TitreNum.Caption:='Or°';
PrintBonQuantitatifDynamique.TitreDesignation.Caption:='DESIGNATION';
PrintBonQuantitatifDynamique.TitreRef.Caption:='UM';
PrintBonQuantitatifDynamique.TitreQuantiteProduit.Caption:='QUANTITES';
PrintBonQuantitatifDynamique.TitreQteDemandee.Caption:='Demd';
PrintBonQuantitatifDynamique.TitreQteRecue.Caption:='Reçues';
PrintBonQuantitatifDynamique.TitreObservation.Caption:='OBSERVATIONS';

R:=6;
m:=1;
Capacyte:=0;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
begin
     if(Capacyte<=CapacyteMax)and(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)then
     begin
          FSFicheSaisie.TesteMemoLigneaire.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[2,R]+' '+FSFicheSaisie.TableauDetaiMouvement.Cells[3,R];

          FSFicheSaisie.TestePrintFacureDinamique.Lines.Clear;
          for i:=0 to FSFicheSaisie.TesteMemoLigneaire.Lines.Capacity do
          begin
               if(FSFicheSaisie.TesteMemoLigneaire.Lines.Strings[i]<>'')then FSFicheSaisie.TestePrintFacureDinamique.Lines.Add(FSFicheSaisie.TesteMemoLigneaire.Lines.Strings[i]);
          end;

          Capacyte:=Capacyte+FSFicheSaisie.TesteMemoLigneaire.Lines.Capacity+1;

          if(Capacyte<=CapacyteMax)then
          begin
               LigneInsert:=PrintBonQuantitatifDynamique.DataDesigne.Lines.Add(FSFicheSaisie.TesteMemoLigneaire.Lines.Text);

               PrintBonQuantitatifDynamique.DataNumOrdre.Lines.Insert(LigneInsert,(CompleteZeroGauche(inttostr(R-5),'2')));
               PrintBonQuantitatifDynamique.DataRef.Lines.Insert(LigneInsert,(FSFicheSaisie.TableauDetaiMouvement.Cells[4,R]));
               PrintBonQuantitatifDynamique.DataQDemmande.Lines.Insert(LigneInsert,(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R]));
               PrintBonQuantitatifDynamique.DataQRecue.Lines.Insert(LigneInsert,(''));
               PrintBonQuantitatifDynamique.DataObservation.Lines.Insert(LigneInsert,(''));

               PrintBonQuantitatifDynamique.DataDesigne.Lines.Add('');
               PrintBonQuantitatifDynamique.DataNumOrdre.Lines.Add('');
               PrintBonQuantitatifDynamique.DataRef.Lines.Add('');
               PrintBonQuantitatifDynamique.DataQDemmande.Lines.Add('');
               PrintBonQuantitatifDynamique.DataQRecue.Lines.Add('');
               PrintBonQuantitatifDynamique.DataObservation.Lines.Add('');
          end
          else R:=R-1;
     end
     else
     if(Capacyte>CapacyteMax)then else R:=R-1;

     if(Capacyte>=CapacyteMax)or(R>=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)then
     begin
          PrintBonQuantitatifDynamique.NbrPage.Caption:='Page N°: '+inttostr(m)+'/'+inttostr(NPage);
          if(ApercuAvantImpression=true)                            
          then PrintBonQuantitatifDynamique.Preview
          else PrintBonQuantitatifDynamique.Print;

          InitialisationPrintBCQDynamique;
          Capacyte:=0;
          m:=m+1;
     end;
R:=R+1;
end;

end;

end;

