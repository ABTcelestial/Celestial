Function ControleAnomaliesListeMouvement(TableauListeMouvement:TStringGrid; var ListeNumControle:string):boolean;
var  R,l,NumMax,NumMin,NumControle:integer;  OKAnomalie:boolean;   
begin
     ControleAnomaliesListeMouvement:=false;
     ListeNumControle:='';

     R:=1;
     NumMin:=999999999;
     NumMax:=0;
     while(R<=TableauListeMouvement.RowCount-1)do
     begin
          if(NumMin>strtointeger(TableauListeMouvement.Cells[2,R]))then NumMin:=strtointeger(TableauListeMouvement.Cells[2,R]);
          if(NumMax<strtointeger(TableauListeMouvement.Cells[2,R]))then NumMax:=strtointeger(TableauListeMouvement.Cells[2,R]);
     R:=R+1;
     end;

     l:=1;
     NumControle:=NumMin;
     while(NumControle+l<NumMax)do
     begin
          R:=1;
          OKAnomalie:=false;
          while(R<=TableauListeMouvement.RowCount-1)and(OKAnomalie=false)do
          begin
               if(NumControle+l=strtointeger(TableauListeMouvement.Cells[2,R]))then OKAnomalie:=true;
          R:=R+1;
          end;

          if(OKAnomalie=false)then
          begin
               if(ListeNumControle='')
               then ListeNumControle:=inttostr(NumControle+l)
               else ListeNumControle:=ListeNumControle+';'+inttostr(NumControle+l);
          end;
     l:=l+1;
     end;

     if(ListeNumControle<>'')then ControleAnomaliesListeMouvement:=true;
end;

