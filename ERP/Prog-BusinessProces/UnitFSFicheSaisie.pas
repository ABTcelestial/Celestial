try
if FileExists(ChFormule)then
Reset(FFormule)
else begin affichermessage('Attention ! {'+ChFormule+'} n''existe pas !'); exit; end;//Rewrite(FFormule);
seek(FFormule,0);
i:=0;
jVR:=0;
T:=7;
while not eof(FFormule)do
begin
    Read(FFormule,RFormule);

    if(ReafficheVariable=true)
    and(ExisteCharinString('VR',RFormule.FormuleTexte)or(RFormule.TypeAffichage='VR'))
    then
    begin
         jVR:=jVR+1;
         FSFicheSaisie.TableauVariable.Rows[jVR].Text:=inttostr(jVR);
         TableauVariable.Cells[1,jVR]:=inttostr(RFormule.PositionFormule);
