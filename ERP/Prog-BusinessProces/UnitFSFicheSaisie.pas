Procedure ProcSelectListeAppartenance(TableauListeAppartenanceMouvement,TableauDetaiMouvementAppartenanceMouvemant,TableauRecapitulatifDetailMouvements,TableauPositionMouvement:TStringGrid; EditMontantGlobaleAppartenanceMouvement:TMemo; EditOrdreListeMouvementAppartenant,EditNumAvisAppartenanceMouvement:TEdit; ExerciceSource,CodeTiers,DateDebut,DateFin,NumProjet,DebitCreditPositif:string; RowSelect,ColSelectOK,ColMontant,ColIndex,ColDate,ColOrdreListeMouvement,ColNumPrelevementUF,ColNumPrelevement,ColListeNumAvis:integer;  RIn:integer; var ROut:integer);
var  R:integer;  ListeNumPrelevementSource,ListeNumPrelevementAnnee,ListeNumPrelevementUFSource,ListeNumPrelevementUFAnnee,ListeOrdreListeMouvementSource,ListeOrdreListeMouvementAnnee,Index,DateDebutAM,DateFinAM,ExerciceSelect:string;
begin
     FSTraitementDonnees.RapportTraitementMouvements.Lines.Text:='';

     FSTraitementDonnees.RapportTraitementMouvements.Lines.Add('Début de traitement:');

     if(RIn=0)then
     begin
          TableauDetaiMouvementAppartenanceMouvemant.RowCount:=2;
          TableauDetaiMouvementAppartenanceMouvemant.Rows[1].Text:='';
     end;

     EditOrdreListeMouvementAppartenant.Text:='';
     EditNumAvisAppartenanceMouvement.Text:='';
     ListeOrdreListeMouvementAnnee:='';
     ListeOrdreListeMouvementSource:='';
     ListeNumPrelevementUFAnnee:='';
     ListeNumPrelevementAnnee:='';
     ListeNumPrelevementUFSource:='';
     ListeNumPrelevementSource:='';
     R:=1;
     while(R<=TableauListeAppartenanceMouvement.RowCount-1)do
     begin
          RowSelect:=R;
          if(TableauListeAppartenanceMouvement.Cells[ColSelectOK,RowSelect]='OK')then
          begin
               FSTraitementDonnees.RapportTraitementMouvements.Lines.Add(TableauListeAppartenanceMouvement.Cells[8,RowSelect]+' N° '+TableauListeAppartenanceMouvement.Cells[2,RowSelect]+' du '+TableauListeAppartenanceMouvement.Cells[3,RowSelect]+' montant: '+TableauListeAppartenanceMouvement.Cells[6,RowSelect]);

               ExerciceSelect:=lastlaters(TableauListeAppartenanceMouvement.Cells[ColDate,RowSelect],4);
               DateDebutAM:='01/01/'+ExerciceSelect;
               DateFinAM:='31/12/'+ExerciceSelect;

               Index:=TableauListeAppartenanceMouvement.Cells[ColIndex,RowSelect]; //4 1  6 1

               if(EditOrdreListeMouvementAppartenant.Text='')
               then EditOrdreListeMouvementAppartenant.Text:=Index+TableauListeAppartenanceMouvement.Cells[ColOrdreListeMouvement,RowSelect]
               else EditOrdreListeMouvementAppartenant.Text:=EditOrdreListeMouvementAppartenant.Text+';'+Index+TableauListeAppartenanceMouvement.Cells[ColOrdreListeMouvement,RowSelect];

               if(EditNumAvisAppartenanceMouvement.Text='')then
               begin
                    EditNumAvisAppartenanceMouvement.Text:=TableauListeAppartenanceMouvement.Cells[ColListeNumAvis,RowSelect];
               end
               else
               begin
                    if not(FunctionFichierInclu(TableauListeAppartenanceMouvement.Cells[ColListeNumAvis,RowSelect],EditNumAvisAppartenanceMouvement.Text))
                    then EditNumAvisAppartenanceMouvement.Text:=EditNumAvisAppartenanceMouvement.Text+';'+TableauListeAppartenanceMouvement.Cells[ColListeNumAvis,RowSelect];
               end;

               if(Index='LM')or(Index='')then
               begin
                    if(ExerciceSelect=ExerciceAnnee)then
                    begin
                         if(ListeOrdreListeMouvementAnnee='')
                         then ListeOrdreListeMouvementAnnee:=TableauListeAppartenanceMouvement.Cells[ColOrdreListeMouvement,RowSelect]
                         else ListeOrdreListeMouvementAnnee:=ListeOrdreListeMouvementAnnee+';'+TableauListeAppartenanceMouvement.Cells[ColOrdreListeMouvement,RowSelect];
                    end
                    else
                     begin
                         if(ListeOrdreListeMouvementSource='')
                         then ListeOrdreListeMouvementSource:=TableauListeAppartenanceMouvement.Cells[ColOrdreListeMouvement,RowSelect]
                         else ListeOrdreListeMouvementSource:=ListeOrdreListeMouvementSource+';'+TableauListeAppartenanceMouvement.Cells[ColOrdreListeMouvement,RowSelect];
                    end;
               end;

               if(Index='UF')then
               begin
                    if(strtointeger(ExerciceSelect)>=strtointeger(ExerciceAnnee))then
                    begin
                         if(ListeNumPrelevementUFAnnee='')
                         then ListeNumPrelevementUFAnnee:=TableauListeAppartenanceMouvement.Cells[ColNumPrelevementUF,RowSelect]
                         else ListeNumPrelevementUFAnnee:=ListeNumPrelevementUFAnnee+';'+TableauListeAppartenanceMouvement.Cells[ColNumPrelevementUF,RowSelect];

                         if(ListeNumPrelevementAnnee='')
                         then ListeNumPrelevementAnnee:=TableauListeAppartenanceMouvement.Cells[ColNumPrelevement,RowSelect]
                         else ListeNumPrelevementAnnee:=ListeNumPrelevementAnnee+';'+TableauListeAppartenanceMouvement.Cells[ColNumPrelevement,RowSelect];
                    end
                    else
                    begin
                         if(ListeNumPrelevementUFSource='')
                         then ListeNumPrelevementUFSource:=TableauListeAppartenanceMouvement.Cells[ColNumPrelevementUF,RowSelect]
                         else ListeNumPrelevementUFSource:=ListeNumPrelevementUFSource+';'+TableauListeAppartenanceMouvement.Cells[ColNumPrelevementUF,RowSelect];

                         if(ListeNumPrelevementSource='')
                         then ListeNumPrelevementSource:=TableauListeAppartenanceMouvement.Cells[ColNumPrelevement,RowSelect]
                         else ListeNumPrelevementSource:=ListeNumPrelevementSource+';'+TableauListeAppartenanceMouvement.Cells[ColNumPrelevement,RowSelect];
                    end;
               end;
          end;
     R:=R+1;
     end;

     if(ListeOrdreListeMouvementSource<>'')then
     begin
          DateDebutAM:='01/01/'+ExerciceSource;
          DateFinAM:='31/12/'+ExerciceSource;
          CalculeAutoAppartenanceMouvement(TableauListeAppartenanceMouvement,TableauDetaiMouvementAppartenanceMouvemant,TableauRecapitulatifDetailMouvements,TableauPositionMouvement,ExerciceSource,ListeOrdreListeMouvementSource,DebitCreditPositif,FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,FSFicheSaisie.EditNbrChiffreApresVerguleCout.Text,DateDebutAM,DateFinAM,EditOrdreListeMouvementAppartenant,ColSelectOK,ColDate,RIn,RIn);

          LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
     end;
     if(ListeOrdreListeMouvementAnnee<>'')then
     begin
          DateDebutAM:='01/01/'+ExerciceAnnee;
          DateFinAM:='31/12/'+ExerciceAnnee;
          CalculeAutoAppartenanceMouvement(TableauListeAppartenanceMouvement,TableauDetaiMouvementAppartenanceMouvemant,TableauRecapitulatifDetailMouvements,TableauPositionMouvement,ExerciceAnnee,ListeOrdreListeMouvementAnnee,DebitCreditPositif,FSFicheSaisie.EditNbrChiffreApresVerguleQte.Text,FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,FSFicheSaisie.EditNbrChiffreApresVerguleCout.Text,DateDebutAM,DateFinAM,EditOrdreListeMouvementAppartenant,ColSelectOK,ColDate,RIn,RIn);

          LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
     end;

     if(ListeNumPrelevementSource<>'')and(ListeNumPrelevementUFSource<>'')then
     begin
          DateDebutAM:='01/01/'+ExerciceSource;
          DateFinAM:='31/12/'+ExerciceSource;
          ListeDetailArticlePrelevementUniteFondsPointeur(TableauDetaiMouvementAppartenanceMouvemant,ListeNumPrelevementSource,ListeNumPrelevementUFSource,'',CodeTiers,DateDebutAM,DateFinAM,false,false,true,false,true,RIn,NumProjet,RIn);

          LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
     end;
     if(ListeNumPrelevementAnnee<>'')and(ListeNumPrelevementUFAnnee<>'')then
     begin
          DateDebutAM:=DateDebut;  //DateDebutAM:='01/01/'+ExerciceAnnee;
          DateFinAM:=DateFin;      //DateFinAM:='31/12/'+ExerciceAnnee;
          ListeDetailArticlePrelevementUniteFondsPointeur(TableauDetaiMouvementAppartenanceMouvemant,ListeNumPrelevementAnnee,ListeNumPrelevementUFAnnee,'',CodeTiers,DateDebutAM,DateFinAM,false,false,true,false,true,RIn,NumProjet,RIn);

          LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
     end;

     ROut:=RIn;

     FSTraitementDonnees.RapportTraitementMouvements.Lines.Add('Fin du traitement.');

     FSTraitementDonnees.RapportTraitementMouvements.Visible:=false;
end;        

