procedure TFSFicheSaisie.TableauListeMouvementEnter(Sender: TObject);
begin

     if(FSFicheSaisie.RBListeDetailMouvementParMois.Checked=true)then
     begin
          if(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
          begin
               if(datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])=true)then
               begin
                    FSFicheSaisie.EditMois.ItemIndex:=strtointeger(Midellaters(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row],4,5))-1;
                    FSFicheSaisie.EditAnnee.Text:=Midellaters(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row],7,10);
               end
               else
               begin
                    FSFicheSaisie.EditMois.ItemIndex:=strtointeger(Midellaters(datetostr(date),4,5))-1;
                    FSFicheSaisie.EditAnnee.Text:=Midellaters(datetostr(date),7,10);
               end;
          end;
     end;

     if(FSFicheSaisie.RBListeDetailMouvementParDate.Checked=true)then
     begin
          if(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
          begin
               if(datecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])=true)
               then FSFicheSaisie.EditChercheDateDetailMouvement.Date:=strtodate(FSFicheSaisie.TableauListeMouvement.Cells[5,FSFicheSaisie.TableauListeMouvement.Row])
               else FSFicheSaisie.EditChercheDateDetailMouvement.Date:=date;
          end;
     end;
end;

procedure TFSFicheSaisie.TimerImporterDetailListeMouvementTimer(Sender: TObject);
var  Repitition:integer;
     OKChargement:boolean;
     Codebarre,Titre,SousTitre:string;
begin
     FSFicheSaisie.TimerImporterDetailListeMouvement.Enabled:=false;

     if(FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text='-1')then Exit;

     if(FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text<>'0')then Exit;

     FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text:='1';

     OKChargement:=false;

     if(FSFicheSaisie.TableauListeMouvement.Cells[3,FSFicheSaisie.TableauListeMouvement.Row]<>'')
     and(FSFicheSaisie.TableauListeMouvement.Cells[4,FSFicheSaisie.TableauListeMouvement.Row]<>'')
     then
     begin
          FSFicheSaisie.EditPositionMouvementAfficher.Text:=FSFicheSaisie.TableauListeMouvement.Cells[40,FSFicheSaisie.TableauListeMouvement.Row];
          FSFicheSaisie.RBChargerPointeurDetailMouvement.Checked:=true;
          ImporterDetailListeMouvement(FSFicheSaisie.TableauListeMouvement,FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable);

          OKChargement:=true;
     end
     else InitialisationFicheSaisie(false,false,false,false,true,true);

     ListeTypeFichierTiersInclu(FSFicheSaisie.EditFichierTiersConserne.Text,FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row],FSFicheSaisie.EditFunctionFichierConcerne,FSFicheSaisie.TitreEditFunctionFichierConcerne);

     if(OKChargement=false)then
     begin
          if(FSFicheSaisie.EditExecutionProcAfficheListeMouvementPointeur.Text='0')
          then showmessage('Chargement du mouvement non effectué !');
     end
     else
     begin
          FSFicheSaisie.TimerControleMontant.Enabled:=true;
     end;

     Codebarre:=Completezerogauche(inttostr(99-strtointeger(FSFicheSaisie.EditPositionMouvement.Text)),'2')+Completezerogauche(inttostr(99999-strtointeger(FSFicheSaisie.EditOrdreListeMouvement.Text)),'5');
     //Codebarre:=Completezerogauche(FSFicheSaisie.EditPositionMouvement.Text,'2')+Completezerogauche(FSFicheSaisie.EditOrdreListeMouvement.Text,'5');
     if(FSFicheSaisie.RBNumEtatType1.Checked=true)then
     begin
          Titre:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
          CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'7');
     end
     else
     if(FSFicheSaisie.RBNumEtatType2.Checked=true)then
     begin
          Titre:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
          Midellaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),9,10)+'-'+
          CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'5');
     end
     else
     if(FSFicheSaisie.RBNumEtatType3.Checked=true)then
     begin
          Titre:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
          Midellaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),7,10)+'-'+
          CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'3');
     end
     else
     begin
          Titre:=FSFicheSaisie.EditDesignationMouvement.Text+' N°: '+
          CompleteZeroGauche(FSFicheSaisie.EditNumListeMouvement.Text,'7');
     end;

     Titre:='';
     SousTitre:='';

     if(FunctAfficherCodeBarresDansEtatsMouvement=true)then  //FSMenuPrincipal.PhotoVide.Picture;
     begin
          ChargerCodeBarre(Titre,firstlaters(Codebarre,7),SousTitre);
          FSFicheSaisie.ImageCodebarre.Picture:=FSEtiquettesCodeBarre.ImageCodebarre.Picture;
     end
     else
     begin
          FSFicheSaisie.ImageCodebarre.Picture:=FSMenuPrincipal.PhotoVide.Picture;
     end;

     FSFicheSaisie.EditExecutionTimerImporterDetailListeMouvement.Text:='0';

     FSFicheSaisie.AfficheAttenteDetailMouvement.Visible:=false;
     FSFicheSaisie.TableauListeMouvement.SetFocus;
end;

procedure TFSFicheSaisie.TimerControleMontantTimer(Sender: TObject);
var  R,i,PBegin,PEnd:integer; OKCodeTiers,OKControle,OKListeMouvement:boolean;  MontantListeAvis:real;
     TypeProces,FichierConcerne,Adresse:string;
begin
     FSFicheSaisie.TimerControleMontant.Enabled:=false;

     OKControle:=true;
     R:=6;
     while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OKControle=true)do
     begin
          if(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R]='')then OKControle:=false;
     R:=R+1;
     end;

     if(FSFicheSaisie.EditOrdreListeMouvement.Text<>FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row])then OKControle:=false;

     if(FSFicheSaisie.EditCodeTiersConserne.Text<>FSFicheSaisie.TableauListeMouvement.Cells[9,FSFicheSaisie.TableauListeMouvement.Row])then OKControle:=false;

     if(OKControle=true)and(FSFicheSaisie.EditNumListeMouvement.Text<>'')and(FSFicheSaisie.EditNumListeMouvement.Text=FSFicheSaisie.TableauListeMouvement.Cells[2,FSFicheSaisie.TableauListeMouvement.Row])and(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>0)and(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]<>'')and(strtoreal(FSFicheSaisie.EditMontantMouvement.Text)<>strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]))then
     begin
           if nonoui('Attention ! Le montant du mouvement enregistré, diffčre de ce lui calculé ! Voulez vous réindexer ?')then
           begin
                TypeProces:='Business';
                FichierConcerne:='FListeMouvement';
                Adresse:='';
                if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                begin
                     AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
                end;

                ChListeMouvement:=Adresse;
                assignfile(FListeMouvement,ChListeMouvement);
                try
                if FileExists(ChListeMouvement)then
                Reset(FListeMouvement)
                else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
                Seek(FListeMouvement,0);
                i:=0;
                OKListeMouvement:=false;
                while not eof(FListeMouvement)and(OKListeMouvement=false)do
                begin
                     read(FListeMouvement,RListeMouvement);

                     if(inttostr(RListeMouvement.OrdreListeMouvement)=FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row])then
                     begin
                          OKListeMouvement:=true;
                          RTypeMouvement:=chercherTypeMouvement(RListeMouvement.PositionTypeMouvement,ExerciceAnnee,AdresseFichierConcerne);

                          if(RTypeMouvement.DesignationTypeMouvement=FSFicheSaisie.EditDesignationTypeMouvement.Text)then
                          begin
                               IndiquerPositionDetailMouvement(RTypeMouvement.DesignationTypeMouvement,ExerciceAnnee,RListeMouvement.OrdreListeMouvement,PBegin,PEnd);

                               RListeMouvement.MontantMouvement:=strtoreal(FSFicheSaisie.EditMontantMouvement.Text);
                               RListeMouvement.PositionDetailMouvementBegin:=PBegin;
                               RListeMouvement.PositionDetailMouvementEnd:=PEnd;

                               Seek(FListeMouvement,i);
                               write(FListeMouvement,RListeMouvement);

                               FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]:=FSFicheSaisie.EditMontantMouvement.Text;
                               FSFicheSaisie.TableauListeMouvement.Cells[38,FSFicheSaisie.TableauListeMouvement.Row]:=inttostr(PBegin);
                               FSFicheSaisie.TableauListeMouvement.Cells[39,FSFicheSaisie.TableauListeMouvement.Row]:=inttostr(PEnd);
                          end;
                     end;
                i:=i+1;
                LibererMemoireProcessus('BusinessProces.exe',true);
                end;
                finally
                CloseFile(FListeMouvement);
                end;

                TableauListeMouvementClick(FSFicheSaisie.TableauListeMouvement);
           end
           else
           begin
                FSFicheSaisie.TableauDetaiMouvement.SetFocus;
           end;
          //AfficherMessage('Attention ! Le montant du mouvement enregistré, diffčre de ce lui calculé !');
     end
     else
     if(OKControle=true)and(FSFicheSaisie.EditNumAvis.Text<>'')then
     begin
          R:=1;
          OKCodeTiers:=true;
          while(R<=FSFicheSaisie.TableauListeAvisTrouver.RowCount-1)and(OKCodeTiers=true)do
          begin
               if(FSFicheSaisie.RBSuspendreDetailMouvement.Checked=true)then Exit;
               if(FSFicheSaisie.EditCodeTiersConserne.Text<>FSFicheSaisie.TableauListeAvisTrouver.Cells[8,R])then OKCodeTiers:=false;
          R:=R+1;
          end;

          if(OKCodeTiers=false)then
          begin
               AfficherMessage('Attention données avis attribués incorrecte !');
          end;
     end;
end;

