procedure TFSFicheSaisie.RBListeDetailMouvementParMoisClick(
  Sender: TObject);
var  i,NumAnneeSyst,NumAnneeAct:integer;  DateMouvementDebut,DateMouvementFin,OKExecution:string;
begin
     if(FSFicheSaisie.RBChercheArticleParCodeBarre.Checked=true)
     or(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)then
     begin
          FSFicheSaisie.EditMois.ItemIndex:=strtointeger(Midellaters(datetostr(date),4,5))-1;
     end;

     EnregistrerOptionsFicheSaisie(FSFicheSaisie.EditCodeMouvement.Text);

     FSFicheSaisie.AfficherChercherNumeroListeMouvement.Visible:=false;
     FSFicheSaisie.TableauChercherTiers.Visible:=false;
     
     FSFicheSaisie.RBSuspendreTraitement.Checked:=true;
     
     //InitialisationFicheSaisie(true,true,true,true,true);

     FSFicheSaisie.RBAfficherValeursMonetaires.Checked:=true;

     FSFicheSaisie.AfficheParMois.Visible:=true;
     FSFicheSaisie.EditChercheDateDetailMouvement.Visible:=false;

     //FSFicheSaisie.EditMois.ItemIndex:=strtointeger(MidelLaters(datetostr(Date),4,5))-1;

     FSFicheSaisie.EditAnnee.Items.Text:='';
     NumAnneeSyst:=strtointeger(ExerciceAnnee);
     NumAnneeAct:=strtointeger(MidelLaters(datetostr(Date),7,10));
     i:=0;
     while(NumAnneeSyst<=NumAnneeAct)do
     begin
          FSFicheSaisie.EditAnnee.Items.Add(inttostr(NumAnneeSyst));
          NumAnneeSyst:=NumAnneeSyst+1;
          i:=i+1;
     end;
     FSFicheSaisie.EditAnnee.ItemIndex:=i-1;

     DetailPeriodeListeMouvement(FSFicheSaisie.RBListeDetailMouvementParDate,FSFicheSaisie.RBListeDetailMouvementParMois,DateMouvementDebut,DateMouvementFin);
