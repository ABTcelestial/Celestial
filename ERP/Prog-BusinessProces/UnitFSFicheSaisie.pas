     ListeTypeFichierTiersInclu(FSFicheSaisie.EditFichierTiersConserne.Text,FSFicheSaisie.TableauListeMouvement.Cells[8,FSFicheSaisie.TableauListeMouvement.Row],FSFicheSaisie.EditFunctionFichierConcerne,FSFicheSaisie.TitreEditFunctionFichierConcerne);

     FSFicheSaisie.BitEchapClick(FSFicheSaisie.BitEchap);

     if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)or(FSFicheSaisie.RBAvecDateExecution.Checked=true)then
     begin
          FSFicheSaisie.AfficheExecutionMouvement.Left:=FSFicheSaisie.TableauListeMouvement.Left;
          FSFicheSaisie.AfficheExecutionMouvement.Top:=FSFicheSaisie.AfficheOptionDetailMouvement.Height-
                                                       FSFicheSaisie.AfficheExecutionMouvement.Height-24;

          FSFicheSaisie.AfficheExecutionMouvement.Width:=FSFicheSaisie.TableauListeMouvement.Width;

          FSFicheSaisie.AfficheExecutionMouvement.Visible:=true;

          FSFicheSaisie.TableauListeMouvement.Height:=FSFicheSaisie.AfficheExecutionMouvement.Top-
                                                      FSFicheSaisie.TableauListeMouvement.Top-7;
     end
     else
     begin
          FSFicheSaisie.AfficheExecutionMouvement.Visible:=false;

          FSFicheSaisie.TableauListeMouvement.Height:=FSFicheSaisie.AfficheOptionDetailMouvement.Height-
                                                      FSFicheSaisie.TableauListeMouvement.Top-24;
     end;
end;

