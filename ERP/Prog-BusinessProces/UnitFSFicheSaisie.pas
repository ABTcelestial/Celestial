Procedure ReindixationPositionDetailMouvement;
var i,PBegin,PEnd:integer; TypeProcesTM,FichierConcerneTM,AdresseTM,TypeProces,FichierConcerne,Adresse:string;  valeurLast,ValeurNext,SoldeTransfert:real;
begin
     valeurLast:=0;
     ValeurNext:=0;

     TypeProcesTM:='Business';   FichierConcerneTM:='FTypeMouvement';
     if not(FunctionAdresseProces(TypeProcesTM,FichierConcerneTM,'',AdresseTM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerneTM+' recherché !');
     end;

     ChTypeMouvement:=AdresseTM;
     assignfile(FTypeMouvement,ChTypeMouvement);
     try
     if FileExists(ChTypeMouvement)
     then Reset(FTypeMouvement)
     else begin affichermessage('Attention ! {'+ChTypeMouvement+'} n''existe pas !'); exit; end;//Rewrite(FTypeMouvement);
     seek(FTypeMouvement,0);
     while not eof(FTypeMouvement)do
     begin
           Read(FTypeMouvement,RTypeMouvement);

           PointeurDetailMouvement:=TList.Create;

           TypeProces:='Business';
           FichierConcerne:='DétailMouvement '+RTypeMouvement.DesignationTypeMouvement;
           Adresse:='';
           if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
           begin
                AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
           end;

           ChDetailMouvementCopie:=Adresse+' '+'Transfert';
           assignfile(FDetailMouvementCopie,ChDetailMouvementCopie);
           try
           if FileExists(ChDetailMouvementCopie)then
           Reset(FDetailMouvementCopie)
           else Rewrite(FDetailMouvementCopie);//création nouveau fichier
           Seek(FDetailMouvementCopie,0);
           Truncate(FDetailMouvementCopie);

           ChDetailMouvement:=Adresse;
           assignfile(FDetailMouvement,ChDetailMouvement);
           if FileExists(ChDetailMouvement)then
           begin
                 try
                 Reset(FDetailMouvement);
                 Seek(FDetailMouvement,0);
                 i:=0;
                 while not eof(FDetailMouvement)do
                 begin
                      read(FDetailMouvement,RDetailMouvement);
                      if(RDetailMouvement.ValidationDetailMouvement=true)then
                      begin
                           valeurLast:=valeurLast+(RDetailMouvement.Quantite*RDetailMouvement.PrixUnitaire);
                           RegistrePointeurDetailMouvement:=TRegistrePointeurDetailMouvement.Create;
                           RegistrePointeurDetailMouvement.PositionInitiale:=i;
                           RegistrePointeurDetailMouvement.CodeTrie:=inttostr(RDetailMouvement.OrdreListeMouvement);
                           PointeurDetailMouvement.Add(RegistrePointeurDetailMouvement);
                      end;
                 i:=i+1;
                 end;

                 PointeurDetailMouvement.Sort(TriePointeurDetailMouvementNumPlus);

                 for i:=0 to PointeurDetailMouvement.Count-1 do
                 begin
                      Seek(FDetailMouvement,TRegistrePointeurDetailMouvement(PointeurDetailMouvement[i]).PositionInitiale);
                      read(FDetailMouvement,RDetailMouvement);
                      RDetailMouvement.PositionDetailMouvement:=i;
                      ValeurNext:=ValeurNext+(RDetailMouvement.Quantite*RDetailMouvement.PrixUnitaire);
                      Seek(FDetailMouvementCopie,i);
                      write(FDetailMouvementCopie,RDetailMouvement);
                 end;
                 finally
                 CloseFile(FDetailMouvement);
                 end;

                 for i:=0 to PointeurDetailMouvement.Count-1 do TRegistrePointeurDetailMouvement(PointeurDetailMouvement.Items[i]).Free;
                 PointeurDetailMouvement.Free;

                 ValiderReindixationPositionDetailMouvement(RTypeMouvement.DesignationTypeMouvement);
           end;
           finally
           CloseFile(FDetailMouvementCopie);
           end;
     end;
     finally
     CloseFile(FTypeMouvement);
     end;

     LibererMemoireProcessus('BusinessProces.exe',true);

     SoldeTransfert:=ValePrecis(valeurLast,2)-ValePrecis(ValeurNext,2);

     FSFicheSaisie.AfficheResultatReindixationDetailMouvement.Caption:='Valeure avant: '+Vergule(floattostr(valeurLast),'2','C','')+' Valeure aprés: '+Vergule(floattostr(ValeurNext),'2','C','')+' ecart: '+Vergule(floattostr(SoldeTransfert),'2','C','');

     if(SoldeTransfert=0)
     then FSFicheSaisie.AfficheResultatReindixationDetailMouvement.Color:=clLime
     else FSFicheSaisie.AfficheResultatReindixationDetailMouvement.Color:=clYellow;

     //----------------------------- mise ŕ joir position détail mouvement dans liste mouvement

     LibererMemoireProcessus('BusinessProces.exe',true);

     TypeProces:='Business';
     FichierConcerne:='FListeMouvement';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChListeMouvement:=Adresse;
     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
     Seek(FListeMouvement,0);
     i:=0;
     while not eof(FListeMouvement)do
     begin
          read(FListeMouvement,RListeMouvement);
          RTypeMouvement:=chercherTypeMouvement(RListeMouvement.PositionTypeMouvement,ExerciceAnnee,AdresseFichierConcerne);
          IndiquerPositionDetailMouvement(RTypeMouvement.DesignationTypeMouvement,ExerciceAnnee,RListeMouvement.OrdreListeMouvement,PBegin,PEnd);

          RListeMouvement.PositionDetailMouvementBegin:=PBegin;
          RListeMouvement.PositionDetailMouvementEnd:=PEnd;

          Seek(FListeMouvement,i);
          write(FListeMouvement,RListeMouvement);
     i:=i+1;
     LibererMemoireProcessus('BusinessProces.exe',true);
     end;
     finally
     CloseFile(FListeMouvement);
     end;
end;

