procedure TFSFicheSaisie.BitOperationListeMouvementClick(Sender: TObject);
var  iMois,R,C,lLM,lDM,p,NbrNewArticle,NbrChargeArticle,PositionDetailMouvementBegin,PositionDetailMouvementEnd,RowEditing:integer;
     OKNumListeMouvement,OKMAJStockAOperer,OKDetailMouvementExiste,OKMiseAJour:boolean;  QteAOperer,PrixAOperer:real; SigneMouvementAOperer,SigneMouvementFormuleComposition,CodeStockConcerneSource,CodeStockConcerneCible,CodeArticleAOperer,TypeProces,FichierConserne,Adresse,TypeProcesNOM,FichierConserneNOM,AdresseNOM,RowSelectLM,NumLMSelect:string;
begin
     FSFicheSaisie.RapportMiseAJourStock.Lines.Add('Mise ŕ jou du stock: '+FSFicheSaisie.EditDesignationTypeMouvement.Text+', OrdreListeMouvement: '+FSFicheSaisie.EditOrdreListeMouvement.Text);
     FSFicheSaisie.RapportMiseAJourStock.Lines.Add('');

     FSFicheSaisie.AfficherOperationsListeMouvement.Visible:=false;

     iAnnee:=strtointeger(Lastlaters(datetostr(FSFicheSaisie.EditDateDetailMouvement.Date),4));

     TypeProces:='Business';   FichierConserne:='FListeMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
     end;

     ChListeMouvement:=IndiqueAdresseListeMouvement(FSFicheSaisie.EditPositionTypeMouvement.Text,TypeProcesReseauxListeMouvement);

     if(TypeProcesReseauxListeMouvement='Réseaux')then
     begin
          showmessage('Opération réseaux non autorisé !');
          Exit;
     end;

     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else Rewrite(FListeMouvement); //Création du fichier FListeMouvement
     Seek(FListeMouvement,0);
     OKNumListeMouvement:=false;
     lLM:=0;
     while not eof(FListeMouvement)and(OKNumListeMouvement=false)do
     begin
          read(FListeMouvement,RListeMouvement);
          if(RListeMouvement.OrdreListeMouvement=strtointeger(FSFicheSaisie.EditOrdreListeMouvement.Text))then OKNumListeMouvement:=true;
     lLM:=lLM+1;
     end;

     if(OKNumListeMouvement=true)then lLM:=lLM-1;       

     RListeMouvement.OrdreListeMouvement:=strtointeger(FSFicheSaisie.EditOrdreListeMouvement.Text);
     RListeMouvement.NumListeMouvement:=strtointeger(FSFicheSaisie.EditNumListeMouvement.Text);
     RListeMouvement.PositionTypeMouvement:=strtointeger(FSFicheSaisie.EditPositionTypeMouvement.Text);
     RListeMouvement.PositionMouvement:=strtointeger(FSFicheSaisie.EditPositionMouvement.Text);
     RListeMouvement.DateMouvement:=datetostr(FSFicheSaisie.EditDateDetailMouvement.Date);
     RListeMouvement.CodeTypeFormule:=FSFicheSaisie.EditCodeTypeFormuleAfficher.Text;
     RListeMouvement.TypeProces:=FSFicheSaisie.EditTypeProces.Text;
     RListeMouvement.FichierTiersConserne:=FSFicheSaisie.EditFunctionFichierConcerne.Text;
     RListeMouvement.CodeTiers:=FSFicheSaisie.EditCodeTiersConserne.Text;
     RListeMouvement.DataTiersSupplementaire:=FSFicheSaisie.EditDataTiersSupplementaire.Text;
     //if(RListeMouvement.PositionDetailMouvementBegin>0)and(RListeMouvement.PositionDetailMouvementEnd>0)
     //then
     RListeMouvement.MontantMouvement:=strtoreal(FSFicheSaisie.EditMontantMouvement.Text);
     RListeMouvement.NumProjetFinance:=FSFicheSaisie.EditNumProjet.Text;
     RListeMouvement.NumDomiciliation:=FSFicheSaisie.EditNumDomiciliation.Text;
     RListeMouvement.Domiciliation:=FSFicheSaisie.EditDomiciliation.Text;
     RListeMouvement.ModePaiement:=FSFicheSaisie.EditModePayement.Text;
     RListeMouvement.NumPiece:=FSFicheSaisie.EditNumPiece.Text;

     if(FSFicheSaisie.RBAvecDateExecution.Checked=true)then
     begin
          RListeMouvement.DateExecutionMouvement:=datetostr(FSFicheSaisie.EditDateExecutionMouvement.Date);
          RListeMouvement.OKExecution:=FSFicheSaisie.OKExecutionOui.Checked;
     end
     else
     begin
          RListeMouvement.DateExecutionMouvement:=datetostr(FSFicheSaisie.EditDateDetailMouvement.Date);
          RListeMouvement.OKExecution:=true;
     end;

     if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
     begin
          RListeMouvement.CodePaysExecutionMouvement:=FSFicheSaisie.EditCodePaysExecutionMouvement.Text;
          RListeMouvement.CodeWilayaExecutionMouvement:=FSFicheSaisie.EditCodeWilayaExecutionMouvement.Text;
          RListeMouvement.CodeDairaExecutionMouvement:=FSFicheSaisie.EditCodeDairaExecutionMouvement.Text;
          RListeMouvement.CodeCommuneExecutionMouvement:=FSFicheSaisie.EditCodeCommuneExecutionMouvement.Text;
          RListeMouvement.CodeZoneExecutionMouvement:=FSFicheSaisie.EditCodeZoneExecutionMouvement.Text;
          RListeMouvement.AdresseExecutionMouvement:=FSFicheSaisie.EditAdresseExecutionMouvement.Text;
     end
     else
     begin
          RListeMouvement.CodePaysExecutionMouvement:='';
          RListeMouvement.CodeWilayaExecutionMouvement:='';
          RListeMouvement.CodeDairaExecutionMouvement:='';
          RListeMouvement.CodeCommuneExecutionMouvement:='';
          RListeMouvement.CodeZoneExecutionMouvement:='';
          RListeMouvement.AdresseExecutionMouvement:='';
     end;

     if(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text<>'')
     then RListeMouvement.AdresseExecutionMouvement:=FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text;

     RListeMouvement.OrdreListeMouvementAppartenant:=FSFicheSaisie.EditOrdreListeMouvementAppartenantSauvgarde.Text;
     RListeMouvement.ListeNumAvis:=FSFicheSaisie.EditNumAvis.Text;
     RListeMouvement.SourceName:=FSFicheSaisie.EditSourceName.Text;
     RListeMouvement.DataSourceName:=FSFicheSaisie.EditDataSourceName.Text;
     RListeMouvement.ReferenceSourceListeMouvement:=FSFicheSaisie.EditReferenceListeMouvement.Text;
     RListeMouvement.ValidationListeMouvement:=FSFicheSaisie.RBListeMouvementMaintenue.Checked;
     RListeMouvement.CodeUtilisateur:=FSMenuPrincipal.EditCodeUtilisateur.Text;

     if(FSFicheSaisie.RBChercheArticleParPontBascule.Checked=true)and(FSFicheSaisie.EditOrdreListeMouvementPontBascule.Text=FSFicheSaisie.EditOrdreListeMouvement.Text)then
     begin
           RListeMouvement.MatriculeResponsablePrelevement:=FSFicheSaisie.EditMatriculePontBascule.Text;
           RListeMouvement.TypeVehiculePrelevement:=FSFicheSaisie.EditTypeVehiculePrelevement.Text;
           RListeMouvement.TonageVehiculePrelevement:=FSFicheSaisie.EditTonageVehiculePrelevement.Text;
           RListeMouvement.CodeResponsablePrelevement:=FSFicheSaisie.EditCodeResponsablePrelevement.Text;
           RListeMouvement.NomResponsablePrelevement:=FSFicheSaisie.EditNomResponsablePrelevement.Text;
           RListeMouvement.PrenomResponsablePrelevement:=FSFicheSaisie.EditPrenomResponsablePrelevement.Text;
           RListeMouvement.IndiceInialPontBascule:=strtoreal(FSFicheSaisie.EditIndiceInialPontBascule.Text);
           RListeMouvement.IndiceFinalPontBascule:=strtoreal(FSFicheSaisie.EditIndiceFinalPontBascule.Text);
           RListeMouvement.DateIndiceInial:=FSFicheSaisie.EditDateIndiceInitial.Text;
           RListeMouvement.HeureIndiceInial:=FSFicheSaisie.EditHeureIndiceInitial.Text;

           if(RListeMouvement.IndiceFinalPontBascule<>0)then
           begin
                RListeMouvement.DateIndiceFinal:=datetostr(FSFicheSaisie.EditDateIndiceFinal.Date);
                RListeMouvement.HeureIndiceFinal:=timetostr(FSFicheSaisie.EditHeureIndiceFinal.Time);
           end
           else
           begin
                RListeMouvement.DateIndiceFinal:='';
                RListeMouvement.HeureIndiceFinal:='';
           end;

           RListeMouvement.NumeroPont:=FSFicheSaisie.EditNumeroPont.Text;
     end
     else
     begin
           RListeMouvement.MatriculeResponsablePrelevement:='';
           RListeMouvement.TypeVehiculePrelevement:='';
           RListeMouvement.TonageVehiculePrelevement:='';
           RListeMouvement.CodeResponsablePrelevement:='';
           RListeMouvement.NomResponsablePrelevement:='';
           RListeMouvement.PrenomResponsablePrelevement:='';
           RListeMouvement.IndiceInialPontBascule:=0;
           RListeMouvement.IndiceFinalPontBascule:=0;
           RListeMouvement.DateIndiceInial:=datetostr(Date);
           RListeMouvement.HeureIndiceInial:=timetostr(Time);
           RListeMouvement.DateIndiceFinal:=datetostr(Date);
           RListeMouvement.HeureIndiceFinal:=timetostr(Time);
     end;
     //-----------------------------suivra ! '' enregistrement liste mouvement ''-------------

     if(RListeMouvement.PositionDetailMouvementBegin<>-1)and(RListeMouvement.PositionDetailMouvementEnd<>-1)then
     begin
           TypeProces:='Business';   FichierConserne:=FSFicheSaisie.EditCodeTypeFormuleBase.Text;
