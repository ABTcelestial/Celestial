                    end;

                    if(TableauDetaiMouvement.Cells[C,3]='%')then
                    begin
                         TableauDetaiMouvement.Cells[C,Row]:=Vergule(floattostr(strtoreal(TableauDetaiMouvement.Cells[C,Row])*100),'0','C','')+'%';
                    end;

               C:=C+1;
               end;
          end;
     end;
     finally
     Closefile(FDetailMouvement);
     end;

     if(Row>0)then TableauDetaiMouvement.RowCount:=Row+1
               else
               begin
                    TableauDetaiMouvement.RowCount:=2;
                    TableauDetaiMouvement.Rows[1].Text:='';
               end;
     TrierTableauACol(TableauDetaiMouvement,11,0,0,'Num');
     AjusterColWidth(TableauDetaiMouvement,'','');
end;

procedure TFSFicheSaisie.BitBtn15Click(Sender: TObject);
var  i,l,CMontant:integer;  OKDetailMouvement:boolean;    ListePositionDetailMouvement:string;
begin
     FSFicheSaisie.EditListeDetailMouvement.Text:='';
     ListePositionDetailMouvement:='';
     i:=1;
     while(i<=FSFicheSaisie.TableauDetaiMouvementFichierCible.RowCount-1)do
     begin
          l:=1;
          OKDetailMouvement:=false;
          while(l<=FSFicheSaisie.TableauDetaiMouvementFichierDistination.RowCount-1)and(OKDetailMouvement=false)do
          begin
               if(FSFicheSaisie.TableauDetaiMouvementFichierCible.Cells[2,i]=FSFicheSaisie.TableauDetaiMouvementFichierDistination.Cells[2,l])
               and(FSFicheSaisie.TableauDetaiMouvementFichierCible.Cells[3,i]=FSFicheSaisie.TableauDetaiMouvementFichierDistination.Cells[3,l])
               and(FSFicheSaisie.TableauDetaiMouvementFichierCible.Cells[8,i]=FSFicheSaisie.TableauDetaiMouvementFichierDistination.Cells[8,l])
               and(FSFicheSaisie.TableauDetaiMouvementFichierCible.Cells[9,i]=FSFicheSaisie.TableauDetaiMouvementFichierDistination.Cells[9,l])
               then
               begin
                    OKDetailMouvement:=true;
                    if(ListePositionDetailMouvement='')
                    then ListePositionDetailMouvement:=FSFicheSaisie.TableauDetaiMouvementFichierCible.Cells[0,i]
                    else ListePositionDetailMouvement:=ListePositionDetailMouvement+';'+FSFicheSaisie.TableauDetaiMouvementFichierCible.Cells[0,i];
               end;
          l:=l+1;
          end;
     i:=i+1;
     end;

     FSFicheSaisie.EditListeDetailMouvement.Text:=ListePositionDetailMouvement;

     ChDetailMouvement:=FSFicheSaisie.EditAdresseFichierDistination.Text;
     assignfile(FDetailMouvement,ChDetailMouvement);
     if FileExists(ChDetailMouvement)then
     begin
          try
          Reset(FDetailMouvement);
          Seek(FDetailMouvement,0);
          i:=0;
          while not eof(FDetailMouvement)do
          begin
               read(FDetailMouvement,RDetailMouvement);
               i:=i+1;
          end;

          ChDetailMouvementCopie:=FSFicheSaisie.EditAdresseFichierCible.Text;
          assignfile(FDetailMouvementCopie,ChDetailMouvementCopie);
          if FileExists(ChDetailMouvementCopie)then
          begin
               try
               Reset(FDetailMouvementCopie);
               Seek(FDetailMouvementCopie,0);
               l:=0;
               while not eof(FDetailMouvementCopie)do
               begin
                    read(FDetailMouvementCopie,RDetailMouvementCopie);
                    if(Not(ExisteNuminTexte(inttostr(RDetailMouvementCopie.PositionDetailMouvement),FSFicheSaisie.EditListeDetailMouvement.Text)))
                    and(RDetailMouvementCopie.ValidationDetailMouvement=true)
                    and(DateCorrecte(RDetailMouvementCopie.DateMouvement))
                    and(RDetailMouvementCopie.Quantite<>0)
                    and(RDetailMouvementCopie.PrixUnitaire<>0)then
                    begin
                         Seek(FDetailMouvement,i);
                         write(FDetailMouvement,RDetailMouvementCopie);
                         i:=i+1;

                         Seek(FDetailMouvementCopie,l);
                         RDetailMouvementCopie.ValidationDetailMouvement:=false;
                         write(FDetailMouvementCopie,RDetailMouvementCopie);
                    end;
                    l:=l+1;
               end;
               finally
               CloseFile(FDetailMouvementCopie);
               end;
          end
          else Affichermessage('le fichier distination '+ChDetailMouvementCopie+' n''éxiste pas !');

          Seek(FDetailMouvement,0);
          i:=0;
          while not eof(FDetailMouvement)do
          begin
               read(FDetailMouvement,RDetailMouvement);
               RDetailMouvement.PositionDetailMouvement:=i;
               RDetailMouvement.NumDetailMouvement:=i;
               Seek(FDetailMouvement,i);
               write(FDetailMouvement,RDetailMouvement);
               i:=i+1;
          end;
          finally
          CloseFile(FDetailMouvement);
          end;
     end
     else Affichermessage('le fichier distination '+ChDetailMouvement+' n''éxiste pas !');

     ProceAfficheDetailMouvementFichierCible(TableauFormules,TableauVariable,TableauDetaiMouvementFichierCible,'',FSFicheSaisie.EditValidationDetailMouvement.Text,FSFicheSaisie.RBDetailMouvementAfficher.Checked,FSFicheSaisie.EditAdresseFichierCible.Text,CMontant);
     ProceAfficheDetailMouvementFichierCible(TableauFormules,TableauVariable,TableauDetaiMouvementFichierDistination,'',FSFicheSaisie.EditValidationDetailMouvement.Text,FSFicheSaisie.RBDetailMouvementAfficher.Checked,FSFicheSaisie.EditAdresseFichierDistination.Text,CMontant);
end;

