          R:=0;
          while(R<=FSFicheSaisie.TableauListeMouvement.RowCount-1)do
          begin
               FSFicheSaisie.TableauListeMouvementTransformation.Rows[R].Text:=FSFicheSaisie.TableauListeMouvement.Rows[R].Text;
               FSFicheSaisie.TableauListeMouvementTransformation.Cells[0,R]:='';
          R:=R+1;
          end;

          ProcListeTypeMouvement(FSFicheSaisie.TableauTypeMouvementTransformation);
          ProcListeMouvement(FSFicheSaisie.TableauMouvementTransformation,FSFicheSaisie.TableauTypeMouvementTransformation.Cells[1,FSFicheSaisie.TableauTypeMouvementTransformation.Row],'','','');

          R:=0;
          while(R<=FSFicheSaisie.TableauTypeMouvementTransformation.RowCount-1)do
          begin
               if(FSFicheSaisie.TableauTypeMouvementTransformation.Cells[1,R]=FSFicheSaisie.TableauListeMouvementTransformation.Cells[3,1])then
               begin
                    RowTypeMouvement:=R;
                    FSFicheSaisie.TableauTypeMouvementTransformation.Cells[0,R]:='OK';
               end
               else FSFicheSaisie.TableauTypeMouvementTransformation.Cells[0,R]:='';
          R:=R+1;
          end;
          FSFicheSaisie.TableauTypeMouvementTransformation.Row:=RowTypeMouvement;
          FSFicheSaisie.EditPositionTypeMouvementTransformation.Text:=FSFicheSaisie.TableauTypeMouvementTransformation.Cells[1,RowTypeMouvement];

          R:=0;
          while(R<=FSFicheSaisie.TableauMouvementTransformation.RowCount-1)do
          begin
               if(FSFicheSaisie.TableauMouvementTransformation.Cells[1,R]=FSFicheSaisie.TableauListeMouvementTransformation.Cells[4,1])then
               begin
                    RowTypeMouvement:=R;
                    FSFicheSaisie.TableauMouvementTransformation.Cells[0,R]:='OK';
               end
               else FSFicheSaisie.TableauMouvementTransformation.Cells[0,R]:='';
          R:=R+1;
          end;

          FSFicheSaisie.TableauMouvementTransformation.Row:=RowTypeMouvement;
          FSFicheSaisie.EditPositionMouvementTransformation.Text:=FSFicheSaisie.TableauMouvementTransformation.Cells[1,RowTypeMouvement];
     end;

     if(FSFicheSaisie.EditCodeAutorisation.Text='12345')then
     begin
          FSFicheSaisie.RBActiverAutorisationsManipulations.Checked:=false;
          FSFicheSaisie.EditCodeAutorisation.Text:='';

          showmessage('Les manipulations sont autorisées !');
     end;
end;

