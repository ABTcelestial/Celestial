Procedure RemplireAvisPrMouvement(OrdreListeMounement,NumAvis,BaseAvis:string);
var   i:integer;    TypeProces,FichierConserne,Adresse:string;
begin
     TypeProces:='Business';   FichierConserne:='FListeMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
     end;

     RListeMouvement:=chercherListeMouvement(inttostr(RListeMouvement.PositionTypeMouvement),OrdreListeMounement);

     ChListeMouvement:=IndiqueAdresseListeMouvement(inttostr(RListeMouvement.PositionTypeMouvement),TypeProcesReseauxListeMouvement);
     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
     Seek(FListeMouvement,0);
     i:=0;
     while not eof(FListeMouvement)do
     begin
          read(FListeMouvement,RListeMouvement);
          if Existenumintexte(inttostr(RListeMouvement.OrdreListeMouvement),OrdreListeMounement)then
          begin
               Seek(FListeMouvement,i);

               if(RListeMouvement.ListeNumAvis='')then
               begin
                    RListeMouvement.ListeNumAvis:='{'+BaseAvis+'}'+NumAvis;
               end
               else
               begin
                    if not(ExisteNumAvisinTexte(BaseAvis,NumAvis,RListeMouvement.ListeNumAvis))
                    then RListeMouvement.ListeNumAvis:='{'+BaseAvis+'}'+NumAvis;
               end;

               write(FListeMouvement,RListeMouvement);
          end;
     i:=i+1;
     end;
     finally
     CloseFile(FListeMouvement);
     end;
end;

