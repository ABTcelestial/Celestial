if(TypeProces='Social')then
begin
     if FileExists(Adresse)then
     begin
          assignfile(FEmploye,Adresse);
          try
          reset(FEmploye);
          Seek(FEmploye,0);
          OKTiers:=false;
          NewCodeTiersSupplementaire:=1;
          i:=0;
          while not eof(FEmploye)and(OKTiers=false)do
          begin
               Read(FEmploye,REmploye);

               if(NewCodeTiersSupplementaire<=REmploye.NSerie)then NewCodeTiersSupplementaire:=REmploye.NSerie+1;

               if(NomTiersSupplementaire<>'')then
               begin
                    if(REmploye.Nom=NomTiersSupplementaire)then
                    begin
                         OKTiers:=true;
