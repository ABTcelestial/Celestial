                           QteAOperer:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R]);
                           PrixAOperer:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[7,R]);
                      end;
