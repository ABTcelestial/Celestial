Procedure ProcSauvegarderDetailMouvementSelect;
var R:integer;
begin
     FSFicheSaisie.Sauvegarder.FileName:='SauvegardeDetailMouvement';
     if(FSFicheSaisie.Sauvegarder.Execute)then
     begin
          ChSauvegardeDetailMouvement:=FSFicheSaisie.Sauvegarder.FileName;
          assignfile(FSauvegardeDetailMouvement,ChSauvegardeDetailMouvement);
          try
          Rewrite(FSauvegardeDetailMouvement);
          Seek(FSauvegardeDetailMouvement,0);
          Truncate(FSauvegardeDetailMouvement);

          R:=6;
          While R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1 do
          begin
               RSauvegardeDetailMouvement.CodeArticle:=FSFicheSaisie.TableauDetaiMouvement.Cells[1,R];
               RSauvegardeDetailMouvement.DesignationArticle:=FSFicheSaisie.TableauDetaiMouvement.Cells[2,R];
               RSauvegardeDetailMouvement.ReferenceArticle:=FSFicheSaisie.TableauDetaiMouvement.Cells[3,R];
               RSauvegardeDetailMouvement.UMArticle:=FSFicheSaisie.TableauDetaiMouvement.Cells[4,R];
               RSauvegardeDetailMouvement.CoutUnitaireArticle:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[5,R]);
               RSauvegardeDetailMouvement.Quantite:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[6,R]);
               RSauvegardeDetailMouvement.PrixUnitaire:=strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[7,R]);

               Seek(FSauvegardeDetailMouvement,R-6);
               Write(FSauvegardeDetailMouvement,RSauvegardeDetailMouvement);

          R:=R+1;
          end;
          finally
          CloseFile(FSauvegardeDetailMouvement);
          end;
     end;
end;

Procedure ProcImporterDetailMouvementSelect;
var R:integer;
begin
     FSFicheSaisie.OuvrirUnFichier.FileName:='SauvegardeDetailMouvement';
     if(FSFicheSaisie.OuvrirUnFichier.Execute)then
     begin
          ChSauvegardeDetailMouvement:=FSFicheSaisie.OuvrirUnFichier.FileName;
          assignfile(FSauvegardeDetailMouvement,ChSauvegardeDetailMouvement);
          if FileExists(ChSauvegardeDetailMouvement)then
          begin
               try
               Reset(FSauvegardeDetailMouvement);
               Seek(FSauvegardeDetailMouvement,0);
               R:=1;
               while not eof(FSauvegardeDetailMouvement)do
               begin
                    read(FSauvegardeDetailMouvement,RSauvegardeDetailMouvement); Application.ProcessMessages;

                    FSFicheSaisie.TableauDetaiMouvement.Rows[R+5].Text:='';
                    FSFicheSaisie.TableauDetaiMouvement.Cells[1,R+5]:=RSauvegardeDetailMouvement.CodeArticle;
                    FSFicheSaisie.TableauDetaiMouvement.Cells[2,R+5]:=RSauvegardeDetailMouvement.DesignationArticle;
                    FSFicheSaisie.TableauDetaiMouvement.Cells[3,R+5]:=RSauvegardeDetailMouvement.ReferenceArticle;
                    FSFicheSaisie.TableauDetaiMouvement.Cells[4,R+5]:=RSauvegardeDetailMouvement.UMArticle;
                    FSFicheSaisie.TableauDetaiMouvement.Cells[5,R+5]:=Floattostr(RSauvegardeDetailMouvement.CoutUnitaireArticle);
                    FSFicheSaisie.TableauDetaiMouvement.Cells[6,R+5]:=Floattostr(RSauvegardeDetailMouvement.Quantite);
                    FSFicheSaisie.TableauDetaiMouvement.Cells[7,R+5]:=Floattostr(RSauvegardeDetailMouvement.PrixUnitaire);
               R:=R+1;
               end;
               FSFicheSaisie.TableauDetaiMouvement.RowCount:=R+5;

               R:=6;
               while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
               begin
                    ///******************************************************************************
                    CalculeFicheSaisie(FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable,FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.EditModePayement.Text,FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,R,FSFicheSaisie.EditCodeTypeFormuleAfficher,true);
                    ///******************************************************************************
               R:=R+1;
               end;

               AfficherRecapeFicheSaisie(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.EditChiffreEnLettres,FSFicheSaisie.EditTitreChiffreEnLettres,FSFicheSaisie.EditMontantMouvement);
               FSFicheSaisie.TableauDetaiMouvement.SetFocus;

          finally
          CloseFile(FSauvegardeDetailMouvement);
          end;
          end;
     end;
end;

