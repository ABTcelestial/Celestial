           FSFicheSaisie.EditNumAvis.Text:=FSFicheSaisie.EditNumAvisAppartenanceMouvement.Text;

           FSFicheSaisie.AfficheListeAppartenanceMouvement.Visible:=false;
     end
     else
     begin
          showmessage('Aucune séléction !');
          FSFicheSaisie.TableauListeAppartenanceMouvement.SetFocus;
     end;
end;

Procedure CalculeAutoAppartenanceMouvement(TableauListeAppartenanceMouvement,TableauDetaiMouvementAppartenanceMouvemant,TableauRecapitulatifDetailMouvements,TableauPositionMouvement:TStringGrid; ExerciceSource,ListeOrdreListeMouvement,DebitCreditPositif,NbrChiffreApresVerguleQuantite,NbrChiffreApresVergulePrix,NbrChiffreApresVerguleCout,DateDebutLM,DateFinLM:string; EditOrdreListeMouvementAppartenant:TEdit; ColSelect,ColDate,NbrRowIn:integer; var NbrRowOut:integer);
var  iCAAM,RCAAM,CCAAM,lCAAM,mCAAM,PBeginDM,PEndDM,IDM,PBeginLM,PEndLM,PLM:integer;
     NotRow,NotCol,TypeProcesInt,FichierConcerneInt,Adresse,TypeProcess:string;
     OKDetailMouvementCAAM,OKTiersCAAM,OKExisteNum:boolean;
     CoutAnterieur,CoutActuel,PrixAnterieur,PrixActuel,QuantiteAnterieur,QuantiteActuelle,Solde:real;
     TableauPointeurData:TableauPointeurDatas;
     SigneDebitCredit:integer;
     TListeMouvementPointeur:TListeMouvements;
     TRegistreListeNum:TRegistreListeNums;
     i,Taille:integer;
begin
     for lCAAM:=1 to NbrRowIn do
     begin
          setlength(TableauPointeurData,lCAAM);
          TableauPointeurData[lCAAM-1].Data1:=TableauDetaiMouvementAppartenanceMouvemant.Cells[1,lCAAM];
          TableauPointeurData[lCAAM-1].RowPointeur:=lCAAM;
     end;

     RCAAM:=1;
     OKTiersCAAM:=false;
     while(RCAAM<=TableauListeAppartenanceMouvement.RowCount-1)and(OKTiersCAAM=false)do
     begin
          if(TableauListeAppartenanceMouvement.Cells[ColSelect,RCAAM]='OK')
          and(Lastlaters(TableauListeAppartenanceMouvement.Cells[ColDate,RCAAM],4)=ExerciceSource)
          then OKTiersCAAM:=true;
     RCAAM:=RCAAM+1;
     end;

     if(OKTiersCAAM=false)then
     begin
          FSAvis.EditCodeTiersTeste.Text:='';
          FSAvis.EditTiersTeste.Text:='';
     end;

     if(NbrRowIn=0)then
     begin
           TableauDetaiMouvementAppartenanceMouvemant.ColCount:=23;
           TableauDetaiMouvementAppartenanceMouvemant.Cols[0].Text:='N°';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[1].Text:='Code Article';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[2].Text:='Article';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[3].Text:='Réf';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[4].Text:='U.M';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[5].Text:='Coűt U.';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[6].Text:='Quantité';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[7].Text:='Prix U.';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[8].Text:='Montant';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[9].Text:='P°';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[10].Text:='N°Prel.UF';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[11].Text:='N°Prel';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[12].Text:='N°Equipe';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[13].Text:='Matricule';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[14].Text:='Date';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[15].Text:='Heure';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[16].Text:='Type Preces';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[17].Text:='Fichier Concerne';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[18].Text:='Code Tires';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[19].Text:='Tiers';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[20].Text:='Coűt total';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[21].Text:='Valeur Ajouter';
           TableauDetaiMouvementAppartenanceMouvemant.Cols[22].Text:='Ord.Liste Mouvement';
           TableauDetaiMouvementAppartenanceMouvemant.RowCount:=2;
           TableauDetaiMouvementAppartenanceMouvemant.Rows[1].Text:='';

           AjusterColWidth(TableauDetaiMouvementAppartenanceMouvemant,'','');

           TableauRecapitulatifDetailMouvements.ColCount:=9;
           TableauRecapitulatifDetailMouvements.Cols[0].Text:='N°';
           TableauRecapitulatifDetailMouvements.Cols[1].Text:='Code Article';
           TableauRecapitulatifDetailMouvements.Cols[2].Text:='Article';
           TableauRecapitulatifDetailMouvements.Cols[3].Text:='Réf';
           TableauRecapitulatifDetailMouvements.Cols[4].Text:='U.M';
           TableauRecapitulatifDetailMouvements.Cols[5].Text:='Quantité';
           TableauRecapitulatifDetailMouvements.Cols[6].Text:='Prix U.';
           TableauRecapitulatifDetailMouvements.Cols[7].Text:='Montant Débit';
           TableauRecapitulatifDetailMouvements.Cols[8].Text:='Montant Crédit';

           TableauRecapitulatifDetailMouvements.RowCount:=2;
           TableauRecapitulatifDetailMouvements.Rows[1].Text:='';

           AjusterColWidth(TableauRecapitulatifDetailMouvements,'','');
     end;

     FSTraitementDonnees.Rapport.Lines.Add('Cargement Type mouvement');

     TTypeMouvementCopie:=RemplireTTypeMouvement;
     TMouvementCopie:=RemplireTMouvement('');

     iCAAM:=1;
     lCAAM:=NbrRowIn;
     while(iCAAM<=TableauPositionMouvement.RowCount-1)do
     begin
          IndiquerPositionListeMouvementPeriodique(inttostr(TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].PositionTypeMouvement),inttostr(TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].PositionMouvement),TypeProcess,DateDebutLM,DateFinLM,PBeginLM,PEndLM);

          FSTraitementDonnees.Rapport.Lines.Add('Chargement: '+TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].DesignationMouvement+', PBeginLM: '+inttostr(PBeginLM)+', PEndLM:'+inttostr(PEndLM));

          TListeMouvementPointeur:=RemplireTListeMouvement(inttostr(TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].PositionTypeMouvement),ExerciceSource,PBeginLM,PEndLM,PBeginDM,PEndDM);
          ExisteNuminTexteSpecial(ListeOrdreListeMouvement,TRegistreListeNum,Taille);

          if(TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].DebitCredit=DebitCreditPositif)then
          begin
               SigneDebitCredit:=1;
          end
          else
          begin
               SigneDebitCredit:=-1;
          end;

          IndiquerPositionDetailMouvementGroupeListeMouvement(ListeOrdreListeMouvement,PBeginLM,PEndLM,PBeginDM,PEndDM);

          FSTraitementDonnees.Rapport.Lines.Add('Début traitement '+'DétailMouvement '+TTypeMouvementCopie[TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].PositionTypeMouvement].DesignationTypeMouvement+', PBeginDM:'+inttostr(PBeginDM)+', PEndDM:'+inttostr(PEndDM));

          TypeProcesInt:='Business';
          FichierConcerneInt:='DétailMouvement '+TTypeMouvementCopie[TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].PositionTypeMouvement].DesignationTypeMouvement;
          Adresse:='';
          if not(FunctionAdresseProces(TypeProcesInt,FichierConcerneInt,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerneInt+' recherché !');
          end; 

          PBeginDM:=0;
          PEndDM:=999999999;

          ChDetailMouvement:=ConvertirAdresseExerciceAnnee(Adresse,ExerciceAnnee,ExerciceSource);

          assignfile(FDetailMouvement,ChDetailMouvement);
          try
          if FileExists(ChDetailMouvement)then
          Reset(FDetailMouvement)
          else begin affichermessage('Attention ! {'+ChDetailMouvement+'} n''existe pas !'); exit; end;//Rewrite(FDetailMouvement);
          IDM:=PBeginDM;
          Seek(FDetailMouvement,PBeginDM);
          while not eof(FDetailMouvement)and(IDM<=PEndDM)do
          begin
               read(FDetailMouvement,RDetailMouvement);  Application.ProcessMessages;  if(FSTraitementDonnees.RBSuspendreTBohr.Checked)then Exit;
               IDM:=IDM+1;

               CoutAnterieur:=0;
               CoutActuel:=0;
               PrixAnterieur:=0;
               PrixActuel:=0;
               QuantiteAnterieur:=0;
               QuantiteActuelle:=0;

               OKExisteNum:=false;
               i:=0;
               while(i<Taille)and(OKExisteNum=false)do
               begin
                    if(TRegistreListeNum[i]=RDetailMouvement.OrdreListeMouvement)then OKExisteNum:=true;
               i:=i+1;
               end;

               if(RDetailMouvement.ValidationDetailMouvement=true)
               and(RDetailMouvement.OrdreListeMouvement<=High(TListeMouvementPointeur))
               and(TListeMouvementPointeur[RDetailMouvement.OrdreListeMouvement].PositionMouvement=strtointeger(TableauPositionMouvement.Cells[0,iCAAM]))
               and(OKExisteNum=true)
               then
               begin
               
                         mCAAM:=1;
                         OKDetailMouvementCAAM:=false;
                         while(mCAAM<=lCAAM)and(OKDetailMouvementCAAM=false)do
                         begin
                              Application.ProcessMessages;  if(FSTraitementDonnees.RBSuspendreTBohr.Checked)then Exit;

                              if(RDetailMouvement.CodeArticle=TableauPointeurData[mCAAM-1].Data1)then
                              begin
                                   mCAAM:=TableauPointeurData[mCAAM-1].RowPointeur;
                                   OKDetailMouvementCAAM:=true;
                                   FSTraitementDonnees.Rapport.Lines.Add('Mise ŕ jour Appartenance Détail Mouvement N° '+inttostr(RDetailMouvement.NumDetailMouvement)+' : '+'{Qte: '+floattostr(RDetailMouvement.Quantite)+' '+RDetailMouvement.UMArticle+'} '+RDetailMouvement.CodeArticle+' '+RDetailMouvement.DesignationArticle+' '+RDetailMouvement.ReferenceArticle+' Ordre LM: '+inttostr(RDetailMouvement.OrdreListeMouvement));

                                   CoutAnterieur:=strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[5,mCAAM]);
                                   CoutActuel:=RDetailMouvement.CoutUnitaireArticle;
                                   PrixAnterieur:=strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[7,mCAAM]);
                                   PrixActuel:=RDetailMouvement.PrixUnitaire;
                                   QuantiteAnterieur:=strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,mCAAM]);
                                   QuantiteActuelle:=RDetailMouvement.Quantite*SigneDebitCredit;

                                   if((QuantiteAnterieur<>0)or(QuantiteActuelle<>0))then
                                   begin
                                        if((QuantiteAnterieur+QuantiteActuelle)<>0)then
                                        begin
                                             TableauDetaiMouvementAppartenanceMouvemant.Cells[5,mCAAM]:=floattostr(((CoutAnterieur*QuantiteAnterieur)+
                                                                                                                     (CoutActuel*QuantiteActuelle))/
                                                                                                                     (QuantiteAnterieur+QuantiteActuelle));

                                             TableauDetaiMouvementAppartenanceMouvemant.Cells[7,mCAAM]:=floattostr(((PrixAnterieur*QuantiteAnterieur)+
                                                                                                                     (PrixActuel*QuantiteActuelle))/
                                                                                                                     (QuantiteAnterieur+QuantiteActuelle));
                                        end
                                        else
                                        begin
                                             if(QuantiteAnterieur>0)then
                                             begin
                                                  TableauDetaiMouvementAppartenanceMouvemant.Cells[5,mCAAM]:=floattostr(CoutAnterieur);
                                                  TableauDetaiMouvementAppartenanceMouvemant.Cells[7,mCAAM]:=floattostr(PrixAnterieur);
                                             end
                                             else
                                             if(QuantiteActuelle>0)then
                                             begin
                                                  TableauDetaiMouvementAppartenanceMouvemant.Cells[5,mCAAM]:=floattostr(CoutActuel);
                                                  TableauDetaiMouvementAppartenanceMouvemant.Cells[7,mCAAM]:=floattostr(PrixActuel);
                                             end;
                                        end;

                                        TableauDetaiMouvementAppartenanceMouvemant.Cells[6,mCAAM]:=floattostr(QuantiteAnterieur+QuantiteActuelle);
                                   end;

                                   if(not ExisteNumIntexte(inttostr(RDetailMouvement.OrdreListeMouvement),TableauDetaiMouvementAppartenanceMouvemant.Cells[22,mCAAM]))
                                   then TableauDetaiMouvementAppartenanceMouvemant.Cells[22,mCAAM]:=TableauDetaiMouvementAppartenanceMouvemant.Cells[22,mCAAM]+';'+inttostr(RDetailMouvement.OrdreListeMouvement);

                                   /////////////////////////////////////////////
                                   TableauRecapitulatifDetailMouvements.Cells[5,mCAAM]:=floattostr(strtoreal(TableauRecapitulatifDetailMouvements.Cells[5,mCAAM])+RDetailMouvement.Quantite);
                                   TableauRecapitulatifDetailMouvements.Cells[6,mCAAM]:=floattostr(PrixActuel);
                                   if(SigneDebitCredit=1)
                                   then TableauRecapitulatifDetailMouvements.Cells[7,mCAAM]:=floattostr(strtoreal(TableauRecapitulatifDetailMouvements.Cells[5,mCAAM])*strtoreal(TableauRecapitulatifDetailMouvements.Cells[6,mCAAM]))
                                   else TableauRecapitulatifDetailMouvements.Cells[8,mCAAM]:=floattostr(strtoreal(TableauRecapitulatifDetailMouvements.Cells[5,mCAAM])*strtoreal(TableauRecapitulatifDetailMouvements.Cells[6,mCAAM]));
                                   /////////////////////////////////////////////
                              end;
                              mCAAM:=mCAAM+1;
                         LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
                         end;

                         if(OKDetailMouvementCAAM=false)then
                         begin
                              QuantiteActuelle:=RDetailMouvement.Quantite*SigneDebitCredit;

                              lCAAM:=lCAAM+1;
                              TableauDetaiMouvementAppartenanceMouvemant.Rows[lCAAM].Text:=inttostr(lCAAM);
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[1,lCAAM]:=RDetailMouvement.CodeArticle;
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[2,lCAAM]:=RDetailMouvement.DesignationArticle;
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[3,lCAAM]:=RDetailMouvement.ReferenceArticle;
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[4,lCAAM]:=RDetailMouvement.UMArticle;
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[5,lCAAM]:=floattostr(RDetailMouvement.CoutUnitaireArticle);
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[6,lCAAM]:=floattostr(QuantiteActuelle);
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[7,lCAAM]:=floattostr(RDetailMouvement.PrixUnitaire);

                              TableauDetaiMouvementAppartenanceMouvemant.Cells[20,lCAAM]:='';
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[21,lCAAM]:='';
                              TableauDetaiMouvementAppartenanceMouvemant.Cells[22,mCAAM]:=inttostr(RDetailMouvement.OrdreListeMouvement);

                              //////////////////////////////////////////////////
                              TableauRecapitulatifDetailMouvements.Rows[lCAAM].Text:=inttostr(lCAAM);
                              TableauRecapitulatifDetailMouvements.Cells[1,lCAAM]:=RDetailMouvement.CodeArticle;
                              TableauRecapitulatifDetailMouvements.Cells[2,lCAAM]:=RDetailMouvement.DesignationArticle;
                              TableauRecapitulatifDetailMouvements.Cells[3,lCAAM]:=RDetailMouvement.ReferenceArticle;
                              TableauRecapitulatifDetailMouvements.Cells[4,lCAAM]:=RDetailMouvement.UMArticle;
                              TableauRecapitulatifDetailMouvements.Cells[5,lCAAM]:=floattostr(RDetailMouvement.Quantite);
                              TableauRecapitulatifDetailMouvements.Cells[6,lCAAM]:=floattostr(RDetailMouvement.PrixUnitaire);
                              if(SigneDebitCredit=1)
                              then TableauRecapitulatifDetailMouvements.Cells[7,lCAAM]:=floattostr(RDetailMouvement.Quantite*RDetailMouvement.PrixUnitaire)
                              else TableauRecapitulatifDetailMouvements.Cells[8,lCAAM]:=floattostr(RDetailMouvement.Quantite*RDetailMouvement.PrixUnitaire);
                              //////////////////////////////////////////////////

                              FSTraitementDonnees.Rapport.Lines.Add('Nouvel ..... Appartenance Détail Mouvement N° '+inttostr(RDetailMouvement.NumDetailMouvement)+' du '+RDetailMouvement.DateMouvement+' : '+'{Qte: '+floattostr(RDetailMouvement.Quantite)+' '+RDetailMouvement.UMArticle+'} '+RDetailMouvement.CodeArticle+' '+RDetailMouvement.DesignationArticle+' '+RDetailMouvement.ReferenceArticle);

                              setlength(TableauPointeurData,lCAAM);
                              TableauPointeurData[lCAAM-1].Data1:=RDetailMouvement.CodeArticle;
                              TableauPointeurData[lCAAM-1].RowPointeur:=lCAAM;

                              FSTraitementDonnees.RapportTraitementMouvements.Lines.Add('Détail mouvement N° '+inttostr(RDetailMouvement.NumDetailMouvement)+' : '+RDetailMouvement.CodeArticle+' '+RDetailMouvement.DesignationArticle+' '+RDetailMouvement.ReferenceArticle);
                         end;
               end;
          end;
          finally
          CloseFile(FDetailMouvement);
          end;

          FSTraitementDonnees.Rapport.Lines.Add('Fin de Chargement: '+TMouvementCopie[strtointeger(TableauPositionMouvement.Cells[0,iCAAM])].DesignationMouvement+', PBeginLM: '+inttostr(PBeginLM)+', PEndLM:'+inttostr(PEndLM));

          iCAAM:=iCAAM+1;
     LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);
     end;

     if(lCAAM>0)then
     begin
          TableauDetaiMouvementAppartenanceMouvemant.RowCount:=lCAAM+3;
          TableauRecapitulatifDetailMouvements.RowCount:=lCAAM+4;

          CummulerAticleTableau(TableauDetaiMouvementAppartenanceMouvemant,FSTraitementDonnees.TableauCummulerArticle,SigneDebitCredit);
          lCAAM:=TableauDetaiMouvementAppartenanceMouvemant.RowCount-3;

          TableauDetaiMouvementAppartenanceMouvemant.Rows[lCAAM+1].Text:='';
          TableauDetaiMouvementAppartenanceMouvemant.Rows[lCAAM+2].Text:='';
          TableauDetaiMouvementAppartenanceMouvemant.Cells[5,lCAAM+2]:='Total:  ';

          //////////////////////////////////////////////////////////////////////
          TableauRecapitulatifDetailMouvements.Rows[lCAAM+1].Text:='';
          TableauRecapitulatifDetailMouvements.Rows[lCAAM+2].Text:='';
          TableauRecapitulatifDetailMouvements.Rows[lCAAM+3].Text:='';
          TableauRecapitulatifDetailMouvements.Cells[5,lCAAM+2]:='Total:  ';
          TableauRecapitulatifDetailMouvements.Cells[5,lCAAM+3]:='Solde:  ';
          //////////////////////////////////////////////////////////////////////

          RCAAM:=1;
          while(RCAAM<=lCAAM)do
          begin
               TableauDetaiMouvementAppartenanceMouvemant.Cells[8,RCAAM]:=floattostr((strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,RCAAM])*strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[7,RCAAM])));

               TableauDetaiMouvementAppartenanceMouvemant.Cells[6,lCAAM+2]:=floattostr(strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,lCAAM+2])+strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,RCAAM]));

               /////////////////////////////////////////////////////////////////
               TableauRecapitulatifDetailMouvements.Cells[7,lCAAM+2]:=floattostr(strtoreal(TableauRecapitulatifDetailMouvements.Cells[7,lCAAM+2])+strtoreal(TableauRecapitulatifDetailMouvements.Cells[7,RCAAM]));
               TableauRecapitulatifDetailMouvements.Cells[8,lCAAM+2]:=floattostr(strtoreal(TableauRecapitulatifDetailMouvements.Cells[8,lCAAM+2])+strtoreal(TableauRecapitulatifDetailMouvements.Cells[8,RCAAM]));
               /////////////////////////////////////////////////////////////////

               TableauDetaiMouvementAppartenanceMouvemant.Cells[8,lCAAM+2]:=floattostr(strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[8,lCAAM+2])+
               (strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,RCAAM])*strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[7,RCAAM])));

               TableauDetaiMouvementAppartenanceMouvemant.Cells[20,RCAAM]:=floattostr((strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,RCAAM])*strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[5,RCAAM])));

               TableauDetaiMouvementAppartenanceMouvemant.Cells[20,lCAAM+2]:=floattostr(strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[20,lCAAM+2])+
               (strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,RCAAM])*strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[5,RCAAM])));

               TableauDetaiMouvementAppartenanceMouvemant.Cells[21,RCAAM]:=floattostr((strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[8,RCAAM])-strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[20,RCAAM])));

               TableauDetaiMouvementAppartenanceMouvemant.Cells[21,lCAAM+2]:=floattostr(strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[21,lCAAM+2])+
               (strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[8,RCAAM])-strtoreal(TableauDetaiMouvementAppartenanceMouvemant.Cells[20,RCAAM])));

          RCAAM:=RCAAM+1;

          FSTraitementDonnees.Rapport.Lines.Add('Calcule des Totaux: '+TableauDetaiMouvementAppartenanceMouvemant.Cells[1,RCAAM]+' '+TableauDetaiMouvementAppartenanceMouvemant.Cells[2,RCAAM]+' '+TableauDetaiMouvementAppartenanceMouvemant.Cells[3,RCAAM]);
          end;
     end
     else TableauDetaiMouvementAppartenanceMouvemant.RowCount:=2;

     LibererMemoireProcessus('BusinessProces.exe',FSMenuPrincipal.RBOptimisation.Checked);

     NbrRowOut:=lCAAM;

     RCAAM:=1;
     while(RCAAM<=TableauDetaiMouvementAppartenanceMouvemant.RowCount-3)do             
     begin
          TableauDetaiMouvementAppartenanceMouvemant.Cells[5,RCAAM]:=Vergule(TableauDetaiMouvementAppartenanceMouvemant.Cells[5,RCAAM],NbrChiffreApresVerguleCout,'C','');
          TableauDetaiMouvementAppartenanceMouvemant.Cells[6,RCAAM]:=Vergule(TableauDetaiMouvementAppartenanceMouvemant.Cells[6,RCAAM],NbrChiffreApresVerguleQuantite,'C','');
