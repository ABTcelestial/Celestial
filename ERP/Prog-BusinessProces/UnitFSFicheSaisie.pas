                PrintFactureDinamiquePaysage.Code_R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[1,R];
                PrintFactureDinamiquePaysage.Design_R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[2,R]+' '+FSFicheSaisie.TableauDetaiMouvement.Cells[3,R];
                PrintFactureDinamiquePaysage.UM_R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[4,R];
                PrintFactureDinamiquePaysage.Qte_R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[6,R];
                PrintFactureDinamiquePaysage.PUHT_R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[7,R];
                PrintFactureDinamiquePaysage.MHT_R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[8,R];
                if(TableIndexCol[0].NumCols>0)then PrintFactureDinamiquePaysage.Formule_0R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[0].NumCols,R];
                if(TableIndexCol[1].NumCols>0)then PrintFactureDinamiquePaysage.Formule_1R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[1].NumCols,R];
                if(TableIndexCol[2].NumCols>0)then PrintFactureDinamiquePaysage.Formule_2R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[2].NumCols,R];
                if(TableIndexCol[3].NumCols>0)then PrintFactureDinamiquePaysage.Formule_3R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[3].NumCols,R];
                if(TableIndexCol[4].NumCols>0)then PrintFactureDinamiquePaysage.Formule_4R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[4].NumCols,R];
                if(TableIndexCol[5].NumCols>0)then PrintFactureDinamiquePaysage.Formule_5R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[5].NumCols,R];
                if(TableIndexCol[6].NumCols>0)then PrintFactureDinamiquePaysage.Formule_6R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[6].NumCols,R];
                if(TableIndexCol[7].NumCols>0)then PrintFactureDinamiquePaysage.Formule_7R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[7].NumCols,R];
                if(TableIndexCol[8].NumCols>0)then PrintFactureDinamiquePaysage.Formule_8R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[8].NumCols,R];
                if(TableIndexCol[9].NumCols>0)then PrintFactureDinamiquePaysage.Formule_9R.Lines.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[TableIndexCol[9].NumCols,R];
           end;

     HeightFactureDinamiquePaysage(l,Position);
     end
     else R:=R-1;

     if(l=18)or(R=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)or(OKHeightMax=true)then
     begin

          if(R>=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)then
          begin
                l:=1;
                n:=0;
                while(l<=FSFicheSaisie.TableauFormules.RowCount)do
                begin
                     if(FSFicheSaisie.TableauFormules.RowHeights[l]>10)then
                     begin
                          n:=n+1;
                          PrintFactureDinamiquePaysage.TitreDataTauto.Lines.Add(FSFicheSaisie.TableauFormules.Cells[2,l]);
                          PrintFactureDinamiquePaysage.DataTauto.Lines.Add(FSFicheSaisie.TableauFormules.Cells[5,l]);
                     end;
                l:=l+1;
                end;

                PrintFactureDinamiquePaysage.TitreDataTauto.Height:=n*13;
                PrintFactureDinamiquePaysage.DataTauto.Height:=PrintFactureDinamiquePaysage.TitreDataTauto.Height;

                PrintFactureDinamiquePaysage.CadreDatatTauto.Height:=13+n*13;
                PrintFactureDinamiquePaysage.TextArreteeLaFacture.Enabled:=true;
                PrintFactureDinamiquePaysage.TextChiffreenLettre.Enabled:=true;

                PrintFactureDinamiquePaysage.TitreSignataire.Top:=PrintFactureDinamiquePaysage.CadreDatatTauto.Top+PrintFactureDinamiquePaysage.CadreDatatTauto.Height+10;
                PrintFactureDinamiquePaysage.BasTT3.Top:=PrintFactureDinamiquePaysage.TitreSignataire.Top+PrintFactureDinamiquePaysage.TitreSignataire.Height+3;
                PrintFactureDinamiquePaysage.PageASuivre.Top:=PrintFactureDinamiquePaysage.TitreSignataire.Top;

                if(AnsiUpperCase(Firstlaters(FSFicheSaisie.EditDesignationMouvement.Text,7))='FACTURE')
                or(AnsiUpperCase(Firstlaters(FSFicheSaisie.EditDesignationMouvement.Text,9))='SITUATION')
                or(AnsiUpperCase(Firstlaters(FSFicheSaisie.EditDesignationMouvement.Text,5))='VENTE')
                or(AnsiUpperCase(Firstlaters(FSFicheSaisie.EditDesignationMouvement.Text,5))='FICHE')
                or(AnsiUpperCase(Firstlaters(FSFicheSaisie.EditDesignationMouvement.Text,10))='PRESTATION')
                then PrintFactureDinamiquePaysage.TextArreteeLaFacture.Lines.Text:='Arręter la présente '+AnsiLowerCase(FSFicheSaisie.EditDesignationMouvement.Text)+' ŕ la somme de :'
                else PrintFactureDinamiquePaysage.TextArreteeLaFacture.Lines.Text:='Arręter le présent '+AnsiLowerCase(FSFicheSaisie.EditDesignationMouvement.Text)+' ŕ la somme de :';

                PrintFactureDinamiquePaysage.TextArreteeLaFacture.Width:=MinInt(650,PrintFactureDinamiquePaysage.CadreDatatTauto.Left-50);
                PrintFactureDinamiquePaysage.TextChiffreenLettre.Width:=PrintFactureDinamiquePaysage.TextArreteeLaFacture.Width;

                PrintFactureDinamiquePaysage.TextChiffreenLettre.Lines.Text:=FSFicheSaisie.EditChiffreEnLettres.Lines.Text;

                PrintFactureDinamiquePaysage.PageASuivre.Caption:='Fin.';
                PrintFactureDinamiquePaysage.PageSuite.Caption:='Page: '+inttostr(m)+' et Fin';
          end
          else
          begin
               PrintFactureDinamiquePaysage.CadreDatatTauto.Height:=50;
               PrintFactureDinamiquePaysage.TitreDataTauto.Height:=30;
               PrintFactureDinamiquePaysage.DataTauto.Height:=30;

               PrintFactureDinamiquePaysage.DataTauto.Lines.Text:='A suivre ...';
               PrintFactureDinamiquePaysage.PageASuivre.Caption:='A suivre Page: '+inttostr(m+1);

               PrintFactureDinamiquePaysage.TitreSignataire.Top:=PrintFactureDinamiquePaysage.CadreDatatTauto.Top+PrintFactureDinamiquePaysage.CadreDatatTauto.Height+10;
               PrintFactureDinamiquePaysage.BasTT3.Top:=PrintFactureDinamiquePaysage.TitreSignataire.Top+PrintFactureDinamiquePaysage.TitreSignataire.Height+3;
               PrintFactureDinamiquePaysage.PageASuivre.Top:=PrintFactureDinamiquePaysage.TitreSignataire.Top;

               PrintFactureDinamiquePaysage.PageSuite.Caption:='Page: '+inttostr(m)+' ŕ suivre';
          end;

          if(ApercuAvantImpression=true)
           then PrintFactureDinamiquePaysage.Preview
           else PrintFactureDinamiquePaysage.Print;

          l:=0;
          for n:=(R+1)to MinInt((R+18),FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
          begin
               l:=l+1;
               //InitialisationSituation(n,l);
          end;

          for l:=1 to 18 do ClearFactureDinamiquePaysage(l,false);

          Position:=36;
          m:=m+1;
          l:=0;
          InitialisationPrintFactureDinamiquePaysage;
     end;
R:=R+1;
end;

end;

end;

