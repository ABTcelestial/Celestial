Procedure ImprimerFactureAutre1(ApercuAvantImpression:boolean);
var R,m,NPage,NbrChiffreCode:integer;  OK,OKAvis:boolean; Origine,ModePaiement,Domiciliation,NumPiece,DataTiersSupplementaire:string;
begin
ModePaiement:=FSFicheSaisie.EditModePayement.Text;
NumPiece:=FSFicheSaisie.EditNumPiece.Text;
Domiciliation:=FSFicheSaisie.EditDomiciliation.Text;

if(FSFicheSaisie.RBAfficherCodeArticleComplet.Checked=true)
then NbrChiffreCode:=10
else NbrChiffreCode:=4;

OKAvis:=false;


PrintFactureAutre1.TextPayement.Lines.Text:=ModePaiement+' '+Domiciliation+' N°: '+NumPiece;

if(FSFicheSaisie.EditDataSourceName.Text<>'')then
begin
     PrintFactureAutre1.TextPayement.Lines.Add(FSFicheSaisie.EditSourceName.Text+FSFicheSaisie.EditDataSourceName.Text);
end;

if(FSFicheSaisie.RBInfoAdresseExecutionMouvement.Checked=true)then
begin
     if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
     begin
          if(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text<>'')then
          begin
               PrintFactureAutre1.Projet.Caption:='Destination: ';
               PrintFactureAutre1.TextProjet.Lines.Text:=FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text;
          end
          else
          begin                
               PrintFactureAutre1.Projet.Caption:='Adresse: ';
               PrintFactureAutre1.TextProjet.Lines.Text:=FSFicheSaisie.EditAdresseExecutionMouvement.Text;
          end;
     end
     else
     begin
          if(FSFicheSaisie.RBAfficheReferenceListeMouvement.Checked=true)and(FSFicheSaisie.EditReferenceListeMouvement.Text<>'')then
          begin
               PrintFactureAutre1.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
               PrintFactureAutre1.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;
          end
          else
          begin
               PrintFactureAutre1.Projet.Caption:='';
               PrintFactureAutre1.TextProjet.Lines.Text:='';
          end;
     end;
end;

R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
     if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
     then
     begin
          OK:=true;
          showmessage('Veuillez enregistrer les modifications avant l''impression SVP !');
     end;
     R:=R+1;
end;

if(OK=false)
and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
begin
Division(FSFicheSaisie.TableauDetaiMouvement.RowCount-5,15,NPage,m);
if(m>0)then NPage:=NPage+1;
{*******************Entreprise***************}
OpenFParc(RParc);
PrintFactureAutre1.TextEntreprise.Caption:=RParc.Text1;

PrintFactureAutre1.DataEntreprise.Lines.Text:='';
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text2);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text3);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text4);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text5);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text6);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text7);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text8);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text9);
PrintFactureAutre1.DataEntreprise.Lines.Add(RParc.Text10);
