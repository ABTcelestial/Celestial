               TableauListeMouvement.Cells[13,R]:='';
               TableauListeMouvement.Cells[14,R]:=RPrelevementUniteFonds.DatePrelevement;
               TableauListeMouvement.Cells[15,R]:='';//RPrelevementUniteFonds.CodePaysExecutionMouvement;
               TableauListeMouvement.Cells[16,R]:='';//ChercherLocalisationGeographique(RPrelevementUniteFonds.CodePaysExecutionMouvement,'FPays').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[17,R]:='';//RPrelevementUniteFonds.CodeWilayaExecutionMouvement;
               TableauListeMouvement.Cells[18,R]:='';//ChercherLocalisationGeographique(RPrelevementUniteFonds.CodeWilayaExecutionMouvement,'FWilaya').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[19,R]:='';//RPrelevementUniteFonds.CodeDairaExecutionMouvement;
               TableauListeMouvement.Cells[20,R]:='';//ChercherLocalisationGeographique(RPrelevementUniteFonds.CodeDairaExecutionMouvement,'FDaira').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[21,R]:='';//RPrelevementUniteFonds.CodeCommuneExecutionMouvement;
               TableauListeMouvement.Cells[22,R]:='';//ChercherLocalisationGeographique(RPrelevementUniteFonds.CodeCommuneExecutionMouvement,'FCommune').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[23,R]:='';//RPrelevementUniteFonds.CodeZoneExecutionMouvement;
               TableauListeMouvement.Cells[24,R]:='';//ChercherLocalisationGeographique(RPrelevementUniteFonds.CodeZoneExecutionMouvement,'FZone').IntitulleLocalisationGeographique;
               TableauListeMouvement.Cells[25,R]:='';//RPrelevementUniteFonds.AdresseExecutionMouvement;
               TableauListeMouvement.Cells[26,R]:='';//booleantostr(RPrelevementUniteFonds.OKExecution);
               TableauListeMouvement.Cells[27,R]:='';//RPrelevementUniteFonds.NumProjetFinance;
               TableauListeMouvement.Cells[28,R]:='';//ChercherProjetFinance(RPrelevementUniteFonds.NumProjetFinance).DesignationProjetFinance;
               TableauListeMouvement.Cells[29,R]:=RPrelevementUniteFonds.ModePaiement;
               TableauListeMouvement.Cells[30,R]:='';//RPrelevementUniteFonds.NumDomiciliation;
               TableauListeMouvement.Cells[31,R]:=RPrelevementUniteFonds.Domiciliation;
               TableauListeMouvement.Cells[32,R]:=RPrelevementUniteFonds.NumPiece;
               TableauListeMouvement.Cells[33,R]:='';//RPrelevementUniteFonds.ListeNumAvis;
               TableauListeMouvement.Cells[34,R]:='UF'
          end;
     end;
     finally
     CloseFile(FPrelevementUniteFonds);
     end;

     if(R>0)then TableauListeMouvement.RowCount:=R+1
            else TableauListeMouvement.RowCount:=2;

     NbrRowOut:=R;

     NotRow:='';

     NotCol:='1;3;4;6-11;14-34';

     for C:=1 to TableauListeMouvement.ColCount-1 do
     if ExisteNumInTexte(inttostr(C),NotCol)then TableauListeMouvement.ColWidths[C]:=0;
     AjusterColWidth(TableauListeMouvement,NotRow,NotCol);

     TrierTableauARowSpecial(TableauListeMouvement,1,IndiceFinControleTrieRow,1,inttostr(RubriqueTrie),'Date','+');

