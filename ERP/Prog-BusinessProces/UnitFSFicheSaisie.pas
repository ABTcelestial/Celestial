          FSFicheSaisie.AfficheExecutionMouvement.Visible:=false;
     end;

     ListeBaseAvisInclu(IndiqueBaseAvis(FichierTiersConcerne),IndiqueBaseAvisInListeNumAvis(FSFicheSaisie.EditNumAvis.Text,FSFicheSaisie.EditBaseAvis.Text),FSAvis.EditBaseAvis,FSAvis.TitreEditBaseAvis);
     ListeBaseAvisInclu(IndiqueBaseAvis(FichierTiersConcerne),IndiqueBaseAvisInListeNumAvis(FSFicheSaisie.EditNumAvis.Text,FSFicheSaisie.EditBaseAvis.Text),FSFicheSaisie.EditBaseAvis,FSFicheSaisie.TitreEditBaseAvis);

     if(FSFicheSaisie.EditNumAvis.Text<>'')then
     begin
          OKAvisTrouver:=ChercherAvis(FSFicheSaisie.EditNumAvis.Text,FSFicheSaisie.EditBaseAvis.Text,TypeProces,FichierTiersConcerne,FSFicheSaisie.RBModePayementNumAvis.Checked,FSFicheSaisie.RBModePayementModePayement.Checked,FSFicheSaisie.RBModePayementDomiciliation.Checked,FSFicheSaisie.RBModePayementNumPiece.Checked,FSFicheSaisie.RBModePayementDateAvis.Checked,FSFicheSaisie.RBModePayementDateExecution.Checked,FSFicheSaisie.TableauListeAvisTrouver,FSFicheSaisie.EditListeNumAvisTrouver,FSFicheSaisie.EditListeModePaiementTrouver,FSFicheSaisie.EditListeDomiciliationAvisTrouver,FSFicheSaisie.EditListeDomiciliationPieceTrouver,FSFicheSaisie.EditListeNumPieceTrouver,FSFicheSaisie.EditListeDateTrouver,FSFicheSaisie.EditMemoLiseAvisTrouver);
     end
     else
     begin
          OKAvisTrouver:=false;
     end;

     if(FSFicheSaisie.EditNumAvis.Text<>'')then
     begin
          if(OKAvisTrouver=true)then
          begin
               if(FSFicheSaisie.EditModePayement.Text<>FSFicheSaisie.EditListeModePaiementTrouver.Text)
