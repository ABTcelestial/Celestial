     begin
          if(strtoreal(FSFicheSaisie.EditValeur.Text)<>0)
          then FSFicheSaisie.TableauVariable.Cells[4,FSFicheSaisie.TableauVariable.Row]:=Vergule(FSFicheSaisie.EditValeur.Text,FuncNbrDecimale(FSFicheSaisie.EditValeur.Text),'C','')+FSFicheSaisie.TypeValeur.Caption
          else FSFicheSaisie.TableauVariable.Cells[4,FSFicheSaisie.TableauVariable.Row]:='0'+FSFicheSaisie.TableauVariable.Cells[5,FSFicheSaisie.TableauVariable.Row];
     end
     else FSFicheSaisie.TableauVariable.Cells[4,FSFicheSaisie.TableauVariable.Row]:=FSFicheSaisie.EditValeur.Text;
     AjustementTableauVariable(FSFicheSaisie.TableauVariable);

     for R:=6 to FSFicheSaisie.TableauDetaiMouvement.RowCount-1 do
     begin
          if(FSFicheSaisie.RBAppliqueVarAll.Checked=false)then
          begin
               if(FSFicheSaisie.TableauDetaiMouvement.Row=R)
               then OKCalcule:=true
               else OKCalcule:=false;
          end
          else OKCalcule:=true;

          if(OKCalcule=true)then
          CalculeFicheSaisie(FSFicheSaisie.TableauFormules,FSFicheSaisie.TableauVariable,FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.EditModePayement.Text,FSFicheSaisie.EditNbrChiffreApresVergulePrix.Text,R,FSFicheSaisie.EditCodeTypeFormuleAfficher,true);
     end;

     AfficherRecapeFicheSaisie(FSFicheSaisie.TableauDetaiMouvement,FSFicheSaisie.TableauFormules,FSFicheSaisie.EditChiffreEnLettres,FSFicheSaisie.EditTitreChiffreEnLettres,FSFicheSaisie.EditMontantMouvement);
     FSFicheSaisie.TableauVariable.SetFocus;
     FSFicheSaisie.AfficheValeur.Visible:=false;
end;

end;

