procedure TFSFicheSaisie.TableauCompteTiersKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var TypeProces,FichierConcerne,Adresse:string;    OrdreTiers:Integer;
begin
     if key in[VK_RETURN]then
     begin
          TypeProces:=FSFicheSaisie.EditTypeProces.Text;
          FichierConcerne:=FSFicheSaisie.EditFichierTiersConserne.Text;
          Adresse:='';
          if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
          begin
               AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
               Exit;
          end;

          if(FichierConcerne<>'FProjetFinance')then
          begin
                ChTiers:=Adresse;
                assignfile(FTiers,ChTiers);
                try
                if FileExists(ChTiers)then
                Reset(FTiers)
                else begin affichermessage('Attention ! {'+ChTiers+'} n''existe pas !'); exit; end;//Rewrite(FTiers);
                Seek(FTiers,0);
                OrdreTiers:=1;
                while not eof(FTiers)do
                begin
                     read(FTiers,RTiers);
                     if(FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row]<>'')then
                     begin
                          if(Firstlaters(RTiers.CodeTiers,6)=FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row])then
                          begin
                               if(strtointeger(lastlaters(RTiers.CodeTiers,4))>=OrdreTiers)then OrdreTiers:=strtointeger(lastlaters(RTiers.CodeTiers,4))+1;
                          end;
                     end
                     else
                     begin
                          if(strtointeger(lastlaters(RTiers.CodeTiers,4))>=OrdreTiers)then OrdreTiers:=strtointeger(lastlaters(RTiers.CodeTiers,4))+1;
                     end;
                end;
                finally
                Closefile(FTiers);
                end;

                FSFicheSaisie.EditCompteTiersRecherche.Text:=FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row];
                FSFicheSaisie.EditCodeTiers.Text:=FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row]+Completezerogauche(inttostr(OrdreTiers),'4');
          end
          else
          begin
                ChProjetFinance:=Adresse;
                assignfile(FProjetFinance,ChProjetFinance);
                try
                if FileExists(ChProjetFinance)then
                Reset(FProjetFinance)
                else begin affichermessage('Attention ! {'+ChProjetFinance+'} n''existe pas !'); exit; end;//Rewrite(FProjetFinance);
                Seek(FProjetFinance,0);
                OrdreTiers:=1;
                while not eof(FProjetFinance)do
                begin
                     read(FProjetFinance,RProjetFinance);
                     if(FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row]<>'')then
                     begin
                          if(Firstlaters(RProjetFinance.NumProjetFinance,5)=FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row])then
                          begin
                               if(strtointeger(lastlaters(RProjetFinance.NumProjetFinance,5))>=OrdreTiers)then OrdreTiers:=strtointeger(lastlaters(RProjetFinance.NumProjetFinance,5))+1;
                          end;
                     end
                     else
                     begin
                          if(strtointeger(lastlaters(RProjetFinance.NumProjetFinance,5))>=OrdreTiers)then OrdreTiers:=strtointeger(lastlaters(RProjetFinance.NumProjetFinance,5))+1;
                     end;
                end;
                finally
                closefile(FProjetFinance);
                end;

                FSFicheSaisie.EditCompteTiersRecherche.Text:=FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row];
                FSFicheSaisie.EditCodeTiers.Text:=FSFicheSaisie.TableauCompteTiers.Cells[1,FSFicheSaisie.TableauCompteTiers.Row]+Completezerogauche(inttostr(OrdreTiers),'5');
          end;


          FSFicheSaisie.EditTiersConserne.Text:='';
          FSFicheSaisie.TableauCompteTiers.Visible:=false;
          FSFicheSaisie.EditNomTiers.SetFocus;
     end;
end;

