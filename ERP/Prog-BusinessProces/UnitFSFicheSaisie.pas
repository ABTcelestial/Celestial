PrintBonQuantitatifPaysage.DataTiers.Lines.Text:='';
PrintBonQuantitatifPaysage.DataTiers.Lines.Add(RTier.NomTiers+' '+RTier.PrenomTiers);
PrintBonQuantitatifPaysage.DataTiers.Lines.Add(RTier.AdresseTiers);
{***************Fin Fournisseur***************}

