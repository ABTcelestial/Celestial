          TypeData:='';

          TrierTableauARowSpecial(FSFicheSaisie.TableauListeMouvement,1,FSFicheSaisie.TableauListeMouvement.RowCount-1,1,inttostr(FSFicheSaisie.TableauListeMouvement.Col),TypeData,'+');
     end;

     if(key in['i','I'])then
     begin
          FSFicheSaisie.AfficheSoldeAnterieur.Visible:=true;
     end;
end;

