                    end;

                    if(OKFormule=false)
                    and(TableauDetaiMouvement.Cells[C,0]<>'')
                    and(TableauDetaiMouvement.Cells[C,0]=inttostr(RDetailMouvement.RRegistreFormule2.PositionFormule))
                    then
                    begin
                         OKFormule:=true;
                         TableauDetaiMouvement.Cells[C,Row]:=Vergule(floattostr(RDetailMouvement.RRegistreFormule2.ValeurFormule),'2','C','');
                    end;

                    if(OKFormule=false)
                    and(TableauDetaiMouvement.Cells[C,0]<>'')
                    and(TableauDetaiMouvement.Cells[C,0]=inttostr(RDetailMouvement.RRegistreFormule3.PositionFormule))
                    then
                    begin
                         OKFormule:=true;
                         TableauDetaiMouvement.Cells[C,Row]:=Vergule(floattostr(RDetailMouvement.RRegistreFormule3.ValeurFormule),'2','C','');
                    end;

                    if(OKFormule=false)
