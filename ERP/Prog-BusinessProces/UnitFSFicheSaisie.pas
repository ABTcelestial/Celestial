Function FunctionNombreChiffreApresVerguleQte(Quantite,UniteMesure:string; NbrChiffreApresVerguleDefaut:string; RBNbrChiffreApresVerguleAutomatique:boolean):string;
var NbrChiffreApresVergule:string;
begin
     NbrChiffreApresVergule:=NbrChiffreApresVerguleDefaut;

     if ExisteCharinString('2',UniteMesure)then NbrChiffreApresVergule:='2'
     else
     if ExisteCharinString('3',UniteMesure)then NbrChiffreApresVergule:='3'
     else
     if(RBNbrChiffreApresVerguleAutomatique=true)and(strtoreal(Quantite)<>0)then NbrChiffreApresVergule:=FuncNbrDecimale(Quantite);

     FunctionNombreChiffreApresVerguleQte:=NbrChiffreApresVergule;
end;

Procedure ImprimerBonQuantitatifPaysage(ApercuAvantImpression:boolean);
var R,m,NPage:integer;  OK,OKAvis:boolean; Origine,ModePaiement:string;
begin
PrintBonQuantitatifPaysage.ModePaiementCheque.Enabled:=false;
PrintBonQuantitatifPaysage.ModePaiementEspece.Enabled:=false;
PrintBonQuantitatifPaysage.ModePaiementATerme.Enabled:=false;
PrintBonQuantitatifPaysage.ModePaiement.Caption:='Chčque N°:';

PrintBonQuantitatifPaysage.TitreSignataire.Caption:=FSFicheSaisie.EditSignataire.Text;

ModePaiement:=FSFicheSaisie.EditModePayement.Text;

OKAvis:=false;

if(OKAvis=true)then
begin
     if(ModePaiement='Chčque')
     or(ModePaiement='Bon')
     or(ModePaiement='Virement')
     then
     begin
          PrintBonQuantitatifPaysage.ModePaiementCheque.Enabled:=true;
          PrintBonQuantitatifPaysage.ModePaiement.Caption:=ModePaiement;
     end;

     if(ModePaiement='Espčce')then
     begin
          PrintBonQuantitatifPaysage.ModePaiementEspece.Enabled:=true;
     end;

     if(ModePaiement<>'Chčque')
     and(ModePaiement<>'Bon')
     and(ModePaiement<>'Virement')
     and(ModePaiement<>'Espčce')
     then
     begin
          PrintBonQuantitatifPaysage.ModePaiementATerme.Enabled:=true;
     end;

end
else
begin
     if(ModePaiement<>'')then
     begin
          if(ModePaiement='Chčque')
          or(ModePaiement='Bon')
          or(ModePaiement='Virement')
          then
          begin
               PrintBonQuantitatifPaysage.ModePaiementCheque.Enabled:=true;
               PrintBonQuantitatifPaysage.ModePaiement.Caption:=ModePaiement;
          end;

          if(ModePaiement='Espčce')
          then
          begin
               PrintBonQuantitatifPaysage.ModePaiementEspece.Enabled:=true;
          end;

          if(ModePaiement='A Terme')
          then
          begin
               PrintBonQuantitatifPaysage.ModePaiementATerme.Enabled:=true;
          end;

          if(ModePaiement='Autres')
          then
          begin
               PrintBonQuantitatifPaysage.ModePaiementCheque.Enabled:=true;
               PrintBonQuantitatifPaysage.ModePaiement.Caption:=ModePaiement;
          end;
     end;
end;

R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
     if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
     then
     begin
          OK:=true;
          showmessage('Veuillez enregistrer les modifications avant l''impression SVP !');
     end;
     R:=R+1;
end;

if(OK=false)
and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
begin
Division(FSFicheSaisie.TableauDetaiMouvement.RowCount-5,20,NPage,m);
if(m>0)then NPage:=NPage+1;
{*******************Entreprise***************}
OpenFParc(RParc);
PrintBonQuantitatifPaysage.TextEntreprise.Caption:=RParc.Text1;

PrintBonQuantitatifPaysage.DataEntreprise.Lines.Text:='';
PrintBonQuantitatifPaysage.DataEntreprise.Lines.Add(RParc.Text2);
PrintBonQuantitatifPaysage.DataEntreprise.Lines.Add(RParc.Text3);
PrintBonQuantitatifPaysage.DataEntreprise.Lines.Add(RParc.Text4);
PrintBonQuantitatifPaysage.DataEntreprise.Lines.Add(RParc.Text5);
