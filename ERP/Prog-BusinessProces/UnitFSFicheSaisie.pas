Procedure ControleListeNumAvisListeMouvement(PositionTypeMouvement,PositionMouvement,DateMouvementDebut,DateMouvementFin:string; UtiliserIndexation:boolean);
var  i,R,iMois,iPLM:integer;   PLMBegin,PLMEnd,AdresseListeMouvement:string;   OKAvis,OKAnomalie:boolean;
begin
     FSFicheSaisie.TableAvisErronnes.ColCount:=8;
     FSFicheSaisie.TableAvisErronnes.Cols[0].Text:='Ord';
     FSFicheSaisie.TableAvisErronnes.Cols[1].Text:='N° Avis';
     FSFicheSaisie.TableAvisErronnes.Cols[2].Text:='Date';
     FSFicheSaisie.TableAvisErronnes.Cols[3].Text:='Type proces';
     FSFicheSaisie.TableAvisErronnes.Cols[4].Text:='Fichier cencerne';
     FSFicheSaisie.TableAvisErronnes.Cols[5].Text:='Code Tiers';
     FSFicheSaisie.TableAvisErronnes.Cols[6].Text:='Tiers';
     FSFicheSaisie.TableAvisErronnes.Cols[7].Text:='Montant';

     FSFicheSaisie.TableAvisErronnes.RowCount:=2;
     FSFicheSaisie.TableAvisErronnes.Rows[1].Text:='';
     R:=0;

     RMouvement:=ChercherMouvement(PositionTypeMouvement,strtointeger(PositionMouvement),AdresseFichierConcerne);

     TypeProces:='Business';   FichierConcerne:='FTypeFichierTiers';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChTypeFichierTiers:=Adresse;
     assignfile(FTypeFichierTiers,ChTypeFichierTiers);
     if FileExists(ChTypeFichierTiers)then
     begin
          try
          Reset(FTypeFichierTiers);
          Seek(FTypeFichierTiers,0);
          while not eof(FTypeFichierTiers)do
          begin
               read(FTypeFichierTiers,RTypeFichierTiers);
               if FunctionFichierInclu(RTypeFichierTiers.FichierConcerne,RMouvement.FichierTiersConserne)then
               begin
                     ///////////////////////////////////////////////////////////////////////////
                     TypeProces:='Business';   FichierConcerne:=RTypeFichierTiers.BaseAvis;
                     if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                     begin
                          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
                     end;

                     ChAvis:=Adresse;
                     assignfile(FAvis,ChAvis);
                     if FileExists(ChAvis)then
                     begin
                          try
                          Reset(FAvis);

                          if(UtiliserIndexation=true)
                          and(strtointeger(MidelLaters(DateMouvementDebut,7,10))=strtointeger(MidelLaters(DateMouvementFin,7,10)))then
                          begin
                               iAnnee:=strtointeger(MidelLaters(DateMouvementDebut,7,10));
                               if(strtointeger(MidelLaters(DateMouvementDebut,4,5))=strtointeger(MidelLaters(DateMouvementFin,4,5)))then
                               begin
                                    iMois:=strtointeger(MidelLaters(DateMouvementFin,4,5));
                                    PLMBegin:=inttostr(RMouvement.RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementBegin);
                                    PLMEnd:=inttostr(RMouvement.RegistrePositionListeMouvementParPeriode[iAnnee,iMois].PositionListeMouvementEnd);
                               end
                               else
                               begin
                                    PLMBegin:='0';
                                    PLMEnd:='999999999';
                               end;
                          end
                          else
                          begin
                               PLMBegin:='0';
                               PLMEnd:='999999999';
                          end;

                          AdresseListeMouvement:=IndiqueAdresseListeMouvement(PositionTypeMouvement,TypeProcesReseauxListeMouvement);
                          ChListeMouvement:=AdresseListeMouvement;
                          assignfile(FListeMouvement,ChListeMouvement);
                          if FileExists(ChListeMouvement)then
                          begin
                               try
                               Reset(FListeMouvement);
                               iPLM:=strtointeger(PLMBegin);
                               Seek(FListeMouvement,iPLM);
                               while(not eof(FListeMouvement))and(iPLM<=strtointeger(PLMEnd))do
                               begin
                                    read(FListeMouvement,RListeMouvement);  Application.ProcessMessages;
                                    iPLM:=iPLM+1;

                                    if(RListeMouvement.ValidationListeMouvement=true)
                                    and(inttostr(RListeMouvement.PositionTypeMouvement)=PositionTypeMouvement)
                                    and(inttostr(RListeMouvement.PositionMouvement)=PositionMouvement)
                                    and(RListeMouvement.ListeNumAvis<>'')then
                                    begin
                                         Seek(FAvis,0);
                                         i:=0;
                                         OKAvis:=false;
                                         while not eof(FAvis)and(OKAvis=false)do
                                         begin
                                              read(FAvis,RAvis);

                                              if(RAvis.ValiditeAvis=true)and(ExisteNuminTexte(inttostr(RAvis.NumAvis),RListeMouvement.ListeNumAvis))then
                                              begin
                                                    OKAvis:=true;

                                                    if(RAvis.Origine='')then
                                                    begin
                                                         RAvis.Origine:='FSC'+inttostr(RListeMouvement.OrdreListeMouvement);
                                                    end
                                                    else
                                                    begin
                                                         if not FunctionFichierInclu('FSC'+inttostr(RListeMouvement.OrdreListeMouvement),RAvis.Origine)
                                                         then RAvis.Origine:=RAvis.Origine+';'+'FSC'+inttostr(RListeMouvement.OrdreListeMouvement);
                                                    end;

                                                    if(OKAvis=true)then
                                                    begin
                                                         Seek(FAvis,i);
                                                         write(FAvis,RAvis);
                                                    end;

                                                    if(OKAnomalie=true)then
                                                    begin
                                                         if((RAvis.Origine)<>('FSC'+inttostr(RListeMouvement.OrdreListeMouvement)))then
                                                         begin
                                                              R:=R+1;
                                                              FSFicheSaisie.TableAvisErronnes.Rows[R].Text:=inttostr(R);
                                                              FSFicheSaisie.TableAvisErronnes.Cells[1,R]:=CompleteZeroGauche(inttostr(RAvis.NumAvis),'5');
                                                              FSFicheSaisie.TableAvisErronnes.Cells[2,R]:=RAvis.DateAvis;
                                                              FSFicheSaisie.TableAvisErronnes.Cells[3,R]:=RAvis.TypeProces;
                                                              FSFicheSaisie.TableAvisErronnes.Cells[4,R]:=RAvis.AvisConcerneTiers;
                                                              FSFicheSaisie.TableAvisErronnes.Cells[5,R]:=RAvis.CodeTiers;
                                                              FSFicheSaisie.TableAvisErronnes.Cells[6,R]:=RAvis.IdentificateurTiers;
                                                              FSFicheSaisie.TableAvisErronnes.Cells[7,R]:=Vergule(floattostr(RAvis.Montant),'2','C','');
                                                         end;
                                                    end;
                                              end;
                                         i:=i+1;
                                         end;
                                    end;
                               end;
                          finally
                          CloseFile(FListeMouvement);
                          end;
                          end;
                     finally
                     CloseFile(FAvis);
                     end;
                     end;
                     ///////////////////////////////////////////////////////////////////////////
               end;
          end;
     Finally
     CloseFile(FTypeFichierTiers);
     end;
     end;

     if(R>0)then FSFicheSaisie.TableAvisErronnes.RowCount:=R+1
            else FSFicheSaisie.TableAvisErronnes.RowCount:=2;

     AjusterColWidth(FSFicheSaisie.TableAvisErronnes,'','');
end;

