     if key in[',','.','?',';',':','/','a'..'Z']then key:=DecimalSeparator;
end;

Procedure AssocierTauxFormule;
var  R,l:integer;  OKFormule:boolean; RFormuleTeste:RFormules;  ValeurTaux:real;
begin
     R:=1;
     while(R<=FSFicheSaisie.TableauFormules.RowCount-1)do
     begin
          RFormuleCopie:=ChercherFormule(FSFicheSaisie.EditCodeTypeFormuleAfficher.Text,FSFicheSaisie.TableauFormules.Cells[0,R]);
          if(RFormuleCopie.Base<>'')then
          begin
               l:=R-1;
               OKFormule:=false;
               ValeurTaux:=0;
               while(l>=1)and(OKFormule=false)do
               begin
                    RFormuleTeste:=ChercherFormule(FSFicheSaisie.EditCodeTypeFormuleAfficher.Text,FSFicheSaisie.TableauFormules.Cells[0,l]);

                    if(ExisteCharInString('+'+RFormuleCopie.Base,RFormuleTeste.Accumuler))then
                    begin
                         ValeurTaux:=ValeurTaux+strtoreal(FSFicheSaisie.TableauFormules.Cells[5,l]);
                    end
                    else
                    if(ExisteCharInString('-'+RFormuleCopie.Base,RFormuleTeste.Accumuler))then
                    begin
                         ValeurTaux:=ValeurTaux-strtoreal(FSFicheSaisie.TableauFormules.Cells[5,l]);
                    end
                    else
                    if(ExisteCharInString('='+RFormuleCopie.Base,RFormuleTeste.Accumuler))or(RFormuleCopie.Base=RFormuleTeste.FormuleTexte)then
                    begin
                         OKFormule:=true;
                         ValeurTaux:=ValeurTaux+strtoreal(FSFicheSaisie.TableauFormules.Cells[5,l]);
                         if(ValeurTaux<>0)then ValeurTaux:=ValePrecis(strtoreal(FSFicheSaisie.TableauFormules.Cells[5,R])/ValeurTaux,5);
                         FSFicheSaisie.TableauFormules.Cells[2,R]:=RFormuleCopie.Libelle+' ...('+Vergule(floattostr(ValeurTaux),FuncNbrDecimale(floattostr(ValeurTaux*100)),'C','%')+')';
                    end;
               l:=l-1;
               end;
          end;
     R:=R+1;
     end;
end;

