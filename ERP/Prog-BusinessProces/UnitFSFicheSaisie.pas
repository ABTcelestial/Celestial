procedure TFSFicheSaisie.BitValiderTransformationClick(Sender: TObject);
var  i,l,m,R,OrdreListeMouvement,PositionTMLast,PositionTMNew:integer;  OKListeMouvement:boolean; TypeProces,FichierConserne,Adresse,TypeProcesNOM,FichierConserneNOM,AdresseNOM:string;
begin
     TypeProces:='Business';   FichierConserne:='FListeMouvement';
     if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
     end;

     ChListeMouvement:=Adresse;
     assignfile(FListeMouvement,ChListeMouvement);
     try
     if FileExists(ChListeMouvement)then
     Reset(FListeMouvement)
     else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
     Seek(FListeMouvement,0);
     i:=0;
     while not eof(FListeMouvement)do
     begin
          read(FListeMouvement,RListeMouvement);

          R:=1;
          OKListeMouvement:=false;
          while(R<=FSFicheSaisie.TableauListeMouvementTransformation.RowCount-1)and(OKListeMouvement=false)do
          begin
               if(FSFicheSaisie.TableauListeMouvementTransformation.Cells[0,R]='OK')
               and(RListeMouvement.OrdreListeMouvement=strtointeger(FSFicheSaisie.TableauListeMouvementTransformation.Cells[1,R]))
               then
               begin
                    OKListeMouvement:=true;
               end;
          R:=R+1;
          end;

          if(OKListeMouvement=true)then
          begin
               OrdreListeMouvement:=RListeMouvement.OrdreListeMouvement;
               PositionTMLast:=RListeMouvement.PositionTypeMouvement;
               PositionTMNew:=strtointeger(FSFicheSaisie.EditPositionTypeMouvementTransformation.Text);
               RListeMouvement.PositionTypeMouvement:=strtointeger(FSFicheSaisie.EditPositionTypeMouvementTransformation.Text);
               RListeMouvement.PositionMouvement:=strtointeger(FSFicheSaisie.EditPositionMouvementTransformation.Text);
               RListeMouvement.CodeTypeFormule:=FSFicheSaisie.TableauMouvementTransformation.Cells[8,FSFicheSaisie.TableauMouvementTransformation.Row];
               Seek(FListeMouvement,i);
               write(FListeMouvement,RListeMouvement);

               if(PositionTMLast<>PositionTMNew)then
               begin
                    TypeProcesNOM:='Business';   FichierConserneNOM:='DétailMouvement '+ChercherTypeMouvement(PositionTMNew,ExerciceAnnee,AdresseFichierConcerne).DesignationTypeMouvement;
                    if not(FunctionAdresseProces(TypeProcesNOM,FichierConserneNOM,'',AdresseNOM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                    begin
                         AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneNOM+' recherché !');
                    end;

                    ChDetailMouvement:=AdresseNOM;
                    assignfile(FDetailMouvement,ChDetailMouvement);
                    try
                    if FileExists(ChDetailMouvement)
                    then Reset(FDetailMouvement)
                    else Rewrite(FDetailMouvement); //possibilité de criation nouveau fichier
                    Seek(FDetailMouvement,0);
                    l:=0;
                    while not eof(FDetailMouvement)do
                    begin
                         read(FDetailMouvement,RDetailMouvement);
                         l:=l+1;
                    end;

                    TypeProcesNOM:='Business';   FichierConserneNOM:='DétailMouvement '+ChercherTypeMouvement(PositionTMLast,ExerciceAnnee,AdresseFichierConcerne).DesignationTypeMouvement;
                    if not(FunctionAdresseProces(TypeProcesNOM,FichierConserneNOM,'',AdresseNOM,TypeProcesReseaux,NomDossierPartageReseauxOut))then
                    begin
                         AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserneNOM+' recherché !');
                    end;

                    ChDetailMouvementCopie:=AdresseNOM;
                    assignfile(FDetailMouvementCopie,ChDetailMouvementCopie);
                    if FileExists(ChDetailMouvementCopie)then
                    begin
                         try
                         Reset(FDetailMouvementCopie);
                         Seek(FDetailMouvementCopie,0);
                         m:=0;
                         while not eof(FDetailMouvementCopie)do
                         begin
                              read(FDetailMouvementCopie,RDetailMouvementCopie);
                              if(RDetailMouvementCopie.OrdreListeMouvement=OrdreListeMouvement)then
                              begin
                                   Seek(FDetailMouvement,l);
                                   RDetailMouvement:=RDetailMouvementCopie;
                                   RDetailMouvement.PositionDetailMouvement:=l;
                                   RDetailMouvement.NumDetailMouvement:=l+1;
                                   write(FDetailMouvement,RDetailMouvement);
                                   l:=l+1;
                                   RDetailMouvementCopie.ValidationDetailMouvement:=false;
                                   Seek(FDetailMouvementCopie,m);
                                   write(FDetailMouvementCopie,RDetailMouvementCopie);
                              end;
                         m:=m+1;
                         end;
                         finally
                         CloseFile(FDetailMouvementCopie);
                         end;
                    end;
                    finally
                    Closefile(FDetailMouvement);
                    end;
               end;
          end;
          i:=i+1;
     end;
     finally
     CloseFile(FListeMouvement);
     end;
end;

