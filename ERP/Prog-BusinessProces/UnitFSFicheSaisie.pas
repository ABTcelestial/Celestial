procedure TFSFicheSaisie.TableauDetaiMouvementDblClick(Sender: TObject);
var  R,RowOut,C,ColVale:integer;   NotCol:string;  MontantTotal,MontantSupp,MontantListeMouvement,Ecart:real; OKColVale:boolean;
begin
     if not ControleNumDetailMouvement(FSFicheSaisie.EditNumListeMouvement)then Exit;

     if(FSFicheSaisie.AfficherOperationDetailMouvement.Visible=true)and(FSFicheSaisie.RBAjouterSupprimeDM.Checked=true)then
     begin
          FSFicheSaisie.AfficherOperationDetailMouvementInfo.Caption:='';

          if(not ExisteNumInTexte(FSFicheSaisie.TableauDetaiMouvement.Cells[0,FSFicheSaisie.TableauDetaiMouvement.Row],FSFicheSaisie.EditOperationPositionDetailMouvement.Text))then
          begin
               if(FSFicheSaisie.EditOperationPositionDetailMouvement.Text='')then
               begin
                    FSFicheSaisie.EditOperationPositionDetailMouvement.Text:=FSFicheSaisie.TableauDetaiMouvement.Cells[0,FSFicheSaisie.TableauDetaiMouvement.Row];
               end
               else
               begin
                    FSFicheSaisie.EditOperationPositionDetailMouvement.Text:=FSFicheSaisie.EditOperationPositionDetailMouvement.Text+';'+FSFicheSaisie.TableauDetaiMouvement.Cells[0,FSFicheSaisie.TableauDetaiMouvement.Row]
               end;
          end;

          MontantListeMouvement:=strtoreal(FSFicheSaisie.TableauListeMouvement.Cells[11,FSFicheSaisie.TableauListeMouvement.Row]);

          C:=FSFicheSaisie.TableauDetaiMouvement.ColCount-1;
          ColVale:=0;
          OKColVale:=false;
          while(C>0)and(OKColVale=false)do
          begin
               if(FSFicheSaisie.TableauDetaiMouvement.ColWidths[C]>0)then
               begin
                    OKColVale:=true;
                    ColVale:=C;
               end;
          C:=C-1;
          end;

          if(ColVale>0)then
          begin
               R:=6;
               MontantTotal:=0;
               MontantSupp:=0;
               while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
               begin
                    MontantTotal:=MontantTotal+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColVale,R]);

                    if ExisteNumInTexte(FSFicheSaisie.TableauDetaiMouvement.Cells[0,R],FSFicheSaisie.EditOperationPositionDetailMouvement.Text)
                    then MontantSupp:=MontantSupp+strtoreal(FSFicheSaisie.TableauDetaiMouvement.Cells[ColVale,R]);
               R:=R+1;
               end;

               FSFicheSaisie.AfficherOperationDetailMouvementInfo.Caption:='Liste Mouvement: '+Vergule(floattostr(MontantListeMouvement),'2','C','')+', Détail Mouvement: '+Vergule(floattostr(MontantTotal-MontantSupp),'2','C','')+', Ecart: '+Vergule(floattostr(MontantListeMouvement-(MontantTotal-MontantSupp)),'2','C','');

               Ecart:=MontantListeMouvement-(MontantTotal-MontantSupp);
               if(Ecart<0)then Ecart:=Ecart*(-1);
               if(Ecart<=1/100)
               then FSFicheSaisie.AfficherOperationDetailMouvementInfo.Color:=clLime
               else FSFicheSaisie.AfficherOperationDetailMouvementInfo.Color:=clRed;
          end;
     end
     else
     begin
           if(FSFicheSaisie.EditCodeTiersConserne.Text='')then
           begin
                FSFicheSaisie.EditTiersConserne.SetFocus;
           end
           else
           begin
                if(FSFicheSaisie.EditListeAppartenanceCodeMouvement.Text<>'')then
                begin
                     FSFicheSaisie.AffichChoisOperationAppartenance.Visible:=true;
                     FSFicheSaisie.AfficheTitreOperation.Caption:='Choisissez le mode d''opération !';
                     FSFicheSaisie.BitOperationAutoSelection.SetFocus;
                end
                else
                begin
                     ProcAfficheStockArticleListe(FSFicheSaisie.TableauCompteConcerne,FSFicheSaisie.EditTypeStock.Text,FSFicheSaisie.EditNumProjet.Text,FSFicheSaisie.EditCompteConserne.Text,'','','',FSFicheSaisie.TableauDetaiMouvement.Cells[1,FSFicheSaisie.TableauDetaiMouvement.Row],FSFicheSaisie.RBDistingueDesigRef.Checked,0,RowOut);
                     NotCol:='5;6;8-'+inttostr(FSFicheSaisie.TableauCompteConcerne.ColCount-1);
                     for C:=0 to FSFicheSaisie.TableauCompteConcerne.ColCount-1 do if(Existenumintexte(inttostr(C),NotCol))then FSFicheSaisie.TableauCompteConcerne.ColWidths[C]:=0;
                     AjusterColWidth(FSFicheSaisie.TableauCompteConcerne,'',NotCol);
                     if(FSFicheSaisie.TableauCompteConcerne.Visible=true)then FSFicheSaisie.TableauCompteConcerne.SetFocus;
                end;
           end;
     end;
end;

procedure TFSFicheSaisie.TableauCompteConcerneDblClick(Sender: TObject);
var  i,R,ACol:integer;
     PrixArticle:real;
     Confirme:boolean;
     RubriqueApplicationTaxeAjouter:string;
begin
     FSFicheSaisie.AfficheDetailMouvement.Visible:=true;

     FSFicheSaisie.LabelOperation.Caption:=FSFicheSaisie.EditDesignationMouvement.Text;

     if(FSFicheSaisie.EditSigneMouvement.Text='-')
     then FSFicheSaisie.LabelMouvementStock.Caption:='Déstockage';

     if(FSFicheSaisie.EditSigneMouvement.Text='+')
     then FSFicheSaisie.LabelMouvementStock.Caption:='Stockage';

     FSFicheSaisie.LabelCodeTiers.Caption:=FSFicheSaisie.EditCodeTiersConserne.Text;
     FSFicheSaisie.LabelTiers.Caption:=Lastlaters(FSFicheSaisie.EditFichierTiersConserne.Text,Longueur(FSFicheSaisie.EditFichierTiersConserne.Text)-1);
     FSFicheSaisie.LabelCodeArticle.Caption:=FSFicheSaisie.TableauCompteConcerne.Cells[1,FSFicheSaisie.TableauCompteConcerne.Row];
     FSFicheSaisie.LabelDesignationArticle.Caption:=FSFicheSaisie.TableauCompteConcerne.Cells[2,FSFicheSaisie.TableauCompteConcerne.Row];
     FSFicheSaisie.LabelRefArticle.Caption:=FSFicheSaisie.TableauCompteConcerne.Cells[3,FSFicheSaisie.TableauCompteConcerne.Row];
     FSFicheSaisie.LabelUniteMusure.Caption:=FSFicheSaisie.TableauCompteConcerne.Cells[4,FSFicheSaisie.TableauCompteConcerne.Row];
     FSFicheSaisie.EditUniteMesure.Text:=FSFicheSaisie.TableauCompteConcerne.Cells[4,FSFicheSaisie.TableauCompteConcerne.Row];
     FSFicheSaisie.UniteMesure.Caption:=FSFicheSaisie.TableauCompteConcerne.Cells[4,FSFicheSaisie.TableauCompteConcerne.Row];
     FSFicheSaisie.LabelCout.Caption:=FSFicheSaisie.TableauCompteConcerne.Cells[10,FSFicheSaisie.TableauCompteConcerne.Row];

     ACol:=11;

     if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Achat')then ACol:=10;
     if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Détail')then ACol:=11;
     if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Gros')then ACol:=12;
     if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix D.Gros')then ACol:=13;

     if(FSFicheSaisie.EditTypeStock.Text='Marche')then
     begin
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Coűt Unitaire')then ACol:=10;
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Marché')then ACol:=11;
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Soutraitance')then ACol:=12;
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Attache')then ACol:=13;
     end;

     if(FSFicheSaisie.EditTypeStock.Text='Article')then
     begin
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Achat')then ACol:=10;
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Détail')then ACol:=11;
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix Gros')then ACol:=12;
          if(FSFicheSaisie.EditTypePrixMouvement.Text='Prix D.Gros')then ACol:=13;
     end;

     FSFicheSaisie.EditTaxeAjouter.Text:=ValeurTaxeAjouter('Fiche de Saisie commerciale',FSFicheSaisie.EditCodeZoneExecutionMouvement.Text,FSFicheSaisie.TableauCompteConcerne.Cells[1,FSFicheSaisie.TableauCompteConcerne.Row],RubriqueApplicationTaxeAjouter);
     FSFicheSaisie.EditRubriqueApplicationTaxeAjouter.Text:=RubriqueApplicationTaxeAjouter;
     AffecterRBRubriqueApplicationTaxeAjouter(FSFicheSaisie.EditRubriqueApplicationTaxeAjouter.Text);
     FSFicheSaisie.EditTaxeBareme.Text:='';
     PrixArticle:=strtoreal(FSFicheSaisie.TableauCompteConcerne.Cells[ACol,FSFicheSaisie.TableauCompteConcerne.Row]);

     FSFicheSaisie.EditPrixMouvement.Text:=Vergule(floattostr(PrixArticle),'2','C','');

     FSFicheSaisie.EditQuantiteStock.Text:=Vergule(FSFicheSaisie.TableauCompteConcerne.Cells[7,FSFicheSaisie.TableauCompteConcerne.Row],'2','C','');

     FSFicheSaisie.AfficheArticleSelection.Text:=FSFicheSaisie.LabelDesignationArticle.Caption+' '+FSFicheSaisie.LabelRefArticle.Caption+' {'+FSFicheSaisie.LabelUniteMusure.Caption+'}';

     FSFicheSaisie.EditQuantiteMouvement.Text:='';
     FSFicheSaisie.EditQuantiteMouvement.SetFocus;
     FSFicheSaisie.AfficheOptionCompteConcerne.Visible:=false;
     FSFicheSaisie.TableauCompteConcerne.Visible:=false;

     if(FunctStockSpecifierParStructure(false)=true)
     and(Lastlaters(FSFicheSaisie.TableauCompteConcerne.Cells[0,FSFicheSaisie.TableauCompteConcerne.Row],3)='BDP')then
     begin
           ChStockArticle:=RParc.Parcours+'\'+Exercice+'FStock'+FSFicheSaisie.EditTypeStock.Text+FSFicheSaisie.EditNumProjet.Text;
           assignfile(FStockArticle,ChStockArticle);
           try
           if FileExists(ChStockArticle)then
           Reset(FStockArticle)
           else begin affichermessage('Attention ! {'+ChStockArticle+'} n''existe pas !'); exit; end;//Rewrite(FStockArticle);
           Seek(FStockArticle,0);
           Confirme:=true;
           while not eof(FStockArticle) do
           begin
                Read(FStockArticle,RStockArticle);
                if(RStockArticle.Code=FSFicheSaisie.TableauCompteConcerne.Cells[1,FSFicheSaisie.TableauCompteConcerne.Row])then
                begin
                     Confirme:=false;
                end;
           end;
           finally
           Closefile(FStockArticle);
           end;

           {******************************}
           if(Confirme=true)then
           begin
                 assignfile(FStockArticle,ChStockArticle);
                 try
                 if FileExists(ChStockArticle)then
                 Reset(FStockArticle)
                 else Rewrite(FStockArticle); //création nouveau fichier
                 Seek(FStockArticle,0);
                 i:=0;
                 while not eof(FStockArticle) do
                 begin
                      Read(FStockArticle,RStockArticle);
                      i:=i+1;
                 end;
                 R:=i+1;
                 Seek(FStockArticle,i);
                 Truncate(FStockArticle);
                 RStockArticle.PrixVenteDetaille:=strtoreal(FSFicheSaisie.TableauCompteConcerne.Cells[11,FSFicheSaisie.TableauCompteConcerne.Row]);
                 RStockArticle.Design:=FSFicheSaisie.TableauCompteConcerne.Cells[2,FSFicheSaisie.TableauCompteConcerne.Row];
                 RStockArticle.Ref:=FSFicheSaisie.TableauCompteConcerne.Cells[3,FSFicheSaisie.TableauCompteConcerne.Row];
                 RStockArticle.Code:=FSFicheSaisie.TableauCompteConcerne.Cells[1,FSFicheSaisie.TableauCompteConcerne.Row];
                 RStockArticle.UM:=FSFicheSaisie.TableauCompteConcerne.Cells[4,FSFicheSaisie.TableauCompteConcerne.Row];
                 RStockArticle.QteEntree:=0;
                 RStockArticle.QteSortie:=0;
                 RStockArticle.QteStock:=0;
                 RStockArticle.QteInitial:=0;
                 RStockArticle.QteLimite:=0;
                 RStockArticle.CoutUnitaire:=strtoreal(FSFicheSaisie.TableauCompteConcerne.Cells[10,FSFicheSaisie.TableauCompteConcerne.Row]);
                 RStockArticle.PrixVenteDemiGros:=strtoreal(FSFicheSaisie.TableauCompteConcerne.Cells[13,FSFicheSaisie.TableauCompteConcerne.Row]);
                 RStockArticle.PrixVenteGros:=strtoreal(FSFicheSaisie.TableauCompteConcerne.Cells[12,FSFicheSaisie.TableauCompteConcerne.Row]);
                 RStockArticle.Observ:='';
                 RStockArticle.Emplace:='';
                 RStockArticle.CodeBarre:=Firstlaters(RStockArticle.Code,6);
                 RStockArticle.Formule:='';
                 RStockArticle.enregistrement:='';

                 Write(FStockArticle,RStockArticle);

                 finally
                 Closefile(FStockArticle);
                 end;
           end;
     end;
end;

