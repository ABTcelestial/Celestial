Function StringInFonStyle(TexteFontStyle:String):TFontStyles;
begin
     if(TexteFontStyle='[fsBold]')
     then StringInFonStyle:=[fsBold];

     if(TexteFontStyle='[fsItalic]')
     then StringInFonStyle:=[fsItalic];

     if(TexteFontStyle='[fsUnderline]')
     then StringInFonStyle:=[fsUnderline];

     if(TexteFontStyle='[fsStrikeOut]')
     then StringInFonStyle:=[fsStrikeOut];

     if(TexteFontStyle='[fsBold,fsItalic]')
     then StringInFonStyle:=[fsBold,fsItalic];

     if(TexteFontStyle='[fsBold,fsUnderline]')
     then StringInFonStyle:=[fsBold,fsUnderline];

     if(TexteFontStyle='[fsBold,fsStrikeOut]')
     then StringInFonStyle:=[fsBold,fsStrikeOut];

     if(TexteFontStyle='[fsItalic,fsUnderline,fsStrikeOut]')
     then StringInFonStyle:=[fsItalic,fsUnderline,fsStrikeOut];

     if(TexteFontStyle='[fsItalic,fsUnderline]')
     then StringInFonStyle:=[fsItalic,fsUnderline];

     if(TexteFontStyle='[fsItalic,fsStrikeOut]')
     then StringInFonStyle:=[fsItalic,fsStrikeOut];

     if(TexteFontStyle='[fsBold,fsItalic,fsUnderline,fsStrikeOut]')
     then StringInFonStyle:=[fsBold,fsItalic,fsUnderline,fsStrikeOut];
end;

Function FonStyleInString(FontStyle:TFontStyles):String;
begin
     if(FontStyle=[fsBold])
     then FonStyleInString:='[fsBold]';

     if(FontStyle=[fsItalic])
     then FonStyleInString:='[fsItalic]';

     if(FontStyle=[fsUnderline])
     then FonStyleInString:='[fsUnderline]';

     if(FontStyle=[fsStrikeOut])
     then FonStyleInString:='[fsStrikeOut]';

     if(FontStyle=[fsBold,fsItalic])
     then FonStyleInString:='[fsBold,fsItalic]';

     if(FontStyle=[fsBold,fsUnderline])
     then FonStyleInString:='[fsBold,fsUnderline]';

     if(FontStyle=[fsBold,fsStrikeOut])
     then FonStyleInString:='[fsBold,fsStrikeOut]';

     if(FontStyle=[fsItalic,fsUnderline,fsStrikeOut])
     then FonStyleInString:='[fsItalic,fsUnderline,fsStrikeOut]';

     if(FontStyle=[fsItalic,fsUnderline])
     then FonStyleInString:='[fsItalic,fsUnderline]';

     if(FontStyle=[fsItalic,fsStrikeOut])
     then FonStyleInString:='[fsItalic,fsStrikeOut]';

     if(FontStyle=[fsBold,fsItalic,fsUnderline,fsStrikeOut])
     then FonStyleInString:='[fsBold,fsItalic,fsUnderline,fsStrikeOut]';
end;


