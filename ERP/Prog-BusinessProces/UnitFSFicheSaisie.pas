                    and(TableauDetaiMouvement.Cells[C,0]=inttostr(RDetailMouvement.RRegistreFormule4.PositionFormule))
                    then
                    begin
                         OKFormule:=true;
                         TableauDetaiMouvement.Cells[C,Row]:=Vergule(floattostr(RDetailMouvement.RRegistreFormule4.ValeurFormule),'2','C','');
                    end;

                    if(OKFormule=false)
                    and(TableauDetaiMouvement.Cells[C,0]<>'')
                    and(TableauDetaiMouvement.Cells[C,0]=inttostr(RDetailMouvement.RRegistreFormule5.PositionFormule))
                    then
                    begin
                         OKFormule:=true;
                         TableauDetaiMouvement.Cells[C,Row]:=Vergule(floattostr(RDetailMouvement.RRegistreFormule5.ValeurFormule),'2','C','');
                    end;

                    if(OKFormule=false)
