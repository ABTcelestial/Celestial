procedure TFSFicheSaisie.StaticText7Click(Sender: TObject);
var  R:integer; OKArticle:boolean; RebriqueRecherche:string;
begin
     FSFicheSaisie.AfficheCliqueDroitTableauListeMouvement.Visible:=false;
     FSFicheSaisie.AffichePrintBordereauRemiseCodeBarre.Visible:=true;
     FSFicheSaisie.EditNomPrenomEmploye.Text:='';

     FSFicheSaisie.TableauRemiseCodeBarre.ColCount:=6;
     FSFicheSaisie.TableauRemiseCodeBarre.Cols[0].Text:='N°';
     FSFicheSaisie.TableauRemiseCodeBarre.Cols[1].Text:='Code';
     FSFicheSaisie.TableauRemiseCodeBarre.Cols[2].Text:='Désignation';
     FSFicheSaisie.TableauRemiseCodeBarre.Cols[3].Text:='U.M';
     FSFicheSaisie.TableauRemiseCodeBarre.Cols[4].Text:='Quantité';
     FSFicheSaisie.TableauRemiseCodeBarre.Cols[5].Text:='Code Barre';

     FSFicheSaisie.TableauRemiseCodeBarre.RowCount:=2;
     FSFicheSaisie.TableauRemiseCodeBarre.Rows[1].Text:='';
     R:=6;
     while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)do
     begin
           FSFicheSaisie.TableauRemiseCodeBarre.Rows[R-5].Text:=inttostr(R-5);
           FSFicheSaisie.TableauRemiseCodeBarre.Cells[1,R-5]:=FSFicheSaisie.TableauDetaiMouvement.Cells[1,R];
           FSFicheSaisie.TableauRemiseCodeBarre.Cells[2,R-5]:=FSFicheSaisie.TableauDetaiMouvement.Cells[2,R]+' '+FSFicheSaisie.TableauDetaiMouvement.Cells[3,R];
           FSFicheSaisie.TableauRemiseCodeBarre.Cells[3,R-5]:='T';
           FSFicheSaisie.TableauRemiseCodeBarre.Cells[4,R-5]:=FSFicheSaisie.TableauDetaiMouvement.Cells[6,R];

           RStockArticleCopie:=ChercherStockArticle('Article','',FSFicheSaisie.TableauRemiseCodeBarre.Cells[1,R-5],'CodeArticle',OKArticle,RebriqueRecherche);
           FSFicheSaisie.TableauRemiseCodeBarre.Cells[5,R-5]:=RStockArticleCopie.CodeBarre;
     R:=R+1;
     end;

     if(R-5>0)then FSFicheSaisie.TableauRemiseCodeBarre.RowCount:=R-5
              else FSFicheSaisie.TableauRemiseCodeBarre.RowCount:=2;

     AjusterColWidth(FSFicheSaisie.TableauRemiseCodeBarre,'','');
     
     FSFicheSaisie.EditNomPrenomEmploye.SetFocus;
     
end;

