procedure TFSFicheSaisie.StaticText4Click(Sender: TObject);
var  R:integer; NumMin,NumMax,DateMin,DateMax,TimeMin,TimeMax,dateBegin:string;
begin
     FSFicheSaisie.AfficheCliqueDroitTableauListeMouvement.Visible:=false;

     NumMin:='999999999';
     NumMax:='0';
     DateMin:='31/12/9999';
     DateMax:='01/01/1000';
     TimeMin:='23:59:59';
     TimeMax:='00:00:00';
     R:=1;
     while(R<=FSFicheSaisie.TableauListeMouvement.RowCount-1)do
     begin
          if(NumMin<>'99999999')then
          begin
               if(strtointeger(NumMin)>strtointeger(FSFicheSaisie.TableauListeMouvement.Cells[2,R]))then NumMin:=FSFicheSaisie.TableauListeMouvement.Cells[2,R];
          end
          else NumMin:=FSFicheSaisie.TableauListeMouvement.Cells[2,R];

          if(NumMax<>'0')then
          begin
               if(strtointeger(NumMax)<strtointeger(FSFicheSaisie.TableauListeMouvement.Cells[2,R]))then NumMax:=FSFicheSaisie.TableauListeMouvement.Cells[2,R];
          end
          else NumMax:=FSFicheSaisie.TableauListeMouvement.Cells[2,R];

          if(timecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[50,R]))then
          begin
               if(DateMin<>'31/12/9999')then
               begin
                    if(strtotime(DateMin)>strtotime(FSFicheSaisie.TableauListeMouvement.Cells[50,R]))then DateMin:=FSFicheSaisie.TableauListeMouvement.Cells[50,R];
               end
               else DateMin:=FSFicheSaisie.TableauListeMouvement.Cells[50,R];

               if(DateMax<>'01/01/1000')then
               begin
                    if(strtotime(DateMax)<strtotime(FSFicheSaisie.TableauListeMouvement.Cells[50,R]))then DateMax:=FSFicheSaisie.TableauListeMouvement.Cells[50,R];
               end
               else DateMax:=FSFicheSaisie.TableauListeMouvement.Cells[50,R];
          end;

          if(timecorrecte(FSFicheSaisie.TableauListeMouvement.Cells[51,R]))then
          begin
               if(TimeMin<>'23:59:59')then
               begin
                    if(strtotime(TimeMin)>strtotime(FSFicheSaisie.TableauListeMouvement.Cells[51,R]))then TimeMin:=FSFicheSaisie.TableauListeMouvement.Cells[51,R];
               end
               else TimeMin:=FSFicheSaisie.TableauListeMouvement.Cells[51,R];

               if(TimeMax<>'00:00:00')then
               begin
                    if(strtotime(TimeMax)<strtotime(FSFicheSaisie.TableauListeMouvement.Cells[51,R]))then TimeMax:=FSFicheSaisie.TableauListeMouvement.Cells[51,R];
               end
               else TimeMax:=FSFicheSaisie.TableauListeMouvement.Cells[51,R];
          end;
     R:=R+1;
     end;

     if(DateMin='31/12/9999')then DateMin:=datetostr(date);
     if(DateMax='01/01/1000')then DateMax:=datetostr(date);
     if(TimeMin='23:59:59')then TimeMin:='00:00:00';

     FSFicheSaisie.EditCodeUtilisateurPriodique.Text:='';
     FSFicheSaisie.EditUtilisateurPriodique.Text:='';

     FSFicheSaisie.IncrimenteEditNumLMBeginUtilisateurPriodique.Min:=strtointeger(NumMin);
     FSFicheSaisie.IncrimenteEditNumLMBeginUtilisateurPriodique.Max:=strtointeger(NumMax);
     FSFicheSaisie.IncrimenteEditNumLMBeginUtilisateurPriodique.Position:=strtointeger(NumMin);

     FSFicheSaisie.IncrimenteEditNumLMEndUtilisateurPriodique.Min:=strtointeger(NumMin);
     FSFicheSaisie.IncrimenteEditNumLMEndUtilisateurPriodique.Max:=strtointeger(NumMax);
     FSFicheSaisie.IncrimenteEditNumLMEndUtilisateurPriodique.Position:=strtointeger(NumMax);;


     FSFicheSaisie.EditDateLMBeginPriodique.Date:=strtodate(DateMin);
     FSFicheSaisie.EditDateLMEndPriodique.Date:=strtodate(DateMax);

     {if(FSFicheSaisie.RBListeDetailMouvementParMois.Checked=true)then
     begin
          dateBegin:='01/'+Completezerogauche(inttostr(FSFicheSaisie.EditMois.ItemIndex+1),'2')+'/'+FSFicheSaisie.EditAnnee.Text;
          FSFicheSaisie.EditDateLMBeginPriodique.Date:=strtodate(dateBegin);
          FSFicheSaisie.EditDateLMEndPriodique.Date:=strtodate(completezerogauche(inttostr(lastday(dateBegin)),'2')+'/'+Completezerogauche(inttostr(FSFicheSaisie.EditMois.ItemIndex+1),'2')+'/'+FSFicheSaisie.EditAnnee.Text);;
     end
     else
     begin
          dateBegin:=datetostr(FSFicheSaisie.EditChercheDateDetailMouvement.Date);
          FSFicheSaisie.EditDateLMBeginPriodique.Date:=strtodate(dateBegin);
          FSFicheSaisie.EditDateLMEndPriodique.Date:=strtodate(dateBegin);
     end;}

     FSFicheSaisie.EditHeureLMBeginPriodique.Time:=strtotime(TimeMin);
