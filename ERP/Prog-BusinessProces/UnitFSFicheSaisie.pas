Procedure ImprimerFacture(ApercuAvantImpression:boolean);
var R,m,NPage:integer;  OK,OKAvis:boolean; Origine,ModePaiement,Domiciliation,NumPiece:string;
begin
ModePaiement:=FSFicheSaisie.EditModePayement.Text;
NumPiece:='';
Domiciliation:='';
                     
OKAvis:=false;

if(OKAvis=true)then
begin
     if(ModePaiement='Chčque')
     or(ModePaiement='Bon')
     or(ModePaiement='Virement')
     then
     begin
          PrintFacture.TextPayement.Caption:=ModePaiement+' N°: '+NumPiece+' '+Domiciliation;
     end;

     if(ModePaiement='Espčce')then
     begin
          PrintFacture.TextPayement.Caption:=ModePaiement+' N°: '+NumPiece;
     end;

     if(ModePaiement<>'Chčque')
     and(ModePaiement<>'Bon')
     and(ModePaiement<>'Virement')
     and(ModePaiement<>'Espčce')
     then
     begin
          PrintFacture.TextPayement.Caption:=ModePaiement;
     end;

end
else
begin
     if(ModePaiement<>'')then
     begin
          if(ModePaiement='Chčque')
          or(ModePaiement='Bon')
          or(ModePaiement='Virement')
          then
          begin
               PrintFacture.TextPayement.Caption:=ModePaiement+' N°: '+NumPiece+' '+Domiciliation;
          end;

          if(ModePaiement='Espčce')
          then
          begin
               PrintFacture.TextPayement.Caption:=ModePaiement+' N°: '+NumPiece;
          end;

          if(ModePaiement='A Terme')
          then
          begin
               PrintFacture.TextPayement.Caption:=ModePaiement+' N°: '+NumPiece;
          end;

          if(ModePaiement='Autres')
          then
          begin
               PrintFacture.TextPayement.Caption:=ModePaiement+' N°: '+NumPiece;
          end;
     end;
end;

if(FSFicheSaisie.RBInfoAdresseExecutionMouvement.Checked=true)then
begin
     if(FSFicheSaisie.RBAvecLocalisationGeographique.Checked=true)then
     begin
          if(FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text<>'')then
          begin
               PrintFacture.Projet.Caption:='Destination: ';
               PrintFacture.TextProjet.Lines.Text:=FSFicheSaisie.EditInfoAdresseExecutionMouvement.Text;
          end
          else
          begin
               PrintFacture.Projet.Caption:='Adresse: ';
               PrintFacture.TextProjet.Lines.Text:=FSFicheSaisie.EditAdresseExecutionMouvement.Text;
          end;
     end
     else
     begin
          if(FSFicheSaisie.RBAfficheReferenceListeMouvement.Checked=true)and(FSFicheSaisie.EditReferenceListeMouvement.Text<>'')then
          begin
               PrintFacture.Projet.Caption:='Réf:'+FSFicheSaisie.EditTitreReferenceListeMouvement.Text;
               PrintFacture.TextProjet.Lines.Text:=FSFicheSaisie.EditReferenceListeMouvement.Text;
          end
          else
          begin
               PrintFacture.Projet.Caption:='';
               PrintFacture.TextProjet.Lines.Text:='';
          end;
     end;
end;

R:=6;
OK:=false;
while(R<=FSFicheSaisie.TableauDetaiMouvement.RowCount-1)and(OK=false)do
begin
     if(FSFicheSaisie.TableauDetaiMouvement.Cells[1,R]='')
     then
     begin
          OK:=true;
          showmessage('Veuillez enregistrer les modifications avant l''impression SVP !');
     end;
     R:=R+1;
end;

if(OK=false)
and(FSFicheSaisie.TableauListeMouvement.Cells[1,FSFicheSaisie.TableauListeMouvement.Row]<>'')then
begin
Division(FSFicheSaisie.TableauDetaiMouvement.RowCount-5,15,NPage,m);
if(m>0)then NPage:=NPage+1;
{*******************Entreprise***************}
OpenFParc(RParc);
PrintFacture.TextEntreprise.Caption:=RParc.Text1;

PrintFacture.DataEntreprise.Lines.Text:='';
PrintFacture.DataEntreprise.Lines.Add(RParc.Text2);
PrintFacture.DataEntreprise.Lines.Add(RParc.Text3);
PrintFacture.DataEntreprise.Lines.Add(RParc.Text4);
PrintFacture.DataEntreprise.Lines.Add(RParc.Text5);
PrintFacture.DataEntreprise.Lines.Add(RParc.Text6);
PrintFacture.DataEntreprise.Lines.Add(RParc.Text7);
PrintFacture.DataEntreprise.Lines.Add(RParc.Text8);
PrintFacture.DataEntreprise.Lines.Add(RParc.Text9);
