          FSTiers.TableauCompteTiers.SetFocus;
     end
     else
     begin
          if(FSTiers.EditCodeTiers.Text='')
          or((FSTiers.EditCodeTiers.Text<>'')and(Firstlaters(FSTiers.EditCodeTiers.Text,longueur(FSTiers.TableauListeCompteCP.Cells[1,FSTiers.TableauListeCompteCP.Row]))<>FSTiers.TableauListeCompteCP.Cells[1,FSTiers.TableauListeCompteCP.Row])) then
          begin
               TypeProces:=FSTiers.EditSelectTypeProces.Text;
               FichierConcerne:=FSTiers.EditFichierConcerne.Text;
               Adresse:='';
               if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
               begin
                    //AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
               end;

               ChClient:=Adresse;
               assignfile(FClient,ChClient);
               if FileExists(ChClient)then
               Reset(FClient)
               else Rewrite(FClient);
               Seek(FClient,0);
               OrdreClient:=1;
               while not eof(FClient)do
               begin
                    read(FClient,RClient);
                    if(FSTiers.TableauListeCompteCP.Cells[1,FSTiers.TableauListeCompteCP.Row]<>'')then
                    begin
                         if(Firstlaters(RClient.CodeTiers,6)=FSTiers.TableauListeCompteCP.Cells[1,FSTiers.TableauListeCompteCP.Row])then
                         begin
                              if(strtointeger(lastlaters(RClient.CodeTiers,4))>=OrdreClient)then OrdreClient:=strtointeger(lastlaters(RClient.CodeTiers,4))+1;
                         end;
                    end
                    else
                    begin
                         if(strtointeger(lastlaters(RClient.CodeTiers,4))>=OrdreClient)then OrdreClient:=strtointeger(lastlaters(RClient.CodeTiers,4))+1;
                    end;
               end;
               Closefile(FClient);
          FSTiers.EditCodeTiers.Text:=FSTiers.TableauListeCompteCP.Cells[1,FSTiers.TableauListeCompteCP.Row]+Completezerogauche(inttostr(OrdreClient),'4');
          end;

          FSTiers.EditNom.SetFocus;
          FSTiers.AfficheListeCompteCP.Visible:=false;
     end;
end;

