Procedure ListeTypeFichierTiersBox(TypeProcesRecherche,FichierConcerneCondition,BaseAvisCondition:string; ListeFichierConcerne:TComboBox; TitreFichierConcerne:TLabel);
var  i:integer;   OKTypeFichierTiers:boolean;    TypeProces,FichierConserne,Adresse:string;
begin
ListeFichierConcerne.Items.Text:='';

TypeProces:='Business';   FichierConserne:='FTypeFichierTiers';
if not(FunctionAdresseProces(TypeProces,FichierConserne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
begin
     AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConserne+' recherché !');
end;

ChTypeFichierTiers:=Adresse;
assignfile(FTypeFichierTiers,ChTypeFichierTiers);
if FileExists(ChTypeFichierTiers)then
begin
     Reset(FTypeFichierTiers);
     Seek(FTypeFichierTiers,0);
     i:=0;
     while not eof(FTypeFichierTiers)do
     begin
          read(FTypeFichierTiers,RTypeFichierTiers);

          if(TypeProcesRecherche<>'Tous')then
          begin
               if(RTypeFichierTiers.TypeProces=TypeProcesRecherche)
               then OKTypeFichierTiers:=true
               else OKTypeFichierTiers:=false;

          end
          else OKTypeFichierTiers:=true;

          if(OKTypeFichierTiers=true)then
          begin
               if(FichierConcerneCondition<>'')then
               begin
                    if(FunctionFichierInclu(RTypeFichierTiers.FichierConcerne,FichierConcerneCondition)=true)
                    then OKTypeFichierTiers:=true
                    else OKTypeFichierTiers:=false;
               end;
          end;

          if(OKTypeFichierTiers=true)then
          begin
               if(BaseAvisCondition<>'')then
               begin
                    if(FunctionFichierInclu(RTypeFichierTiers.BaseAvis,BaseAvisCondition)=true)
                    then OKTypeFichierTiers:=true
                    else OKTypeFichierTiers:=false;
               end;
          end;

          if(OKTypeFichierTiers=true)then
          begin
               i:=i+1;
               ListeFichierConcerne.Items.Add(RTypeFichierTiers.FichierConcerne);
          end;
      end;
      CloseFile(FTypeFichierTiers);
end;

ListeFichierConcerne.ItemIndex:=0;
TitreFichierConcerne.Caption:=inttostr(i)+' Fichier Consérner !';
