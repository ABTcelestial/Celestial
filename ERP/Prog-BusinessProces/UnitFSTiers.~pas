procedure TFSTiers.EditListeNomPosteReseauxNonAutoriserEnter(
  Sender: TObject);
var  R:integer;
begin
     FSTiers.TableauPosteReseaux.Top:=FSTiers.AfficheOperationTiers.Top+
                                      FSTiers.PageTiers.Top+
                                      FSTiers.EditListeNomPosteReseauxNonAutoriser.Top+
                                      FSTiers.EditListeNomPosteReseauxNonAutoriser.Height+27;
     FSTiers.TableauPosteReseaux.Left:=FSTiers.AfficheOperationTiers.Left+
                                       FSTiers.PageTiers.Left+
                                       FSTiers.EditListeNomPosteReseauxNonAutoriser.Left+4;
     
     FSTiers.TableauPosteReseaux.Visible:=true;

     FSTiers.TableauPosteReseaux.ColCount:=3;
     FSTiers.TableauPosteReseaux.Cols[0].Text:='Sélect';
     FSTiers.TableauPosteReseaux.Cols[1].Text:='Nom Poste';
     FSTiers.TableauPosteReseaux.Cols[2].Text:='Adresse';

     FSTiers.TableauPosteReseaux.RowCount:=2;
     FSTiers.TableauPosteReseaux.Rows[1].Text:='';

     OpenFParc(RParc);
     ChAdresseDossierPartageReseaux:=RParc.Parcours+'\'+Exercice+'FAdresseDossierPartageReseaux';
     assignfile(FAdresseDossierPartageReseaux,ChAdresseDossierPartageReseaux);
     if FileExists(ChAdresseDossierPartageReseaux)then
     Reset(FAdresseDossierPartageReseaux)
     else Rewrite(FAdresseDossierPartageReseaux);
     Seek(FAdresseDossierPartageReseaux,0);
     R:=0;
     while not eof(FAdresseDossierPartageReseaux)do
     begin
          read(FAdresseDossierPartageReseaux,RAdresseDossierPartageReseaux);

          if(RAdresseDossierPartageReseaux.EmlacementLocalOuReseaux='Réseaux')then
          begin
               R:=R+1;
               FSTiers.TableauPosteReseaux.Rows[R].Text:='';

               if ExisteCharInString(AnsiUpperCase(RAdresseDossierPartageReseaux.NomPosteReseaux),AnsiUpperCase(FSTiers.EditListeNomPosteReseauxNonAutoriser.Text))
               then FSTiers.TableauPosteReseaux.Cells[0,R]:='OK'
               else FSTiers.TableauPosteReseaux.Cells[0,R]:='';
               FSTiers.TableauPosteReseaux.Cells[1,R]:=RAdresseDossierPartageReseaux.NomPosteReseaux;
               FSTiers.TableauPosteReseaux.Cells[2,R]:=RAdresseDossierPartageReseaux.AdresseDossierPartageReseaux;
          end;
     end;
     CloseFile(FAdresseDossierPartageReseaux);

     if(R>0)then FSTiers.TableauPosteReseaux.RowCount:=R+1
            else FSTiers.TableauPosteReseaux.RowCount:=2;

     AjusterColWidth(FSTiers.TableauPosteReseaux,'','');
     FSTiers.TableauPosteReseaux.SetFocus;
end;

