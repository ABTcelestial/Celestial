Procedure ImporteTitreDataTiers(TypeProces,FichierConcerne:string);
     var  OKTitreDataTiers:boolean; TypeProcesInt,FichierConcerneInt,Adresse:string;
begin
     FSTiers.EditTitreDataTiers1.Text:='';
     FSTiers.RBChampsObligatoire1.Checked:=false;
     FSTiers.EditTitreDataTiers2.Text:='';
     FSTiers.RBChampsObligatoire2.Checked:=false;
     FSTiers.EditTitreDataTiers3.Text:='';
     FSTiers.RBChampsObligatoire3.Checked:=false;
     FSTiers.EditTitreDataTiers4.Text:='';
     FSTiers.RBChampsObligatoire4.Checked:=false;
     FSTiers.EditTitreDataTiers5.Text:='';
     FSTiers.RBChampsObligatoire5.Checked:=false;
     FSTiers.EditTitreDataTiers6.Text:='';
     FSTiers.RBChampsObligatoire6.Checked:=false;

     TypeProcesInt:='Business';
     FichierConcerneInt:='FTitreDataTiers';
     Adresse:='';
     if not(FunctionAdresseProces(TypeProcesInt,FichierConcerneInt,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerneInt+' recherché !');
     end;

     ChTitreDataTiers:=Adresse;
     assignfile(FTitreDataTiers,ChTitreDataTiers);
     if FileExists(ChTitreDataTiers)then
     Reset(FTitreDataTiers)
     else Rewrite(FTitreDataTiers);
     Seek(FTitreDataTiers,0);
     OKTitreDataTiers:=false;
     while not eof(FTitreDataTiers)and(OKTitreDataTiers=false)do
     begin
          read(FTitreDataTiers,RTitreDataTiers);

          if(RTitreDataTiers.TypeProces=TypeProces)
          then OKTitreDataTiers:=true
          else OKTitreDataTiers:=false;

          if(OKTitreDataTiers=true)then
          begin
               if(RTitreDataTiers.FichierConcerne=FichierConcerne)
               then OKTitreDataTiers:=true
               else OKTitreDataTiers:=false;
          end;

          if(OKTitreDataTiers=true)then
          begin
               FSTiers.EditTitreDataTiers1.Text:=RTitreDataTiers.TitreData1.TitreData;
               FSTiers.RBChampsObligatoire1.Checked:=RTitreDataTiers.TitreData1.ChampsObligatoire;
               FSTiers.EditTitreDataTiers2.Text:=RTitreDataTiers.TitreData2.TitreData;
               FSTiers.RBChampsObligatoire2.Checked:=RTitreDataTiers.TitreData2.ChampsObligatoire;
               FSTiers.EditTitreDataTiers3.Text:=RTitreDataTiers.TitreData3.TitreData;
               FSTiers.RBChampsObligatoire3.Checked:=RTitreDataTiers.TitreData3.ChampsObligatoire;
               FSTiers.EditTitreDataTiers4.Text:=RTitreDataTiers.TitreData4.TitreData;
               FSTiers.RBChampsObligatoire4.Checked:=RTitreDataTiers.TitreData4.ChampsObligatoire;
               FSTiers.EditTitreDataTiers5.Text:=RTitreDataTiers.TitreData5.TitreData;
               FSTiers.RBChampsObligatoire5.Checked:=RTitreDataTiers.TitreData5.ChampsObligatoire;
               FSTiers.EditTitreDataTiers6.Text:=RTitreDataTiers.TitreData6.TitreData;
               FSTiers.RBChampsObligatoire6.Checked:=RTitreDataTiers.TitreData6.ChampsObligatoire;
          end;
     end;
     CloseFile(FTitreDataTiers);
end;

