procedure TFSTiers.BitBtn4Click(Sender: TObject);
var  i:integer;  TypeProces,FichierConcerne,FichierConcerneTranfert:string;   Confirme:boolean;
     ChercheNumTypeAvis,ChercheSigneDebitCredit:integer;
begin

if(FSTiers.BitOperationTiers.Caption='Valider')then
begin
     //             MSIE A JOUR FAVIS
     TypeProces:=FSTiers.EditSelectTypeProces.Text;
     FichierConcerne:=FSTiers.EditFichierConcerne.Text;
     FichierConcerneTranfert:=FSTiers.EditFichierConcerneTranfert.Text;

     Confirme:=false;

     if(FSTiers.EditCodeTiers.Text<>FSTiers.EditCodeOperation.Text)then
     begin
          showmessage('Veuillez modifier d''abords l''enregistrement avant transfert !');
          Exit;
     end;

     if(FichierConcerneTranfert='')then
     begin
          showmessage('Veuillez choisir le fichier distinataire !');
          Exit;
     end;

     if(FSTiers.EditFichierConcerneTranfert.Text<>FSTiers.EditFichierConcerne.Text)then
     begin
          OpenFParc(RParc);
          ChAvis:=RParc.Parcours+'\'+Exercice+'FAvis';
          assignfile(FAvis,ChAvis);
          if FileExists(ChAvis)then
          Reset(FAvis)
          else Rewrite(FAvis);
          Seek(FAvis,0);
          i:=0;
          while not eof(FAvis)do
          begin
               read(FAvis,RAvis);

               if(RAvis.AvisConcerneTiers<>'')and(FichierConcerne<>'')then
               begin
                    if(RAvis.CodeTiers=FSTiers.EditCodeOperation.Text)
                    and(RAvis.TypeProces=TypeProces)
                    and(RAvis.AvisConcerneTiers=FichierConcerne)
                    then
                    begin
                         Confirme:=true;
                         RAvis.AvisConcerneTiers:=FSTiers.EditFichierConcerneTranfert.Text;
                         Seek(FAvis,i);
                         write(FAvis,RAvis);
                    end;
               end;                
          i:=i+1;
          end;
          Closefile(FAvis);
     end;

     //       MISE A JOU LISTE MOUVEMENT

     if(FSTiers.EditFichierConcerneTranfert.Text<>FSTiers.EditFichierConcerne.Text)then
     begin
          OpenFParc(RParc);
          ChListeMouvement:=RParc.Parcours+'\'+Exercice+'FListeMouvement';
          assignfile(FListeMouvement,ChListeMouvement);
          if FileExists(ChListeMouvement)then
          Reset(FListeMouvement)
          else begin Showmessage('Attention ! '+ChListeMouvement+' n''existe pas !'); Exit; end;
          Seek(FListeMouvement,0);
          i:=0;
          while not eof(FListeMouvement)do
          begin
               read(FListeMouvement,RListeMouvement);

               if(RListeMouvement.CodeTiers=FSTiers.EditCodeOperation.Text)
               and(RListeMouvement.TypeProces=TypeProces)
               and(RListeMouvement.FichierTiersConserne=FichierConcerne)
               then
               begin
                    Confirme:=true;
                    RListeMouvement.FichierTiersConserne:=FSTiers.EditFichierConcerneTranfert.Text;
                    Seek(FListeMouvement,i);
                    write(FListeMouvement,RListeMouvement);

               end;
          i:=i+1;
          end;
          Closefile(FListeMouvement);
     end;

     if(FSTiers.EditFichierConcerneTranfert.Text<>FSTiers.EditFichierConcerne.Text)then
     begin
          OpenFParc(RParc);
          ChListeGroupeTiers:=RParc.Parcours+'\'+Exercice+'FListeGroupeTiers';
          assignfile(FListeGroupeTiers,ChListeGroupeTiers);
          if FileExists(ChListeGroupeTiers)then
          Reset(FListeGroupeTiers)
          else Rewrite(FListeGroupeTiers);
          Seek(FListeGroupeTiers,0);
          i:=0;
          while not eof(FListeGroupeTiers)do
          begin
               read(FListeGroupeTiers,RListeGroupeTiers);

               RGroupeTiersCopie:=ChercheGroupeTiers(RListeGroupeTiers.PositionGroupeTiers);

               if(RListeGroupeTiers.CodeTiers=FSTiers.EditCodeOperation.Text)
               and(RGroupeTiersCopie.TypeProces=TypeProces)
               and(RGroupeTiersCopie.FichierConcerneTiers=FichierConcerne)
               then
               begin
                    Confirme:=true;
                    showmessage('Veuillez consulter la liste des groupes !');
                    //RListeGroupeTiers.CodeTiers:=FSTiers.EditCodeTiers.Text;
                    //Seek(FListeGroupeTiers,i);
                    //write(FListeGroupeTiers,RListeGroupeTiers);
               end;
          i:=i+1;
          end;
          Closefile(FListeGroupeTiers);
     end;

     if(EnregistrementTiers(TypeProces,FichierConcerneTranfert,FSTiers.EditCodeOperation.Text))then
     begin
          DeleteFTiers(FSTiers.EditCodeTiers.Text,FSTiers.EditSelectTypeProces.Text,FSTiers.EditFichierConcerne.Text,Confirme);
     end
     else
     begin
          showmessage('Le registre n''est pas transféré !');
     end;
end;

ListeTiersMotsCle(FSTiers.TableauTiers,FSTiers.EditSelectTypeProces.Text,FSTiers.EditFichierConcerne.Text,'','',FSTiers.EditRechercheTiers.Text,EditNbrKeyUp,EditNbrKeyUpMemo,FSTiers.TimerLancerAfficheTiers,false,FSTiers.RBRechercheTiersMotCle.Checked);
FSTiers.AfficheOperationTiers.Visible:=false;
end;

