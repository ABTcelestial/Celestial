     if(FunctionAdresseProces(TypeProces,FicheirConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut)=true)then
     begin
          if(TypeProces='Paie')then
          begin
               if(FicheirConcerne='FPersonnel')then
               begin
                    ChPersonnel:=Adresse;
