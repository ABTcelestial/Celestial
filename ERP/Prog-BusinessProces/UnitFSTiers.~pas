Function MaskTelephone(NumTelephone:string):string;
var  T:integer;  Mask:string;
begin
     T:=1;
     Mask:='';
     While(T<=longueur(NumTelephone))do
     begin
          if(NumTelephone[T]<>'-')then
          begin
               Mask:=Mask+'9';
          end
          else
          begin
               Mask:=Mask+'-';
          end;
     T:=T+1;
     end;
     if(mask='')then Mask:='999-99-99-99';
     MaskTelephone:=Mask+';1;';
end;

