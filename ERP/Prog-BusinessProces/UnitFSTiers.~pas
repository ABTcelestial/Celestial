procedure TFSTiers.TableauPosteReseauxExit(Sender: TObject);
var  R:integer;
begin
     FSTiers.EditListeNomPosteReseauxNonAutoriser.Text:='';
     FSTiers.TableauPosteReseaux.Visible:=false;
     R:=1;
     while(R<=FSTiers.TableauPosteReseaux.RowCount-1)do
     begin
          if(FSTiers.TableauPosteReseaux.Cells[0,R]='OK')then
          begin
               if(FSTiers.EditListeNomPosteReseauxNonAutoriser.Text='')
               then FSTiers.EditListeNomPosteReseauxNonAutoriser.Text:=FSTiers.TableauPosteReseaux.Cells[1,R]
               else FSTiers.EditListeNomPosteReseauxNonAutoriser.Text:=FSTiers.EditListeNomPosteReseauxNonAutoriser.Text+';'+FSTiers.TableauPosteReseaux.Cells[1,R];
          end;
     R:=R+1;
     end;

     FSTiers.BitOperationTiers.SetFocus;
end;

