if key in[VK_RETURN]then
begin
     if Strtoboolean(FSTiers.TableauListeCompteCP.Cells[6,FSTiers.TableauListeCompteCP.Row])=true then
     begin
          FSTiers.AfficheCompteTiers.Visible:=true;
