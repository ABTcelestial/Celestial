function IsApplicationRunning(const ExecutablePath: string): Boolean;
var
  hSnapshot: THandle;
  ProcessEntry32: TProcessEntry32;
  hProcess: THandle;
  ModuleName: array[0..MAX_PATH] of Char;
  I: Integer;
begin
  Result := False;
  hSnapshot := CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
  if hSnapshot <> INVALID_HANDLE_VALUE then
  begin
    ProcessEntry32.dwSize := SizeOf(ProcessEntry32);
    if Process32First(hSnapshot, ProcessEntry32) then
    begin
      repeat
        hProcess := OpenProcess(PROCESS_QUERY_INFORMATION or PROCESS_VM_READ, False, ProcessEntry32.th32ProcessID);
        if hProcess <> 0 then
        begin
          if GetModuleFileNameEx(hProcess, 0, ModuleName, SizeOf(ModuleName)) > 0 then
          begin
            if SameText(ExtractFileName(ModuleName), ExtractFileName(ExecutablePath)) then
            begin
              Result := True;
              CloseHandle(hProcess);
              break;
            end;
          end;
          CloseHandle(hProcess);
        end;
      until not Process32Next(hSnapshot, ProcessEntry32);
    end;
    CloseHandle(hSnapshot);
  end;
end;

function TerminateProcessByHandle(ProcessHandle: THandle): Boolean;
begin
  Result := TerminateProcess(ProcessHandle, 0);
end;

function TerminateProcessByName(const ProcessName: string): Boolean;
var
  ProcessEntry32: TProcessEntry32;
  ProcessHandle: THandle;
  hSnapshot: THandle;
begin
  Result := False;
  hSnapshot := CreateToolhelp32Snapshot(TH32CS_SNAPPROCESS, 0);
  if hSnapshot <> INVALID_HANDLE_VALUE then
  try
    ProcessEntry32.dwSize := SizeOf(ProcessEntry32);
    if Process32First(hSnapshot, ProcessEntry32) then
    repeat
      if CompareText(ProcessEntry32.szExeFile, PChar(ProcessName)) = 0 then
      begin
        ProcessHandle := OpenProcess(PROCESS_TERMINATE, False, ProcessEntry32.th32ProcessID);
        if ProcessHandle <> 0 then
        try
          Result := TerminateProcessByHandle(ProcessHandle);
        finally
          CloseHandle(ProcessHandle);
        end;
        Break; // Arręte la recherche aprčs avoir trouvé le premier processus
      end;
    until not Process32Next(hSnapshot, ProcessEntry32);
  finally
    CloseHandle(hSnapshot);
  end;
end;

Function CloseApplicationByNam(AppName: string):boolean;
var  OKFermerAppllication:boolean;
begin
     OKFermerAppllication:=TerminateProcessByName(AppName);

     if(OKFermerAppllication=true)
     then FSCourrierMail.AfficheNotificationEnvoiMail.Caption:='Application ' + AppName + ' fermée avec succčs.'
     else FSCourrierMail.AfficheNotificationEnvoiMail.Caption:='Impossible de fermer l''application ' + AppName + '.';

     CloseApplicationByNam:=OKFermerAppllication;

     FSCourrierMail.AfficheNotificationEnvoiMail.Visible:=true;
end;

