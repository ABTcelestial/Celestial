     ReInitialisationFicheMail(false);
     
     FSCourrierMail.EditMessageTexte.Text:=FSCourrierMail.MailEntreprise.Text+'&'+
                                           FSCourrierMail.CodeSecuriteMailEntreprise.Text+'&'+
                                           FSCourrierMail.EditMailTiers.Text+'&'+
