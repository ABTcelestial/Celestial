Procedure EnregistrerMailEntreprise;
begin
     OpenFParc(RParc);
     ChMailEntreprise:=RParc.Parcours+'\'+Exercice+'FMailEntreprise';
     assignfile(FMailEntreprise,ChMailEntreprise);
     if FileExists(ChMailEntreprise)then
     Reset(FMailEntreprise)
     else Rewrite(FMailEntreprise);
     Seek(FMailEntreprise,0);
     Truncate(FMailEntreprise);
     RMailEntreprise.MailEntreprise:=FSCourrierMail.MailEntreprise.Text;
     RMailEntreprise.CodeSecuriteMailEntreprise:=FSCourrierMail.CodeSecuriteMailEntreprise.Text;
     Seek(FMailEntreprise,0);
     write(FMailEntreprise,RMailEntreprise);
     CloseFile(FMailEntreprise);
end;

Function FindMailEntreprise:string;
begin
     FindMailEntreprise:='';

     OpenFParc(RParc);
     ChMailEntreprise:=RParc.Parcours+'\'+Exercice+'FMailEntreprise';
     assignfile(FMailEntreprise,ChMailEntreprise);
     if FileExists(ChMailEntreprise)then
     begin
          Reset(FMailEntreprise);
          Seek(FMailEntreprise,0);
          if not eof(FMailEntreprise)then
          begin
               read(FMailEntreprise,RMailEntreprise);

               FindMailEntreprise:=RMailEntreprise.MailEntreprise;

          end;
          CloseFile(FMailEntreprise);
     end;
end;

Function FindCodeSecuriteMailEntreprise:string;
