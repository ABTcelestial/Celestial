Procedure ProcChargerFichierParametresMail(AdresseFichierMail:string; var Resultat:string);
var  i,R,l,Nbr:integer;
     TextGlobal,TextSequance:string;
     FichierMail:TextFile;
begin
     FSCourrierMail.TableauResultaEnvoi.ColCount:=2;
     FSCourrierMail.TableauResultaEnvoi.Cols[0].Text:='Résult';
     FSCourrierMail.TableauResultaEnvoi.Cols[1].Text:='Value';

     FSCourrierMail.TableauResultaEnvoi.RowCount:=2;
     FSCourrierMail.TableauResultaEnvoi.Rows[1].Text:='';
     R:=0;

     AdresseFichierMail:=FSCourrierMail.EditAdresseFichierParametresMail.Text;

     AssignFile(FichierMail,AdresseFichierMail);
     Reset(FichierMail);
     FSCourrierMail.FichierEnvoi.Lines.Text:='';       
     while not eof(FichierMail)do
     begin
          TextGlobal:='';
          Readln(FichierMail,TextGlobal);
          FSCourrierMail.FichierEnvoi.Lines.Add(TextGlobal);
     end;
     CloseFile(FichierMail);

     FSCourrierMail.EditMessageTexte.Text:=FSCourrierMail.FichierEnvoi.Lines.Strings[0];
     TextGlobal:=FSCourrierMail.EditMessageTexte.Text;
     TextSequance:='';
     i:=1;
     Nbr:=0;
     Resultat:='';
     l:=longueur(TextGlobal);
     while(i<=l)do
     begin
          if(TextGlobal[i]<>'&')then
          begin
               TextSequance:=TextSequance+TextGlobal[i];
          end;

          if(TextGlobal[i]='&')or(i=l)then
          begin
               Nbr:=Nbr+1;

               if(Nbr=1)and(FSCourrierMail.RBMailEntreprise.Checked)then FSCourrierMail.MailEntreprise.Text:=TextSequance;
               if(Nbr=2)and(FSCourrierMail.RBCodeSecuriteMailEntreprise.Checked)then FSCourrierMail.CodeSecuriteMailEntreprise.Text:=TextSequance;
               if(Nbr=3)and(FSCourrierMail.RBEditMailTiers.Checked)then FSCourrierMail.EditMailTiers.Text:=TextSequance;
               if(Nbr=4)and(FSCourrierMail.RBEditObjet.Checked)then FSCourrierMail.EditObjet.Text:=TextSequance;
               if(Nbr=5)and(FSCourrierMail.RBEditMessage.Checked)then FSCourrierMail.EditMessage.Text:=TextSequance;
               if(Nbr=6)and(FSCourrierMail.RBEditPieceJointe.Checked)then FSCourrierMail.EditPieceJointe.Text:=TextSequance;
               if(Nbr>=7)then
               begin
                    if(TextSequance<>'0')and((TextSequance<>'1'))then TextSequance:='Aucun Résultat ('+TextSequance+')';
                    R:=R+1;
                    FSCourrierMail.TableauResultaEnvoi.Rows[R].Text:='Résult '+inttostr(R);
                    if(TextSequance='0')then FSCourrierMail.TableauResultaEnvoi.Cells[1,R]:='Non Envoiyé'
                    else
                    if(TextSequance='1')then FSCourrierMail.TableauResultaEnvoi.Cells[1,R]:='Envoyé avec succčs'
                    else
                    FSCourrierMail.TableauResultaEnvoi.Cells[1,R]:=TextSequance;

                    Resultat:=TextSequance;
               end;

               TextSequance:='';
          end;
     i:=i+1;
     end;

     if(R>0)then FSCourrierMail.TableauResultaEnvoi.RowCount:=R+1
            else FSCourrierMail.TableauResultaEnvoi.RowCount:=2;

     AjusterColWidth(FSCourrierMail.TableauResultaEnvoi,'','');

end;

procedure TFSCourrierMail.TimerControleParametresMailTimer(Sender: TObject);
var  Resultat:string;
begin
     ProcChargerFichierParametresMail(FSCourrierMail.EditAdresseFichierParametresMail.Text,Resultat);

     if(FSCourrierMail.TimerAttenteResultatEnvoiMail.Enabled=false) then FSCourrierMail.TimerAttenteResultatEnvoiMail.Enabled:=true;

     FSCourrierMail.EditResultatEnvoi.Text:=Resultat;

     if(Resultat<>'')then
     begin
          FSCourrierMail.EditIncrimenteTimer.Text:='0';
          FSCourrierMail.TimerAttenteResultatEnvoiMail.Enabled:=false;
          FSCourrierMail.TimerControleParametresMail.Enabled:=false;
          FSCourrierMail.TimerNotificationEnvoiMail.Enabled:=true;
     end;
end;

procedure TFSCourrierMail.TimerNotificationEnvoiMailTimer(Sender: TObject);
var  Couleur:TColor; MessageTexte:string;
begin
     Couleur:=clBtnFace;
     MessageTexte:='Aucun résultat';

     FSCourrierMail.AfficheNotificationEnvoiMail.Visible:=true;

     FSCourrierMail.EditIncrimenteTimer.Text:=inttostr(strtointeger(FSCourrierMail.EditIncrimenteTimer.Text)+1);

     if(FSCourrierMail.EditResultatEnvoi.Text<>'0')
     and(FSCourrierMail.EditResultatEnvoi.Text<>'1')then begin Couleur:=clYellow; MessageTexte:=FSCourrierMail.EditResultatEnvoi.Text; end;
     if(FSCourrierMail.EditResultatEnvoi.Text='0')then begin Couleur:=clRed;    MessageTexte:='Non Envoiyé'; end;
     if(FSCourrierMail.EditResultatEnvoi.Text='1')then begin Couleur:=clLime;   MessageTexte:='Envoyé avec succčs'; end;
      
     FSCourrierMail.AfficheNotificationEnvoiMail.Caption:=MessageTexte;

     if(FSCourrierMail.AfficheNotificationEnvoiMail.Color=clBtnFace)
     then FSCourrierMail.AfficheNotificationEnvoiMail.Color:=Couleur
     else FSCourrierMail.AfficheNotificationEnvoiMail.Color:=clBtnFace;

     if(strtointeger(FSCourrierMail.EditIncrimenteTimer.Text)>=50)then
     begin
          FSCourrierMail.AfficheNotificationEnvoiMail.Visible:=false;
          FSCourrierMail.TimerNotificationEnvoiMail.Enabled:=false;
     end;
end;

Procedure ReInitialisationFicheMail(All:boolean);
begin
     FSCourrierMail.TimerAttenteResultatEnvoiMail.Enabled:=false;
     FSCourrierMail.TimerControleParametresMail.Enabled:=false;
     FSCourrierMail.TimerNotificationEnvoiMail.Enabled:=false;
     FSCourrierMail.AfficheNotificationEnvoiMail.Visible:=false;

     FSCourrierMail.TableauResultaEnvoi.RowCount:=2;
     FSCourrierMail.TableauResultaEnvoi.Rows[1].Text:='';

     if(All=true)then
     begin
          FSCourrierMail.EditMailTiers.Text:='';
          FSCourrierMail.Tiers.Caption:='';
          FSCourrierMail.EditObjet.Text:='';
          FSCourrierMail.EditMessage.Lines.Text:='';
          FSCourrierMail.EditPieceJointe.Text:='';
          FSCourrierMail.FichierEnvoi.Lines.Text:='';
          FSCourrierMail.EditMessageTexte.Text:='';
     end;

