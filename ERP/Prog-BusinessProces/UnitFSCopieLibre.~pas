    ComCtrls, ToolWin, OleCtrls, ShockwaveFlashObjects_TLB, AgentObjects_TLB,
    ExtDlgs, jpeg, Mask, ShellCtrls, ActnMan, ActnCtrls, ActnMenus, ShellAPI, TlHelp32;

type
