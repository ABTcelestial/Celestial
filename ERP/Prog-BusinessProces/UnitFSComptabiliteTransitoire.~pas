procedure TFSComptabiliteTransitoire.TableauPiecesComptableKeyPress(
  Sender: TObject; var Key: Char);
var  TypeProces,FichierConcerne,Adresse:string;  OKPieceComptable:boolean;
begin

if key in['s','S']then
begin
     TypeProces:='Comptabilité';
     FichierConcerne:='FJournalGeneralTransitoire'+Firstlaters(FSComptabiliteTransitoire.EditNumEntite.Text,5);
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChJournalGeneral:=Adresse;
     assignfile(FJournalGeneral,ChJournalGeneral);
     if FileExists(ChJournalGeneral)
     then Reset(FJournalGeneral)else Rewrite(FJournalGeneral);
     Seek(FJournalGeneral,0);
     OKPieceComptable:=false;
     while not eof(FJournalGeneral)and(OKPieceComptable=false)do
     begin
          Read(FJournalGeneral,RJournalGeneral);
          if(RJournalGeneral.NumPiece=FSComptabiliteTransitoire.TableauPiecesComptable.Cells[4,FSComptabiliteTransitoire.TableauPiecesComptable.Row])then
          begin
               OKPieceComptable:=true;
               showmessage('La pičce est enregistré dans le journal comptable!');
          end;
     end;
     CloseFile(FJournalGeneral);

     if(OKPieceComptable=false)then
     begin
          FSComptabiliteTransitoire.AfficheOperationPiecesComptable.Visible:=true;
          FSComptabiliteTransitoire.BitOperationPiecesComptable.Kind:=bkCancel;
          FSComptabiliteTransitoire.BitOperationPiecesComptable.Caption:='Supprimer';
          FSComptabiliteTransitoire.BitOperationPiecesComptable.SetFocus;
     end
     else FSComptabiliteTransitoire.TableauPiecesComptable.SetFocus;
end;
end;

procedure TFSComptabiliteTransitoire.TableauJournalauxiliaireKeyPress(
  Sender: TObject; var Key: Char);
var  R:integer;
begin
     if key in['+']then
     begin
          for R:=1 to FSComptabiliteTransitoire.TableauJournalauxiliaire.RowCount-1 do
          if(R<>FSComptabiliteTransitoire.TableauJournalauxiliaire.Row)then FSComptabiliteTransitoire.TableauJournalauxiliaire.Cells[7,R]:='';

