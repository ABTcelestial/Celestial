          FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text:=FSComptabiliteTransitoire.TableauJournalauxiliaire.Cells[1,RowSelect];
          if(FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text<>'')then
