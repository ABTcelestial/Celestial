Procedure ProcImputationJournalGeneralTransitoire(NumEntite:string);
var  i,C,NumImputation:integer; TypeProces,FichierConcerne,Adresse:string;  OKExistePiece:boolean;
begin
     TypeProces:='Comptabilité';
     FichierConcerne:='FJournalGeneralTransitoire'+Firstlaters(NumEntite,5);
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     assignfile(FJournalGeneral,Adresse);
     if FileExists(Adresse)then
     begin
          Reset(FJournalGeneral);
          Seek(FJournalGeneral,0);
          i:=0;
          NumImputation:=1;
          while not eof(FJournalGeneral)do
          begin
               Read(FJournalGeneral,RJournalGeneral);
               if(NumImputation<=RJournalGeneral.NumImputation)then NumImputation:=RJournalGeneral.NumImputation+1;
          i:=i+1;
          end;

          C:=1;
          while(C<=FSComptabiliteTransitoire.TableauDataImputation.ColCount-1)do
          begin
               Seek(FJournalGeneral,i);
               Truncate(FJournalGeneral);
               RJournalGeneral.NumImputation:=NumImputation;

               if(NumEntite='Tous')
               then RJournalGeneral.NumEntite:=''
               else RJournalGeneral.NumEntite:=NumEntite;

               RJournalGeneral.CodeJournal:=FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text;
               RJournalGeneral.DateImputation:=datetostr(FSComptabiliteTransitoire.EditDateImputation.Date);
               RJournalGeneral.NumPiece:=FSComptabiliteTransitoire.EditNumPieceComptable.Text;
               RJournalGeneral.CodeTiers:=FSComptabiliteTransitoire.TableauDataImputation.Cells[C,4];
               RJournalGeneral.TypeProces:=FSComptabiliteTransitoire.TableauDataImputation.Cells[C,2];
               RJournalGeneral.FichierTiersConserne:=FSComptabiliteTransitoire.TableauDataImputation.Cells[C,3];
               RJournalGeneral.DebitCredit:=FSComptabiliteTransitoire.TableauDataImputation.Cells[C,5];
               RJournalGeneral.NumCompte:=FSComptabiliteTransitoire.TableauDataImputation.Cells[C,7];
               RJournalGeneral.MontantImputer:=strtoreal(FSComptabiliteTransitoire.TableauDataImputation.Cells[C,8]);
               write(FJournalGeneral,RJournalGeneral);
               i:=i+1;
               NumImputation:=NumImputation+1;
          C:=C+1;
          end;
          CloseFile(FJournalGeneral);
     end;
end;

Procedure ProcNouvelPieceComptable(NumEntite:string);
var  i:integer; TypeProces,FichierConcerne,Adresse:string;  OKExistePiece:boolean;
begin
     TypeProces:='Comptabilité';
     FichierConcerne:='FPiecesComptableTransitoire'+Firstlaters(NumEntite,5);
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     assignfile(FPiecesComptable,Adresse);
     if FileExists(Adresse)then
     begin
          Reset(FPiecesComptable);
          Seek(FPiecesComptable,0);
          i:=0;
          OKExistePiece:=false;
          while not eof(FPiecesComptable)and(OKExistePiece=false)do
          begin
               Read(FPiecesComptable,RPiecesComptable);
               if(RPiecesComptable.NumPiece=FSComptabiliteTransitoire.EditNumPieceComptable.Text)then
               begin
                    OKExistePiece:=true;
              end;
          i:=i+1;
          end;

          if(OKExistePiece=false)then
          begin
               Seek(FPiecesComptable,i);
               Truncate(FPiecesComptable);
               RPiecesComptable.NumPiece:=FSComptabiliteTransitoire.EditNumPieceComptable.Text;

               if(FSComptabiliteTransitoire.EditNumEntite.Text='Tous')
               then RPiecesComptable.NumEntite:=''
               else RPiecesComptable.NumEntite:=FSComptabiliteTransitoire.EditNumEntite.Text;

               RPiecesComptable.DateImputation:=datetostr(FSComptabiliteTransitoire.EditDateImputation.Date);
               RPiecesComptable.NumComptePrincipal:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,6];
               RPiecesComptable.NumCptTiers:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,7];

               RPiecesComptable.DesignationDocument:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,9];
               RPiecesComptable.NumeroDocument:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,10];
               RPiecesComptable.DateDocument:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,11];

               RPiecesComptable.IntituleOperationBase:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,15];
               RPiecesComptable.DesignationDocumentBase:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,12];
               RPiecesComptable.NumeroDocumentBase:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,13];
               RPiecesComptable.DateDocumentBase:=FSComptabiliteTransitoire.TableauDataImputation.Cells[1,14];

               write(FPiecesComptable,RPiecesComptable);
          end
          else
          begin
               showmessage('Le numéro de la pičce comptable est déjŕ enregistré !');
               Exit;
          end;
     Closefile(FPiecesComptable);
     end;
end;

