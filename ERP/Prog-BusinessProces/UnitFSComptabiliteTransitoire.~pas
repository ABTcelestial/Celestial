procedure TFSComptabiliteTransitoire.TableauEntiteKeyDown(Sender: TObject;
  var Key: Word; Shift: TShiftState);
var  i,R,OrdrePiece,NbrOK:integer; OKRowSelecte:boolean;
     NumTypeAvis:integer; CompteImputation,DebitCredit,TypeProces,FichierConcerne,JourneauxAuxiliaireUtilise,Adresse:string;
begin
     if key in[VK_RETURN]then
     begin
          FSComptabiliteTransitoire.EditNumEntite.Text:=FSComptabiliteTransitoire.TableauEntite.Cells[1,FSComptabiliteTransitoire.TableauEntite.Row];
          FSComptabiliteTransitoire.EditNomEntite.Text:=FSComptabiliteTransitoire.TableauEntite.Cells[2,FSComptabiliteTransitoire.TableauEntite.Row];
          FSComptabiliteTransitoire.TableauEntite.Visible:=false;

          if(FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text='')then
          begin
               FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.SetFocus;
          end
          else
          begin
               FSComptabiliteTransitoire.TableauJournalauxiliaire.Visible:=false;
               TypeProces:='Comptabilité';
               FichierConcerne:='FJournalGeneralTransitoire'+Firstlaters(FSComptabiliteTransitoire.EditNumEntite.Text,5);
               if not(FunctionAdresseProces(TypeProces,FichierConcerne,'',Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
               begin
                    AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
               end;

               assignfile(FJournalGeneral,Adresse);
               if FileExists(Adresse)then
               begin
                    Reset(FJournalGeneral);
                    Seek(FJournalGeneral,0);
                    i:=0;
                    OrdrePiece:=1;
                    while not eof(FJournalGeneral)do
                    begin
                         Read(FJournalGeneral,RJournalGeneral);

                         if(FSComptabiliteTransitoire.EditNumPieceComptable.Text='')
                         and(Firstlaters(RJournalGeneral.NumPiece,longueur(FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text+'/'+lastlaters(datetostr(FSComptabiliteTransitoire.EditDateImputation.Date),7)+'/'))=FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text+'/'+lastlaters(datetostr(FSComptabiliteTransitoire.EditDateImputation.Date),7)+'/')then
                         begin
                              if(OrdrePiece<=strtointeger(lastlaters(RJournalGeneral.NumPiece,longueur(RJournalGeneral.NumPiece)-longueur(Firstlaters(RJournalGeneral.NumPiece,longueur(FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text))+'/'+lastlaters(datetostr(FSComptabiliteTransitoire.EditDateImputation.Date),7)+'/'))))
                              then OrdrePiece:=strtointeger(lastlaters(RJournalGeneral.NumPiece,longueur(RJournalGeneral.NumPiece)-longueur(Firstlaters(RJournalGeneral.NumPiece,longueur(FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text))+'/'+lastlaters(datetostr(FSComptabiliteTransitoire.EditDateImputation.Date),7)+'/')))+1;
                         end;
                    i:=i+1;
                    end;
                    FSComptabiliteTransitoire.EditNumPieceComptable.Text:=FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text+'/'+lastlaters(datetostr(FSComptabiliteTransitoire.EditDateImputation.Date),7)+'/'+Completezerogauche(inttostr(OrdrePiece),'2');
               end
               else
               begin
                    Affichermessage('Le fichier Adresse n''existe pas !');
               end;
          end;
     end;
end;

