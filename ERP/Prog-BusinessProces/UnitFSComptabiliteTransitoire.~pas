procedure TFSComptabiliteTransitoire.TabSheet2Show(Sender: TObject);
var     TypeProces,FichierConcerne,Adresse:string;  OKExisteJournal:boolean;
begin
     TypeProces:='Comptabilité';
     FichierConcerne:='FJournalauxiliaire';
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;
     FSComptabiliteTransitoire.EditJournal.Text:='';
     ChJournalauxiliaire:=Adresse;
     assignfile(FJournalauxiliaire,ChJournalauxiliaire);
     if FileExists(ChJournalauxiliaire)
     then Reset(FJournalauxiliaire)else Rewrite(FJournalauxiliaire);
     Seek(FJournalauxiliaire,0);
     OKExisteJournal:=false;
     while not eof(FJournalauxiliaire)and(OKExisteJournal=false)do
     begin
          Read(FJournalauxiliaire,RJournalauxiliaire);
          if(firstlaters(FSComptabiliteTransitoire.EditJournalAuxiliaireUtiliseAvis.Text,longueur(RJournalauxiliaire.CodeJournal))=RJournalauxiliaire.CodeJournal)then
          begin
               OKExisteJournal:=true;
               FSComptabiliteTransitoire.EditJournal.Text:=RJournalauxiliaire.Designation;
          end;
     end;
     CloseFile(FJournalauxiliaire);
     
     ProcListePiecesComptable(FSComptabiliteTransitoire.TableauPiecesComptable,FSComptabiliteTransitoire.RBPieceEntitePrecise.Checked,'',FSComptabiliteTransitoire.RBExtentionFichierConcerne.Caption,'');
end;

Procedure ProcListePiecesComptable(TableauPiecesComptable:TStringGrid; PieceEntitePrecise:boolean; NPiece,ExtentionFichierConcerne,RowSelect:string);
var i:integer; OKpiece:boolean;   TypeProces,FichierConcerne,Adresse:string;
begin
     TableauPiecesComptable.RowCount:=2;
     TableauPiecesComptable.Rows[1].Text:='';
     TableauPiecesComptable.Cols[0].Text:='N°';
     TableauPiecesComptable.Cols[1].Text:='Date Imputation';
     TableauPiecesComptable.Cols[2].Text:='Cpt Principal';
     TableauPiecesComptable.Cols[3].Text:='Tiers';
     TableauPiecesComptable.Cols[4].Text:='Num Pičce';
     TableauPiecesComptable.Cols[5].Text:='Désignation';
     TableauPiecesComptable.Cols[6].Text:='Numéro';
     TableauPiecesComptable.Cols[7].Text:='Date';
     TableauPiecesComptable.Cols[8].Text:='Intitulé de l''opération';
     TableauPiecesComptable.Cols[9].Text:='DesignationDocumentBase';
     TableauPiecesComptable.Cols[10].Text:='NumeroDocumentBase';
     TableauPiecesComptable.Cols[11].Text:='DateDocumentBase';
     TableauPiecesComptable.Cols[12].Text:='NumEntite';
     TableauPiecesComptable.Cols[13].Text:='Entité';

     TypeProces:='Comptabilité';
     FichierConcerne:='FPiecesComptableTransitoire'+Firstlaters(FSComptabiliteTransitoire.EditNumEntite.Text,5);
     if not(FunctionAdresseProces(TypeProces,FichierConcerne,Adresse,TypeProcesReseaux,NomDossierPartageReseauxOut))then
     begin
          AfficherMessage('Veuillez indiquer l''adresse du Proces qui génére le fichier '+FichierConcerne+' recherché !');
     end;

     ChPiecesComptable:=Adresse;
     assignfile(FPiecesComptable,ChPiecesComptable);
     if FileExists(ChPiecesComptable)
     then Reset(FPiecesComptable)else Rewrite(FPiecesComptable);
     Seek(FPiecesComptable,0);
     i:=0;
     while not eof(FPiecesComptable)do
     begin
          Read(FPiecesComptable,RPiecesComptable);

          if(FSComptabiliteTransitoire.EditNumEntite.Text<>'')then
          begin
               if(PieceEntitePrecise=true)then
               begin
                    if(RPiecesComptable.NumEntite=FSComptabiliteTransitoire.EditNumEntite.Text)
                    then OKPiece:=true
                    else OKPiece:=false;
               end
               else
               begin
                    if(firstlaters(RPiecesComptable.NumEntite,longueur(FSComptabiliteTransitoire.EditNumEntite.Text))=FSComptabiliteTransitoire.EditNumEntite.Text)
                    then OKPiece:=true
                    else OKPiece:=false;
               end;
          end
          else OKPiece:=false;

          if(OKPiece=true)then
          begin
               if(NPiece<>'')then
               begin
                    if(firstlaters(RPiecesComptable.NumPiece,longueur(NPiece))=NPiece)
                    then OKPiece:=true
                    else OKPiece:=false;
               end;
          end;

          if(OKPiece=true)then
          begin
          i:=i+1;
          TableauPiecesComptable.Rows[i].Text:=inttostr(i);
          TableauPiecesComptable.Cells[1,i]:=RPiecesComptable.DateImputation;
          TableauPiecesComptable.Cells[2,i]:=RPiecesComptable.NumComptePrincipal;
          TableauPiecesComptable.Cells[3,i]:=RPiecesComptable.NumCptTiers;
          TableauPiecesComptable.Cells[4,i]:=RPiecesComptable.NumPiece;
          RTiersCopie:=ChercherTiers('','',RPiecesComptable.NumCptTiers,'');
          TableauPiecesComptable.Cells[5,i]:=RPiecesComptable.DesignationDocument+' '+RTiersCopie.NomTiers+' '+RTiersCopie.PrenomTiers;
          TableauPiecesComptable.Cells[6,i]:=RPiecesComptable.NumeroDocument;
          TableauPiecesComptable.Cells[7,i]:=RPiecesComptable.DateDocument;
          TableauPiecesComptable.Cells[8,i]:=RPiecesComptable.IntituleOperationBase;
          TableauPiecesComptable.Cells[9,i]:=RPiecesComptable.DesignationDocumentBase;
          TableauPiecesComptable.Cells[10,i]:=RPiecesComptable.NumeroDocumentBase;
          TableauPiecesComptable.Cells[11,i]:=RPiecesComptable.DateDocumentBase;
          TableauPiecesComptable.Cells[12,i]:=RPiecesComptable.NumEntite;
          TableauPiecesComptable.Cells[13,i]:=FSComptabiliteTransitoire.EditNomEntite.Text;//DesignationEntite(RPiecesComptable.NumEntite);
          end;
     end;
     CloseFile(FPiecesComptable);

     if(i>0)then TableauPiecesComptable.RowCount:=i+1
            else
            begin
                 TableauPiecesComptable.RowCount:=2;
                 TableauPiecesComptable.Rows[1].Text:='';
            end;
     AjusterColWidth(TableauPiecesComptable,'','1-3;9-12'); 

     if(RowSelect<>'')then
     begin
          TableauPiecesComptable.Row:=MaxInt(1,strtointeger(RowSelect));
     end;
     TableauPiecesComptable.SetFocus;
end;

